@*
   Views/KasubkelKdi/PermintaanData.cshtml — PERBAIKAN
   ─────────────────────────────────────────────────────────────────────────
   PERUBAHAN:
   1. Kolom Action: satu tombol primer + dropdown ⋯
   2. Label: "Kelola Sub-tugas" (bukan "Kelola Tugas"), "Terima Disposisi"
   3. Empty state dengan CTA kontekstual
   ─────────────────────────────────────────────────────────────────────────
*@
@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Permintaan Data — Kasubkel KDI";
    ViewData["Role"]  = "Kasubkel KDI";
    Layout = "_LayoutAdmin";
    var q      = ViewData["Q"]      as string;
    var status = ViewData["Status"] as int?;
}

<partial name="Partials/_FormStyles" />
<partial name="Partials/_ActionMenu" />

<div class="flex items-center justify-between mb-4">
    <div>
        <p class="font-bold text-gray-700 text-sm">Permintaan Data</p>
        <p class="text-xs text-gray-400 mt-0.5">Semua permohonan dengan keperluan permintaan data</p>
    </div>
    <a href="/kasubkel-kdi" class="text-xs font-semibold text-blue-600 hover:text-blue-800 flex items-center gap-1">← Dashboard</a>
</div>

<!-- Search + Filter -->
<form method="get" class="flex gap-2 mb-4">
    <input type="text" name="q" value="@q" placeholder="Cari nomor / nama pemohon..."
           class="flex-1 border border-gray-200 rounded-xl px-4 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-300" />
    <select name="status" class="border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-none">
        <option value="">Semua Status</option>
        <option value="6"  selected="@(status==6)">Didisposisi (Baru)</option>
        <option value="7"  selected="@(status==7)">Sedang Diproses</option>
        <option value="8"  selected="@(status==8)">Observasi Dijadwalkan</option>
        <option value="12" selected="@(status==12)">Wawancara Dijadwalkan</option>
        <option value="10" selected="@(status==10)">Data Siap</option>
        <option value="15" selected="@(status==15)">Feedback Pemohon</option>
        <option value="11" selected="@(status==11)">Selesai</option>
    </select>
    <button type="submit" class="bg-[#002d7a] hover:bg-blue-900 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-colors">Cari</button>
    @if (!string.IsNullOrEmpty(q) || status.HasValue)
    {
        <a href="/kasubkel-kdi/permintaan-data" class="border border-gray-200 text-gray-500 text-xs font-medium px-3 py-2 rounded-xl hover:bg-gray-50 transition-colors">Reset</a>
    }
</form>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    @if (!Model.Any())
    {
        @* ── Empty state kontekstual ── *@
        <div class="text-center py-16 px-6">
            <div class="w-16 h-16 bg-blue-50 border border-blue-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">📊</div>
            @if (!string.IsNullOrEmpty(q) || status.HasValue)
            {
                <p class="text-sm font-semibold text-gray-600 mb-1">Tidak ada hasil ditemukan</p>
                <p class="text-xs text-gray-400 mb-4">Coba ubah kata kunci atau pilih filter status yang berbeda.</p>
                <a href="/kasubkel-kdi/permintaan-data" class="inline-flex items-center gap-2 text-xs font-semibold text-blue-600 hover:underline">↩ Lihat semua permintaan data</a>
            }
            else
            {
                <p class="text-sm font-semibold text-gray-600 mb-1">Belum ada permintaan data</p>
                <p class="text-xs text-gray-400 mb-4">Permintaan data akan muncul setelah disposisi dari Kepegawaian diterima.</p>
                <a href="/kasubkel-kdi" class="inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-bold px-4 py-2 rounded-xl">← Kembali ke Dashboard</a>
            }
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-50">
                        <th class="col-th">No Permohonan</th>
                        <th class="col-th">Nama Pemohon</th>
                        <th class="col-th">Kategori</th>
                        <th class="col-th">Tgl Permohonan</th>
                        <th class="col-th">Batas Waktu</th>
                        <th class="col-th">Status</th>
                        <th class="col-th">Pengampu</th>
                        <th class="col-th">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model)
                    {
                        bool overdue     = item.IsOverdue;
                        bool isNew       = item.StatusPPIDID == StatusId.Didisposisi;
                        bool isInProgress = item.StatusPPIDID == StatusId.DiProses
                                         || item.StatusPPIDID == StatusId.ObservasiDijadwalkan
                                         || item.StatusPPIDID == StatusId.ObservasiSelesai
                                         || item.StatusPPIDID == StatusId.WawancaraDijadwalkan
                                         || item.StatusPPIDID == StatusId.WawancaraSelesai;
                        bool isDataSiap  = item.StatusPPIDID == StatusId.DataSiap;
                        bool isFeedback  = item.StatusPPIDID == StatusId.FeedbackPemohon;
                        bool isSelesai   = item.StatusPPIDID == StatusId.Selesai;

                        @* Resolusi primer *@
                        string? primerHref  = null;
                        string? primerLabel = null;
                        string  primerColor = "";

                        if (isNew) {
                            primerHref = $"/kasubkel-kdi/terima/{item.PermohonanPPIDID}";
                            primerLabel = "Terima Disposisi";
                            primerColor = "cyan";
                        } else if (isInProgress) {
                            primerHref = $"/kasubkel-kdi/subtasks/{item.PermohonanPPIDID}";
                            primerLabel = "Kelola Sub-tugas";
                        } else if (isDataSiap) {
                            primerHref = $"/kasubkel-kdi/minta-feedback/{item.PermohonanPPIDID}";
                            primerLabel = "Minta Feedback";
                            primerColor = "emerald";
                        } else if (isFeedback) {
                            primerHref = $"/kasubkel-kdi/subtasks/{item.PermohonanPPIDID}";
                            primerLabel = "Lihat Sub-tugas";
                            primerColor = "amber";
                        }

                        string badgeCls = item.StatusPPIDID switch
                        {
                            StatusId.DataSiap             => "bg-emerald-50 text-emerald-700",
                            StatusId.FeedbackPemohon      => "bg-amber-50 text-amber-700",
                            StatusId.Selesai              => "bg-emerald-100 text-emerald-800",
                            StatusId.DiProses             => "bg-blue-50 text-blue-700",
                            StatusId.Didisposisi          => "bg-cyan-50 text-cyan-700",
                            StatusId.ObservasiDijadwalkan => "bg-orange-50 text-orange-700",
                            StatusId.WawancaraDijadwalkan => "bg-violet-50 text-violet-700",
                            _                             => "bg-gray-100 text-gray-500"
                        };

                        <tr class="hover:bg-blue-50/30 transition-colors group @(isNew ? "bg-cyan-50/30" : "")">
                            <td class="px-4 py-3 font-mono text-xs text-blue-600 font-semibold whitespace-nowrap">
                                @item.NoPermohonan
                                @if (isNew) { <span class="ml-1 text-[10px] bg-cyan-100 text-cyan-700 px-1.5 py-0.5 rounded font-bold">BARU</span> }
                            </td>
                            <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>
                            <td class="px-4 py-3">
                                <span class="text-xs font-medium @(item.KategoriPemohon == "Mahasiswa" ? "text-blue-600" : "text-emerald-600")">
                                    @(item.KategoriPemohon == "Mahasiswa" ? "🎓" : "🏢") @item.KategoriPemohon
                                </span>
                            </td>
                            <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">@item.TanggalPermohonan?.ToString("dd MMM yyyy")</td>
                            <td class="px-4 py-3 whitespace-nowrap">
                                @if (item.BatasWaktu.HasValue)
                                {
                                    <span class="text-xs font-medium @(overdue ? "text-red-600" : item.HariSisa <= 3 ? "text-amber-600" : "text-gray-500")">
                                        @(overdue ? "⚠ " : "")@item.BatasWaktu.Value.ToString("dd MMM yyyy")
                                        @if (item.HariSisa.HasValue && item.StatusPPIDID < StatusId.Selesai)
                                        {
                                            <span class="block text-[10px] @(overdue ? "text-red-400" : "text-gray-400")">
                                                @(overdue ? $"Lewat {Math.Abs(item.HariSisa.Value)} hari" : $"Sisa {item.HariSisa.Value} hari")
                                            </span>
                                        }
                                    </span>
                                }
                                else { <span class="text-gray-300 text-xs">—</span> }
                            </td>
                            <td class="px-4 py-3">
                                <span class="text-[11px] @badgeCls px-2.5 py-0.5 rounded-full font-medium">
                                    @item.Status?.NamaStatusPPID
                                </span>
                            </td>
                            <td class="px-4 py-3 text-xs text-gray-500">@(string.IsNullOrEmpty(item.Pengampu) ? "—" : item.Pengampu)</td>

                            <td class="px-4 py-3">
                                <div class="action-cell">
                                    @if (primerHref != null)
                                    {
                                        <a href="@primerHref" class="btn-action-primary @primerColor">@primerLabel</a>
                                    }
                                    else if (!isSelesai)
                                    {
                                        <a href="/kasubkel-kdi/detail/@item.PermohonanPPIDID"
                                           class="btn-action-primary" style="background:#6b7280">Detail</a>
                                    }

                                    <div class="action-more-wrap">
                                        <button class="btn-action-more" onclick="toggleActionMenu(this)" type="button">⋯</button>
                                        <div class="action-dropdown hidden">
                                            <a href="/kasubkel-kdi/detail/@item.PermohonanPPIDID" class="action-dd-item">📋 Detail & Log</a>
                                            @if (!isNew && !isSelesai)
                                            {
                                                <a href="/kasubkel-kdi/subtasks/@item.PermohonanPPIDID" class="action-dd-item">⚙️ Sub-tugas</a>
                                            }
                                            @if (isDataSiap)
                                            {
                                                <a href="/kasubkel-kdi/subtasks/@item.PermohonanPPIDID" class="action-dd-item">⚙️ Sub-tugas</a>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
