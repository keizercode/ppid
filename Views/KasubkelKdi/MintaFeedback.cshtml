@* ══════════════════════════════════════════════════════════════════════
   Views/KasubkelKdi/MintaFeedback.cshtml
   Konfirmasi sebelum mengubah status ke FeedbackPemohon (15)
══════════════════════════════════════════════════════════════════════ *@
@model PermohonanPPID
@{
    ViewData["Title"] = "Minta Feedback Pemohon";
    ViewData["Role"]  = "Kasubkel KDI";
    Layout = "_LayoutAdmin";

    var pr       = Model.Pribadi;
    bool hasData = ViewData["HasData"] as bool? ?? false;
    var lacakUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/Lacak?noPermohonan={Uri.EscapeDataString(Model.NoPermohonan ?? "")}";
}

<div class="max-w-xl mx-auto">
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

    <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
        <div class="w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center text-xl">📨</div>
        <div>
            <h3 class="font-bold text-gray-800">Minta Feedback Pemohon</h3>
            <p class="text-xs font-mono text-gray-400 mt-0.5">@Model.NoPermohonan · @pr?.Nama</p>
        </div>
    </div>

    <div class="p-6">

        <!-- Checklist sebelum minta feedback -->
        <div class="mb-5">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Checklist Sebelum Lanjut</p>
            <div class="space-y-2">
                @{
                    var items = new[]{
                        (true,  "Semua sub-tugas paralel sudah selesai"),
                        (hasData, "File data hasil sudah diupload dan tersedia untuk diunduh"),
                        (Model.StatusPPIDID == StatusId.DataSiap, "Status permohonan: Data Siap"),
                    };
                }
                @foreach (var (ok, label) in items)
                {
                    <div class="flex items-center gap-2.5 @(ok ? "text-emerald-700" : "text-red-600")">
                        <span class="w-5 h-5 @(ok ? "bg-emerald-100" : "bg-red-100") rounded-full flex items-center justify-center text-xs flex-shrink-0">
                            @(ok ? "✓" : "✗")
                        </span>
                        <span class="text-sm @(ok ? "font-medium" : "font-bold")">@label</span>
                    </div>
                }
            </div>
        </div>

        <!-- Apa yang terjadi -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-5">
            <p class="font-bold text-amber-800 text-sm mb-2">Yang akan terjadi:</p>
            <ul class="space-y-1.5 text-xs text-amber-700">
                <li>• Status berubah dari <strong>Data Siap</strong> ke <strong>Feedback Pemohon</strong></li>
                <li>• Pemohon dapat melihat status dan mengunduh data di portal publik</li>
                <li>• Pemohon diminta mengisi kuesioner kepuasan layanan</li>
                <li>• Setelah kuesioner diisi, status otomatis menjadi <strong>Selesai</strong></li>
                <li>• Jika pemohon tidak merespons, KDI dapat tandai selesai secara manual</li>
            </ul>
        </div>

        <!-- Link untuk dikirim ke pemohon -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-5">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Link Portal Publik (kirim ke pemohon)</p>
            <div class="flex items-center gap-2">
                <code class="text-xs text-blue-600 flex-1 break-all">@lacakUrl</code>
                <button type="button" onclick="copyLink('@lacakUrl')"
                        class="flex-shrink-0 text-[11px] bg-gray-100 hover:bg-gray-200 text-gray-600 px-2.5 py-1.5 rounded-lg font-medium transition-colors"
                        id="copyBtn">
                    Salin
                </button>
            </div>
            <p class="text-[10px] text-gray-400 mt-1">Pemohon cukup memasukkan nomor <strong>@Model.NoPermohonan</strong> di portal.</p>
        </div>

        @if (!hasData)
        {
            <div class="bg-red-50 border border-red-200 rounded-xl p-3 mb-4 flex gap-2 items-start">
                <span class="text-red-500 flex-shrink-0">⚠️</span>
                <p class="text-xs text-red-700 leading-relaxed">
                    File data hasil belum ada. Pastikan sub-tugas Permintaan Data sudah selesai dan file sudah diupload sebelum meminta feedback.
                </p>
            </div>
        }

        <form asp-action="MintaFeedbackPost" asp-controller="KasubkelKdi" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="permohonanId" value="@Model.PermohonanPPIDID" />
            <div class="flex gap-3">
                <a href="/kasubkel-kdi/subtasks/@Model.PermohonanPPIDID" class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">← Kembali</a>
                <button type="submit" class="flex-grow bg-amber-500 hover:bg-amber-600 text-white font-bold py-2.5 px-6 rounded-xl text-sm shadow-sm">
                    📨 Minta Feedback Pemohon →
                </button>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
<script>
function copyLink(url) {
    navigator.clipboard.writeText(url).then(() => {
        const btn = document.getElementById('copyBtn');
        btn.textContent = '✓ Disalin!';
        btn.classList.replace('bg-gray-100','bg-emerald-100');
        btn.classList.replace('text-gray-600','text-emerald-700');
        setTimeout(() => {
            btn.textContent = 'Salin';
            btn.classList.replace('bg-emerald-100','bg-gray-100');
            btn.classList.replace('text-emerald-700','text-gray-600');
        }, 2000);
    });
}
</script>
}
