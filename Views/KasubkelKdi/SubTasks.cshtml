@*
   Views/KasubkelKdi/SubTasks.cshtml — PERBAIKAN EMPTY STATE
   ─────────────────────────────────────────────────────────────────────────
   PERUBAHAN:
   - Empty state "Sub-tugas belum tersedia" → penjelasan MENGAPA + CTA
   - Loading state via _FormStyles partial
   - Label konsisten: "Kelola Sub-tugas" (bukan "Kelola Tugas")
   ─────────────────────────────────────────────────────────────────────────
*@
@model ParallelTasksVm
@{
    ViewData["Title"] = $"Sub-tugas Data — {Model.Permohonan.NoPermohonan}";
    ViewData["Role"]  = "Kasubkel KDI";
    Layout = "_LayoutAdmin";

    var p         = Model.Permohonan;
    var pr        = p.Pribadi;
    var ppid      = pr?.PribadiPPID;
    var current   = p.StatusPPIDID ?? StatusId.TerdaftarSistem;

    var stData = Model.GetTask(JenisTask.PermintaanData);

    bool isDataSiap  = current == StatusId.DataSiap;
    bool isFeedback  = current == StatusId.FeedbackPemohon;
    bool isSelesai   = current == StatusId.Selesai;
    bool canFeedback = isDataSiap;
    bool canForceClose = isDataSiap || isFeedback;

    var tugasDocs   = ViewData["TugasDocs"]  as List<DokumenPPID>   ?? new();
    @* var obsWawTasks = ViewData["ObsWawTasks"] as List<SubTaskPPID> ?? new(); *@
}

<partial name="Partials/_FormStyles" />

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-300 rounded-2xl px-5 py-3 mb-4 flex items-start gap-3">
        <span class="text-emerald-500 text-lg flex-shrink-0">✅</span>
        <p class="text-emerald-800 text-sm font-medium">@Html.Raw(TempData["Success"])</p>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-300 rounded-2xl px-5 py-3 mb-4 flex items-start gap-3">
        <span class="text-red-500 text-lg flex-shrink-0">⚠️</span>
        <p class="text-red-800 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
    </div>
}

<div class="max-w-5xl mx-auto">

    <a href="/kasubkel-kdi" class="inline-flex items-center gap-1.5 text-blue-600 hover:text-blue-800 text-sm font-medium mb-5">← Kembali Dashboard</a>

    <!-- Header -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <p class="text-[10px] text-gray-400 uppercase tracking-widest font-semibold mb-1">Sub-tugas Permintaan Data — KDI</p>
            <h2 class="text-2xl font-extrabold font-mono text-gray-800">@p.NoPermohonan</h2>
            <p class="text-sm text-gray-500 mt-1">@pr?.Nama — @p.JudulPenelitian</p>
        </div>
        <div class="flex items-center gap-2 border rounded-full px-4 py-2 self-start sm:self-center
            @(isSelesai   ? "bg-emerald-50 border-emerald-200 text-emerald-700" :
              isFeedback  ? "bg-amber-50 border-amber-200 text-amber-700" :
              isDataSiap  ? "bg-blue-50 border-blue-200 text-blue-700" :
                            "bg-gray-100 border-gray-200 text-gray-500")">
            <span class="w-2 h-2 rounded-full
                @(isSelesai  ? "bg-emerald-400" :
                  isFeedback ? "bg-amber-400" :
                  isDataSiap ? "bg-blue-500" : "bg-gray-400")"></span>
            <span class="text-sm font-semibold">@(p.Status?.NamaStatusPPID ?? "—")</span>
        </div>
    </div>


    <!-- Sub-tugas Permintaan Data -->
    <div class="mb-4">
        @if (stData is null)
        {
            @* ── Empty state dengan MENGAPA kosong + CTA ── *@
            <div class="bg-white rounded-2xl border border-dashed border-gray-300 p-8 text-center">
                <div class="w-14 h-14 bg-blue-50 border border-blue-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">📊</div>
                <p class="text-sm font-semibold text-gray-700 mb-1">Sub-tugas Permintaan Data belum dibuat</p>
                <p class="text-xs text-gray-400 mb-4 leading-relaxed max-w-xs mx-auto">
                    Sub-tugas akan tersedia setelah Anda menerima disposisi dari dashboard KDI.
                    Pastikan status permohonan sudah <strong>Didisposisi</strong>.
                </p>
                @if (current == StatusId.Didisposisi)
                {
                    <a href="/kasubkel-kdi/terima/@p.PermohonanPPIDID"
                       class="inline-flex items-center gap-2 bg-cyan-600 hover:bg-cyan-700 text-white text-xs font-bold px-5 py-2.5 rounded-xl">
                        📥 Terima Disposisi Sekarang →
                    </a>
                }
                else
                {
                    <a href="/kasubkel-kdi" class="inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-bold px-5 py-2.5 rounded-xl">
                        ← Kembali ke Dashboard
                    </a>
                }
            </div>
        }
        else
        {
            string cardBorder = stData.IsSelesai    ? "border-emerald-200" :
                                stData.IsDibatalkan ? "border-red-200"     :
                                stData.IsInProgress ? "border-amber-200"   : "border-gray-200";

            string badgeBg = stData.StatusTask switch
            {
                SubTaskStatus.Selesai    => "bg-emerald-100 text-emerald-800",
                SubTaskStatus.InProgress => "bg-amber-100 text-amber-800",
                SubTaskStatus.Dibatalkan => "bg-red-100 text-red-700",
                _                        => "bg-gray-100 text-gray-500"
            };

            <div class="bg-white rounded-2xl border @cardBorder shadow-sm p-5">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center gap-2.5">
                        <span class="text-2xl">📊</span>
                        <p class="font-bold text-gray-800 text-sm">Permintaan Data</p>
                    </div>
                    <span class="text-[11px] @badgeBg px-2.5 py-0.5 rounded-full font-semibold">
                        @SubTaskStatus.GetLabel(stData.StatusTask)
                    </span>
                </div>

                @if (stData.HasFile)
                {
                    <div class="bg-emerald-50 rounded-xl p-3 mb-3">
                        <p class="text-xs text-emerald-700">📎 @(stData.NamaFile ?? "File tersedia")</p>
                        @if (!string.IsNullOrEmpty(stData.FilePath))
                        {
                            <a href="@stData.FilePath" target="_blank" class="text-xs text-blue-500 hover:underline mt-0.5 block">Unduh file →</a>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(stData.Catatan))
                {
                    <p class="text-xs text-gray-500 mb-3 italic leading-relaxed">📝 @stData.Catatan</p>
                }

                @if (!string.IsNullOrEmpty(stData.ReopenAlasan))
                {
                    <div class="bg-violet-50 border border-violet-100 rounded-xl p-2.5 mb-2">
                        <p class="text-[11px] text-violet-600">↩ Di-reopen: @stData.ReopenAlasan</p>
                    </div>
                }

                @if (stData.IsDibatalkan)
                {
                    <div class="bg-red-50 border border-red-100 rounded-xl p-2.5 mb-2">
                        <p class="text-[11px] text-red-600 font-medium">🚫 Dibatalkan: @(stData.BatalAlasan ?? "—")</p>
                    </div>
                    <a href="/kasubkel-kdi/reopen-subtask/@p.PermohonanPPIDID/PermintaanData"
                       class="w-full flex items-center justify-center gap-2 bg-violet-600 hover:bg-violet-700 text-white text-xs font-bold px-4 py-2 rounded-xl transition-colors">
                        ↩ Buka Kembali
                    </a>
                }
                else if (!stData.IsSelesai)
                {
                    <div class="flex gap-2">
                        <a href="/kasubkel-kdi/upload-data/@p.PermohonanPPIDID"
                           class="flex-1 flex items-center justify-center gap-2 bg-[#002d7a] hover:bg-blue-900 text-white text-xs font-bold px-4 py-2 rounded-xl transition-colors">
                            ⬆ Upload Data →
                        </a>
                        <a href="/kasubkel-kdi/batal-subtask/@p.PermohonanPPIDID/PermintaanData"
                           class="bg-red-50 hover:bg-red-100 border border-red-100 text-red-600 text-[11px] font-semibold px-3 py-2 rounded-xl transition-colors">
                            🚫 Batalkan
                        </a>
                    </div>
                }
                else
                {
                    <div class="flex items-center justify-between">
                        <div class="text-emerald-600 text-xs font-semibold">
                            ✓ Selesai @stData.SelesaiAt?.ToLocalTime().ToString("dd MMM HH:mm")
                        </div>
                        <div class="flex gap-1.5">
                            @if (stData.HasFile)
                            {
                                <a href="/kasubkel-kdi/revisi-file/@p.PermohonanPPIDID/PermintaanData"
                                   class="text-[11px] bg-blue-50 hover:bg-blue-100 border border-blue-100 text-blue-600 px-2 py-1 rounded-lg font-medium transition-colors">
                                    📝 Revisi File
                                </a>
                            }
                            <a href="/kasubkel-kdi/batal-subtask/@p.PermohonanPPIDID/PermintaanData"
                               class="text-[11px] bg-red-50 hover:bg-red-100 border border-red-100 text-red-600 px-2 py-1 rounded-lg font-medium transition-colors">
                                🚫 Batalkan
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Tindak Lanjut -->
    @if (!isSelesai)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Tindak Lanjut</p>

            @if (isDataSiap)
{
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4">
        <div class="flex items-start gap-3">
            <span class="text-2xl">📨</span>
            <div>
                <p class="font-bold text-blue-800 text-sm">Langkah Selanjutnya</p>
                <p class="text-blue-600 text-xs mt-1 leading-relaxed">
                    Semua data sudah siap. <strong>Loket Kepegawaian</strong> yang akan
                    meminta feedback dari pemohon via portal publik. KDI tidak mengelola
                    tahap feedback secara langsung.
                </p>
            </div>
        </div>
    </div>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-3 flex items-center gap-2">
        <span class="text-gray-400 text-sm">ℹ️</span>
        <p class="text-xs text-gray-500">
            Hubungi Loket Kepegawaian atau tunggu hingga mereka mengubah status
            ke <strong>Feedback Pemohon</strong>.
        </p>
    </div>
}
            else if (isFeedback)
            {
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4">
                    <div class="flex items-start gap-3">
                        <span class="text-2xl">⏳</span>
                        <div>
                            <p class="font-bold text-amber-800 text-sm">Menunggu Feedback dari Pemohon</p>
                            <p class="text-amber-700 text-xs mt-1 leading-relaxed">
                                Status otomatis menjadi <strong>Selesai</strong> setelah pemohon mengisi feedback di portal publik
                                (nomor: <span class="font-mono">@p.NoPermohonan</span>).
                            </p>
                        </div>
                    </div>
                </div>
            }

            @if (canForceClose)
            {
                <div class="mt-4 pt-4 border-t border-gray-100">
                    <p class="text-xs text-gray-400 mb-2">
                        Override darurat — hanya jika Loket tidak dapat dihubungi:
                    </p>
                    <form asp-action="TandaiSelesai" asp-controller="KasubkelKdi" method="post"
                        onsubmit="return confirm('Override: tandai selesai tanpa feedback? Tindakan ini akan dicatat.')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="permohonanId" value="@p.PermohonanPPIDID"/>
                        <button type="submit"
                                class="inline-flex items-center gap-2 border border-red-200 text-red-600 text-xs font-semibold px-4 py-2 rounded-xl hover:bg-red-50 transition-colors">
                            ⚠ Override: Tandai Selesai (darurat)
                        </button>
                    </form>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-5 mb-4 flex items-center gap-4">
            <div class="w-12 h-12 bg-emerald-500 rounded-xl flex items-center justify-center text-white text-2xl flex-shrink-0">🏁</div>
            <div>
                <p class="font-bold text-emerald-800">Permohonan Selesai</p>
                <p class="text-emerald-600 text-sm mt-0.5">
                    Tanggal selesai: <strong>@(p.TanggalSelesai?.ToString("dd MMMM yyyy") ?? "—")</strong>
                </p>
            </div>
        </div>
    }

    <!-- Laporan Final -->
    @if (tugasDocs.Any())
    {
        <div class="bg-white rounded-2xl border border-indigo-100 shadow-sm p-5 mb-4">
            <p class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest mb-3">Laporan Final Pemohon (@tugasDocs.Count)</p>
            <div class="space-y-2">
                @foreach (var f in tugasDocs)
                {
                    <div class="flex items-center gap-2.5 bg-indigo-50 border border-indigo-100 rounded-xl px-3 py-2">
                        <span class="text-indigo-500 flex-shrink-0">📎</span>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-medium text-indigo-800 truncate">@f.NamaDokumenPPID</p>
                            <p class="text-[10px] text-indigo-400">@f.CreatedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>
                        </div>
                        <a href="@f.UploadDokumenPPID" target="_blank"
                           class="text-[11px] bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-2 py-1 rounded-lg font-medium">Unduh</a>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Info Pemohon -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Info Pemohon</p>
            <dl class="space-y-2">
                <div><dt class="text-[10px] text-gray-400 uppercase font-semibold">Nama</dt><dd class="text-sm font-semibold text-gray-800">@pr?.Nama</dd></div>
                <div><dt class="text-[10px] text-gray-400 uppercase font-semibold">NIK</dt><dd class="font-mono text-sm text-gray-700">@pr?.NIK</dd></div>
                @if (!string.IsNullOrEmpty(ppid?.Lembaga)) {
                    <div><dt class="text-[10px] text-gray-400 uppercase font-semibold">Lembaga</dt><dd class="text-sm text-gray-700">@ppid.Lembaga</dd></div>
                }
                @if (!string.IsNullOrEmpty(pr?.Telepon)) {
                    <div><dt class="text-[10px] text-gray-400 uppercase font-semibold">Telepon</dt><dd class="text-sm text-gray-700">@pr.Telepon</dd></div>
                }
            </dl>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Info Permohonan</p>
            <dl class="space-y-2">
                <div>
                    <dt class="text-[10px] text-gray-400 uppercase font-semibold">Batas Waktu</dt>
                    <dd class="text-sm @(p.IsOverdue ? "text-red-600 font-semibold" : "text-gray-700")">
                        @(p.BatasWaktu?.ToString("dd MMM yyyy") ?? "—") @(p.IsOverdue ? " ⚠" : "")
                    </dd>
                </div>
                <div><dt class="text-[10px] text-gray-400 uppercase font-semibold">Unit / Bidang</dt><dd class="text-sm text-gray-700">@(p.NamaBidang ?? "PSMDI")</dd></div>
                @if (!string.IsNullOrEmpty(p.Pengampu)) {
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase font-semibold">Pengampu</dt>
                        <dd class="text-sm text-gray-700">
                            @p.Pengampu
                            @if (!string.IsNullOrEmpty(p.TeleponPengampu)) {
                                <a href="tel:@p.TeleponPengampu" class="ml-2 text-blue-500 text-xs hover:underline">📞 @p.TeleponPengampu</a>
                            }
                        </dd>
                    </div>
                }
            </dl>
        </div>
    </div>

    <div class="flex flex-wrap gap-3">
        <a href="/kasubkel-kdi/detail/@p.PermohonanPPIDID"
           class="inline-flex items-center gap-2 border border-gray-200 text-gray-600 text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-gray-50 transition-colors">
            📋 Lihat Detail & Audit Log
        </a>
    </div>
</div>
