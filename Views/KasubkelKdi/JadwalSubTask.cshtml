@* ══════════════════════════════════════════════════════════════════════
   Views/KasubkelKdi/JadwalSubTask.cshtml — FIXED RZ1031
   FIX: @(condition ? "checked" : "") di area atribut tag helper dilarang.
        asp-for pada <input type="radio"> secara otomatis membandingkan
        Model.LokasiJenis dengan value="" untuk menentukan checked state —
        tidak perlu atribut checked eksplisit.
══════════════════════════════════════════════════════════════════════ *@
@model JadwalSubTaskVm
@{
    bool isWaw = Model.JenisTask == JenisTask.Wawancara;
    ViewData["Title"] = $"Jadwal {(isWaw ? "Wawancara" : "Observasi")}";
    ViewData["Role"]  = "Kasubkel KDI";
    Layout = "_LayoutAdmin";
    string icon    = isWaw ? "🎤" : "🔍";
    string color   = isWaw ? "violet" : "orange";
    string postUrl = isWaw ? "/kasubkel-kdi/jadwal-wawancara" : "/kasubkel-kdi/jadwal-observasi";
}

<div class="max-w-xl mx-auto">
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

    <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
        <div class="w-10 h-10 bg-@color-100 rounded-xl flex items-center justify-center text-xl">@icon</div>
        <div>
            <h3 class="font-bold text-gray-800">Buat Jadwal @(isWaw ? "Wawancara" : "Observasi")</h3>
            <p class="text-xs font-mono text-gray-400 mt-0.5">@Model.NoPermohonan · @Model.NamaPemohon</p>
        </div>
    </div>

    <div class="p-6">

        @if (!string.IsNullOrEmpty(Model.DetailKeperluan))
        {
            <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 mb-4">
                <p class="text-[10px] text-gray-400 uppercase font-bold mb-1">Detail Keperluan Pemohon</p>
                <p class="text-sm text-gray-700 leading-relaxed">@Model.DetailKeperluan</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.NamaBidangTerkait))
        {
            <div class="bg-@color-50 border border-@color-100 rounded-xl p-3 mb-4">
                <p class="text-xs text-@color-700">Unit terkait: <strong>@Model.NamaBidangTerkait</strong></p>
            </div>
        }

        <form action="@postUrl" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SubTaskID" />
            <input type="hidden" asp-for="PermohonanPPIDID" />
            <input type="hidden" asp-for="NoPermohonan" />
            <input type="hidden" asp-for="NamaPemohon" />
            <input type="hidden" asp-for="JenisTask" />

            <div class="grid grid-cols-2 gap-3 mb-4">
                <div>
                    <label class="lbl">Tanggal <span class="req">*</span></label>
                    <input asp-for="Tanggal" type="date" class="fld" />
                    <span asp-validation-for="Tanggal" class="err"></span>
                </div>
                <div>
                    <label class="lbl">Jam <span class="req">*</span></label>
                    <input asp-for="Waktu" type="time" class="fld" />
                    <span asp-validation-for="Waktu" class="err"></span>
                </div>
                <div class="col-span-2">
                    <label class="lbl">Nama PIC / @(isWaw ? "Narasumber" : "Koordinator") <span class="req">*</span></label>
                    <input asp-for="NamaPIC" class="fld" placeholder="Nama narasumber atau koordinator" />
                    <span asp-validation-for="NamaPIC" class="err"></span>
                </div>
                <div class="col-span-2">
                    <label class="lbl">No. Telepon PIC</label>
                    <input asp-for="TeleponPIC" class="fld" placeholder="08xxxxxxxxxx" />
                    <span asp-validation-for="TeleponPIC" class="err"></span>
                </div>

                @* ── LOKASI ONLINE/OFFLINE ──
                   FIX RZ1031 (line 81 & 87 original):
                   Hapus @(condition ? "checked" : "") — atribut mentah C# di area
                   tag helper dilarang compiler Razor. asp-for="LokasiJenis" dengan
                   value="Offline"/"Online" sudah cukup: tag helper membandingkan
                   Model.LokasiJenis == value untuk emit checked="checked" otomatis.
                *@
                <div class="col-span-2">
                    <label class="lbl">Jenis Pertemuan <span class="req">*</span></label>
                    <div class="grid grid-cols-2 gap-2">
                        <label class="flex items-center gap-2.5 p-3 rounded-xl border-2 border-gray-200 cursor-pointer has-[:checked]:border-gray-600 has-[:checked]:bg-gray-50 transition-all">
                            <input asp-for="LokasiJenis" type="radio" value="Offline" id="lokasiOffline"
                                   class="accent-gray-600" />
                            <span class="text-sm font-semibold text-gray-700">📍 Offline</span>
                        </label>
                        <label class="flex items-center gap-2.5 p-3 rounded-xl border-2 border-gray-200 cursor-pointer has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 transition-all">
                            <input asp-for="LokasiJenis" type="radio" value="Online" id="lokasiOnline"
                                   class="accent-blue-600" />
                            <span class="text-sm font-semibold text-gray-700">🌐 Online</span>
                        </label>
                    </div>
                    <span asp-validation-for="LokasiJenis" class="err"></span>
                </div>

                <div class="col-span-2" id="lokasiDetailWrap">
                    <label class="lbl" id="lokasiDetailLabel">
                        <span id="lblOffline">Nama Ruangan</span>
                        <span id="lblOnline" class="hidden">Link Zoom / Google Meet</span>
                    </label>
                    <input asp-for="LokasiDetail" class="fld" id="lokasiDetailInput"
                           placeholder="Misal: Ruang Rapat Lantai 3 / https://zoom.us/j/..." />
                </div>
            </div>

            <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-3 mb-4 flex gap-2 items-start">
                <span class="text-yellow-500 flex-shrink-0 mt-0.5">📣</span>
                <p class="text-xs text-yellow-800 leading-relaxed">
                    <strong>Kewajiban Petugas:</strong> Setelah jadwal tersimpan, petugas
                    <strong class="text-yellow-900">wajib mengingatkan produsen data / narasumber</strong>
                    melalui telepon, WhatsApp, atau tatap muka langsung.
                </p>
            </div>

            <div class="flex gap-3">
                <a href="/kasubkel-kdi/subtasks/@Model.PermohonanPPIDID"
                   class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">← Kembali</a>
                <button type="submit"
                        class="flex-grow bg-@color-600 hover:bg-@color-700 text-white font-bold py-2.5 px-6 rounded-xl text-sm shadow-sm">
                    📅 Simpan Jadwal →
                </button>
            </div>
        </form>
    </div>
</div>
</div>

<style>
    .lbl{display:block;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
    .req{color:#f87171}
    .fld{display:block;width:100%;border:1px solid #e5e7eb;border-radius:10px;padding:9px 14px;font-size:13.5px;background:#fafafa;outline:none;transition:all .15s}
    .fld:focus{box-shadow:0 0 0 2.5px #8b5cf6;border-color:transparent;background:white}
    .err{color:#ef4444;font-size:11px;margin-top:3px;display:block}
</style>

<script>
// Toggle label dan placeholder sesuai jenis lokasi
function updateLokasiUI() {
    const isOnline = document.getElementById('lokasiOnline').checked;
    document.getElementById('lblOffline').classList.toggle('hidden', isOnline);
    document.getElementById('lblOnline').classList.toggle('hidden', !isOnline);
    document.getElementById('lokasiDetailInput').placeholder = isOnline
        ? 'https://zoom.us/j/123456 atau https://meet.google.com/abc-defg-hij'
        : 'Misal: Ruang Rapat Lantai 3 Gedung DLH';
}

document.getElementById('lokasiOffline').addEventListener('change', updateLokasiUI);
document.getElementById('lokasiOnline').addEventListener('change', updateLokasiUI);

// Init
updateLokasiUI();
</script>
