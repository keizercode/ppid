@*
   Views/Shared/Partials/_FormStyles.cshtml
   ─────────────────────────────────────────────────────────────────────────
   DESIGN TOKEN TERPUSAT untuk semua form admin PPID.

   PENGGUNAAN — cukup satu baris di bagian atas setiap form view:
     <partial name="Partials/_FormStyles" />

   Menggantikan blok <style> berulang yang terdapat di:
     - PetugasLoket/DaftarPemohon, Edit, UploadData, UploadTTD
     - KasubkelKdi/JadwalSubTask, SelesaiSubTask, BatalSubTask, dll.
     - KasubkelKepegawaian/SuratIzin, Verifikasi
     - LoketUmum/DaftarPemohon
   ─────────────────────────────────────────────────────────────────────────
*@
<style>
/* ── Form field tokens ──────────────────────────────────────────────── */
.lbl  { display:block; font-size:11px; font-weight:700; color:#6b7280;
        text-transform:uppercase; letter-spacing:.05em; margin-bottom:4px }
.req  { color:#f87171}
.fld  { display:block; width:100%; border:1px solid #e5e7eb; border-radius:10px;
        padding:9px 14px; font-size:13.5px; background:#fafafa; outline:none;
        transition:all .15s }
.fld:focus  { box-shadow:0 0 0 2.5px #3b82f6; border-color:transparent; background:#fff }
.fld:disabled { background:#f3f4f6; color:#9ca3af; cursor:not-allowed }
select.fld  { appearance:none;
              background-image:url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
              background-repeat:no-repeat; background-position:right 10px center;
              background-size:16px; padding-right:2.5rem }
select.fld:disabled { background-color:#f3f4f6; color:#9ca3af; cursor:not-allowed }
.err  { color:#ef4444; font-size:11px; margin-top:3px; display:block }

/* ── File input ─────────────────────────────────────────────────────── */
.file-fld { width:100%; font-size:12px; color:#6b7280;
            border:1px solid #e5e7eb; border-radius:10px;
            padding:6px 10px; background:#fafafa }
.file-fld::file-selector-button { margin-right:8px; padding:4px 10px;
            border-radius:6px; border:none; font-size:11px; font-weight:700;
            background:#ecfdf5; color:#065f46; cursor:pointer }

/* ── Section header ─────────────────────────────────────────────────── */
.sec-header { display:flex; align-items:center; gap:10px;
              margin-bottom:16px; padding-bottom:12px;
              border-bottom:1px solid #f9fafb }
.sec-num    { width:24px; height:24px; background:#2563eb; border-radius:6px;
              color:#fff; font-size:11px; font-weight:900;
              display:flex; align-items:center; justify-content:center; flex-shrink:0 }
.sec-title  { font-weight:700; color:#374151; font-size:.875rem }

/* ── Table column header ────────────────────────────────────────────── */
.col-th { padding:12px 16px; text-align:left; font-size:10px; font-weight:700;
          color:#9ca3af; text-transform:uppercase; letter-spacing:.05em }

/* ── Submit button loading state ────────────────────────────────────── */
.btn-submit[data-loading] {
    opacity:.65; pointer-events:none; cursor:not-allowed;
}
.btn-submit[data-loading]::before {
    content:''; display:inline-block; width:12px; height:12px;
    border:2px solid rgba(255,255,255,.4); border-top-color:#fff;
    border-radius:50%; animation:btnSpin .6s linear infinite;
    margin-right:6px; vertical-align:middle;
}
@@keyframes btnSpin { to { transform:rotate(360deg) } }

/* ── Tab navigation (shared across Loket pages) ─────────────────────── */
.tab-btn { display:inline-flex; align-items:center; gap:6px; padding:7px 14px;
           border-radius:10px; font-size:12px; font-weight:600;
           border:1px solid #e5e7eb; color:#6b7280; background:white;
           text-decoration:none; transition:all .15s }
.tab-btn:hover  { background:#f9fafb; color:#374151 }
.tab-btn.active { background:#002d7a; color:white; border-color:#002d7a }

/* ── Stat chips (Wawancara/Observasi filter) ────────────────────────── */
.stat-chip { display:inline-flex; align-items:center; gap:6px; padding:5px 12px;
             border-radius:20px; font-size:12px; font-weight:600;
             border:1px solid #e5e7eb; color:#6b7280; background:white;
             text-decoration:none; transition:all .15s }
.stat-chip:hover { background:#f9fafb }
.chip-count { font-size:10px; font-weight:900; background:#e5e7eb; color:#374151;
              padding:1px 6px; border-radius:10px }
.active-all     { background:#374151; color:white; border-color:#374151 }
.active-all .chip-count { background:rgba(255,255,255,.25); color:white }
.active-amber   { background:#fef3c7; border-color:#fbbf24; color:#92400e }
.active-violet  { background:#ede9fe; border-color:#7c3aed; color:#5b21b6 }
.active-orange  { background:#fff7ed; border-color:#f97316; color:#7c2d12 }
.active-emerald { background:#d1fae5; border-color:#059669; color:#065f46 }
</style>

@* ── Script: submit loading state — otomatis berlaku pada semua .btn-submit ── *@
<script>
(function () {
    'use strict';
    document.addEventListener('submit', function (e) {
        var form = e.target;
        if (!form || form.tagName !== 'FORM') return;
        var btn = form.querySelector('.btn-submit');
        if (!btn) return;
        // Validasi HTML5 native — jika gagal, jangan disable
        if (form.checkValidity && !form.checkValidity()) return;
        var orig = btn.innerHTML;
        btn.setAttribute('data-loading', '1');
        btn.disabled = true;
        btn.innerHTML = '<span style="opacity:.7">Menyimpan…</span>';
        // Safety fallback — enable kembali setelah 15 detik (timeout/error)
        setTimeout(function () {
            btn.removeAttribute('data-loading');
            btn.disabled = false;
            btn.innerHTML = orig;
        }, 15000);
    });
})();
</script>
