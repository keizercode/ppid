@*
   Views/Shared/Partials/_PublicNavBar.cshtml
   ─────────────────────────────────────────────────────────────────────
   Navbar publik PPID DLH Jakarta — reusable di semua halaman publik.

   PENGGUNAAN:
     <partial name="Partials/_PublicNavBar" />

   ACTIVE STATE:
     Set ViewData["ActiveNav"] di controller atau view:
       ViewData["ActiveNav"] = "beranda";   // beranda | laporan | lacak
   ─────────────────────────────────────────────────────────────────────
*@
@{
    var active = (ViewData["ActiveNav"] as string ?? "beranda").ToLower();
    bool isHome = active == "beranda";
}

<style>
 /* Hanya CSS dropdown — sisanya sudah ada di home.css */
 .nav-dropdown-wrap { position: relative; }
 .nav-dropdown-btn {
     display: inline-flex; align-items: center; gap: 5px;
     padding: 7px 14px; border-radius: 10px;
     font-size: 13.5px; font-weight: 500; color: var(--muted);
     background: none; border: none; cursor: pointer;
     transition: all .15s; white-space: nowrap;
     font-family: inherit;
 }
 .nav-dropdown-btn:hover { background: var(--bg); color: var(--text); }
 .nav-dropdown-btn.active-parent { background: var(--ijo-light); color: var(--ijo-dark); font-weight: 600; }
 .nav-dropdown-btn svg { width: 14px; height: 14px; transition: transform .2s; }
 .nav-dropdown-btn.open svg { transform: rotate(180deg); }
 .nav-dd-panel {
     position: absolute; top: calc(100% + 6px); left: 0;
     background: white; border: 1px solid var(--border);
     border-radius: 12px; min-width: 200px;
     box-shadow: 0 8px 32px rgba(0,0,0,.1);
     padding: 6px; z-index: 200;
     opacity: 0; transform: translateY(-6px) scale(.98);
     pointer-events: none;
     transition: opacity .18s ease, transform .18s ease;
 }
 .nav-dd-panel.open { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
 .nav-dd-item {
     display: flex; align-items: center; gap: 10px;
     padding: 9px 12px; border-radius: 8px;
     font-size: 13px; font-weight: 500; color: var(--muted);
     text-decoration: none; transition: background .12s;
 }
 .nav-dd-item:hover { background: var(--bg); color: var(--ijo-dark); }
 .nav-dd-item svg { width: 16px; height: 16px; color: var(--muted); flex-shrink: 0; }
 .nav-dd-item:hover svg, .nav-dd-item.active svg { color: var(--ijo-dark); }
 .nav-dd-item.active { background: var(--ijo-light); color: var(--ijo-dark); font-weight: 600; }
 .mobile-nav-section {
     font-size: 10px; font-weight: 700; color: var(--muted);
     text-transform: uppercase; letter-spacing: .07em;
     padding: 14px 14px 4px;
 }
 </style>

<!-- ══ TICKER ══ -->
<div class="ticker-bar">
    <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;overflow:hidden;white-space:nowrap">
        <div class="ticker-inner">
            <span>📞 Telepon: (+62) 852-1243-6339</span>
            <span>✉ Email: ppid.dlh@jakarta.go.id</span>
            <span>🕐 Jam Layanan: Senin – Jumat, 08.00 – 16.00 WIB</span>
            <span>📍 Grha Intirub Business Park, Jl. Cililitan Besar No. 454, Jakarta Timur</span>
            <span>📞 Telepon: (+62) 852-1243-6339</span>
            <span>✉ Email: ppid.dlh@jakarta.go.id</span>
            <span>🕐 Jam Layanan: Senin – Jumat, 08.00 – 16.00 WIB</span>
            <span>📍 Grha Intirub Business Park, Jl. Cililitan Besar No. 454, Jakarta Timur</span>
        </div>
    </div>
</div>

<!-- ══ NAVBAR ══ -->
<header class="main-nav" id="mainNav">
    <div class="nav-inner">
        <!-- Brand -->
        <a href="/" class="nav-brand">
            <img src="https://res.cloudinary.com/dmcvht1vr/image/upload/v1775802585/ppid-removebg-preview_brah2r.png"
                 alt="Logo PPID DLH Jakarta" />
        </a>

        <!-- Desktop links -->
        <nav class="nav-links">
            <a href="/" class="nav-link @(active=="beranda"?"active":"")">Beranda</a>
            <a href="@(isHome?"#tentang":"/#tentang")" class="nav-link">Tentang PPID</a>
            <a href="@(isHome?"#alur":"/#alur")" class="nav-link">Alur</a>
            <a href="@(isHome?"#syarat":"/#syarat")" class="nav-link">Persyaratan</a>

            <!-- Dropdown: Laporan -->
            <div class="nav-dropdown-wrap" id="ddLaporan">
                <button class="nav-dropdown-btn @(active=="laporan"?"active-parent":"")"
                        onclick="toggleNavDd('ddLaporan')" type="button"
                        aria-haspopup="true" aria-expanded="false">
                    Laporan
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
                    </svg>
                </button>
                <div class="nav-dd-panel" id="ddLaporan-panel" role="menu">
                    <a href="/laporan-ppid" class="nav-dd-item @(active=="laporan"?"active":"")" role="menuitem">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/>
                        </svg>
                        Laporan PPID
                    </a>
                </div>
            </div>

            <a href="@(isHome?"#lacak":"/#lacak")" class="nav-link @(active=="lacak"?"active":"")">Lacak</a>
        </nav>

        <div class="nav-spacer"></div>

        <!-- CTA -->
        <a href="@(isHome?"#lacak":"/#lacak")" class="nav-cta">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
            </svg>
            Lacak Permohonan
        </a>

        <!-- Hamburger -->
        <button class="nav-hamburger" id="navHamburger" aria-label="Toggle menu" type="button">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

<!-- ══ MOBILE OVERLAY & DRAWER ══ -->
<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
    <a href="/" class="mobile-nav-link @(active=="beranda"?"active":"")">Beranda</a>
    <a href="@(isHome?"#tentang":"/#tentang")" class="mobile-nav-link">Tentang PPID</a>
    <a href="@(isHome?"#alur":"/#alur")" class="mobile-nav-link">Alur</a>
    <a href="@(isHome?"#syarat":"/#syarat")" class="mobile-nav-link">Persyaratan</a>

    <div class="mobile-nav-section">Laporan</div>
    <a href="/laporan-ppid" class="mobile-nav-link @(active=="laporan"?"active":"")">Laporan PPID</a>

    <a href="@(isHome?"#lacak":"/#lacak")" class="mobile-nav-link @(active=="lacak"?"active":"")">Lacak</a>
    <a href="@(isHome?"#lacak":"/#lacak")" class="mobile-nav-cta">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
        </svg>
        Lacak Permohonan
    </a>
</nav>

<script>
(function () {
    'use strict';

    /* ── Hamburger / Drawer ──────────────────────────────────────────── */
    var hamburger = document.getElementById('navHamburger');
    var drawer    = document.getElementById('mobileNav');
    var overlay   = document.getElementById('mobileNavOverlay');

    function toggleDrawer(open) {
        hamburger.classList.toggle('open', open);
        drawer.classList.toggle('open', open);
        overlay.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
    }

    hamburger.addEventListener('click', function () {
        toggleDrawer(!drawer.classList.contains('open'));
    });
    overlay.addEventListener('click', function () { toggleDrawer(false); });
    drawer.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { toggleDrawer(false); });
    });

    /* ── Desktop dropdown ────────────────────────────────────────────── */
    window.toggleNavDd = function (wrapId) {
        var wrap  = document.getElementById(wrapId);
        var btn   = wrap.querySelector('.nav-dropdown-btn');
        var panel = document.getElementById(wrapId + '-panel');
        var isOpen = panel.classList.contains('open');

        // Close all
        document.querySelectorAll('.nav-dd-panel').forEach(function (p) {
            p.classList.remove('open');
        });
        document.querySelectorAll('.nav-dropdown-btn').forEach(function (b) {
            b.classList.remove('open');
            b.setAttribute('aria-expanded', 'false');
        });

        if (!isOpen) {
            panel.classList.add('open');
            btn.classList.add('open');
            btn.setAttribute('aria-expanded', 'true');
        }
    };

    /* Close on outside click */
    document.addEventListener('click', function (e) {
        if (!e.target.closest('.nav-dropdown-wrap')) {
            document.querySelectorAll('.nav-dd-panel').forEach(function (p) {
                p.classList.remove('open');
            });
            document.querySelectorAll('.nav-dropdown-btn').forEach(function (b) {
                b.classList.remove('open');
                b.setAttribute('aria-expanded', 'false');
            });
        }
    });

    /* Close on Escape */
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') {
            document.querySelectorAll('.nav-dd-panel').forEach(function (p) {
                p.classList.remove('open');
            });
            document.querySelectorAll('.nav-dropdown-btn').forEach(function (b) {
                b.classList.remove('open');
                b.setAttribute('aria-expanded', 'false');
            });
        }
    });
})();
</script>
