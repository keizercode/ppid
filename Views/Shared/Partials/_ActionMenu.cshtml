@*
   Views/Shared/Partials/_ActionMenu.cshtml
*@
<style>
.action-cell{display:flex;align-items:center;gap:4px}
.btn-action-primary{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;white-space:nowrap;padding:5px 10px;border-radius:8px;background:#002d7a;color:white;text-decoration:none;transition:background .12s}
.btn-action-primary:hover{background:#1e40af}
.btn-action-primary.cyan{background:#0891b2}.btn-action-primary.cyan:hover{background:#0e7490}
.btn-action-primary.emerald{background:#059669}.btn-action-primary.emerald:hover{background:#047857}
.btn-action-primary.amber{background:#d97706}.btn-action-primary.amber:hover{background:#b45309}
.btn-action-primary.violet{background:#7c3aed}.btn-action-primary.violet:hover{background:#6d28d9}
.action-more-wrap{position:relative}
.btn-action-more{display:flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:6px;background:#f3f4f6;border:1px solid #e5e7eb;color:#6b7280;font-size:14px;font-weight:700;cursor:pointer;transition:all .12s;flex-shrink:0;line-height:1;padding:0}
.btn-action-more:hover{background:#e5e7eb;color:#374151}
/* Template dropdown — disembunyikan di tempat asal, di-clone ke body saat dibuka */
.action-dropdown{display:none}
/* Portal dropdown yang di-render di body */
#__action-portal{position:fixed;z-index:99999;background:white;border:1px solid #e5e7eb;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.14),0 2px 8px rgba(0,0,0,.07);min-width:172px;overflow:hidden;display:none}
.action-dd-item{display:block;padding:8px 14px;font-size:12px;font-weight:500;color:#374151;text-decoration:none;transition:background .1s;white-space:nowrap}
.action-dd-item:hover{background:#f9fafb;color:#111827}
.action-dd-item.danger{color:#dc2626}
.action-dd-item.danger:hover{background:#fef2f2}
.action-dd-divider{height:1px;background:#f3f4f6;margin:2px 0}
</style>

<script>
(function(){
'use strict';

/* ── Buat satu portal div di body — hidup di luar semua stacking context ── */
var portal = document.getElementById('__action-portal');
if(!portal){
    portal = document.createElement('div');
    portal.id = '__action-portal';
    document.body.appendChild(portal);
}

var _srcMenu = null; /* referensi .action-dropdown asli yang sedang terbuka */

/* ── Tutup portal ─────────────────────────────────────────────────── */
function closePortal(){
    portal.style.display = 'none';
    portal.innerHTML     = '';
    _srcMenu             = null;
}

/* ── Posisikan portal ─────────────────────────────────────────────── */
function positionPortal(rect){
    portal.style.top    = (rect.bottom + 4) + 'px';
    portal.style.right  = (window.innerWidth - rect.right) + 'px';
    portal.style.left   = 'auto';
    portal.style.bottom = 'auto';

    requestAnimationFrame(function(){
        var pr = portal.getBoundingClientRect();
        if(pr.bottom > window.innerHeight - 8){
            portal.style.top    = 'auto';
            portal.style.bottom = (window.innerHeight - rect.top + 4) + 'px';
        }
    });
}

/* ── Toggle ───────────────────────────────────────────────────────── */
window.toggleActionMenu = function(btn){
    var wrap = btn.closest('.action-more-wrap');
    var menu = wrap.querySelector('.action-dropdown');
    var same = _srcMenu === menu;

    closePortal();
    if(same) return; /* klik ulang = tutup */

    /* Salin konten ke portal — portal ada di body, bebas dari overflow clip */
    _srcMenu          = menu;
    portal.innerHTML  = menu.innerHTML;
    portal.style.display = 'block';

    positionPortal(btn.getBoundingClientRect());
};

/* ── Tutup saat klik di luar ──────────────────────────────────────── */
document.addEventListener('click', function(e){
    if(!e.target.closest('.action-more-wrap') && !e.target.closest('#__action-portal'))
        closePortal();
});

/* ── Tutup saat scroll / resize ───────────────────────────────────── */
window.addEventListener('scroll', closePortal, true);
window.addEventListener('resize', closePortal);
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closePortal(); });

})();
</script>
