@*
   Views/Shared/Partials/_ConfirmModal.cshtml
   ─────────────────────────────────────────────────────────────────────────
   REUSABLE confirmation modal dengan dua fase:
     Phase 1 — ringkasan + tombol konfirmasi (konten diisi halaman masing-masing)
     Phase 2 — animasi SVG hasil (✅ / ❌) lalu submit/redirect otomatis

   PENGGUNAAN:
     1. Letakkan partial di halaman yang membutuhkan:
            <partial name="Partials/_ConfirmModal" />

     2. Ubah tombol submit menjadi type="button" dengan onclick:
            <button type="button" onclick="showConfirmPopup()">...</button>

     3. Definisikan dua fungsi JS di halaman Anda:

        // showConfirmPopup() — validasi lalu render fase 1
        function showConfirmPopup() {
            if (!validate()) { shakeButton('btn-id'); return; }
            document.getElementById('modal-content').innerHTML = `...fase-1-html...`;
            openModal();
        }

        // runResult() — dipanggil dari tombol fase-1 "Ya, Konfirmasi"
        function runResult() {
            showResultPhase({
                isSuccess : true,
                title     : 'Berhasil!',
                sub       : 'Deskripsi singkat.',
                chip      : 'Label chip',
                onDone    : () => document.getElementById('nama-form').submit()
            });
        }

   JS UTILITIES YANG TERSEDIA SETELAH INCLUDE:
     openModal()                    — buka modal
     closeModal()                   — tutup modal (animasi fade)
     showToast(msg)                 — tampilkan validation toast bawah
     shakeButton(id)                — animasi shake pada elemen dengan id
     buildSvgMark(isSuccess)        — return HTML string animated SVG ✅/❌
     showResultPhase(opts)          — render fase 2 + auto-call opts.onDone
       opts: { isSuccess, title, sub, chip, onDone, delayMs? }

   KELAS CSS TERSEDIA UNTUK FASE 1:
     .m-header .m-badge .m-badge.ap .m-badge.rj
     .m-title .m-sub
     .m-summary .m-row .m-row-lbl .m-row-val
     .m-notice
     .m-actions .btn-back .btn-go .btn-go.ap .btn-go.rj
   ─────────────────────────────────────────────────────────────────────────
*@

<!-- ══ MODAL OVERLAY ══ -->
<div id="modal-overlay" class="modal-overlay" aria-hidden="true" onclick="onOverlayClick(event)">
    <div id="modal-box" class="modal-box" role="dialog" aria-modal="true">
        <div id="modal-content"></div>
    </div>
</div>

<!-- ══ VALIDATION TOAST ══ -->
<div id="vld-toast" role="alert" aria-live="polite">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#fbbf24" stroke-width="2.5" style="flex-shrink:0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
    </svg>
    <span id="vld-toast-msg"></span>
</div>

<style>
/* ══ OVERLAY ══════════════════════════════════════════════════════════════ */
.modal-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(3, 12, 40, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex; align-items: center; justify-content: center; padding: 20px;
    opacity: 0; pointer-events: none;
    transition: opacity .2s ease;
}
.modal-overlay.open { opacity: 1; pointer-events: all; }

/* ══ BOX ══════════════════════════════════════════════════════════════════ */
.modal-box {
    background: #fff;
    border-radius: 22px;
    box-shadow: 0 32px 80px rgba(0,20,70,.22), 0 4px 16px rgba(0,20,70,.10);
    width: 100%; max-width: 420px;
    opacity: 0;
    transform: translateY(20px) scale(.97);
    transition: transform .3s cubic-bezier(.34,1.56,.64,1), opacity .2s ease;
    overflow: hidden;
}
.modal-overlay.open .modal-box {
    opacity: 1;
    transform: translateY(0) scale(1);
}

/* ══ FASE 1 — Confirm ══════════════════════════════════════════════════ */
.m-header    { padding: 24px 24px 0; text-align: center; }
.m-badge     { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; padding: 5px 13px; border-radius: 99px; margin-bottom: 12px; }
.m-badge.ap  { background: #ecfdf5; color: #065f46; border: 1px solid #6ee7b7; }
.m-badge.rj  { background: #fef2f2; color: #991b1b; border: 1px solid #fca5a5; }
.m-badge.info{ background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
.m-title     { font-size: 16px; font-weight: 800; color: #111827; letter-spacing: -.02em; margin-bottom: 4px; }
.m-sub       { font-size: 12px; color: #9ca3af; line-height: 1.6; margin-bottom: 0; }

.m-summary   { margin: 16px 24px; background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 14px; overflow: hidden; }
.m-row       { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; padding: 9px 14px; border-bottom: 1px solid #f1f5f9; }
.m-row:last-child { border-bottom: none; }
.m-row-lbl   { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; white-space: nowrap; flex-shrink: 0; }
.m-row-val   { font-size: 12.5px; font-weight: 700; color: #1e293b; text-align: right; word-break: break-all; }

.m-notice    { margin: 0 24px 16px; display: flex; align-items: flex-start; gap: 8px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 10px 13px; font-size: 11.5px; color: #92400e; line-height: 1.55; }

.m-actions   { display: flex; gap: 10px; padding: 0 24px 24px; }
.btn-back    { flex: 1; padding: 11px 0; border-radius: 12px; border: 1.5px solid #e2e8f0; background: #fff; font-size: 13px; font-weight: 700; color: #64748b; cursor: pointer; transition: all .15s; }
.btn-back:hover { background: #f8fafc; border-color: #cbd5e1; color: #1e293b; }
.btn-go      { flex: 2; padding: 11px 0; border-radius: 12px; border: none; font-size: 13px; font-weight: 800; color: #fff; cursor: pointer; transition: all .15s; }
.btn-go.ap   { background: #002d7a; }
.btn-go.ap:hover { background: #1e3a8a; box-shadow: 0 6px 20px rgba(0,45,122,.35); transform: translateY(-1px); }
.btn-go.rj   { background: #dc2626; }
.btn-go.rj:hover { background: #b91c1c; box-shadow: 0 6px 20px rgba(220,38,38,.35); transform: translateY(-1px); }
.btn-go:active { transform: translateY(0) !important; }

/* ══ FASE 2 — Result ═══════════════════════════════════════════════════ */
.m-result    { padding: 36px 24px 32px; text-align: center; display: flex; flex-direction: column; align-items: center; }

.result-icon { width: 80px; height: 80px; margin-bottom: 20px; }
@@keyframes iconPop {
    from { opacity: 0; transform: scale(.5); }
    to   { opacity: 1; transform: scale(1); }
}
.result-icon { animation: iconPop .3s cubic-bezier(.34,1.56,.64,1) both; }

/* SVG stroke draw — circle */
.svg-ring {
    stroke-dasharray: 201;
    stroke-dashoffset: 201;
    animation: drawRing .55s ease .05s forwards;
}
@@keyframes drawRing { to { stroke-dashoffset: 0; } }

/* SVG stroke draw — checkmark */
.svg-check {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: drawStroke .38s ease .52s forwards;
}
@@keyframes drawStroke { to { stroke-dashoffset: 0; } }

/* SVG stroke draw — cross */
.svg-x1 {
    stroke-dasharray: 34; stroke-dashoffset: 34;
    animation: drawStroke .28s ease .52s forwards;
}
.svg-x2 {
    stroke-dasharray: 34; stroke-dashoffset: 34;
    animation: drawStroke .28s ease .72s forwards;
}

.result-title { font-size: 18px; font-weight: 800; color: #111827; letter-spacing: -.025em; margin-bottom: 6px; animation: fadeUp .3s ease .15s both; }
.result-sub   { font-size: 12.5px; color: #6b7280; line-height: 1.65; max-width: 300px; margin: 0 auto 20px; animation: fadeUp .3s ease .25s both; }
.result-chip  { display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px; border-radius: 99px; font-size: 12px; font-weight: 700; animation: fadeUp .3s ease .35s both; }
.result-chip.ap { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
.result-chip.rj { background: #fef2f2; color: #dc2626; border: 1px solid #fca5a5; }
.result-chip.info { background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; }

@@eyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ══ TOAST ════════════════════════════════════════════════════════════ */
#vld-toast {
    position: fixed; bottom: 28px; left: 50%; z-index: 10000;
    transform: translateX(-50%) translateY(6px);
    background: #1e293b; color: #fff;
    font-size: 12.5px; font-weight: 600;
    padding: 10px 18px; border-radius: 12px;
    display: flex; align-items: center; gap: 8px;
    box-shadow: 0 8px 28px rgba(0,0,0,.28);
    opacity: 0; pointer-events: none;
    transition: opacity .2s ease, transform .2s ease;
    white-space: nowrap;
}
#vld-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

@@keyframes shake {
    0%,100% { transform: translateX(0); }
    20%      { transform: translateX(-5px); }
    40%      { transform: translateX(5px); }
    60%      { transform: translateX(-4px); }
    80%      { transform: translateX(3px); }
}
.do-shake { animation: shake .4s ease both; }
</style>

<script>
/* ══════════════════════════════════════════════════════════════════════
   CONFIRM MODAL — Shared Utilities
   Tersedia global setelah partial ini di-include.
══════════════════════════════════════════════════════════════════════ */
(function (w) {
    'use strict';

    /* ── Modal open / close ─────────────────────────────────────────── */
    w.openModal = function () {
        var overlay = document.getElementById('modal-overlay');
        overlay.setAttribute('aria-hidden', 'false');
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', w.onEsc);
    };

    w.closeModal = function () {
        var overlay = document.getElementById('modal-overlay');
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        document.removeEventListener('keydown', w.onEsc);
    };

    w.onEsc = function (e) { if (e.key === 'Escape') w.closeModal(); };

    w.onOverlayClick = function (e) {
        if (e.target === document.getElementById('modal-overlay')) w.closeModal();
    };

    /* ── Toast ──────────────────────────────────────────────────────── */
    var _toastTimer;
    w.showToast = function (msg) {
        var t = document.getElementById('vld-toast');
        document.getElementById('vld-toast-msg').textContent = msg;
        t.classList.add('show');
        clearTimeout(_toastTimer);
        _toastTimer = setTimeout(function () { t.classList.remove('show'); }, 3200);
    };

    /* ── Shake button ───────────────────────────────────────────────── */
    w.shakeButton = function (id) {
        var btn = document.getElementById(id);
        if (!btn) return;
        btn.classList.add('do-shake');
        btn.addEventListener('animationend', function () {
            btn.classList.remove('do-shake');
        }, { once: true });
    };

    /* ── SVG mark builder ───────────────────────────────────────────── */
    w.buildSvgMark = function (isSuccess) {
        if (isSuccess) {
            return '<svg viewBox="0 0 80 80" fill="none" width="80" height="80">'
                 + '<circle class="svg-ring" cx="40" cy="40" r="32" stroke="#10b981" stroke-width="4" stroke-linecap="round"/>'
                 + '<polyline class="svg-check" points="24,41 34,52 56,28" stroke="#10b981" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>'
                 + '</svg>';
        }
        return '<svg viewBox="0 0 80 80" fill="none" width="80" height="80">'
             + '<circle class="svg-ring" cx="40" cy="40" r="32" stroke="#ef4444" stroke-width="4" stroke-linecap="round"/>'
             + '<line class="svg-x1" x1="27" y1="27" x2="53" y2="53" stroke="#ef4444" stroke-width="4.5" stroke-linecap="round"/>'
             + '<line class="svg-x2" x1="53" y1="27" x2="27" y2="53" stroke="#ef4444" stroke-width="4.5" stroke-linecap="round"/>'
             + '</svg>';
    };

    /* ── showResultPhase ─────────────────────────────────────────────
       opts:
         isSuccess  {bool}     — ✅ atau ❌
         title      {string}   — judul hasil
         sub        {string}   — sub teks
         chip       {string}   — teks label chip
         chipCls    {string?}  — 'ap' | 'rj' | 'info'  (default: isSuccess→'ap', else 'rj')
         onDone     {function} — dipanggil setelah delayMs
         delayMs    {number?}  — default 1700
    ─────────────────────────────────────────────────────────────────── */
    w.showResultPhase = function (opts) {
        var cls = opts.chipCls || (opts.isSuccess ? 'ap' : 'rj');
        document.getElementById('modal-content').innerHTML =
            '<div class="m-result">'
          +   '<div class="result-icon">' + w.buildSvgMark(opts.isSuccess) + '</div>'
          +   '<p class="result-title">' + opts.title + '</p>'
          +   '<p class="result-sub">'   + opts.sub   + '</p>'
          +   '<span class="result-chip ' + cls + '">' + opts.chip + '</span>'
          + '</div>';
        setTimeout(opts.onDone, opts.delayMs !== undefined ? opts.delayMs : 1700);
    };

})(window);
</script>
