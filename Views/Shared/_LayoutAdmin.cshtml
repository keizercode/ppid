    @* ── KEPEGAWAIAN ── *@
    @if (isKepeg)
    {
        <p class="nav-group-label">Kepegawaian</p>
        <a href="/kepegawaian" class="nav-item @(path.StartsWith("/kepegawaian") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586l5.414 5.414V19a2 2 0 01-2 2z"/></svg></span>
            Surat Izin
        </a>
    }

    @* ── KASUBKEL KDI ── *@
    @if (isKasubKDI)
    {
        <p class="nav-group-label">Kasubkel KDI</p>
        <a href="/kasubkel-kdi" class="nav-item @(path == "/kasubkel-kdi" ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg></span>
            Dashboard
        </a>
        <a href="/kasubkel-kdi/permintaan-data" class="nav-item @(path.StartsWith("/kasubkel-kdi/permintaan-data") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6M4 19h16V5a2 2 0 00-2-2H6a2 2 0 00-2 2v14z"/></svg></span>
            Permintaan Data
        </a>
    }

    @* ── KDI ── *@
    @if (isKDI)
    {
        <p class="nav-group-label">KDI</p>
        <a href="/kdi" class="nav-item @(path == "/kdi" ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 19h16M6 17V9M12 17V5M18 17v-7"/></svg></span>
            Dashboard KDI
        </a>
        <a href="/kdi/psmdi" class="nav-item @(path.StartsWith("/kdi/psmdi") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg></span>
            PSMDI
        </a>
        <a href="/kdi/bidang" class="nav-item @(path.StartsWith("/kdi/bidang") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg></span>
            Bidang Terkait
        </a>
    }

    @* ── PRODUSEN DATA ── *@
    @if (isProdData)
    {
        <p class="nav-group-label">Produsen Data</p>
        <a href="/produsen-data" class="nav-item @(path.StartsWith("/produsen-data") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg></span>
            Dashboard Wawancara
        </a>
    }

    <div class="mt-4 pt-3" style="border-top:1px solid var(--nav-divider)">
        <a href="/" class="nav-item">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></span>
            Halaman Publik
        </a>
    </div>
</nav>


        <!-- Sidebar footer + theme toggle -->
        <div class="px-4 py-3 flex items-center justify-between" style="border-top:1px solid var(--border-sidebar)">
            <span style="color:var(--footer-ver)" class="text-[10px] font-medium">· Sistem PPID - DLH</span>
            <button class="theme-toggle" onclick="toggleTheme()" title="Ganti tema">
                <svg class="icon-moon w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                </svg>
                <svg class="icon-sun w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                </svg>
            </button>
        </div>
    </aside>

    <!-- ══ CONTENT ══ -->
    <div class="ml-60 flex-1 flex flex-col min-w-0 content-area" style="background:var(--bg-content)">

        <!-- Topbar -->
        <header class="topbar sticky top-0 z-20">
            <div class="px-6 h-14 flex items-center justify-between gap-4">
                <div class="min-w-0">
                    <h1 class="topbar-title text-[14px] font-bold leading-none truncate">@ViewData["Title"]</h1>
                    @if (ViewData["Sub"] != null) { <p class="topbar-sub text-[11px] mt-0.5">@ViewData["Sub"]</p> }
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                    <span class="topbar-pill">
                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                        @ViewData["Role"]
                    </span>
                    <span class="topbar-pill">
                        <svg class="w-3 h-3" style="color:var(--pill-text)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        @DateTime.Now.ToString("dd MMM yyyy")
                    </span>
                </div>
            </div>
        </header>

        @if (TempData["Success"] != null)
        {
            <div class="alert-slide mx-5 mt-4 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 flex items-center gap-2.5">
                <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <p class="text-emerald-800 text-sm font-medium">@Html.Raw(TempData["Success"])</p>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-slide mx-5 mt-4 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-center gap-2.5">
                <div class="w-5 h-5 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0">
                    <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                </div>
                <p class="text-red-800 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
            </div>
        }

        <main class="flex-1 p-5">@RenderBody()</main>

        <footer class="admin-footer px-6 py-3 flex items-center justify-between">
            <p style="color:var(--footer-text)" class="text-[11px]">&copy; @DateTime.Now.Year Dinas Lingkungan Hidup DKI Jakarta</p>
            <p style="color:var(--footer-ver)" class="text-[11px]">PPID Admin</p>
        </footer>
    </div>
</div>

<script>
function toggleTheme() {
    const html = document.documentElement;
    const next = html.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
    html.setAttribute('data-theme', next);
    localStorage.setItem('ppid-theme', next);
}
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
