    @* ── KASUBKEL UMUM ── *@
    @if (isKasubUmum)
    {
        <p class="nav-group-label">Kasubkel Umum</p>
        <a href="/kasubkel-umum" class="nav-item @(path == "/kasubkel-umum" ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg></span>
            Dashboard
        </a>
        <a href="/kasubkel-umum/permohonan" class="nav-item @(path.StartsWith("/kasubkel-umum/permohonan") ? "active" : "")">
