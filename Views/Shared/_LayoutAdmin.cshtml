        </a>
        <a href="/petugas-loket/observasi" class="nav-item @(path.StartsWith("/petugas-loket/observasi") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></span>
            Observasi
        </a>
        <a href="/petugas-loket/data" class="nav-item @(path.StartsWith("/petugas-loket/data") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg></span>
            Menu Data
        </a>
    }

    @* ── LOKET UMUM ── *@
    @if (isLoketUmum)
    {
        <p class="nav-group-label">Loket Umum</p>
        <a href="/loket-umum" class="nav-item @(path == "/loket-umum" ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg></span>
            Dashboard
        </a>
        <a href="/loket-umum/identifikasi" class="nav-item @(path.StartsWith("/loket-umum/identifikasi")||path.StartsWith("/loket-umum/daftar") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg></span>
            Permohonan Baru
        </a>
        <a href="/loket-umum/permintaan-data" class="nav-item @(path.StartsWith("/loket-umum/permintaan-data") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6M4 19h16V5a2 2 0 00-2-2H6a2 2 0 00-2 2v14z"/></svg></span>
            Permintaan Data
        </a>
        <a href="/loket-umum/wawancara" class="nav-item @(path.StartsWith("/loket-umum/wawancara") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg></span>
            Wawancara
        </a>
        <a href="/loket-umum/observasi" class="nav-item @(path.StartsWith("/loket-umum/observasi") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg></span>
            Observasi
