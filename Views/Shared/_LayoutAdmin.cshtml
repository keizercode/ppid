<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin PPID</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap"
    rel="stylesheet" />

    <!-- Inject theme BEFORE paint to avoid flash -->
    <script>
        (function () {
        const t = localStorage.getItem('ppid-theme') || 'light';
        document.documentElement.setAttribute('data-theme', t);
        })();
    </script>

    <style>
        /* ══ CSS VARIABLES ══ */
        :root,
        [data-theme="light"] {
        --bg-body: #F0F2F5;
        --bg-sidebar: #ffffff;
        --border-sidebar: #E5E7EB;
        --bg-topbar: #ffffff;
        --border-topbar: #E5E7EB;
        --bg-content: #F0F2F5;

        --nav-text: #6B7280;
        --nav-text-hover: #111827;
        --nav-text-active: #1D4ED8;
        --nav-bg-hover: #F3F4F6;
        --nav-bg-active: #EFF6FF;
        --nav-accent: #3B82F6;

        --nav-icon-bg: #F9FAFB;
        --nav-icon-border: #E5E7EB;
        --nav-icon-bg-hover: #F3F4F6;
        --nav-icon-bd-hover: #D1D5DB;
        --nav-icon-bg-active: #DBEAFE;
        --nav-icon-bd-active: #BFDBFE;
        --nav-icon-color: #9CA3AF;
        --nav-icon-hover: #374151;
        --nav-icon-active: #2563EB;

        --nav-label: #9CA3AF;
        --nav-divider: #E5E7EB;

        --brand-sub: #9CA3AF;
        --brand-title: #1F2937;

        --user-bg: #F9FAFB;
        --user-sub: #9CA3AF;
        --user-title: #1B3B6F;
        --user-avatar-bg: #DBEAFE;
        --user-avatar-bd: #BFDBFE;
        --user-avatar-ic: #3B82F6;
        --logout-text: #9CA3AF;

        --topbar-title: #1F2937;
        --topbar-sub: #9CA3AF;
        --pill-bg: #F8F9FB;
        --pill-border: #E5E7EB;
        --pill-text: #6B7280;

        --footer-bg: #ffffff;
        --footer-border: #F3F4F6;
        --footer-text: #9CA3AF;
        --footer-ver: #D1D5DB;

        --toggle-bg: #F3F4F6;
        --toggle-border: #E5E7EB;
        --toggle-icon: #6B7280;
        --toggle-hover: #E5E7EB;
        }

        [data-theme="dark"] {
        --bg-body: #0D1117;
        --bg-sidebar: #0c1a3a;
        --border-sidebar: rgba(255, 255, 255, 0.06);
        --bg-topbar: #111827;
        --border-topbar: rgba(255, 255, 255, 0.07);
        --bg-content: #0D1117;

        --nav-text: rgba(255, 255, 255, 0.40);
        --nav-text-hover: rgba(255, 255, 255, 0.85);
        --nav-text-active: #93c5fd;
        --nav-bg-hover: rgba(255, 255, 255, 0.07);
        --nav-bg-active: rgba(59, 130, 246, 0.18);
        --nav-accent: #3B82F6;

        --nav-icon-bg: rgba(255, 255, 255, 0.05);
        --nav-icon-border: rgba(255, 255, 255, 0.07);
        --nav-icon-bg-hover: rgba(255, 255, 255, 0.09);
        --nav-icon-bd-hover: rgba(255, 255, 255, 0.12);
        --nav-icon-bg-active: rgba(59, 130, 246, 0.25);
        --nav-icon-bd-active: rgba(59, 130, 246, 0.35);
        --nav-icon-color: rgba(255, 255, 255, 0.35);
        --nav-icon-hover: rgba(255, 255, 255, 0.70);
        --nav-icon-active: #93c5fd;

        --nav-label: rgba(255, 255, 255, 0.20);
        --nav-divider: rgba(255, 255, 255, 0.06);

        --brand-sub: rgba(255, 255, 255, 0.25);
        --brand-title: rgba(255, 255, 255, 0.90);

        --user-bg: rgba(255, 255, 255, 0.03);
        --user-sub: rgba(255, 255, 255, 0.25);
        --user-title: rgba(255, 255, 255, 0.70);
        --user-avatar-bg: rgba(59, 130, 246, 0.20);
        --user-avatar-bd: rgba(59, 130, 246, 0.30);
        --user-avatar-ic: #93c5fd;
        --logout-text: rgba(255, 255, 255, 0.22);

        --topbar-title: rgba(255, 255, 255, 0.90);
        --topbar-sub: rgba(255, 255, 255, 0.35);
        --pill-bg: rgba(255, 255, 255, 0.05);
        --pill-border: rgba(255, 255, 255, 0.08);
        --pill-text: rgba(255, 255, 255, 0.40);

        --footer-bg: #111827;
        --footer-border: rgba(255, 255, 255, 0.05);
        --footer-text: rgba(255, 255, 255, 0.25);
        --footer-ver: rgba(255, 255, 255, 0.12);

        --toggle-bg: rgba(255, 255, 255, 0.06);
        --toggle-border: rgba(255, 255, 255, 0.10);
        --toggle-icon: rgba(255, 255, 255, 0.45);
        --toggle-hover: rgba(255, 255, 255, 0.10);
        }

        /* ══ APPLY VARIABLES ══ */
        * {
        font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
        background-color: var(--bg-body);
        transition: background-color .25s ease;
        }

        .sidebar {
        background: var(--bg-sidebar);
        border-right: 1px solid var(--border-sidebar);
        transition: background .25s ease, border-color .25s ease;
        }

        /* ── Nav ── */
        .nav-item {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 7px 10px;
        border-radius: 7px;
        font-size: 12.5px;
        font-weight: 500;
        color: var(--nav-text);
        transition: all 0.12s ease;
        text-decoration: none;
        position: relative;
        }

        .nav-item:hover {
        background: var(--nav-bg-hover);
        color: var(--nav-text-hover);
        }

        .nav-item.active {
        background: var(--nav-bg-active);
        color: var(--nav-text-active);
        font-weight: 600;
        }

        .nav-item.active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 3px;
        height: 60%;
        border-radius: 0 3px 3px 0;
        background: var(--nav-accent);
        }

        .nav-icon {
        width: 26px;
        height: 26px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background: var(--nav-icon-bg);
        border: 1px solid var(--nav-icon-border);
        transition: all 0.12s ease;
        }

        .nav-item:hover .nav-icon {
        background: var(--nav-icon-bg-hover);
        border-color: var(--nav-icon-bd-hover);
        }

        .nav-item.active .nav-icon {
        background: var(--nav-icon-bg-active);
        border-color: var(--nav-icon-bd-active);
        }
        .nav-icon svg {
        color: var(--nav-icon-color);
        transition: color 0.12s;
        }

        .nav-item:hover .nav-icon svg {
        color: var(--nav-icon-hover);
        }

        .nav-item.active .nav-icon svg {
        color: var(--nav-icon-active);
        }

        .nav-group-label {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--nav-label);
        padding: 16px 10px 5px;
        font-weight: 700;
        }

        /* ── Topbar ── */
        .topbar {
        background: var(--bg-topbar);
        border-bottom: 1px solid var(--border-topbar);
        transition: background .25s ease, border-color .25s ease;
        }

        .topbar-title {
        color: var(--topbar-title);
        transition: color .25s;
        }

        .topbar-sub {
        color: var(--topbar-sub);
        transition: color .25s;
        }
        .topbar-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--pill-bg);
        border: 1px solid var(--pill-border);
        border-radius: 8px;
        padding: 5px 12px;
        font-size: 11.5px;
        font-weight: 500;
        color: var(--pill-text);
        transition: all .25s;
        }

        /* ── Theme toggle button ── */
        .theme-toggle {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--toggle-bg);
        border: 1px solid var(--toggle-border);
        color: var(--toggle-icon);
        cursor: pointer;
        transition: all .15s ease;
        flex-shrink: 0;
        }

        .theme-toggle:hover {
        background: var(--toggle-hover);
        }

        /* hide/show sun & moon based on theme */
        [data-theme="light"] .icon-moon {
        display: block;
        }

        [data-theme="light"] .icon-sun {
        display: none;
        }

        [data-theme="dark"] .icon-moon {
        display: none;
        }

        [data-theme="dark"] .icon-sun {
        display: block;
        }

        /* ── Footer ── */
        .admin-footer {
        background: var(--footer-bg);
        border-top: 1px solid var(--footer-border);
        transition: background .25s, border-color .25s;
        }

        /* ── Alerts ── */
        .alert-slide {
        animation: alertSlide .25s ease both;
        }

        @@keyframes alertSlide {
        from {
        opacity: 0;
        transform: translateY(-6px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        /* ── Smooth theme transition on content area ── */
        .content-area {
        transition: background-color .25s ease;
        }
    </style>
</head>

<body class="min-h-screen antialiased">
    <div class="flex min-h-screen">

        <!-- ══ SIDEBAR ══ -->
        <aside class="sidebar w-60 fixed top-0 left-0 h-full z-30 flex flex-col">

            <!-- Brand -->
            <div class="px-4 py-4" style="border-bottom:1px solid var(--border-sidebar)">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
                         style="background:linear-gradient(135deg,#1e40af,#3b82f6)">
                        <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             stroke-width="2.2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <div>
                        <p style="color:var(--brand-sub)"
                           class="text-[9px] uppercase tracking-widest leading-none font-semibold">PPID DLH Jakarta</p>
                        <p style="color:var(--brand-title)" class="font-bold text-[13px] leading-tight mt-0.5">Admin
                            Panel</p>
                        </div>
                    </div>
                </div>

                <!-- User info + Logout -->
                <div class="px-4 py-3" style="border-bottom:1px solid var(--border-sidebar); background:var(--user-bg)">
                    <div class="flex items-center justify-between gap-2">
                        <div class="flex items-center gap-2.5 min-w-0">
                            <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0"
                                 style="background:var(--user-avatar-bg); border:1px solid var(--user-avatar-bd)">
                                <svg class="w-3 h-3" style="color:var(--user-avatar-ic)" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="2.2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <p style="color:var(--user-sub)" class="text-[9px] font-medium leading-none">Masuk sebagai
                                </p>
                                <p style="color:var(--user-title)" class="text-[11px] font-semibold mt-0.5 truncate">
                                    @ViewData["Role"]</p>
                                </div>
                            </div>
                            <form asp-action="Logout" asp-controller="Auth" method="post" class="flex-shrink-0">
                                <button type="submit" title="Keluar"
                                        class="flex items-center gap-1 text-[10px] font-semibold transition-colors px-2 py-1 rounded-lg border border-transparent hover:bg-red-50 hover:border-red-100 hover:text-red-500"
                                        style="color:var(--logout-text)">
                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                         stroke-width="2.2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                    </svg>
                                    Keluar
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Nav -->
                    <nav class="flex-1 px-2 py-3 overflow-y-auto space-y-0.5">
                        <p class="nav-group-label">Loket</p>
                        <a asp-controller="PetugasLoket" asp-action="Index"
                               class="nav-item @(Context.Request.Path.StartsWithSegments("/petugas-loket") ? "active" : "")">
                            <span class="nav-icon">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                                </svg>
                            </span>
                            Dashboard Loket
                        </a>
                        <a asp-controller="PetugasLoket" asp-action="Identifikasi"
                               class="nav-item @(Context.Request.Path.StartsWithSegments("/petugas-loket/identifikasi") ? "active" : "")">
                            <span class="nav-icon">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                                </svg>
                            </span>
                            Permohonan Baru
                        </a>

                        <p class="nav-group-label">Kepegawaian</p>
                        <a asp-controller="Kepegawaian" asp-action="Index"
                               class="nav-item @(Context.Request.Path.StartsWithSegments("/kepegawaian") ? "active" : "")">
                            <span class="nav-icon">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                            </span>
                            Surat Izin
                        </a>

                        <p class="nav-group-label">KDI</p>
                        <a asp-controller="Kdi" asp-action="Index"
                               class="nav-item @(Context.Request.Path == "/kdi" ? "active" : "")">
                            <span class="nav-icon">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 19h16M6 17V9M12 17V5M18 17v-7" />
                                </svg>
                            </span>
                            Dashboard KDI
                        </a>
                        <a asp-controller="Kdi" asp-action="Psmdi"
                               class="nav-item @(Context.Request.Path.StartsWithSegments("/kdi/psmdi") ? "active" : "")">
                            <span class="nav-icon">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7" />
                                </svg>
                            </span>
                            PSMDI
                        </a>
                        <a asp-controller="Kdi" asp-action="Bidang"
                               class="nav-item @(Context.Request.Path.StartsWithSegments("/kdi/bidang") ? "active" : "")">
                            <span class="nav-icon">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                            </span>
                            Bidang Terkait
                        </a>

                        <p class="nav-group-label">Produsen Data</p>
                        <a asp-controller="ProdusenData" asp-action="Index"
                               class="nav-item @(Context.Request.Path.StartsWithSegments("/produsen-data") ? "active" : "")">
                            <span class="nav-icon">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
                                </svg>
                            </span>
                            Dashboard Wawancara
                        </a>

                        <div class="mt-4 pt-3" style="border-top:1px solid var(--nav-divider)">
                            <a asp-controller="Home" asp-action="Index" class="nav-item">
                                <span class="nav-icon">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                         stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                </span>
                                Halaman Publik
                            </a>
                        </div>
                    </nav>

                    <!-- Sidebar footer + theme toggle -->
                    <div class="px-4 py-3 flex items-center justify-between" style="border-top:1px solid var(--border-sidebar)">
                        <span style="color:var(--footer-ver)" class="text-[10px] font-medium">· Sistem PPID - DLH</span>

                        <!-- Theme toggle -->
                        <button class="theme-toggle" onclick="toggleTheme()" title="Ganti tema">
                            <!-- Moon (shown in light mode) -->
                            <svg class="icon-moon w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                            </svg>
                            <!-- Sun (shown in dark mode) -->
                            <svg class="icon-sun w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                            </svg>
                        </button>
                    </div>
                </aside>

                <!-- ══ CONTENT ══ -->
                <div class="ml-60 flex-1 flex flex-col min-w-0 content-area" style="background:var(--bg-content)">

                    <!-- Topbar -->
                    <header class="topbar sticky top-0 z-20">
                        <div class="px-6 h-14 flex items-center justify-between gap-4">
                            <div class="min-w-0">
                                <h1 class="topbar-title text-[14px] font-bold leading-none truncate">@ViewData["Title"]</h1>
                                @if (ViewData["Sub"] != null)
                                {
                                    <p class="topbar-sub text-[11px] mt-0.5">@ViewData["Sub"]</p>
                                }
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0">
                                <span class="topbar-pill">
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                                    @ViewData["Role"]
                                </span>
                                <span class="topbar-pill">
                                    <svg class="w-3 h-3" style="color:var(--pill-text)" fill="none" viewBox="0 0 24 24"
                                         stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="4" width="18" height="18" rx="2" />
                                        <line x1="16" y1="2" x2="16" y2="6" />
                                        <line x1="8" y1="2" x2="8" y2="6" />
                                        <line x1="3" y1="10" x2="21" y2="10" />
                                    </svg>
                                    @DateTime.Now.ToString("dd MMM yyyy")
                                </span>
                            </div>
                        </div>
                    </header>

                    @if (TempData["Success"] != null)
                    {
                        <div
                            class="alert-slide mx-5 mt-4 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 flex items-center gap-2.5">
                            <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center flex-shrink-0">
                                <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <p class="text-emerald-800 text-sm font-medium">@Html.Raw(TempData["Success"])</p>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div
                            class="alert-slide mx-5 mt-4 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-center gap-2.5">
                            <div class="w-5 h-5 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0">
                                <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </div>
                            <p class="text-red-800 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
                        </div>
                    }

                    <main class="flex-1 p-5">@RenderBody()</main>

                    <footer class="admin-footer px-6 py-3 flex items-center justify-between">
                        <p style="color:var(--footer-text)" class="text-[11px]">&copy; @DateTime.Now.Year Dinas Lingkungan Hidup
                            DKI Jakarta</p>
                            <p style="color:var(--footer-ver)" class="text-[11px]">PPID Admin</p>
                        </footer>
                    </div>
                </div>

                <script>
                    function toggleTheme() {
                    const html = document.documentElement;
                    const current = html.getAttribute('data-theme');
                    const next = current === 'light' ? 'dark' : 'light';
                    html.setAttribute('data-theme', next);
                    localStorage.setItem('ppid-theme', next);
                    }
                </script>

                @await RenderSectionAsync("Scripts", required: false)
            </body>

        </html>
