    @* ── KASUBKEL KEPEGAWAIAN ── *@
    @if (isKasubKepeg)
    {
        <p class="nav-group-label">Kasubkel Kepegawaian</p>
        <a href="/kasubkel-kepegawaian" class="nav-item @(path == "/kasubkel-kepegawaian" ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg></span>
            Dashboard
        </a>
        <a href="/kasubkel-kepegawaian/permohonan" class="nav-item @(path.StartsWith("/kasubkel-kepegawaian/permohonan") ? "active" : "")">
            <span class="nav-icon"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586l5.414 5.414V19a2 2 0 01-2 2z"/></svg></span>
            Permohonan Baru
        </a>
