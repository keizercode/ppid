<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin PPID</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Plus Jakarta Sans', sans-serif; }
        body { background-color: #F5F7FA; }

        /* Sidebar */
        .sidebar { background: #fff; border-right: 1px solid #E5E7EB; }

        .nav-item {
            display: flex; align-items: center; gap: 9px;
            padding: 7px 10px; border-radius: 8px;
            font-size: 13px; font-weight: 500;
            color: #6B7280;
            transition: all 0.12s ease;
            text-decoration: none;
        }
        .nav-item:hover { background: #F3F4F6; color: #111827; }
        .nav-item.active { background: #EFF6FF; color: #1D4ED8; font-weight: 600; }

        .nav-icon {
            width: 26px; height: 26px;
            background: #F9FAFB;
            border: 1px solid #E5E7EB;
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; flex-shrink: 0;
        }
        .nav-item.active .nav-icon { background: #DBEAFE; border-color: #BFDBFE; }

        .nav-group-label {
            font-size: 9px; text-transform: uppercase;
            letter-spacing: 0.12em; color: #9CA3AF;
            padding: 14px 10px 4px; font-weight: 700;
        }

        .alert-slide { animation: alertSlide .25s ease both; }
        @@keyframes alertSlide {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="min-h-screen antialiased">
<div class="flex min-h-screen">

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar w-52 fixed top-0 left-0 h-full z-30 flex flex-col">

        <!-- Brand -->
        <div class="px-4 py-4 border-b border-gray-100">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 bg-[#1B3B6F] rounded-lg flex items-center justify-center text-sm">🏛</div>
                <div>
                    <p class="text-gray-400 text-[9px] uppercase tracking-widest leading-none font-semibold">PPID DLH</p>
                    <p class="text-gray-800 font-bold text-[13px] leading-tight">Admin Panel</p>
                </div>
            </div>
        </div>

        <!-- Role badge -->
        <div class="px-4 py-2 border-b border-gray-100">
            <div class="flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                <span class="text-[10px] text-gray-400 font-medium">Logged in as</span>
                <span class="text-[10px] text-[#1B3B6F] font-bold ml-auto truncate">@(ViewData["Role"] ?? "Admin")</span>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-2 py-3 overflow-y-auto space-y-0.5">
            <p class="nav-group-label">Loket</p>
            <a href="/petugas-loket" class="nav-item">
                <span class="nav-icon">🗂</span> Dashboard Loket
            </a>
            <a href="/petugas-loket/identifikasi" class="nav-item">
                <span class="nav-icon">➕</span> Permohonan Baru
            </a>

            <p class="nav-group-label">Kepegawaian</p>
            <a href="/kepegawaian" class="nav-item">
                <span class="nav-icon">📋</span> Surat Izin
            </a>

            <p class="nav-group-label">KDI</p>
            <a href="/kdi" class="nav-item">
                <span class="nav-icon">📊</span> Dashboard KDI
            </a>
            <a href="/kdi/psmdi" class="nav-item">
                <span class="nav-icon">💾</span> PSMDI
            </a>
            <a href="/kdi/bidang" class="nav-item">
                <span class="nav-icon">🏢</span> Bidang Terkait
            </a>

            <div class="mt-4 pt-3 border-t border-gray-100">
                <a href="/" class="nav-item">
                    <span class="nav-icon">🌐</span> Halaman Publik
                </a>
            </div>
        </nav>

        <!-- Footer -->
        <div class="px-4 py-3 border-t border-gray-100">
            <p class="text-[10px] text-gray-300 font-medium">v1.0.0 · Sistem PPID</p>
        </div>
    </aside>

    <!-- ══ CONTENT ══ -->
    <div class="ml-52 flex-1 flex flex-col min-w-0">

        <!-- Topbar -->
        <header class="bg-white border-b border-gray-200 sticky top-0 z-20">
            <div class="px-6 h-14 flex items-center justify-between">
                <div>
                    <h1 class="text-[15px] font-bold text-gray-800 leading-none">@ViewData["Title"]</h1>
                    @if (ViewData["Sub"] != null) {
                        <p class="text-xs text-gray-400 mt-0.5">@ViewData["Sub"]</p>
                    }
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-xs text-gray-400 bg-gray-50 border border-gray-200 rounded-lg px-3 py-1.5 font-medium">
                        @DateTime.Now.ToString("dd MMM yyyy")
                    </span>
                </div>
            </div>
        </header>

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert-slide mx-5 mt-4 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 flex items-start gap-2.5">
                <div class="w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-white text-xs font-bold">✓</span>
                </div>
                <p class="text-emerald-800 text-sm font-medium">@Html.Raw(TempData["Success"])</p>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-slide mx-5 mt-4 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-start gap-2.5">
                <div class="w-5 h-5 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-white text-xs font-bold">✕</span>
                </div>
                <p class="text-red-800 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
            </div>
        }

        <main class="flex-1 p-5">@RenderBody()</main>

        <footer class="bg-white border-t border-gray-100 px-6 py-3 flex items-center justify-between">
            <p class="text-xs text-gray-400">&copy; @DateTime.Now.Year Dinas Lingkungan Hidup DKI Jakarta</p>
            <p class="text-xs text-gray-300">PPID Admin v1.0</p>
        </footer>
    </div>
</div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
