<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin PPID</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Plus Jakarta Sans', sans-serif; }

        body { background-color: #f0f4f9; }

        /* Sidebar */
        .sidebar { background: linear-gradient(180deg, #001e55 0%, #002d7a 100%); }
        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 12px; border-radius: 10px;
            font-size: 13px; font-weight: 500;
            color: rgba(255,255,255,0.6);
            transition: all 0.15s ease;
            text-decoration: none;
        }
        .nav-item:hover {
            background: rgba(255,255,255,0.1);
            color: white;
        }
        .nav-item.active {
            background: rgba(255,255,255,0.15);
            color: white;
        }
        .nav-icon {
            width: 28px; height: 28px;
            background: rgba(255,255,255,0.08);
            border-radius: 7px;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }
        .nav-group-label {
            font-size: 9.5px;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(255,255,255,0.3);
            padding: 12px 12px 4px;
            font-weight: 600;
        }

        /* Cards */
        .card { background: white; border-radius: 16px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }

        /* Alert */
        .alert-enter { animation: slideDown 0.25s ease; }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Table rows */
        .tbl-row:hover td { background: #f8faff; }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 10px; }
    </style>
</head>
<body class="min-h-screen">
<div class="flex min-h-screen">

    <!-- ═══════════════════════ SIDEBAR ═══════════════════════ -->
    <aside class="sidebar w-56 fixed top-0 left-0 h-full z-30 flex flex-col">

        <!-- Brand -->
        <div class="px-4 py-5 border-b border-white/10">
            <div class="flex items-center gap-2.5">
                <div class="w-9 h-9 bg-white/10 border border-white/15 rounded-xl flex items-center justify-center text-base">🏛</div>
                <div>
                    <p class="text-white/40 text-[9px] uppercase tracking-widest leading-none">PPID DLH</p>
                    <p class="text-white font-bold text-[13px] leading-tight">Admin Panel</p>
                </div>
            </div>
        </div>

        <!-- Role badge -->
        <div class="px-4 py-2.5 border-b border-white/10">
            <div class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                <span class="text-[10px] text-white/40 uppercase tracking-wide">Role</span>
                <span class="text-[11px] text-amber-300 font-semibold ml-auto">@(ViewData["Role"] ?? "Admin")</span>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-2 py-3 overflow-y-auto space-y-0.5">
            <p class="nav-group-label">Loket</p>
            <a href="/petugas-loket" class="nav-item">
                <span class="nav-icon">🗂</span> Dashboard Loket
            </a>
            <a href="/petugas-loket/identifikasi" class="nav-item">
                <span class="nav-icon">➕</span> Permohonan Baru
            </a>

            <p class="nav-group-label">Kepegawaian</p>
            <a href="/kepegawaian" class="nav-item">
                <span class="nav-icon">📋</span> Surat Izin
            </a>

            <p class="nav-group-label">KDI</p>
            <a href="/kdi" class="nav-item">
                <span class="nav-icon">📊</span> Dashboard KDI
            </a>
            <a href="/kdi/psmdi" class="nav-item">
                <span class="nav-icon">💾</span> PSMDI
            </a>
            <a href="/kdi/bidang" class="nav-item">
                <span class="nav-icon">🏢</span> Bidang Terkait
            </a>

            <div class="mt-4 pt-4 border-t border-white/10">
                <a href="/" class="nav-item">
                    <span class="nav-icon">🌐</span> Halaman Publik
                </a>
            </div>
        </nav>

        <!-- Version -->
        <div class="px-4 py-3 border-t border-white/10">
            <p class="text-[10px] text-white/25">v1.0.0 · Sistem PPID</p>
        </div>
    </aside>

    <!-- ═══════════════════════ CONTENT ═══════════════════════ -->
    <div class="ml-56 flex-1 flex flex-col min-w-0">

        <!-- Topbar -->
        <header class="bg-white border-b border-gray-100 sticky top-0 z-20">
            <div class="px-6 h-14 flex items-center justify-between">
                <div>
                    <h1 class="text-[15px] font-bold text-gray-800 leading-none">@ViewData["Title"]</h1>
                    @if (ViewData["Sub"] != null) {
                        <p class="text-xs text-gray-400 mt-0.5">@ViewData["Sub"]</p>
                    }
                </div>
                <div class="flex items-center gap-3">
                    <div class="text-xs text-gray-400 bg-gray-50 border border-gray-200 rounded-lg px-3 py-1.5">
                        📅 @DateTime.Now.ToString("dd MMM yyyy")
                    </div>
                </div>
            </div>
        </header>

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert-enter mx-5 mt-4 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 flex items-start gap-2.5">
                <span class="text-emerald-500 text-base mt-0.5">✓</span>
                <p class="text-emerald-800 text-sm font-medium">@Html.Raw(TempData["Success"])</p>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-enter mx-5 mt-4 bg-red-50 border border-red-200 rounded-xl px-4 py-3 flex items-start gap-2.5">
                <span class="text-red-500 text-base mt-0.5">✕</span>
                <p class="text-red-800 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
            </div>
        }

        <main class="flex-1 p-5">@RenderBody()</main>

        <footer class="bg-white border-t border-gray-100 px-6 py-3 flex items-center justify-between">
            <p class="text-xs text-gray-400">&copy; @DateTime.Now.Year Dinas Lingkungan Hidup DKI Jakarta</p>
            <p class="text-xs text-gray-300">PPID Admin v1.0</p>
        </footer>
    </div>
</div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
