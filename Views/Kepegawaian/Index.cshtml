@* === KEPEGAWAIAN/Index.cshtml === *@
@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Dashboard Kepegawaian";
    ViewData["Role"]  = "Kepegawaian";
    Layout = "_LayoutAdmin";
}
<div class="flex items-center justify-between mb-4">
    <h3 class="font-semibold text-gray-700 text-sm">Permohonan Menunggu Surat Izin</h3>
</div>
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    @if (!Model.Any()) {
        <div class="text-center py-14 text-gray-400">
            <div class="text-3xl mb-2">📭</div>
            <p class="text-sm">Belum ada permohonan yang perlu surat izin</p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead><tr class="bg-gray-50 border-b text-left">
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">No. Permohonan</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Pemohon</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Kategori</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Judul</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Aksi</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model) {
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-3 font-mono text-xs text-blue-600">@item.NoPermohonan</td>
                            <td class="px-4 py-3 font-medium text-gray-800">@item.Pribadi?.Nama</td>
                            <td class="px-4 py-3 text-xs">@(item.KategoriPemohon == "Mahasiswa" ? "🎓 Mahasiswa" : "🏢 LSM")</td>
                            <td class="px-4 py-3 text-xs text-gray-600 max-w-xs truncate">@item.JudulPenelitian</td>
                            <td class="px-4 py-3">
                                <a href="/kepegawaian/surat-izin/@item.PermohonanPPIDID"
                                   class="text-xs bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-lg font-medium">
                                    📋 Buat Surat Izin
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
