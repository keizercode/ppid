@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Dashboard Kepegawaian";
    ViewData["Role"]  = "Kepegawaian";
    Layout = "_LayoutAdmin";
}

<div class="flex items-center justify-between mb-4">
    <div>
        <p class="font-bold text-gray-700 text-sm">Permohonan Menunggu Surat Izin</p>
        <p class="text-xs text-gray-400 mt-0.5">Daftar permohonan yang perlu diterbitkan surat izin</p>
    </div>
    @if (Model.Any()) {
        <span class="bg-amber-100 text-amber-700 text-xs font-bold px-3 py-1.5 rounded-full">@Model.Count menunggu</span>
    }
</div>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    @if (!Model.Any()) {
        <div class="text-center py-20">
            <div class="text-5xl mb-3">🎉</div>
            <p class="font-semibold text-gray-600 text-sm">Semua surat izin sudah diterbitkan</p>
            <p class="text-gray-400 text-xs mt-1">Belum ada permohonan yang perlu surat izin</p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-50">
                        <th class="px-5 py-3.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">No. Permohonan</th>
                        <th class="px-5 py-3.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Pemohon</th>
                        <th class="px-5 py-3.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Kategori</th>
                        <th class="px-5 py-3.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Judul</th>
                        <th class="px-5 py-3.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model) {
                        <tr class="hover:bg-blue-50/30 transition-colors group">
                            <td class="px-5 py-3.5 font-mono text-xs text-blue-600 font-semibold">@item.NoPermohonan</td>
                            <td class="px-5 py-3.5 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>
                            <td class="px-5 py-3.5">
                                <span class="text-xs font-medium @(item.KategoriPemohon == "Mahasiswa" ? "text-blue-600" : "text-emerald-600")">
                                    @(item.KategoriPemohon == "Mahasiswa" ? "🎓 Mahasiswa" : "🏢 LSM")
                                </span>
                            </td>
                            <td class="px-5 py-3.5 text-xs text-gray-500 max-w-xs truncate">@item.JudulPenelitian</td>
                            <td class="px-5 py-3.5">
                                <a href="/kepegawaian/surat-izin/@item.PermohonanPPIDID"
                                   class="inline-flex items-center gap-1.5 text-xs bg-[#002d7a] hover:bg-blue-900 text-white px-3.5 py-2 rounded-lg font-semibold transition-colors shadow-sm">
                                    📋 Buat Surat Izin
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
