@model SuratIzinVm
@{
    ViewData["Title"] = "Terbitkan Surat Izin";
    ViewData["Role"]  = "Kepegawaian";
    Layout = "_LayoutAdmin";
}

<div class="max-w-2xl mx-auto">
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

    <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
        <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center text-xl">📋</div>
        <div>
            <h3 class="font-bold text-gray-800">Terbitkan Surat Izin Penelitian</h3>
            <p class="text-xs font-mono text-gray-400 mt-0.5">@Model.NoPermohonan · @Model.NamaPemohon</p>
        </div>
    </div>

    <div class="p-6">

        <!-- Ringkasan -->
        <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-5">
            <p class="text-xs font-bold text-blue-600 uppercase tracking-wide mb-3">Ringkasan Permohonan</p>
            <div class="grid grid-cols-2 gap-3 text-sm">
                <div><span class="text-[10px] text-blue-400 uppercase font-semibold block">Kategori</span><p class="text-blue-800 font-medium">@Model.Kategori</p></div>
                <div><span class="text-[10px] text-blue-400 uppercase font-semibold block">No. Permohonan</span><p class="text-blue-800 font-mono font-bold">@Model.NoPermohonan</p></div>
                <div class="col-span-2"><span class="text-[10px] text-blue-400 uppercase font-semibold block">Judul</span><p class="text-blue-700 leading-snug">@Model.JudulPenelitian</p></div>
                <div class="col-span-2">
                    <span class="text-[10px] text-blue-400 uppercase font-semibold block mb-1">Keperluan</span>
                    <div class="flex flex-wrap gap-1.5">
                        @if(Model.IsObservasi)     {<span class="text-xs bg-orange-50 text-orange-700 border border-orange-200 px-2.5 py-0.5 rounded-full font-semibold">🔍 Observasi</span>}
                        @if(Model.IsPermintaanData){<span class="text-xs bg-blue-100 text-blue-700 border border-blue-200 px-2.5 py-0.5 rounded-full font-semibold">📊 Permintaan Data</span>}
                        @if(Model.IsWawancara)     {<span class="text-xs bg-violet-50 text-violet-700 border border-violet-200 px-2.5 py-0.5 rounded-full font-semibold">🎤 Wawancara</span>}
                    </div>
                </div>
            </div>
        </div>

        <form asp-action="SuratIzinPost" asp-controller="Kepegawaian" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PermohonanPPIDID"/>
            <input type="hidden" asp-for="NoPermohonan"/>
            <input type="hidden" asp-for="NamaPemohon"/>
            <input type="hidden" asp-for="Kategori"/>
            <input type="hidden" asp-for="JudulPenelitian"/>

            <!-- Konfirmasi Keperluan -->
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-5">
                <p class="text-xs font-bold text-amber-700 uppercase tracking-wide mb-1">Konfirmasi Keperluan</p>
                <p class="text-xs text-amber-600 mb-3">Centang sesuai kebutuhan pemohon — menentukan alur paralel setelah disposisi.</p>
                <div class="space-y-2.5">
                    <label class="flex items-center gap-3 cursor-pointer bg-white rounded-lg px-3 py-2.5 border border-amber-100 hover:border-amber-300">
                        <input asp-for="IsObservasi" type="checkbox" class="w-4 h-4 rounded" onchange="checkProdusen()"/>
                        <span class="font-semibold text-gray-700 text-sm">🔍 Observasi</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer bg-white rounded-lg px-3 py-2.5 border border-amber-100 hover:border-amber-300">
                        <input asp-for="IsPermintaanData" type="checkbox" class="w-4 h-4 rounded" onchange="checkProdusen()"/>
                        <span class="font-semibold text-gray-700 text-sm">📊 Permintaan Data</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer bg-white rounded-lg px-3 py-2.5 border border-amber-100 hover:border-amber-300">
                        <input asp-for="IsWawancara" type="checkbox" class="w-4 h-4 rounded" onchange="checkProdusen()"/>
                        <span class="font-semibold text-gray-700 text-sm">🎤 Wawancara</span>
                    </label>
                </div>
            </div>

            <!-- No. Surat -->
            <div class="mb-4">
                <label class="lbl">No. Surat Izin <span class="text-red-400">*</span></label>
                <input asp-for="NoSuratIzin" type="text" placeholder="073/Surat.Izin/DINAS.LHK/2026" class="fld"/>
                <span asp-validation-for="NoSuratIzin" class="err"></span>
            </div>

            <!-- Upload Surat -->
            <div class="mb-5">
                <label class="lbl">Upload File Surat Izin</label>
                <input asp-for="FileSuratIzin" type="file" accept=".pdf,.jpg,.jpeg,.png"
                       class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm bg-gray-50 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-emerald-50 file:text-emerald-700"/>
            </div>

            <!-- ══ DISPOSISI MULTI-UNIT — dropdown dari API ══ -->
            <div class="mb-5">
                <label class="lbl">Disposisi ke Unit Kerja <span class="text-gray-400 font-normal normal-case">(bisa lebih dari satu)</span></label>

                <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 space-y-3" id="disposisi-wrapper">

                    <!-- PSMDI -->
                    <label id="lbl-psmdi"
                           class="flex items-center gap-3 cursor-pointer bg-white rounded-lg px-3 py-2.5 border border-gray-200 hover:border-blue-300 has-[:checked]:border-blue-400 has-[:checked]:bg-blue-50 transition-all">
                        <input type="checkbox" name="DisposisiUnits" value="PSMDI" id="chk-psmdi" class="w-4 h-4 rounded accent-blue-600"/>
                        <div>
                            <span class="text-sm font-semibold text-gray-700">PSMDI</span>
                            <span class="text-xs text-gray-400 ml-2">Peran Serta Masyarakat, Data dan Informasi</span>
                        </div>
                    </label>

                    <!-- Bidang Terkait — dropdown dari API -->
                    <div id="bidang-rows-container" class="space-y-2"></div>

                    <!-- Tombol tambah bidang -->
                    <button type="button" id="btn-add-bidang" onclick="addBidangRow()"
                            class="flex items-center gap-2 text-xs font-semibold text-emerald-700 hover:text-emerald-900 px-2 py-1">
                        <span class="w-4 h-4 bg-emerald-100 rounded-full flex items-center justify-center text-[10px] font-black">+</span>
                        Tambah Unit Kerja / Bidang
                    </button>
                </div>

                <div id="bidang-loading" class="hidden text-xs text-blue-500 font-medium mt-2 flex items-center gap-1.5">
                    <span class="inline-block w-3 h-3 border-2 border-blue-300 border-t-blue-600 rounded-full animate-spin"></span>
                    Memuat daftar unit bidang...
                </div>

                <p class="text-[11px] text-gray-400 mt-2">
                    ⚠️ Jika <strong>Wawancara saja</strong> (tanpa Data/Observasi), diteruskan langsung ke Produsen Data.
                </p>
            </div>

            <!-- Produsen Data (khusus wawancara only) -->
            <div id="div-produsen" class="mb-4 hidden">
                <label class="lbl">Unit / Nama Produsen Data (Wawancara)</label>
                <input asp-for="NamaProdusenData" type="text" placeholder="Nama unit atau narasumber wawancara" class="fld"/>
            </div>

            <div class="flex gap-3 pt-2">
                <a href="/kepegawaian" class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
                <button type="submit" class="flex-grow bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2.5 px-8 rounded-xl text-sm shadow-sm">
                    ✅ Terbitkan & Disposisi →
                </button>
            </div>
        </form>
    </div>
</div>
</div>

<style>
    .lbl{display:block;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
    .fld{display:block;width:100%;border:1px solid #e5e7eb;border-radius:10px;padding:9px 14px;font-size:13.5px;background:#fafafa;outline:none;transition:all .15s}
    .fld:focus{box-shadow:0 0 0 2.5px #3b82f6;border-color:transparent;background:white}
    .err{color:#ef4444;font-size:11px;margin-top:3px;display:block}
    select.fld{appearance:none;background-image:url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");background-repeat:no-repeat;background-position:right 10px center;background-size:16px;padding-right:2.5rem}
</style>

<script>
// ── State ─────────────────────────────────────────────────────────────────────
let _bidangList  = [];   // [{id, namaBidang}]
let _rowCount    = 0;

// ── Load bidang dari API ──────────────────────────────────────────────────────
async function loadBidang() {
    document.getElementById('bidang-loading').classList.remove('hidden');
    document.getElementById('btn-add-bidang').disabled = true;
    try {
        const res = await fetch('/api/bidang');
        _bidangList = await res.json();
    } catch(e) {
        console.error('Gagal memuat bidang', e);
        _bidangList = [];
    } finally {
        document.getElementById('bidang-loading').classList.add('hidden');
        document.getElementById('btn-add-bidang').disabled = false;
    }
    // Tambah satu row default
    addBidangRow();
}

// ── Buat select options ───────────────────────────────────────────────────────
function buildOptions(selected) {
    let html = '<option value="">— Pilih Unit Kerja / Bidang —</option>';
    _bidangList.forEach(item => {
        const sel = item.id === selected ? 'selected' : '';
        html += `<option value="${item.id}" data-name="${item.namaBidang}" ${sel}>${item.namaBidang}</option>`;
    });
    return html;
}

// ── Tambah row bidang ─────────────────────────────────────────────────────────
function addBidangRow(preId) {
    const idx  = _rowCount++;
    const div  = document.createElement('div');
    div.id     = `bidang-row-${idx}`;
    div.className = 'flex items-center gap-2 bg-white rounded-lg border border-gray-200 px-3 py-2';
    div.innerHTML = `
        <input type="checkbox" name="DisposisiUnits" value="BidangTerkait"
               id="chk-bidang-${idx}" class="w-4 h-4 rounded accent-emerald-600 flex-shrink-0"
               onchange="onBidangCheck(${idx})"/>
        <select id="sel-bidang-${idx}"
                class="flex-1 border-0 bg-transparent text-sm text-gray-700 focus:outline-none cursor-pointer"
                onchange="onBidangSelect(${idx})" disabled>
            ${buildOptions(preId || '')}
        </select>
        <input type="hidden" name="NamaBidangList" id="bidang-name-${idx}" value="" />
        <button type="button" onclick="removeBidangRow(${idx})"
                class="text-gray-300 hover:text-red-400 text-lg leading-none font-bold flex-shrink-0">×</button>`;
    document.getElementById('bidang-rows-container').appendChild(div);
}

function removeBidangRow(idx) {
    document.getElementById(`bidang-row-${idx}`)?.remove();
}

function onBidangCheck(idx) {
    const chk = document.getElementById(`chk-bidang-${idx}`);
    const sel = document.getElementById(`sel-bidang-${idx}`);
    sel.disabled = !chk.checked;
    if (!chk.checked) {
        document.getElementById(`bidang-name-${idx}`).value = '';
    } else {
        onBidangSelect(idx);
        sel.focus();
    }
}

function onBidangSelect(idx) {
    const sel  = document.getElementById(`sel-bidang-${idx}`);
    const opt  = sel.options[sel.selectedIndex];
    document.getElementById(`bidang-name-${idx}`).value = opt?.dataset.name || '';
}

// ── Toggle Produsen Data ─────────────────────────────────────────────────────
function checkProdusen() {
    const isWaw  = document.querySelector('[name="IsWawancara"]')?.checked;
    const isData = document.querySelector('[name="IsPermintaanData"]')?.checked;
    const isObs  = document.querySelector('[name="IsObservasi"]')?.checked;
    document.getElementById('div-produsen').classList.toggle('hidden', !(isWaw && !isData && !isObs));
}

// ── Init ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    loadBidang();
    checkProdusen();
    document.querySelectorAll('[name="IsWawancara"],[name="IsPermintaanData"],[name="IsObservasi"]')
        .forEach(el => el.addEventListener('change', checkProdusen));
});
</script>
