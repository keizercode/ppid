@model LoginVm
@{
    ViewData["Title"] = "Login Admin";
    Layout = null;
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — PPID Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>* { font-family:'Plus Jakarta Sans',sans-serif; }</style>
</head>
<body class="min-h-screen bg-[#F0F4FA] flex items-center justify-center px-4 py-10">

<div class="w-full max-w-sm">

    <!-- Brand -->
    <div class="text-center mb-8">
        <div class="flex items-center justify-center mb-4">
            <div class="bg-[#1B3B6F] rounded-2xl px-4 py-3 shadow-lg flex items-center gap-3">
                <img src="https://ppid.jakarta.go.id/assets/home/ppidNew/images/logo/logo-ppid-email.png"
                     alt="Logo PPID Jakarta"
                     class="h-9 w-auto object-contain"
                     id="login-logo"
                     onerror="this.style.display='none';document.getElementById('login-logo-fallback').style.display='flex'" />
                <div id="login-logo-fallback"
                     class="text-white font-black text-xl tracking-widest"
                     style="display:none">PPID</div>
                <div class="border-l border-white/20 pl-3">
                    <p class="text-white/60 text-[9px] uppercase tracking-widest leading-none font-semibold">Dinas Lingkungan Hidup</p>
                    <p class="text-white font-bold text-sm leading-tight mt-0.5">DKI Jakarta</p>
                </div>
            </div>
        </div>
        <h1 class="text-lg font-extrabold text-gray-900">Portal Admin PPID</h1>
        <p class="text-gray-400 text-sm mt-1">Masuk ke panel pengelolaan permohonan</p>
    </div>

    <!-- Card Login -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-5 text-red-700 text-sm">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>@err.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="LoginPost" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="mb-4">
                <label class="lbl">Username</label>
                <input asp-for="Username" id="Username" class="fld" placeholder="Masukkan username" autocomplete="username" />
                <span asp-validation-for="Username" class="err"></span>
            </div>

            <div class="mb-5">
                <label class="lbl">Password</label>
                <div class="relative">
                    <input asp-for="Password" type="password" id="Password"
                           class="fld pr-10" placeholder="••••••••" autocomplete="current-password" />
                    <button type="button" onclick="togglePwd()"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                        <svg id="eye-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="err"></span>
            </div>

            <label class="flex items-center gap-2.5 mb-5 cursor-pointer">
                <input asp-for="RememberMe" type="checkbox" class="w-4 h-4 rounded accent-blue-600" />
                <span class="text-sm text-gray-600 font-medium">Ingat saya selama 7 hari</span>
            </label>

            <button type="submit"
                    class="w-full bg-[#1B3B6F] hover:bg-[#122850] text-white font-bold py-3 rounded-xl transition-colors shadow-sm text-sm">
                Masuk ke Sistem
            </button>
        </form>
    </div>

    <!-- Akun Testing -->
    <div class="mt-4 bg-white rounded-xl border border-gray-100 p-4 shadow-sm">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Akun Pengujian</p>

        @{
            var accounts = new (string User, string Role, string Pass, string Color, string DotColor)[]
            {
                ("loket",      "Loket Kepegawaian",    "loket123",      "text-blue-700",   "bg-blue-400"),
                ("loketumum",  "Loket Umum",           "loketumum123",  "text-emerald-700","bg-emerald-400"),
                ("kasubkepeg", "Kasubkel Kepegawaian", "kasubkepeg123", "text-violet-700", "bg-violet-400"),
                ("kasubkdi",   "Kasubkel KDI",         "kasubkdi123",   "text-cyan-700",   "bg-cyan-400"),
                ("admin",      "Administrator",        "admin123",      "text-red-700",    "bg-red-400"),
            };
        }

        <div class="space-y-1">
            @foreach (var (user, role, pass, color, dot) in accounts)
            {
                <button type="button" onclick="fillLogin('@user','@pass')"
                        class="w-full flex items-center gap-2.5 py-1.5 px-2 rounded-lg hover:bg-gray-50 transition-colors text-left">
                    <span class="w-1.5 h-1.5 rounded-full @dot flex-shrink-0"></span>
                    <span class="font-mono font-bold text-xs @color w-28 flex-shrink-0">@user</span>
                    <span class="text-gray-400 text-xs flex-1">@role</span>
                    <span class="font-mono text-gray-300 text-[11px]">@pass</span>
                </button>
            }
        </div>

        <div class="mt-3 pt-3 border-t border-gray-100">
            <p class="text-[10px] font-bold text-gray-300 uppercase tracking-widest mb-2">(role lama — tidak aktif)</p>
            @{
                var legacy = new (string User, string Pass)[]
                {
                    ("kepegawaian", "kepeg123"),
                    ("kdi",         "kdi123"),
                    ("produsen",    "produsen123"),
                };
            }
            <div class="space-y-0.5">
                @foreach (var (u, p) in legacy)
                {
                    <button type="button" onclick="fillLogin('@u','@p')"
                            class="w-full flex items-center gap-2.5 py-1 px-2 rounded-lg hover:bg-gray-50 transition-colors text-left opacity-40">
                        <span class="w-1.5 h-1.5 rounded-full bg-gray-300 flex-shrink-0"></span>
                        <span class="font-mono font-bold text-xs text-gray-400 w-28 flex-shrink-0">@u</span>
                        <span class="font-mono text-gray-300 text-[11px]">@p</span>
                    </button>
                }
            </div>
        </div>
    </div>

    <p class="text-center text-xs text-gray-300 mt-6">
        &copy; @DateTime.Now.Year &middot; PPID Dinas Lingkungan Hidup DKI Jakarta
    </p>
</div>

<style>
    .lbl { display:block; font-size:11px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:.05em; margin-bottom:4px; }
    .fld { display:block; width:100%; border:1px solid #e5e7eb; border-radius:10px; padding:10px 14px; font-size:13.5px; background:#fafafa; outline:none; transition:all .15s; }
    .fld:focus { box-shadow:0 0 0 2.5px #3b82f6; border-color:transparent; background:white; }
    .err { color:#ef4444; font-size:11px; margin-top:3px; display:block; }
</style>

<script>
function togglePwd() {
    const inp = document.getElementById('Password');
    inp.type = inp.type === 'password' ? 'text' : 'password';
}
function fillLogin(user, pass) {
    document.getElementById('Username').value = user;
    document.getElementById('Password').value = pass;
}
</script>

</body>
</html>
