// TUJUAN QUICK-FILL — ADVANCED TOGGLE LOGIC
// ══════════════════════════════════════════════════════════════════════════
(function initTujuanButtons() {
    var field   = g('f-tujuan');
    if (!field) return;

    var buttons = Array.prototype.slice.call(document.querySelectorAll('.tujuan-btn'));

    // Simpan innerHTML asli setiap button sebelum dimodifikasi
    buttons.forEach(function (btn) { btn.dataset.originalHtml = btn.innerHTML; });

    // Tandai satu button sebagai aktif, sisanya non-aktif
    function setActive(activeBtn) {
        buttons.forEach(function (btn) {
            var isThis = (btn === activeBtn);
            btn.classList.toggle('active', isThis);
            btn.innerHTML = isThis
                ? btn.dataset.originalHtml
                  + ' <span class="tujuan-cancel" title="Batalkan pilihan" aria-label="Batalkan">×</span>'
                : btn.dataset.originalHtml;
        });
        field.classList.add('has-preset');
    }

    // Lepas semua state aktif
    function clearActive() {
        buttons.forEach(function (btn) {
            btn.classList.remove('active');
            btn.innerHTML = btn.dataset.originalHtml;
        });
        field.classList.remove('has-preset');
    }

    buttons.forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            // Abaikan klik jika target adalah tanda × sendiri tapi button sudah aktif
            // (tetap jalankan logika toggle di bawah)
            var isActive = this.classList.contains('active');

            if (isActive) {
                // ── DESELECT: klik tombol aktif → batalkan pilihan, kosongkan field ──
                clearActive();
                field.value = '';
                field.focus();
            } else {
                // ── SELECT: pilih baru → isi field, tandai aktif ──
                field.value = this.dataset.value;
                setActive(this);
                // Fokus ke field dan tempatkan kursor di AKHIR teks
                // agar user bisa langsung append tanpa harus klik lagi
                field.focus();
                var len = field.value.length;
                try { field.setSelectionRange(len, len); } catch(e2){}
            }
        });
    });

    // ── SYNC DARI TYPING ────────────────────────────────────────────────
    // Saat user mengetik di field:
    //   • Teks cocok persis dengan salah satu button  → highlight button itu
    //   • Teks berubah (append / hapus / ganti)       → lepas semua highlight,
    //     teks di field TETAP terjaga (tidak dihapus)
    field.addEventListener('input', function () {
        var val = this.value.trim();
        var matched = null;
        buttons.forEach(function (btn) {
            if (btn.dataset.value === val) matched = btn;
        });
        if (matched) {
            setActive(matched);
        } else {
            clearActive();
            // field.classList bisa tetap non-preset;
            // teks tidak disentuh — user bebas mengetik apapun
        }
    });

    // Sync awal jika field sudah terisi (mis. validation error page reload)
    if (field.value.trim()) field.dispatchEvent(new Event('input'));
})();
// ══════════════════════════════════════════════════════════════════════════

(async function init(){
    switchTab('nik');
    await loadProvinsi();
    var sk=getF('f-kabupatenID'),sc=getF('f-kecamatanID'),sl=getF('f-kelurahanID'),sp=getF('f-provinsiID');
    if(sp)pickSel('sel-provinsi',sp,'f-provinsiID','f-namaProvinsi');
    if(sk||sc||sl)await cascadeWilayah(sk,sc,sl,getF('f-namaKabupaten'),getF('f-namaKecamatan'),getF('f-namaKelurahan'));
})();
</script>
