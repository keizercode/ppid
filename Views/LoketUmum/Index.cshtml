@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Dashboard Loket Umum";
    ViewData["Role"]  = "Loket Umum";
    Layout = "_LayoutAdmin";
    var q      = ViewData["Q"]      as string;
    var status = ViewData["Status"] as int?;
    var dash   = ViewData["DashVm"] as DashboardVm ?? new DashboardVm();
    int pctProses  = dash.Total > 0 ? (int)Math.Round(dash.Proses  * 100.0 / dash.Total) : 0;
    int pctSelesai = dash.Total > 0 ? (int)Math.Round(dash.Selesai * 100.0 / dash.Total) : 0;

    string StCls(int? s) => (s ?? 0) switch {

        StatusId.Selesai            => "st st--selesai",
        StatusId.DataSiap           => "st st--siap",
        StatusId.FeedbackPemohon    => "st st--feedback",
        StatusId.MenungguVerifikasi => "st st--verif",
        StatusId.Dibatalkan         => "st st--batal",
        StatusId.TerdaftarSistem    => "st st--daftar",
        StatusId.IdentifikasiAwal   => "st st--daftar",
        StatusId.MenungguSuratIzin  => "st st--surat",
        _                           => "st st--proses"
    };
    string StDot(int? s) => (s ?? 0) switch {
        StatusId.Selesai            => "#059669",
        StatusId.DataSiap           => "#10b981",
        StatusId.FeedbackPemohon    => "#0ea5e9",
        StatusId.MenungguVerifikasi => "#8b5cf6",
        StatusId.Dibatalkan         => "#ef4444",
        StatusId.TerdaftarSistem    => "#9ca3af",
        StatusId.IdentifikasiAwal   => "#9ca3af",
        StatusId.MenungguSuratIzin  => "#3b82f6",
        _                           => "#f59e0b"
    };
}

<partial name="Partials/_ActionMenu" />

<!-- ══ STAT CARDS ══ -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="rounded-2xl p-5 relative overflow-hidden shadow-md min-h-[110px] flex flex-col justify-between" style="background:#0f1f4a">
        <div class="absolute top-0 right-0 w-24 h-24 rounded-full bg-white/5 -translate-y-8 translate-x-8 pointer-events-none"></div>
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-blue-300/70 mb-1">Total Permohonan</p>
        <p class="text-5xl font-black text-white leading-none" style="font-variant-numeric:tabular-nums">@dash.Total</p>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-emerald-400 to-transparent"></div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Proses</p>
        <p class="text-4xl font-black text-gray-800 leading-none mb-2">@dash.Proses</p>
        <div class="w-full bg-amber-50 rounded-full h-1 overflow-hidden"><div class="bg-amber-400 h-full rounded-full" style="width:@pctProses%"></div></div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Selesai</p>
        <p class="text-4xl font-black text-gray-800 leading-none mb-2">@dash.Selesai</p>
        <div class="w-full bg-emerald-50 rounded-full h-1 overflow-hidden"><div class="bg-emerald-500 h-full rounded-full" style="width:@pctSelesai%"></div></div>
    </div>
</div>

<!-- ══ CHARTS ══ -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Total Permohonan per Bulan</p>
        <div style="height:200px"><canvas id="chartTotal"></canvas></div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Proses & Selesai per Bulan</p>
        <div style="height:200px"><canvas id="chartStatus"></canvas></div>
    </div>
</div>

<!-- ══ TABS ══ -->
<div class="flex flex-wrap gap-2 mb-4">
    <a href="/loket-umum"                 class="tab-btn @(Context.Request.Path == "/loket-umum" ? "active" : "")">📋 Semua</a>
    <a href="/loket-umum/permintaan-data" class="tab-btn @(Context.Request.Path.StartsWithSegments("/loket-umum/permintaan-data") ? "active" : "")">📊 Permintaan Data</a>
    <a href="/loket-umum/wawancara"       class="tab-btn @(Context.Request.Path.StartsWithSegments("/loket-umum/wawancara") ? "active" : "")">🎤 Wawancara</a>
    <a href="/loket-umum/observasi"       class="tab-btn @(Context.Request.Path.StartsWithSegments("/loket-umum/observasi") ? "active" : "")">🔍 Observasi</a>
    <a href="/loket-umum/data"            class="tab-btn @(Context.Request.Path.StartsWithSegments("/loket-umum/data") ? "active" : "")">📂 Menu Data</a>
</div>

<!-- ══ SEARCH + ACTION ══ -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-3">
    <form method="get" class="flex gap-2 flex-1">
        <input type="text" name="q" value="@q" placeholder="Cari nama, NIK, atau nomor permohonan..."
               class="flex-1 border border-gray-200 rounded-xl px-4 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-emerald-300" />
        <select name="status" class="border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white">
            <option value="">Semua Status</option>
            <option value="2"  selected="@(status==2)">Terdaftar</option>
            <option value="3"  selected="@(status==3)">Identifikasi Awal</option>
            <option value="14" selected="@(status==14)">Menunggu Verifikasi</option>
            <option value="4"  selected="@(status==4)">Menunggu Surat Izin</option>
            <option value="7"  selected="@(status==7)">Sedang Diproses</option>
            <option value="10" selected="@(status==10)">Data Siap</option>
            <option value="11" selected="@(status==11)">Selesai</option>
        </select>
        <button type="submit" class="bg-emerald-700 hover:bg-emerald-800 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-colors">Cari</button>
        @if (!string.IsNullOrEmpty(q) || status.HasValue)
        {
            <a href="/loket-umum" class="border border-gray-200 text-gray-500 text-xs px-3 py-2 rounded-xl hover:bg-gray-50 flex items-center">Reset</a>
        }
    </form>
    <a href="/loket-umum/daftar"
       class="bg-emerald-700 hover:bg-emerald-800 text-white text-xs font-semibold px-4 py-2 rounded-lg flex items-center gap-1.5 whitespace-nowrap shadow-sm transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Permohonan Baru (LSM)
    </a>
</div>

<!-- ══ TABLE ══ -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="col-th">No Permohonan</th>
                    <th class="col-th">Nama Pemohon</th>
                    <th class="col-th">Kategori</th>
                    <th class="col-th">Keperluan</th>
                    <th class="col-th">Tgl Permohonan</th>
                    <th class="col-th">Batas Waktu</th>
                    <th class="col-th">Status</th>
                    <th class="col-th">Tgl Selesai</th>
                    <th class="col-th">Pengampu</th>
                    <th class="col-th">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        bool overdue = item.IsOverdue;

                        string? primerHref  = null;
                        string? primerLabel = null;
                        string  primerColor = "emerald";

                        if (item.StatusPPIDID == StatusId.TerdaftarSistem)
                        { primerHref = $"/loket-umum/input-identifikasi/{item.PermohonanPPIDID}"; primerLabel = "Input ID"; primerColor = "cyan"; }
                        else if (item.StatusPPIDID == StatusId.IdentifikasiAwal)
                        { primerHref = $"/loket-umum/upload-ttd/{item.PermohonanPPIDID}"; primerLabel = "Upload TTD"; primerColor = "amber"; }
                        else if (item.StatusPPIDID >= StatusId.MenungguSuratIzin)
                        { primerHref = $"/loket-umum/detail/{item.PermohonanPPIDID}"; primerLabel = "Lihat Detail"; primerColor = "emerald"; }

                        bool canCetak = item.StatusPPIDID >= StatusId.IdentifikasiAwal;

                        <tr class="hover:bg-emerald-50/30 transition-colors group @(overdue ? "bg-red-50/20" : "")">

                            @* {{!-- ── No. Permohonan ── --}} *@
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-1.5">
                                    @if (overdue) { <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span> }
                                    <span class="no-perm">@item.NoPermohonan</span>
                                </div>
                            </td>

                            <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>

                            @* {{!-- ── Kategori ── --}} *@
                            <td class="px-4 py-3">
                                <span class="kat-chip kat-umum">
                                    <span class="kat-dot" style="background:#6b7280"></span>🏛️ @item.KategoriPemohon
                                </span>
                            </td>

                            @* {{!-- ── Keperluan ── --}} *@
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if (item.IsObservasi)      { <span class="badge bg-orange-50 text-orange-700 border-orange-100">Obs</span> }
                                    @if (item.IsPermintaanData) { <span class="badge bg-blue-50 text-blue-700 border-blue-100">Data</span> }
                                    @if (item.IsWawancara)      { <span class="badge bg-violet-50 text-violet-700 border-violet-100">Waw</span> }
                                </div>
                            </td>

                            <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">@item.TanggalPermohonan?.ToString("dd MMM yyyy")</td>

                            <td class="px-4 py-3 whitespace-nowrap">
                                @if (item.BatasWaktu.HasValue)
                                {
                                    <span class="text-xs @(overdue ? "text-red-600 font-semibold" : item.HariSisa <= 3 ? "text-amber-600" : "text-gray-500")">
                                        @(overdue ? "⚠ " : "")@item.BatasWaktu.Value.ToString("dd MMM yyyy")
                                        @if (item.HariSisa.HasValue && item.StatusPPIDID < StatusId.Selesai)
                                        {
                                            <span class="block text-[10px] @(overdue ? "text-red-400" : "text-gray-400")">
                                                @(overdue ? $"Lewat {Math.Abs(item.HariSisa.Value)} hari" : $"Sisa {item.HariSisa.Value} hari")
                                            </span>
                                        }
                                    </span>
                                }
                                else { <span class="text-gray-300 text-xs">—</span> }
                            </td>

                            @* {{!-- ── Status ── --}} *@
                            <td class="px-4 py-3">
                                <span class="@StCls(item.StatusPPIDID)">
                                    <span class="st-dot" style="background:@StDot(item.StatusPPIDID)"></span>
                                    @item.Status?.NamaStatusPPID
                                </span>
                            </td>

                            <td class="px-4 py-3 text-xs text-gray-400">@(item.TanggalSelesai?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td class="px-4 py-3 text-xs text-gray-500">@(item.Pengampu ?? "—")</td>

                            <td class="px-4 py-3">
                                <div class="action-cell">
                                    @if (primerHref != null)
                                    { <a href="@primerHref" class="btn-action-primary @primerColor">@primerLabel</a> }
                                    else
                                    { <a href="/loket-umum/detail/@item.PermohonanPPIDID" class="btn-action-primary" style="background:#6b7280">Detail</a> }

                                    <div class="action-more-wrap">
                                        <button class="btn-action-more" onclick="toggleActionMenu(this)" type="button">⋯</button>
                                        <div class="action-dropdown hidden">
                                            <a href="/loket-umum/detail/@item.PermohonanPPIDID" class="action-dd-item">📋 Detail</a>
                                            <a href="/loket-umum/edit/@item.PermohonanPPIDID"   class="action-dd-item">✏️ Edit</a>
                                            @if (item.StatusPPIDID == StatusId.TerdaftarSistem)
                                            { <a href="/loket-umum/input-identifikasi/@item.PermohonanPPIDID" class="action-dd-item">🪪 Input Identifikasi</a> }
                                            @if (item.StatusPPIDID == StatusId.IdentifikasiAwal)
                                            { <a href="/loket-umum/cetak-identifikasi/@item.PermohonanPPIDID" class="action-dd-item">🖨️ Cetak Formulir</a> }
                                            @if (item.StatusPPIDID == StatusId.IdentifikasiAwal)
                                            { <a href="/loket-umum/upload-ttd/@item.PermohonanPPIDID" class="action-dd-item">✍️ Upload TTD</a> }
                                            @if (canCetak && item.StatusPPIDID >= StatusId.MenungguSuratIzin)
                                            { <a href="/loket-umum/cetak-identifikasi/@item.PermohonanPPIDID" class="action-dd-item">📄 Cetak Surat</a> }
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="px-6 py-16 text-center">
                            <div class="max-w-xs mx-auto">
                                <div class="w-16 h-16 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">🏛️</div>
                                @if (!string.IsNullOrEmpty(q) || status.HasValue)
                                {
                                    <p class="text-sm font-semibold text-gray-600 mb-1">Tidak ada hasil ditemukan</p>
                                    <p class="text-xs text-gray-400 mb-4">Coba ubah kata kunci atau filter status.</p>
                                    <a href="/loket-umum" class="inline-flex items-center gap-2 text-xs font-semibold text-emerald-700 hover:underline">↩ Reset filter</a>
                                }
                                else
                                {
                                    <p class="text-sm font-semibold text-gray-600 mb-1">Belum ada permohonan</p>
                                    <p class="text-xs text-gray-400 mb-4">Daftarkan permohonan LSM pertama dari loket ini.</p>
                                    <a href="/loket-umum/daftar" class="inline-flex items-center gap-2 bg-emerald-700 hover:bg-emerald-800 text-white text-xs font-bold px-4 py-2 rounded-xl transition-colors">
                                        + Daftarkan Permohonan LSM Baru
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .col-th{padding:12px 16px;text-align:left;font-size:10px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em}
    .no-perm{font-family:'JetBrains Mono','Fira Code',ui-monospace,monospace;font-size:11.5px;font-weight:700;color:#1d4ed8;background:#eff6ff;border:1px solid #dbeafe;border-radius:6px;padding:3px 8px;white-space:nowrap;letter-spacing:.01em;display:inline-block}
    .kat-chip{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;border-radius:20px;padding:3px 9px;white-space:nowrap;border:1px solid}
    .kat-mhs{color:#1d4ed8;background:#eff6ff;border-color:#bfdbfe}
    .kat-lsm{color:#065f46;background:#f0fdf4;border-color:#a7f3d0}
    .kat-umum{color:#4b5563;background:#f9fafb;border-color:#e5e7eb}
    .kat-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .st{display:inline-flex;align-items:center;gap:5px;font-size:10.5px;font-weight:600;border-radius:20px;padding:3px 9px;white-space:nowrap;border:1px solid;line-height:1.4}
    .st-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .st--selesai{color:#065f46;background:#ecfdf5;border-color:#a7f3d0}
    .st--siap{color:#047857;background:#f0fdf4;border-color:#bbf7d0}
    .st--feedback{color:#0369a1;background:#f0f9ff;border-color:#bae6fd}
    .st--verif{color:#5b21b6;background:#f5f3ff;border-color:#ddd6fe}
    .st--batal{color:#9f1239;background:#fff1f2;border-color:#fecdd3}
    .st--daftar{color:#374151;background:#f9fafb;border-color:#e5e7eb}
    .st--proses{color:#92400e;background:#fffbeb;border-color:#fde68a}
    .st--surat{color:#1e40af;background:#eff6ff;border-color:#bfdbfe}
    .badge{font-size:10px;padding:1px 6px;border-radius:999px;font-weight:600;border:1px solid}
    .tab-btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:10px;font-size:12px;font-weight:600;border:1px solid #e5e7eb;color:#6b7280;background:white;text-decoration:none;transition:all .15s}
    .tab-btn:hover{background:#f9fafb;color:#374151}
    .tab-btn.active{background:#047857;color:white;border-color:#047857}
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const labels=@Html.Raw(dash.LabelsJson),totals=@Html.Raw(dash.TotalJson),proses=@Html.Raw(dash.ProsesJson),selesai=@Html.Raw(dash.SelesaiJson);
const gridC='rgba(0,0,0,.06)',tickC='#9ca3af';
const o={responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:tickC,font:{size:11},boxWidth:12}}},scales:{x:{grid:{color:gridC},ticks:{color:tickC,font:{size:10}}},y:{grid:{color:gridC},ticks:{color:tickC,font:{size:10},stepSize:1},beginAtZero:true}}};
new Chart(document.getElementById('chartTotal'),{type:'bar',data:{labels,datasets:[{label:'Total',data:totals,backgroundColor:'rgba(16,185,129,.7)',borderRadius:6}]},options:o});
new Chart(document.getElementById('chartStatus'),{type:'line',data:{labels,datasets:[
    {label:'Proses',data:proses,borderColor:'#F59E0B',backgroundColor:'rgba(245,158,11,.12)',fill:true,tension:.4,pointRadius:4},
    {label:'Selesai',data:selesai,borderColor:'#10B981',backgroundColor:'rgba(16,185,129,.12)',fill:true,tension:.4,pointRadius:4}
]},options:o});
</script>
}
