@* ─── LoketUmum/Observasi.cshtml ──────────────────────────────────────────── *@
@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Observasi — Loket Umum";
    ViewData["Role"]  = "Loket Umum";
    Layout = "_LayoutAdmin";
    var q = ViewData["Q"] as string;

    string StCls(int? s) => (s ?? 0) switch {
        StatusId.Selesai              => "st st--selesai",
        StatusId.DataSiap             => "st st--siap",
        StatusId.ObservasiDijadwalkan => "st st--obs",
        StatusId.MenungguVerifikasi   => "st st--verif",
        StatusId.TerdaftarSistem      => "st st--daftar",
        StatusId.IdentifikasiAwal     => "st st--daftar",
        StatusId.Dibatalkan           => "st st--batal",
        _                             => "st st--proses"
    };
    string StDot(int? s) => (s ?? 0) switch {
        StatusId.Selesai              => "#059669",
        StatusId.DataSiap             => "#10b981",
        StatusId.ObservasiDijadwalkan => "#f97316",
        StatusId.MenungguVerifikasi   => "#8b5cf6",
        StatusId.TerdaftarSistem      => "#9ca3af",
        StatusId.IdentifikasiAwal     => "#9ca3af",
        StatusId.Dibatalkan           => "#ef4444",
        _                             => "#f59e0b"
    };
}

<partial name="Partials/_ActionMenu" />

<!-- ══ TABS ══ -->
<div class="flex flex-wrap gap-2 mb-4">
    <a href="/loket-umum"                 class="tab-btn">📋 Semua</a>
    <a href="/loket-umum/permintaan-data" class="tab-btn">📊 Permintaan Data</a>
    <a href="/loket-umum/wawancara"       class="tab-btn">🎤 Wawancara</a>
    <a href="/loket-umum/observasi"       class="tab-btn active">🔍 Observasi</a>
    <a href="/loket-umum/data"            class="tab-btn">📂 Menu Data</a>
</div>

<!-- ══ SEARCH + ACTION ══ -->
<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 mb-3">
    <form method="get" class="flex gap-2 flex-1">
        <input type="text" name="q" value="@q" placeholder="Cari nama atau nomor permohonan..."
               class="flex-1 border border-gray-200 rounded-xl px-4 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-emerald-300"/>
        <button type="submit" class="bg-emerald-700 hover:bg-emerald-800 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-colors">Cari</button>
        @if (!string.IsNullOrEmpty(q))
        { <a href="/loket-umum/observasi" class="border border-gray-200 text-gray-500 text-xs px-3 py-2 rounded-xl hover:bg-gray-50 flex items-center">Reset</a> }
    </form>
    <a href="/loket-umum/daftar"
       class="bg-emerald-700 hover:bg-emerald-800 text-white text-xs font-semibold px-4 py-2 rounded-lg flex items-center gap-1.5 whitespace-nowrap shadow-sm transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Permohonan Baru (LSM)
    </a>
</div>

<!-- ══ TABLE ══ -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="col-th">No Permohonan</th>
                    <th class="col-th">Nama Pemohon</th>
                    <th class="col-th">Kategori</th>
                    <th class="col-th">Tgl Permohonan</th>
                    <th class="col-th">Batas Waktu</th>
                    <th class="col-th">Status</th>
                    <th class="col-th">Jadwal Observasi</th>
                    <th class="col-th">Pengampu</th>
                    <th class="col-th">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="px-6 py-16 text-center">
                            <div class="max-w-xs mx-auto">
                                <div class="w-16 h-16 bg-orange-50 border border-orange-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">🔍</div>
                                <p class="text-sm font-semibold text-gray-600 mb-1">
                                    @(string.IsNullOrEmpty(q) ? "Belum ada permohonan observasi" : "Tidak ada hasil yang cocok")
                                </p>
                                @if (!string.IsNullOrEmpty(q))
                                { <a href="/loket-umum/observasi" class="text-xs font-semibold text-emerald-700 hover:underline">↩ Reset filter</a> }
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    bool overdue = item.IsOverdue;
                    var jadwal = item.Jadwal.Where(j => j.JenisJadwal == "Observasi").OrderByDescending(j => j.CreatedAt).FirstOrDefault();
                    string? primerHref = null; string? primerLabel = null; string primerColor = "orange";

                    if (item.StatusPPIDID == StatusId.TerdaftarSistem)
                    { primerHref = $"/loket-umum/input-identifikasi/{item.PermohonanPPIDID}"; primerLabel = "Input ID"; primerColor = "cyan"; }
                    else if (item.StatusPPIDID == StatusId.IdentifikasiAwal)
                    { primerHref = $"/loket-umum/upload-ttd/{item.PermohonanPPIDID}"; primerLabel = "Upload TTD"; primerColor = "amber"; }
                    else
                    { primerHref = $"/loket-umum/detail/{item.PermohonanPPIDID}"; primerLabel = "Lihat Detail"; primerColor = "orange"; }

                    bool canCetak = item.StatusPPIDID >= StatusId.IdentifikasiAwal;

                    <tr class="hover:bg-orange-50/20 transition-colors group @(overdue ? "bg-red-50/20" : "")">

                        <td class="px-4 py-3">
                            <div class="flex items-center gap-1.5">
                                @if (overdue) { <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span> }
                                <span class="no-perm">@item.NoPermohonan</span>
                            </div>
                        </td>
                        <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>
                        <td class="px-4 py-3">
                            <span class="kat-chip kat-umum">
                                <span class="kat-dot" style="background:#6b7280"></span>🏛️ @item.KategoriPemohon
                            </span>
                        </td>
                        <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">@item.TanggalPermohonan?.ToString("dd MMM yyyy")</td>
                        <td class="px-4 py-3 whitespace-nowrap">
                            @if (item.BatasWaktu.HasValue)
                            {
                                <span class="text-xs @(overdue ? "text-red-600 font-semibold" : item.HariSisa <= 3 ? "text-amber-600" : "text-gray-500")">
                                    @(overdue ? "⚠ " : "")@item.BatasWaktu.Value.ToString("dd MMM yyyy")
                                    @if (item.HariSisa.HasValue && item.StatusPPIDID < StatusId.Selesai)
                                    {
                                        <span class="block text-[10px] @(overdue ? "text-red-400" : "text-gray-400")">
                                            @(overdue ? $"Lewat {Math.Abs(item.HariSisa.Value)} hari" : $"Sisa {item.HariSisa.Value} hari")
                                        </span>
                                    }
                                </span>
                            }
                            else { <span class="text-gray-300 text-xs">—</span> }
                        </td>
                        <td class="px-4 py-3">
                            <span class="@StCls(item.StatusPPIDID)">
                                <span class="st-dot" style="background:@StDot(item.StatusPPIDID)"></span>
                                @item.Status?.NamaStatusPPID
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            @if (jadwal != null)
                            {
                                <div class="inline-flex flex-col">
                                    <span class="text-xs font-semibold text-orange-700 bg-orange-50 border border-orange-100 rounded-lg px-2 py-1 leading-tight">
                                        @jadwal.Tanggal?.ToString("dd MMM yyyy")
                                    </span>
                                    <span class="text-[10px] text-gray-400 mt-0.5 pl-1">🕐 @jadwal.Waktu?.ToString("HH:mm")</span>
                                </div>
                            }
                            else { <span class="text-[11px] text-gray-300 italic">Belum dijadwalkan</span> }
                        </td>
                        <td class="px-4 py-3 text-xs text-gray-500">@(item.Pengampu ?? "—")</td>
                        <td class="px-4 py-3">
                            <div class="action-cell">
                                <a href="@primerHref" class="btn-action-primary @primerColor">@primerLabel</a>
                                <div class="action-more-wrap">
                                    <button class="btn-action-more" onclick="toggleActionMenu(this)" type="button">⋯</button>
                                    <div class="action-dropdown hidden">
                                        <a href="/loket-umum/detail/@item.PermohonanPPIDID" class="action-dd-item">📋 Detail</a>
                                        <a href="/loket-umum/edit/@item.PermohonanPPIDID"   class="action-dd-item">✏️ Edit</a>
                                        @if (item.StatusPPIDID == StatusId.TerdaftarSistem)
                                        { <a href="/loket-umum/input-identifikasi/@item.PermohonanPPIDID" class="action-dd-item">🪪 Input Identifikasi</a> }
                                        @if (item.StatusPPIDID == StatusId.IdentifikasiAwal)
                                        { <a href="/loket-umum/cetak-identifikasi/@item.PermohonanPPIDID" class="action-dd-item">🖨️ Cetak Formulir</a>
                                          <a href="/loket-umum/upload-ttd/@item.PermohonanPPIDID"          class="action-dd-item">✍️ Upload TTD</a> }
                                        @if (canCetak && item.StatusPPIDID >= StatusId.MenungguSuratIzin)
                                        { <a href="/loket-umum/cetak-identifikasi/@item.PermohonanPPIDID" class="action-dd-item">📄 Cetak Surat</a> }
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .col-th{padding:12px 16px;text-align:left;font-size:10px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em}
    .no-perm{font-family:'JetBrains Mono','Fira Code',ui-monospace,monospace;font-size:11.5px;font-weight:700;color:#1d4ed8;background:#eff6ff;border:1px solid #dbeafe;border-radius:6px;padding:3px 8px;white-space:nowrap;letter-spacing:.01em;display:inline-block}
    .kat-chip{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;border-radius:20px;padding:3px 9px;white-space:nowrap;border:1px solid}
    .kat-umum{color:#4b5563;background:#f9fafb;border-color:#e5e7eb}
    .kat-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .st{display:inline-flex;align-items:center;gap:5px;font-size:10.5px;font-weight:600;border-radius:20px;padding:3px 9px;white-space:nowrap;border:1px solid;line-height:1.4}
    .st-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .st--selesai{color:#065f46;background:#ecfdf5;border-color:#a7f3d0}
    .st--siap{color:#047857;background:#f0fdf4;border-color:#bbf7d0}
    .st--verif{color:#5b21b6;background:#f5f3ff;border-color:#ddd6fe}
    .st--batal{color:#9f1239;background:#fff1f2;border-color:#fecdd3}
    .st--daftar{color:#374151;background:#f9fafb;border-color:#e5e7eb}
    .st--proses{color:#92400e;background:#fffbeb;border-color:#fde68a}
    .st--obs{color:#7c2d12;background:#fff7ed;border-color:#fed7aa}
    .tab-btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:10px;font-size:12px;font-weight:600;border:1px solid #e5e7eb;color:#6b7280;background:white;text-decoration:none;transition:all .15s}
    .tab-btn:hover{background:#f9fafb;color:#374151}
    .tab-btn.active{background:#047857;color:white;border-color:#047857}
    .btn-action-primary.orange{background:#ea580c}
    .btn-action-primary.orange:hover{background:#c2410c}
</style>
