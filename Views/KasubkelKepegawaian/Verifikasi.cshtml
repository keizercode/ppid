@* ─── Views/KasubkelKepegawaian/Verifikasi.cshtml ──────────────────────── *@
@model VerifikasiVm
@{
    ViewData["Title"] = "Verifikasi Form Identifikasi";
    ViewData["Role"]  = "Kasubkel Kepegawaian";
    Layout = "_LayoutAdmin";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

        <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
            <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center text-xl">✅</div>
            <div>
                <h3 class="font-bold text-gray-800">Verifikasi Form Identifikasi Awal</h3>
                <p class="text-xs font-mono text-gray-400 mt-0.5">@Model.NoPermohonan · @Model.NamaPemohon</p>
            </div>
        </div>

        <div class="p-6">

            <!-- Ringkasan Permohonan -->
            <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-5 space-y-3">
                <p class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">Ringkasan Permohonan</p>
                <div class="grid grid-cols-2 gap-3 text-sm">
                    <div><span class="text-[10px] text-blue-400 uppercase font-semibold block">No. Permohonan</span><p class="font-mono font-bold text-blue-800">@Model.NoPermohonan</p></div>
                    <div><span class="text-[10px] text-blue-400 uppercase font-semibold block">Kategori</span><p class="text-blue-700 font-medium">@Model.Kategori</p></div>
                    <div class="col-span-2"><span class="text-[10px] text-blue-400 uppercase font-semibold block">Judul Penelitian</span><p class="text-blue-700 leading-snug">@Model.JudulPenelitian</p></div>
                    <div class="col-span-2"><span class="text-[10px] text-blue-400 uppercase font-semibold block">Latar Belakang</span><p class="text-blue-600 text-xs leading-relaxed line-clamp-3">@Model.LatarBelakang</p></div>
                    <div class="col-span-2">
                        <span class="text-[10px] text-blue-400 uppercase font-semibold block mb-1">Keperluan</span>
                        <div class="flex flex-wrap gap-2">
                            @if (Model.IsObservasi)      { <span class="text-xs bg-orange-50 text-orange-700 border border-orange-200 px-2.5 py-1 rounded-full font-semibold">🔍 Observasi</span> }
                            @if (Model.IsPermintaanData) { <span class="text-xs bg-blue-50 text-blue-700 border border-blue-200 px-2.5 py-1 rounded-full font-semibold">📊 Permintaan Data</span> }
                            @if (Model.IsWawancara)      { <span class="text-xs bg-violet-50 text-violet-700 border border-violet-200 px-2.5 py-1 rounded-full font-semibold">🎤 Wawancara</span> }
                        </div>
                    </div>
                </div>
            </div>

            <form id="verifikasi-form" asp-action="VerifikasiPost" asp-controller="KasubkelKepegawaian" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PermohonanPPIDID" />
                <input type="hidden" asp-for="NoPermohonan" />
                <input type="hidden" asp-for="NamaPemohon" />
                <input type="hidden" asp-for="JudulPenelitian" />
                <input type="hidden" asp-for="LatarBelakang" />
                <input type="hidden" asp-for="IsObservasi" />
                <input type="hidden" asp-for="IsPermintaanData" />
                <input type="hidden" asp-for="IsWawancara" />

                <!-- Keputusan -->
                <div class="mb-4">
                    <label class="lbl">Keputusan Verifikasi <span class="text-red-400">*</span></label>
                    <div class="grid grid-cols-2 gap-2">
                        <label class="flex items-center gap-2.5 p-3 rounded-xl border-2 border-gray-200 cursor-pointer hover:border-emerald-300 has-[:checked]:border-emerald-500 has-[:checked]:bg-emerald-50">
                            <input asp-for="Disetujui" type="radio" value="true" class="accent-emerald-600" id="setujui" />
                            <span class="text-sm font-semibold text-gray-700">✅ Setujui & Teruskan</span>
                        </label>
                        <label class="flex items-center gap-2.5 p-3 rounded-xl border-2 border-gray-200 cursor-pointer hover:border-red-300 has-[:checked]:border-red-500 has-[:checked]:bg-red-50">
                            <input asp-for="Disetujui" type="radio" value="false" class="accent-red-600" id="tolak" />
                            <span class="text-sm font-semibold text-gray-700">❌ Tolak & Kembalikan</span>
                        </label>
                    </div>
                </div>

                <!-- ── Disposisi Multi-Unit ─────────────────────────────────── -->
                <div id="div-setujui" class="mb-4">
                    <div class="flex items-center justify-between mb-2">
                        <label class="lbl mb-0">Disposisi ke Unit / Bidang <span class="text-red-400">*</span></label>
                        <span id="disposisi-counter" class="text-[10px] font-bold text-blue-600 bg-blue-50 border border-blue-200 px-2 py-0.5 rounded-full hidden">0 dipilih</span>
                    </div>

                    <!-- Hidden inputs untuk binding List<string> DisposisiUnits -->
                    <div id="disposisi-hidden-container"></div>

                    @* di bawah ini belum dibutuhkan *@
                    @* <div class="mb-2">
                        <label class="flex items-center gap-2.5 p-3 rounded-xl border-2 border-gray-200 cursor-pointer hover:border-blue-300 has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50 transition-all">
                            <input type="checkbox" value="PSMDI" data-label="PSMDI"
                                   class="disposisi-cb accent-blue-600 w-4 h-4 flex-shrink-0"
                                   onchange="onDisposisiChange()" />
                            <div>
                                <span class="text-sm font-semibold text-gray-700">PSMDI</span>
                                <span class="text-xs text-gray-400 ml-1">Peran Serta Masyarakat, Data dan Informasi</span>
                            </div>
                        </label>
                    </div> *@

                    <!-- Bidang / Unit Terkait — hierarkis -->
                    <div class="border-2 border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex items-center justify-between px-3 py-2 bg-gray-50 border-b border-gray-200">
                            <span class="text-[11px] font-bold text-gray-500 uppercase tracking-wider">Bidang / Unit Terkait</span>
                            <div class="flex items-center gap-2">
                                <div id="bidang-loading" class="hidden flex items-center gap-1.5 text-[10px] text-blue-500 font-medium">
                                    <span class="inline-block w-3 h-3 border-2 border-blue-300 border-t-blue-600 rounded-full animate-spin"></span>
                                    Memuat...
                                </div>
                                @* button di bawah ini tidak berfungsi jadinya saya comment *@
                                @* <button type="button" onclick="collapseAll()"
                                        class="text-[10px] text-gray-400 hover:text-gray-600 font-semibold px-2 py-1 rounded hover:bg-gray-100 transition-all">
                                    Tutup Semua
                                </button> *@
                            </div>
                        </div>

                        <div id="bidang-tree" class="divide-y divide-gray-100" style="max-height:320px;overflow-y:auto">
                            <!-- populated by JS -->
                            <div id="bidang-skeleton" class="p-4 space-y-2">
                                @for (int i = 0; i < 4; i++)
                                {
                                    <div class="flex gap-2 animate-pulse">
                                        <div class="w-4 h-4 rounded bg-gray-100 flex-shrink-0 mt-0.5"></div>
                                        <div class="flex-1 h-4 bg-gray-100 rounded"></div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <p id="disposisi-error" class="hidden text-xs text-red-500 font-medium mt-1.5">
                        ⚠ Pilih minimal satu unit disposisi.
                    </p>
                </div>

                <!-- Alasan tolak -->
                <div id="div-tolak" class="mb-4 hidden">
                    <label class="lbl">Alasan Penolakan</label>
                    <textarea asp-for="AlasanDitolak" rows="2" class="fld resize-none" placeholder="Tuliskan alasan penolakan..."></textarea>
                </div>

                <!-- Catatan -->
                <div class="mb-5">
                    <label class="lbl">Catatan Verifikasi</label>
                    <textarea asp-for="CatatanVerifikasi" rows="2" class="fld resize-none" placeholder="Catatan internal untuk Kepegawaian..."></textarea>
                </div>

                <div class="flex gap-3">
                    <a href="/kasubkel-kepegawaian" class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
                    <button type="button" id="btn-konfirmasi" onclick="showConfirmPopup()"
                            class="flex-grow bg-[#002d7a] hover:bg-blue-900 text-white font-bold py-2.5 px-8 rounded-xl text-sm shadow-sm transition-all active:scale-95">
                        Konfirmasi Verifikasi →
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<partial name="Partials/_ConfirmModal" />

<style>
    .lbl { display:block; font-size:11px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:.05em; margin-bottom:4px }
    .fld { display:block; width:100%; border:1px solid #e5e7eb; border-radius:10px; padding:9px 14px; font-size:13.5px; background:#fafafa; outline:none; transition:all .15s }
    .fld:focus { box-shadow:0 0 0 2.5px #3b82f6; border-color:transparent; background:white }

    /* Tree */
    .tree-parent { display:flex; align-items:center; gap:8px; padding:10px 12px; cursor:pointer; user-select:none; transition:background .1s; }
    .tree-parent:hover { background:#f9fafb; }
    .tree-parent.has-children .tree-chevron { transition:transform .18s; }
    .tree-parent.open .tree-chevron { transform: rotate(90deg); }
    .tree-children { border-top:1px solid #f3f4f6; background:#fafafa; }
    .tree-child-item { display:flex; align-items:center; gap:8px; padding:8px 12px 8px 32px; transition:background .1s; }
    .tree-child-item:hover { background:#f3f4f6; }
    .tree-child-item:last-child { border-bottom:none; }
</style>

<script>
/* ═══════════════════════════════════════════════════════════════════
   Verifikasi — multi-unit disposisi + hierarkis bidang
═══════════════════════════════════════════════════════════════════ */

let _hierarkiCache = null;

// ── Fetch & render hierarki bidang ────────────────────────────────
async function loadBidangHierarki() {
    if (_hierarkiCache) return;

    document.getElementById('bidang-loading').classList.remove('hidden');
    try {
        const res = await fetch('/api/bidang-hierarki');
        _hierarkiCache = await res.json();
    } catch(e) {
        _hierarkiCache = [];
    } finally {
        document.getElementById('bidang-loading').classList.add('hidden');
    }

    renderBidangTree(_hierarkiCache);
}

function renderBidangTree(items) {
    const tree = document.getElementById('bidang-tree');
    const skel = document.getElementById('bidang-skeleton');
    if (skel) skel.remove();
    tree.innerHTML = '';

    items.forEach(item => {
        const hasChildren = item.children && item.children.length > 0;

        // ── Parent row ───────────────────────────────────────────
        const parentDiv = document.createElement('div');

        const chevron = hasChildren
            ? `<svg class="tree-chevron w-3 h-3 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                   <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
               </svg>`
            : `<span class="w-3 h-3 flex-shrink-0"></span>`;

        parentDiv.innerHTML = `
            <div class="tree-parent ${hasChildren ? 'has-children' : ''}" onclick="${hasChildren ? 'toggleChildren(this)' : ''}">
                ${chevron}
                <input type="checkbox"
                       value="${escHtml(item.namaBidang)}"
                       data-label="${escHtml(item.namaBidang)}"
                       class="disposisi-cb accent-blue-600 w-4 h-4 flex-shrink-0"
                       onclick="event.stopPropagation()"
                       onchange="onDisposisiChange()" />
                <span class="text-[13px] font-semibold text-gray-700 leading-tight">${escHtml(item.namaBidang)}</span>
            </div>`;

        // ── Children ─────────────────────────────────────────────
        if (hasChildren) {
            const childrenDiv = document.createElement('div');
            childrenDiv.className = 'tree-children hidden';

            item.children.forEach(child => {
                const childRow = document.createElement('div');
                childRow.className = 'tree-child-item';
                const childLabel = `${item.namaBidang} — ${child}`;
                childRow.innerHTML = `
                    <input type="checkbox"
                           value="${escHtml(childLabel)}"
                           data-label="${escHtml(childLabel)}"
                           class="disposisi-cb accent-emerald-600 w-3.5 h-3.5 flex-shrink-0"
                           onchange="onDisposisiChange()" />
                    <span class="text-[12px] text-gray-600 leading-tight">${escHtml(child)}</span>`;
                childrenDiv.appendChild(childRow);
            });

            parentDiv.appendChild(childrenDiv);
        }

        tree.appendChild(parentDiv);
    });
}

function toggleChildren(parentEl) {
    const wrap = parentEl.closest('.tree-parent').parentElement;
    const childrenDiv = wrap.querySelector('.tree-children');
    const isOpen = !childrenDiv.classList.contains('hidden');
    childrenDiv.classList.toggle('hidden', isOpen);
    parentEl.classList.toggle('open', !isOpen);
}

function collapseAll() {
    document.querySelectorAll('.tree-children').forEach(d => d.classList.add('hidden'));
    document.querySelectorAll('.tree-parent.open').forEach(p => p.classList.remove('open'));
}

// ── Sync hidden inputs → DisposisiUnits[] ────────────────────────
function onDisposisiChange() {
    const checked = [...document.querySelectorAll('.disposisi-cb:checked')]
        .map(cb => cb.value);

    // Rebuild hidden inputs
    const container = document.getElementById('disposisi-hidden-container');
    container.innerHTML = checked
        .map(v => `<input type="hidden" name="DisposisiUnits" value="${escHtml(v)}" />`)
        .join('');

    // Counter badge
    const counter = document.getElementById('disposisi-counter');
    counter.textContent = `${checked.length} dipilih`;
    counter.classList.toggle('hidden', checked.length === 0);

    // Clear error
    document.getElementById('disposisi-error').classList.add('hidden');
}

// ── Show/hide panel keputusan ─────────────────────────────────────
document.querySelectorAll('[name="Disetujui"]').forEach(r => {
    r.addEventListener('change', function() {
        const ok = this.value === 'true';
        document.getElementById('div-setujui').style.display = ok ? 'block' : 'none';
        document.getElementById('div-tolak').style.display   = ok ? 'none'  : 'block';
        if (ok && !_hierarkiCache) loadBidangHierarki();
    });
});

// ── Collect form state ────────────────────────────────────────────
function collectValues() {
    return {
        isSetujui    : document.querySelector('[name="Disetujui"]:checked')?.value,
        disposisiList: [...document.querySelectorAll('.disposisi-cb:checked')].map(cb => cb.value),
        alasan       : document.querySelector('[name="AlasanDitolak"]')?.value?.trim(),
        noPermohonan : document.querySelector('[name="NoPermohonan"]')?.value,
        namaPemohon  : document.querySelector('[name="NamaPemohon"]')?.value,
    };
}

// ── Validate ──────────────────────────────────────────────────────
function validate(v) {
    if (!v.isSetujui) { showToast('Pilih keputusan verifikasi terlebih dahulu.'); return false; }
    if (v.isSetujui === 'true' && v.disposisiList.length === 0) {
        document.getElementById('disposisi-error').classList.remove('hidden');
        showToast('Pilih minimal satu unit disposisi.');
        return false;
    }
    return true;
}

// ── Modal FASE 1 ──────────────────────────────────────────────────
function showConfirmPopup() {
    const v = collectValues();
    if (!validate(v)) { shakeButton('btn-konfirmasi'); return; }

    const ap = v.isSetujui === 'true';
    const cls = ap ? 'ap' : 'rj';

    const disposisiRows = ap
        ? `<div class="m-row" style="flex-direction:column;align-items:flex-start;gap:6px;">
               <span class="m-row-lbl">Disposisi ke — ${v.disposisiList.length} unit</span>
               <div style="width:100%;max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:3px;padding-right:2px;">
                   ${v.disposisiList.map(u =>
                       `<div style="font-size:11px;font-weight:600;color:#1e293b;
                                    padding:5px 9px;background:#f1f5f9;border-radius:7px;
                                    border:1px solid #e2e8f0;word-break:break-word;line-height:1.4;">
                           <span style="color:#2563eb;margin-right:5px;">→</span>${u}
                        </div>`
                   ).join('')}
               </div>
           </div>`
        : (v.alasan
            ? `<div class="m-row"><span class="m-row-lbl">Alasan Tolak</span><span class="m-row-val" style="color:#dc2626">${v.alasan}</span></div>`
            : '');

    document.getElementById('modal-content').innerHTML = `
        <div class="m-header">
            <div class="m-badge ${cls}">${ap ? '✅ Disetujui & Diteruskan' : '❌ Ditolak & Dikembalikan'}</div>
            <p class="m-title">Konfirmasi Verifikasi</p>
            <p class="m-sub">Periksa kembali data berikut sebelum melanjutkan.</p>
        </div>
        <div class="m-summary">
            <div class="m-row">
                <span class="m-row-lbl">No. Permohonan</span>
                <span class="m-row-val" style="font-family:monospace;color:#002d7a">${v.noPermohonan}</span>
            </div>
            <div class="m-row">
                <span class="m-row-lbl">Pemohon</span>
                <span class="m-row-val">${v.namaPemohon}</span>
            </div>
            ${disposisiRows}
        </div>
        <div class="m-actions">
            <button class="btn-back" onclick="closeModal()">Periksa Lagi</button>
            <button class="btn-go ${cls}" onclick="runResult()">Ya, Konfirmasi →</button>
        </div>`;

    openModal();
}

// ── Modal FASE 2 — animasi lalu submit ────────────────────────────
function runResult() {
    const v  = collectValues();
    const ap = v.isSetujui === 'true';
    showResultPhase({
        isSuccess : ap,
        title     : ap ? 'Verifikasi Disetujui!' : 'Permohonan Ditolak',
        sub       : ap
            ? `Diteruskan ke ${v.disposisiList.length} unit terkait.`
            : 'Permohonan dikembalikan kepada pemohon sesuai keputusan.',
        chip      : ap ? `${v.disposisiList.length} Unit Disposisi` : 'Dikembalikan ke Pemohon',
        onDone    : () => document.getElementById('verifikasi-form').submit()
    });
}

// ── Boot ──────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    // Preload jika radio Setujui sudah terpilih (page reload / error)
    const checked = document.querySelector('[name="Disetujui"]:checked');
    if (checked?.value === 'true') loadBidangHierarki();
});

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
