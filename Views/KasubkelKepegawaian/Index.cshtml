@model DashboardVm
@{
    ViewData["Title"] = "Dashboard Kasubkel Kepegawaian";
    ViewData["Role"]  = "Kasubkel Kepegawaian";
    Layout = "_LayoutAdmin";

    var menunggu = ViewData["MenungguVerifikasi"] as List<PermohonanPPID> ?? new();
    int pctProses  = Model.Total > 0 ? (int)Math.Round(Model.Proses  * 100.0 / Model.Total) : 0;
    int pctSelesai = Model.Total > 0 ? (int)Math.Round(Model.Selesai * 100.0 / Model.Total) : 0;

    var needsVerif = menunggu.Where(p => p.StatusPPIDID == StatusId.IdentifikasiAwal
                                      || p.StatusPPIDID == StatusId.MenungguVerifikasi).ToList();
    var needsSurat = menunggu.Where(p => p.StatusPPIDID == StatusId.MenungguSuratIzin).ToList();

    string StCls(int? s) => (s ?? 0) switch {
        StatusId.Selesai            => "st st--selesai",
        StatusId.DataSiap           => "st st--siap",
        StatusId.FeedbackPemohon    => "st st--feedback",
        StatusId.MenungguVerifikasi => "st st--verif",
        StatusId.IdentifikasiAwal   => "st st--daftar",
        StatusId.Dibatalkan         => "st st--batal",
        StatusId.TerdaftarSistem    => "st st--daftar",
        StatusId.MenungguSuratIzin  => "st st--surat",
        _                           => "st st--proses"
    };
    string StDot(int? s) => (s ?? 0) switch {
        StatusId.Selesai            => "#059669",
        StatusId.DataSiap           => "#10b981",
        StatusId.FeedbackPemohon    => "#0ea5e9",
        StatusId.MenungguVerifikasi => "#8b5cf6",
        StatusId.IdentifikasiAwal   => "#9ca3af",
        StatusId.Dibatalkan         => "#ef4444",
        StatusId.TerdaftarSistem    => "#9ca3af",
        StatusId.MenungguSuratIzin  => "#3b82f6",
        _                           => "#f59e0b"
    };
}

<partial name="Partials/_FormStyles" />
<partial name="Partials/_ActionMenu" />

@* ── Action banner: tugas aktif Kasubkel Kepegawaian ── *@
@if (needsVerif.Any())
{
    bool adaMendesak = needsVerif.Any(p => p.StatusPPIDID == StatusId.MenungguVerifikasi);
    string bannerColor  = adaMendesak ? "violet" : "amber";
    string borderClass  = adaMendesak ? "border-violet-200 bg-violet-50" : "border-amber-200 bg-amber-50";
    string iconBg       = adaMendesak ? "bg-violet-500" : "bg-amber-500";
    string titleColor   = adaMendesak ? "text-violet-800" : "text-amber-800";
    string bodyColor    = adaMendesak ? "text-violet-600" : "text-amber-700";
    string chipBg       = adaMendesak ? "bg-violet-100 text-violet-800 border-violet-200" : "bg-amber-100 text-amber-800 border-amber-200";
    string icon         = adaMendesak ? "📋" : "🔁";
    string judulBanner  = adaMendesak
        ? $"{needsVerif.Count(p => p.StatusPPIDID == StatusId.MenungguVerifikasi)} permohonan menunggu verifikasi Anda"
        : $"{needsVerif.Count} permohonan perlu ditinjau ulang";
    string subBanner    = adaMendesak
        ? "Dokumen identifikasi sudah ditandatangani pemohon dan diunggah Loket. Segera lakukan verifikasi."
        : "Terdapat permohonan yang sebelumnya dikembalikan dan sudah diperbarui. Tinjau ulang sebelum diteruskan.";

    <div class="border @borderClass rounded-2xl p-4 mb-5 flex items-start gap-3 alert-slide">
        <div class="w-8 h-8 @iconBg rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="text-white text-sm">@icon</span>
        </div>
        <div class="flex-1 min-w-0">
            <p class="font-bold @titleColor text-sm">@judulBanner</p>
            <p class="@bodyColor text-xs mt-0.5 leading-relaxed">@subBanner</p>
            <div class="flex flex-wrap gap-2 mt-2">
                @foreach (var p in needsVerif.Take(4))
                {
                    <a href="/kasubkel-kepegawaian/verifikasi/@p.PermohonanPPIDID"
                       class="inline-flex items-center gap-1.5 text-xs font-bold @chipBg border px-3 py-1.5 rounded-lg hover:opacity-80 transition-opacity">
                        @icon @p.NoPermohonan
                    </a>
                }
                @if (needsVerif.Count > 4)
                {
                    <span class="text-xs font-semibold @bodyColor self-center">
                        + @(needsVerif.Count - 4) lainnya
                    </span>
                }
            </div>
        </div>
        <a href="/kasubkel-kepegawaian/permohonan?status=@(adaMendesak ? 14 : 3)"
           class="flex-shrink-0 inline-flex items-center gap-1 text-xs font-bold @titleColor hover:underline mt-0.5">
            Verifikasi Semua
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
        </a>
    </div>
}
else if (needsSurat.Any())
{
    @* {{-- Informasi pasif: semua verifikasi selesai, surat izin menunggu Loket --}} *@
    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 mb-5 flex items-center gap-3 alert-slide">
        <div class="w-8 h-8 bg-slate-400 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-white text-sm">✅</span>
        </div>
        <div class="flex-1 min-w-0">
            <p class="font-bold text-slate-700 text-sm">Semua verifikasi selesai</p>
            <p class="text-slate-500 text-xs mt-0.5">
                @needsSurat.Count permohonan sudah diverifikasi dan diteruskan ke
                <strong>Loket Kepegawaian</strong> untuk penerbitan surat izin.
                Tidak ada tindakan lebih lanjut dari Anda.
            </p>
        </div>
    </div>
}

@* ── Stat Cards ── *@
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="rounded-2xl p-5 relative overflow-hidden shadow-md min-h-[110px] flex flex-col justify-between" style="background:#0f1f4a">
        <div class="absolute top-0 right-0 w-24 h-24 rounded-full bg-white/5 -translate-y-8 translate-x-8 pointer-events-none"></div>
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-blue-300/70 mb-1">Total Permohonan</p>
        <p class="text-5xl font-black text-white leading-none" style="font-variant-numeric:tabular-nums">@Model.Total</p>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-400 to-transparent"></div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Proses</p>
        <p class="text-4xl font-black text-gray-800 leading-none mb-2">@Model.Proses</p>
        <div class="w-full bg-amber-50 rounded-full h-1 overflow-hidden">
            <div class="bg-amber-400 h-full rounded-full" style="width:@pctProses%"></div>
        </div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Selesai</p>
        <p class="text-4xl font-black text-gray-800 leading-none mb-2">@Model.Selesai</p>
        <div class="w-full bg-emerald-50 rounded-full h-1 overflow-hidden">
            <div class="bg-emerald-500 h-full rounded-full" style="width:@pctSelesai%"></div>
        </div>
    </div>
</div>

@* ── Charts ── *@
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Total Permohonan per Bulan</p>
        <div style="height:200px"><canvas id="chartTotal"></canvas></div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Proses &amp; Selesai per Bulan</p>
        <div style="height:200px"><canvas id="chartStatus"></canvas></div>
    </div>
</div>

@* ── Antrian ── *@
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-gray-50 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
            <p class="font-bold text-gray-700 text-sm">Antrian Verifikasi Identifikasi</p>
            <p class="text-xs text-gray-400 mt-0.5">Hanya verifikasi form identifikasi — surat izin diproses Loket Kepegawaian</p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            @if (needsVerif.Any()) { <span class="bg-violet-100 text-violet-700 text-xs font-bold px-2.5 py-1 rounded-full">@needsVerif.Count perlu verifikasi</span> }
            @if (needsSurat.Any()) { <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2.5 py-1 rounded-full">@needsSurat.Count menunggu Loket</span> }
            <a href="/kasubkel-kepegawaian/permohonan" class="text-xs font-semibold text-[#002d7a] hover:underline flex items-center gap-1">
                Semua Permohonan
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-50">
                    <th class="col-th">No Permohonan</th>
                    <th class="col-th">Nama Pemohon</th>
                    <th class="col-th">Kategori</th>
                    <th class="col-th">Keperluan</th>
                    <th class="col-th">Tgl Permohonan</th>
                    <th class="col-th">Batas Waktu</th>
                    <th class="col-th">Status</th>
                    <th class="col-th">Pengampu</th>
                    <th class="col-th">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (!menunggu.Any())
                {
                    <tr>
                        <td colspan="9" class="px-6 py-16 text-center">
                            <div class="max-w-xs mx-auto">
                                <div class="w-16 h-16 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">✅</div>
                                <p class="text-sm font-semibold text-gray-600 mb-1">Semua permohonan sudah diverifikasi</p>
                                <p class="text-xs text-gray-400">Tidak ada antrian yang memerlukan tindakan saat ini.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in menunggu)
                    {
                        bool isSuratIzin = item.StatusPPIDID == StatusId.MenungguSuratIzin;
                        bool isVerif     = item.StatusPPIDID == StatusId.MenungguVerifikasi
                                        || item.StatusPPIDID == StatusId.IdentifikasiAwal;
                        bool overdue     = item.IsOverdue;

                        string? primerHref  = null;
                        string? primerLabel = null;
                        if (isVerif) { primerHref = $"/kasubkel-kepegawaian/verifikasi/{item.PermohonanPPIDID}"; primerLabel = "Verifikasi"; }

                        <tr class="hover:bg-blue-50/30 transition-colors group @(overdue ? "bg-red-50/20" : isSuratIzin ? "bg-blue-50/20" : "")">

                            @* {{!-- ── No. Permohonan ── --}} *@
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-1.5">
                                    @if (overdue) { <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span> }
                                    <span class="no-perm">@item.NoPermohonan</span>
                                </div>
                            </td>

                            <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>

                            @* {{!-- ── Kategori ── --}} *@
                            <td class="px-4 py-3">
                                @if (item.KategoriPemohon == "Mahasiswa")
                                {
                                    <span class="kat-chip kat-mhs"><span class="kat-dot" style="background:#3b82f6"></span>Mahasiswa</span>
                                }
                                else
                                {
                                    <span class="kat-chip kat-lsm"><span class="kat-dot" style="background:#10b981"></span>@item.KategoriPemohon</span>
                                }
                            </td>

                            @* {{!-- ── Keperluan ── --}} *@
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if (item.IsObservasi)      { <span class="badge bg-orange-50 text-orange-700 border-orange-100">Obs</span> }
                                    @if (item.IsPermintaanData) { <span class="badge bg-blue-50 text-blue-700 border-blue-100">Data</span> }
                                    @if (item.IsWawancara)      { <span class="badge bg-violet-50 text-violet-700 border-violet-100">Waw</span> }
                                </div>
                            </td>

                            <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">@item.TanggalPermohonan?.ToString("dd MMM yyyy")</td>

                            <td class="px-4 py-3 whitespace-nowrap">
                                @if (item.BatasWaktu.HasValue)
                                {
                                    <span class="text-xs @(overdue ? "text-red-600 font-semibold" : item.HariSisa <= 3 ? "text-amber-600" : "text-gray-500")">
                                        @(overdue ? "⚠ " : "")@item.BatasWaktu.Value.ToString("dd MMM yyyy")
                                        @if (item.HariSisa.HasValue && item.StatusPPIDID < StatusId.Selesai)
                                        {
                                            <span class="block text-[10px] @(overdue ? "text-red-400" : "text-gray-400")">
                                                @(overdue ? $"Lewat {Math.Abs(item.HariSisa.Value)} hari" : $"Sisa {item.HariSisa.Value} hari")
                                            </span>
                                        }
                                    </span>
                                }
                                else { <span class="text-gray-300 text-xs">—</span> }
                            </td>

                            @* {{!-- ── Status ── --}} *@
                            <td class="px-4 py-3">
                                <span class="@StCls(item.StatusPPIDID)">
                                    <span class="st-dot" style="background:@StDot(item.StatusPPIDID)"></span>
                                    @item.Status?.NamaStatusPPID
                                </span>
                            </td>

                            <td class="px-4 py-3 text-xs text-gray-500">@(item.Pengampu ?? "—")</td>

                            <td class="px-4 py-3">
                                <div class="action-cell">
                                    @if (isVerif)
                                    {
                                        <a href="@primerHref" class="btn-action-primary verif">✅ @primerLabel</a>
                                    }
                                    else if (isSuratIzin)
                                    {
                                        <span class="inline-flex items-center text-[11px] font-medium bg-blue-50 border border-blue-200 text-blue-500 px-2.5 py-1 rounded-lg cursor-default select-none"
                                              title="Penerbitan surat izin dilakukan oleh Loket Kepegawaian">
                                             Menunggu Loket
                                        </span>
                                    }
                                    else
                                    {
                                        <a href="/kasubkel-kepegawaian/detail/@item.PermohonanPPIDID" class="btn-action-primary" style="background:#6b7280">Detail</a>
                                    }
                                    <div class="action-more-wrap">
                                        <button class="btn-action-more" onclick="toggleActionMenu(this)" type="button">⋯</button>
                                        <div class="action-dropdown hidden">
                                            <a href="/kasubkel-kepegawaian/detail/@item.PermohonanPPIDID" class="action-dd-item">📋 Detail</a>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* ── CTA bawah ── *@
<div class="flex gap-3">
    <a href="/kasubkel-kepegawaian/permohonan"
       class="inline-flex items-center gap-2 bg-[#002d7a] hover:bg-blue-900 text-white text-sm font-bold px-5 py-3 rounded-xl shadow-sm transition-colors">
        📋 Lihat Semua Permohonan →
    </a>
</div>

<style>
    .col-th{padding:12px 16px;text-align:left;font-size:10px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;white-space:nowrap}
    /* ── No. Permohonan ── */
    .no-perm{font-family:'JetBrains Mono','Fira Code',ui-monospace,monospace;font-size:11.5px;font-weight:700;color:#1d4ed8;background:#eff6ff;border:1px solid #dbeafe;border-radius:6px;padding:3px 8px;white-space:nowrap;letter-spacing:.01em;display:inline-block}
    /* ── Kategori Chip ── */
    .kat-chip{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:600;border-radius:20px;padding:3px 9px;white-space:nowrap;border:1px solid}
    .kat-mhs{color:#1d4ed8;background:#eff6ff;border-color:#bfdbfe}
    .kat-lsm{color:#065f46;background:#f0fdf4;border-color:#a7f3d0}
    .kat-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    /* ── Status Badge ── */
    .st{display:inline-flex;align-items:center;gap:5px;font-size:10.5px;font-weight:600;border-radius:20px;padding:3px 9px;white-space:nowrap;border:1px solid;line-height:1.4}
    .st-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
    .st--selesai{color:#065f46;background:#ecfdf5;border-color:#a7f3d0}
    .st--siap{color:#047857;background:#f0fdf4;border-color:#bbf7d0}
    .st--feedback{color:#0369a1;background:#f0f9ff;border-color:#bae6fd}
    .st--verif{color:#5b21b6;background:#f5f3ff;border-color:#ddd6fe}
    .st--batal{color:#9f1239;background:#fff1f2;border-color:#fecdd3}
    .st--daftar{color:#374151;background:#f9fafb;border-color:#e5e7eb}
    .st--proses{color:#92400e;background:#fffbeb;border-color:#fde68a}
    .st--surat{color:#1e40af;background:#eff6ff;border-color:#bfdbfe}
    /* ── Keperluan Badge ── */
    .badge{font-size:10px;padding:1px 6px;border-radius:999px;font-weight:600;border:1px solid}
    /* ── Action button ── */
    .btn-action-primary{display:inline-flex;align-items:center;font-size:11px;font-weight:600;padding:4px 10px;border-radius:8px;background:#374151;color:white;white-space:nowrap;transition:opacity .15s;text-decoration:none}
    .btn-action-primary:hover{opacity:.85}
    .btn-action-primary.verif{background:#0369a1}
    .alert-slide{animation:alertSlide .25s ease both}
    @@keyframes alertSlide{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const labels=@Html.Raw(Model.LabelsJson),totals=@Html.Raw(Model.TotalJson),proses=@Html.Raw(Model.ProsesJson),selesai=@Html.Raw(Model.SelesaiJson);
const g='rgba(0,0,0,.06)',t='#9ca3af';
const baseOpts={responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:t,font:{size:11},boxWidth:12}}},scales:{x:{grid:{color:g},ticks:{color:t,font:{size:10}}},y:{grid:{color:g},ticks:{color:t,font:{size:10},stepSize:1},beginAtZero:true}}};
new Chart(document.getElementById('chartTotal'),{type:'bar',data:{labels,datasets:[{label:'Total',data:totals,backgroundColor:'rgba(59,130,246,.7)',borderRadius:6}]},options:baseOpts});
new Chart(document.getElementById('chartStatus'),{type:'line',data:{labels,datasets:[{label:'Proses',data:proses,borderColor:'#F59E0B',backgroundColor:'rgba(245,158,11,.12)',fill:true,tension:.4,pointRadius:4},{label:'Selesai',data:selesai,borderColor:'#10B981',backgroundColor:'rgba(16,185,129,.12)',fill:true,tension:.4,pointRadius:4}]},options:baseOpts});
</script>
}
