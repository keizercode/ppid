@* ════════════════════════════════════════════════════════════════════════════
   Views/KasubkelKepegawaian/Index.cshtml — FIXED
   Perubahan: kolom Action di antrian sekarang membedakan Verifikasi vs Surat Izin
════════════════════════════════════════════════════════════════════════════ *@
@model DashboardVm
@{
    ViewData["Title"] = "Dashboard Kasubkel Kepegawaian";
    ViewData["Role"]  = "Kasubkel Kepegawaian";
    Layout = "_LayoutAdmin";

    var menunggu = ViewData["MenungguVerifikasi"] as List<PermohonanPPID> ?? new();
    int pctProses  = Model.Total > 0 ? (int)Math.Round(Model.Proses  * 100.0 / Model.Total) : 0;
    int pctSelesai = Model.Total > 0 ? (int)Math.Round(Model.Selesai * 100.0 / Model.Total) : 0;

    // Pisahkan antrian berdasarkan stage yang perlu ditindaklanjuti
    var needsVerif  = menunggu.Where(p => p.StatusPPIDID == StatusId.IdentifikasiAwal
                                       || p.StatusPPIDID == StatusId.MenungguVerifikasi).ToList();
    var needsSurat  = menunggu.Where(p => p.StatusPPIDID == StatusId.MenungguSuratIzin).ToList();
}

<!-- ══ ALERT: antrian surat izin (prioritas tinggi) ══ -->
@if (needsSurat.Any())
{
    <div class="bg-blue-50 border border-blue-300 rounded-2xl p-4 mb-5 flex items-start gap-3">
        <div class="w-8 h-8 bg-blue-600 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="text-white text-sm">📄</span>
        </div>
        <div>
            <p class="font-bold text-blue-800 text-sm">@needsSurat.Count permohonan menunggu Surat Izin</p>
            <p class="text-blue-600 text-xs mt-0.5">Sudah diverifikasi — segera terbitkan surat izin agar dapat diteruskan ke KDI.</p>
            <div class="flex flex-wrap gap-2 mt-2">
                @foreach (var p in needsSurat.Take(3))
                {
                    <a href="/kasubkel-kepegawaian/surat-izin/@p.PermohonanPPIDID"
                       class="inline-flex items-center gap-1.5 text-xs font-bold bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded-lg transition-colors">
                        📄 @p.NoPermohonan
                    </a>
                }
                @if (needsSurat.Count > 3)
                {
                    <a href="/kasubkel-kepegawaian/permohonan?status=4"
                       class="text-xs font-semibold text-blue-600 hover:underline self-center">
                        + @(needsSurat.Count - 3) lainnya →
                    </a>
                }
            </div>
        </div>
    </div>
}

<!-- ══ STAT CARDS ══ -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="rounded-2xl p-5 relative overflow-hidden shadow-md min-h-[110px] flex flex-col justify-between" style="background:#0f1f4a">
        <div class="absolute top-0 right-0 w-24 h-24 rounded-full bg-white/5 -translate-y-8 translate-x-8 pointer-events-none"></div>
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-blue-300/70 mb-1">Total Permohonan</p>
        <p class="text-5xl font-black text-white leading-none" style="font-variant-numeric:tabular-nums">@Model.Total</p>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-400 to-transparent"></div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Proses</p>
        <p class="text-4xl font-black text-amber-600 leading-none mb-2">@Model.Proses</p>
        <div class="w-full bg-amber-50 rounded-full h-1.5 overflow-hidden">
            <div class="bg-amber-400 h-full rounded-full" style="width:@pctProses%"></div>
        </div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Selesai</p>
        <p class="text-4xl font-black text-emerald-600 leading-none mb-2">@Model.Selesai</p>
        <div class="w-full bg-emerald-50 rounded-full h-1.5 overflow-hidden">
            <div class="bg-emerald-500 h-full rounded-full" style="width:@pctSelesai%"></div>
        </div>
    </div>
</div>

<!-- ══ CHARTS ══ -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Total Permohonan per Bulan</p>
        <div style="height:180px"><canvas id="chartTotal"></canvas></div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Proses & Selesai per Bulan</p>
        <div style="height:180px"><canvas id="chartStatus"></canvas></div>
    </div>
</div>

<!-- ══ ANTRIAN VERIFIKASI + SURAT IZIN ══ -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-gray-50 flex items-center justify-between">
        <div>
            <p class="font-bold text-gray-700 text-sm">Antrian Tindak Lanjut</p>
            <p class="text-xs text-gray-400 mt-0.5">Permohonan yang perlu diverifikasi atau diterbitkan surat izinnya</p>
        </div>
        <div class="flex items-center gap-2">
            @if (needsVerif.Any())
            {
                <span class="bg-violet-100 text-violet-700 text-xs font-bold px-2.5 py-1 rounded-full">@needsVerif.Count verifikasi</span>
            }
            @if (needsSurat.Any())
            {
                <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2.5 py-1 rounded-full">@needsSurat.Count surat izin</span>
            }
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-50">
                    <th class="col-th">No Permohonan</th>
                    <th class="col-th">Nama Pemohon</th>
                    <th class="col-th">Kategori</th>
                    <th class="col-th">Keperluan</th>
                    <th class="col-th">Tgl Permohonan</th>
                    <th class="col-th">Batas Waktu</th>
                    <th class="col-th">Status</th>
                    <th class="col-th">Tgl Selesai</th>
                    <th class="col-th">Pengampu</th>
                    <th class="col-th">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (!menunggu.Any())
                {
                    <tr>
                        <td colspan="10" class="px-6 py-12 text-center">
                            <div class="text-3xl mb-2">✅</div>
                            <p class="text-sm font-semibold text-gray-500">Semua permohonan sudah ditindaklanjuti</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in menunggu)
                    {
                        bool isSuratIzin = item.StatusPPIDID == StatusId.MenungguSuratIzin;
                        bool isVerif     = item.StatusPPIDID == StatusId.MenungguVerifikasi
                                        || item.StatusPPIDID == StatusId.IdentifikasiAwal;

                        string rowHighlight = isSuratIzin ? "bg-blue-50/40" : "";

                        <tr class="hover:bg-blue-50/30 transition-colors group @rowHighlight">
                            <td class="px-4 py-3 font-mono text-xs text-blue-600 font-semibold">@item.NoPermohonan</td>
                            <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>
                            <td class="px-4 py-3 text-xs @(item.KategoriPemohon=="Mahasiswa"?"text-blue-600":"text-emerald-600") font-medium">
                                @(item.KategoriPemohon == "Mahasiswa" ? "🎓" : "🏢") @item.KategoriPemohon
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if (item.IsObservasi)      { <span class="tag-obs">Obs</span> }
                                    @if (item.IsPermintaanData) { <span class="tag-data">Data</span> }
                                    @if (item.IsWawancara)      { <span class="tag-waw">Waw</span> }
                                </div>
                            </td>
                            <td class="px-4 py-3 text-xs text-gray-400">@item.TanggalPermohonan?.ToString("dd MMM yyyy")</td>
                            <td class="px-4 py-3 text-xs @(item.IsOverdue ? "text-red-600 font-semibold" : "text-gray-500")">
                                @(item.BatasWaktu?.ToString("dd MMM yyyy") ?? "—")
                                @if (item.IsOverdue) { <span> ⚠</span> }
                            </td>
                            <td class="px-4 py-3">
                                @if (isSuratIzin)
                                {
                                    <span class="text-[11px] bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full font-medium">
                                        📄 @item.Status?.NamaStatusPPID
                                    </span>
                                }
                                else
                                {
                                    <span class="text-[11px] bg-violet-50 text-violet-700 px-2 py-0.5 rounded-full font-medium">
                                        @item.Status?.NamaStatusPPID
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3 text-xs text-gray-400">@(item.TanggalSelesai?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td class="px-4 py-3 text-xs text-gray-500">@(item.Pengampu ?? "—")</td>
                            <td class="px-4 py-3">
                                <div class="flex gap-1.5 opacity-80 group-hover:opacity-100 transition-opacity">
                                    <a href="/kasubkel-kepegawaian/detail/@item.PermohonanPPIDID"
                                       class="text-[11px] bg-gray-100 hover:bg-gray-200 text-gray-700 px-2 py-1 rounded-lg font-medium">Detail</a>

                                    @if (isVerif)
                                    {
                                        <a href="/kasubkel-kepegawaian/verifikasi/@item.PermohonanPPIDID"
                                           class="text-[11px] bg-violet-100 hover:bg-violet-200 text-violet-700 px-2.5 py-1 rounded-lg font-semibold">✅ Verifikasi</a>
                                    }
                                    @if (isSuratIzin)
                                    {
                                        <a href="/kasubkel-kepegawaian/surat-izin/@item.PermohonanPPIDID"
                                           class="text-[11px] bg-blue-600 hover:bg-blue-700 text-white px-2.5 py-1 rounded-lg font-bold">📄 Surat Izin</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="flex gap-3">
    <a href="/kasubkel-kepegawaian/permohonan"
       class="inline-flex items-center gap-2 bg-[#002d7a] hover:bg-blue-900 text-white text-sm font-bold px-5 py-3 rounded-xl shadow-sm transition-colors">
        📋 Lihat Semua Permohonan →
    </a>
</div>

<style>
    .col-th { padding: 12px 16px; text-align:left; font-size:10px; font-weight:700; color:#9ca3af; text-transform:uppercase; letter-spacing:.05em; }
    .tag-obs  { font-size:10px; background:#FFF7ED; color:#C2410C; border:1px solid #FED7AA; padding:1px 6px; border-radius:999px; font-weight:600; }
    .tag-data { font-size:10px; background:#EFF6FF; color:#1D4ED8; border:1px solid #BFDBFE; padding:1px 6px; border-radius:999px; font-weight:600; }
    .tag-waw  { font-size:10px; background:#F5F3FF; color:#6D28D9; border:1px solid #DDD6FE; padding:1px 6px; border-radius:999px; font-weight:600; }
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const labels  = @Html.Raw(Model.LabelsJson);
const totals  = @Html.Raw(Model.TotalJson);
const proses  = @Html.Raw(Model.ProsesJson);
const selesai = @Html.Raw(Model.SelesaiJson);
const gridC   = 'rgba(0,0,0,.06)';
const tickC   = '#9ca3af';
const baseOpts = {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: tickC, font: { size:11 }, boxWidth:12 } } },
    scales: {
        x: { grid:{ color:gridC }, ticks:{ color:tickC, font:{size:10} } },
        y: { grid:{ color:gridC }, ticks:{ color:tickC, font:{size:10}, stepSize:1 }, beginAtZero:true }
    }
};
new Chart(document.getElementById('chartTotal'), {
    type:'bar',
    data:{ labels, datasets:[{ label:'Total', data:totals, backgroundColor:'rgba(59,130,246,.7)', borderRadius:6 }] },
    options: baseOpts
});
new Chart(document.getElementById('chartStatus'), {
    type:'line',
    data:{ labels, datasets:[
        { label:'Proses',  data:proses,  borderColor:'#F59E0B', backgroundColor:'rgba(245,158,11,.12)', fill:true, tension:.4, pointRadius:4 },
        { label:'Selesai', data:selesai, borderColor:'#10B981', backgroundColor:'rgba(16,185,129,.12)', fill:true, tension:.4, pointRadius:4 }
    ]},
    options: baseOpts
});
</script>
}
