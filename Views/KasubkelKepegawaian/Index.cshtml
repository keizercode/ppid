@model DashboardVm
@{
    ViewData["Title"] = "Dashboard Kasubkel Kepegawaian";
    ViewData["Role"]  = "Kasubkel Kepegawaian";
    Layout = "_LayoutAdmin";

    var menunggu = ViewData["MenungguVerifikasi"] as List<PermohonanPPID> ?? new();
    int pctProses  = Model.Total > 0 ? (int)Math.Round(Model.Proses  * 100.0 / Model.Total) : 0;
    int pctSelesai = Model.Total > 0 ? (int)Math.Round(Model.Selesai * 100.0 / Model.Total) : 0;

    var needsVerif = menunggu.Where(p => p.StatusPPIDID == StatusId.IdentifikasiAwal
                                      || p.StatusPPIDID == StatusId.MenungguVerifikasi).ToList();
    var needsSurat = menunggu.Where(p => p.StatusPPIDID == StatusId.MenungguSuratIzin).ToList();
}

<partial name="Partials/_FormStyles" />
<partial name="Partials/_ActionMenu" />

@* ── Info banner: surat izin menunggu Loket ── *@
@if (needsSurat.Any())
{
    <div class="bg-blue-50 border border-blue-200 rounded-2xl p-4 mb-5 flex items-start gap-3 alert-slide">
        <div class="w-8 h-8 bg-blue-500 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5">
            <span class="text-white text-sm">📄</span>
        </div>
        <div class="flex-1 min-w-0">
            <p class="font-bold text-blue-800 text-sm">
                @needsSurat.Count permohonan siap — menunggu Surat Izin dari Loket Kepegawaian
            </p>
            <p class="text-blue-600 text-xs mt-0.5 leading-relaxed">
                Verifikasi selesai. Penerbitan surat izin dilakukan oleh
                <strong>Loket Kepegawaian</strong>. Informasikan ke petugas loket untuk memproses.
            </p>
            <div class="flex flex-wrap gap-2 mt-2">
                @foreach (var p in needsSurat.Take(3))
                {
                    <span class="inline-flex items-center gap-1.5 text-xs font-bold bg-blue-100 text-blue-800 border border-blue-200 px-3 py-1.5 rounded-lg">
                        📋 @p.NoPermohonan
                    </span>
                }
                @if (needsSurat.Count > 3)
                {
                    <span class="text-xs font-semibold text-blue-600 self-center">+ @(needsSurat.Count - 3) lainnya</span>
                }
            </div>
        </div>
    </div>
}

@* ── Stat Cards ── *@
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">


    <div class="rounded-2xl p-5 relative overflow-hidden shadow-md min-h-[110px] flex flex-col justify-between"
         style="background:#0f1f4a">
        <div class="absolute top-0 right-0 w-24 h-24 rounded-full bg-white/5 -translate-y-8 translate-x-8 pointer-events-none"></div>
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-blue-300/70 mb-1">Total Permohonan</p>
        <p class="text-5xl font-black text-white leading-none" style="font-variant-numeric:tabular-nums">@Model.Total</p>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-400 to-transparent"></div>
    </div>


    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-4 right-4">
            <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
                <circle cx="18" cy="18" r="14" fill="none" stroke="#FFFBEB" stroke-width="3.5" />
                <circle cx="18" cy="18" r="14" fill="none" stroke="#F59E0B" stroke-width="3.5"
                        stroke-dasharray="@(Math.Round(87.96 * pctProses / 100.0, 1)) 87.96"
                        stroke-linecap="round" />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-amber-500 rotate-90">
                @pctProses%
            </span>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Proses</p>
        <p class="text-4xl font-black text-gray-800 leading-none mb-2">@Model.Proses</p>
        <div class="w-full bg-amber-50 rounded-full h-1 overflow-hidden">
            <div class="bg-amber-400 h-full rounded-full" style="width:@pctProses%"></div>
        </div>
    </div>


    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-4 right-4">
            <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
                <circle cx="18" cy="18" r="14" fill="none" stroke="#ECFDF5" stroke-width="3.5" />
                <circle cx="18" cy="18" r="14" fill="none" stroke="#10B981" stroke-width="3.5"
                        stroke-dasharray="@(Math.Round(87.96 * pctSelesai / 100.0, 1)) 87.96"
                        stroke-linecap="round" />
            </svg>
            <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-emerald-500 rotate-90">
                @pctSelesai%
            </span>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Selesai</p>
        <p class="text-4xl font-black text-gray-800 leading-none mb-2">@Model.Selesai</p>
        <div class="w-full bg-emerald-50 rounded-full h-1 overflow-hidden">
            <div class="bg-emerald-500 h-full rounded-full" style="width:@pctSelesai%"></div>
        </div>
    </div>
</div>

@* ── Charts ── *@
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Total Permohonan per Bulan</p>
        <div style="height:200px"><canvas id="chartTotal"></canvas></div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Proses &amp; Selesai per Bulan</p>
        <div style="height:200px"><canvas id="chartStatus"></canvas></div>
    </div>
</div>

@* ── Antrian ── *@
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-6">


    <div class="px-5 py-4 border-b border-gray-50 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <div>
            <p class="font-bold text-gray-700 text-sm">Antrian Verifikasi Identifikasi</p>
            <p class="text-xs text-gray-400 mt-0.5">
                Hanya verifikasi form identifikasi — surat izin diproses Loket Kepegawaian
            </p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            @if (needsVerif.Any())
            {
                <span class="bg-violet-100 text-violet-700 text-xs font-bold px-2.5 py-1 rounded-full">
                    @needsVerif.Count perlu verifikasi
                </span>
            }
            @if (needsSurat.Any())
            {
                <span class="bg-blue-100 text-blue-700 text-xs font-bold px-2.5 py-1 rounded-full">
                    @needsSurat.Count menunggu Loket
                </span>
            }
            <a href="/kasubkel-kepegawaian/permohonan"
               class="text-xs font-semibold text-[#002d7a] hover:underline flex items-center gap-1">
                Semua Permohonan
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>
    </div>


    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-50">
                    <th class="col-th">No Permohonan</th>
                    <th class="col-th">Nama Pemohon</th>
                    <th class="col-th">Kategori</th>
                    <th class="col-th">Keperluan</th>
                    <th class="col-th">Tgl Permohonan</th>
                    <th class="col-th">Batas Waktu</th>
                    <th class="col-th">Status</th>
                    <th class="col-th">Pengampu</th>
                    <th class="col-th">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (!menunggu.Any())
                {
                    <tr>
                        <td colspan="9" class="px-6 py-16 text-center">
                            <div class="max-w-xs mx-auto">
                                <div class="w-16 h-16 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">✅</div>
                                <p class="text-sm font-semibold text-gray-600 mb-1">Semua permohonan sudah diverifikasi</p>
                                <p class="text-xs text-gray-400">Tidak ada antrian yang memerlukan tindakan saat ini.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in menunggu)
                    {
                        bool isSuratIzin = item.StatusPPIDID == StatusId.MenungguSuratIzin;
                        bool isVerif     = item.StatusPPIDID == StatusId.MenungguVerifikasi
                                        || item.StatusPPIDID == StatusId.IdentifikasiAwal;
                        bool overdue     = item.IsOverdue;

                        @* ── Tentukan primary action (mirip PetugasLoket) ── *@
                        string? primerHref  = null;
                        string? primerLabel = null;


                        if (isVerif)
                        {
                            primerHref  = $"/kasubkel-kepegawaian/verifikasi/{item.PermohonanPPIDID}";
                            primerLabel = "Verifikasi";

                        }
                        else if (isSuratIzin)
                        {
                            @* Tidak ada aksi — Loket yang mengerjakan *@
                            primerLabel = "Menunggu Loket";

                        }

                        <tr class="hover:bg-blue-50/30 transition-colors group @(overdue ? "bg-red-50/20" : isSuratIzin ? "bg-blue-50/20" : "")">


                            <td class="px-4 py-3 font-mono text-xs font-semibold whitespace-nowrap">
                                <div class="flex items-center gap-1.5">
                                    @if (overdue)
                                    {
                                        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>
                                    }
                                    <span class="text-blue-600">@item.NoPermohonan</span>
                                </div>
                            </td>


                            <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>


                            <td class="px-4 py-3 text-xs font-medium
                                @(item.KategoriPemohon == "Mahasiswa" ? "text-blue-600" : "text-emerald-600")">
                                @(item.KategoriPemohon == "Mahasiswa" ? "🎓" : "🏢") @item.KategoriPemohon
                            </td>


                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if (item.IsObservasi)      { <span class="tag-obs">Obs</span> }
                                    @if (item.IsPermintaanData) { <span class="tag-data">Data</span> }
                                    @if (item.IsWawancara)      { <span class="tag-waw">Waw</span> }
                                </div>
                            </td>


                            <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">
                                @item.TanggalPermohonan?.ToString("dd MMM yyyy")
                            </td>


                            <td class="px-4 py-3 whitespace-nowrap">
                                @if (item.BatasWaktu.HasValue)
                                {
                                    <span class="text-xs @(overdue ? "text-red-600 font-semibold" : item.HariSisa <= 3 ? "text-amber-600" : "text-gray-500")">
                                        @(overdue ? "⚠ " : "")@item.BatasWaktu.Value.ToString("dd MMM yyyy")
                                        @if (item.HariSisa.HasValue && item.StatusPPIDID < StatusId.Selesai)
                                        {
                                            <span class="block text-[10px] @(overdue ? "text-red-400" : "text-gray-400")">
                                                @(overdue
                                                    ? $"Lewat {Math.Abs(item.HariSisa.Value)} hari"
                                                    : $"Sisa {item.HariSisa.Value} hari")
                                            </span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-gray-300 text-xs">—</span>
                                }
                            </td>


                            <td class="px-4 py-3">
                                <span class="text-[11px] px-2 py-0.5 rounded-full font-semibold
                                    @(isSuratIzin ? "bg-blue-50 text-blue-700" : "bg-violet-50 text-violet-700")">
                                    @item.Status?.NamaStatusPPID
                                </span>
                            </td>


                            <td class="px-4 py-3 text-xs text-gray-500">@(item.Pengampu ?? "—")</td>


                            <td class="px-4 py-3">
                                <div class="action-cell">
                                    @if (isVerif)
                                    {
                                        <a href="@primerHref" class="btn-action-primary verif">✅ @primerLabel</a>
                                    }
                                    else if (isSuratIzin)
                                    {
                                        <span class="inline-flex items-center text-[11px] font-medium
                                                     bg-blue-50 border border-blue-200 text-blue-500
                                                     px-2.5 py-1 rounded-lg cursor-default select-none"
                                              title="Penerbitan surat izin dilakukan oleh Loket Kepegawaian">
                                            📄 Menunggu Loket
                                        </span>
                                    }
                                    else
                                    {
                                        <a href="/kasubkel-kepegawaian/detail/@item.PermohonanPPIDID"
                                           class="btn-action-primary" style="background:#6b7280">Detail</a>
                                    }

                                    <div class="action-more-wrap">
                                        <button class="btn-action-more" onclick="toggleActionMenu(this)" type="button">⋯</button>
                                        <div class="action-dropdown hidden">
                                            <a href="/kasubkel-kepegawaian/detail/@item.PermohonanPPIDID"
                                               class="action-dd-item">📋 Detail</a>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* ── CTA bawah ── *@
<div class="flex gap-3">
    <a href="/kasubkel-kepegawaian/permohonan"
       class="inline-flex items-center gap-2 bg-[#002d7a] hover:bg-blue-900 text-white text-sm font-bold px-5 py-3 rounded-xl shadow-sm transition-colors">
        📋 Lihat Semua Permohonan →
    </a>
</div>

<style>
    .col-th {
        padding: 12px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: .05em;
        white-space: nowrap;
    }
    .tag-obs  { font-size:10px; background:#FFF7ED; color:#C2410C; border:1px solid #FED7AA; padding:1px 6px; border-radius:999px; font-weight:600; }
    .tag-data { font-size:10px; background:#EFF6FF; color:#1D4ED8; border:1px solid #BFDBFE; padding:1px 6px; border-radius:999px; font-weight:600; }
    .tag-waw  { font-size:10px; background:#F5F3FF; color:#6D28D9; border:1px solid #DDD6FE; padding:1px 6px; border-radius:999px; font-weight:600; }

    /* Primary action tombol (reuse pola PetugasLoket) */
    .btn-action-primary {
        display: inline-flex;
        align-items: center;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 8px;
        background: #374151;
        color: white;
        white-space: nowrap;
        transition: opacity .15s;
        text-decoration: none;
    }
    .btn-action-primary:hover { opacity: .85; }
    .btn-action-primary.verif { background: #0369a1; }
    .btn-action-primary.emerald { background: #059669; }
    .btn-action-primary.blue { background: #2563EB; }
    .btn-action-primary.amber { background: #D97706; }
    .btn-action-primary.cyan { background: #0891B2; }

    .alert-slide { animation: alertSlide .25s ease both; }
    @@keyframes alertSlide {
        from { opacity: 0; transform: translateY(-6px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const labels  = @Html.Raw(Model.LabelsJson);
const totals  = @Html.Raw(Model.TotalJson);
const proses  = @Html.Raw(Model.ProsesJson);
const selesai = @Html.Raw(Model.SelesaiJson);
const g = 'rgba(0,0,0,.06)', t = '#9ca3af';
const baseOpts = {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: t, font: { size:11 }, boxWidth:12 } } },
    scales: {
        x: { grid:{ color:g }, ticks:{ color:t, font:{size:10} } },
        y: { grid:{ color:g }, ticks:{ color:t, font:{size:10}, stepSize:1 }, beginAtZero:true }
    }
};
new Chart(document.getElementById('chartTotal'), {
    type: 'bar',
    data: { labels, datasets:[{ label:'Total', data:totals, backgroundColor:'rgba(59,130,246,.7)', borderRadius:6 }] },
    options: baseOpts
});
new Chart(document.getElementById('chartStatus'), {
    type: 'line',
    data: { labels, datasets:[
        { label:'Proses',  data:proses,  borderColor:'#F59E0B', backgroundColor:'rgba(245,158,11,.12)', fill:true, tension:.4, pointRadius:4 },
        { label:'Selesai', data:selesai, borderColor:'#10B981', backgroundColor:'rgba(16,185,129,.12)', fill:true, tension:.4, pointRadius:4 }
    ]},
    options: baseOpts
});
</script>
}
