@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Daftar Permohonan — Kasubkel Kepegawaian";
    ViewData["Role"]  = "Kasubkel Kepegawaian";
    Layout = "_LayoutAdmin";
    var q      = ViewData["Q"]      as string;
    var status = ViewData["Status"] as int?;
}

<partial name="Partials/_FormStyles" />
<partial name="Partials/_ActionMenu" />

<div class="flex items-center justify-between mb-4">
    <div>
        <p class="font-bold text-gray-700 text-sm">Daftar Permohonan</p>
        <p class="text-xs text-gray-400 mt-0.5">Semua permohonan Loket Kepegawaian (Mahasiswa/Peneliti)</p>
    </div>
    <a href="/kasubkel-kepegawaian"
       class="text-xs font-semibold text-blue-600 hover:text-blue-800 flex items-center gap-1">
        ← Dashboard
    </a>
</div>

@* ── Search + Filter ── *@
<form method="get" class="flex gap-2 mb-4 flex-wrap">
    <input type="text" name="q" value="@q" placeholder="Cari nomor / nama pemohon..."
           class="flex-1 min-w-[200px] border border-gray-200 rounded-xl px-4 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-300" />
    <select name="status" class="border border-gray-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-none">
        <option value="">Semua Status</option>
        <option value="2"  selected="@(status==2)">Terdaftar</option>
        <option value="3"  selected="@(status==3)">Identifikasi Awal</option>
        <option value="14" selected="@(status==14)">Menunggu Verifikasi</option>
        <option value="4"  selected="@(status==4)">Menunggu Surat Izin</option>
        <option value="7"  selected="@(status==7)">Sedang Diproses</option>
        <option value="10" selected="@(status==10)">Data Siap</option>
        <option value="11" selected="@(status==11)">Selesai</option>
    </select>
    <button type="submit"
            class="bg-[#002d7a] hover:bg-blue-900 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-colors">
        Cari
    </button>
    @if (!string.IsNullOrEmpty(q) || status.HasValue)
    {
        <a href="/kasubkel-kepegawaian/permohonan"
           class="border border-gray-200 text-gray-500 text-xs font-medium px-3 py-2 rounded-xl hover:bg-gray-50 transition-colors">
            Reset
        </a>
    }
</form>

@* ── Tabel ── *@
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    @if (!Model.Any())
    {
        <div class="px-6 py-20 text-center">
            <div class="max-w-xs mx-auto">
                <div class="w-16 h-16 bg-blue-50 border border-blue-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">📋</div>
                <p class="text-sm font-semibold text-gray-600 mb-1">
                    @(string.IsNullOrEmpty(q) && !status.HasValue ? "Belum ada permohonan" : "Tidak ada hasil yang cocok")
                </p>
                @if (!string.IsNullOrEmpty(q) || status.HasValue)
                {
                    <a href="/kasubkel-kepegawaian/permohonan"
                       class="inline-flex items-center gap-1 text-xs font-semibold text-blue-600 hover:underline mt-2">
                        ↩ Reset filter
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-100">
                        <th class="col-th">No Permohonan</th>
                        <th class="col-th">Nama Pemohon</th>
                        <th class="col-th">Kategori</th>
                        <th class="col-th">Keperluan</th>
                        <th class="col-th">Tgl Permohonan</th>
                        <th class="col-th">Batas Waktu</th>
                        <th class="col-th">Status</th>
                        <th class="col-th">Tgl Selesai</th>
                        <th class="col-th">Pengampu</th>
                        <th class="col-th">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model)
                    {
                        bool overdue      = item.IsOverdue;
                        bool bisaVerif    = item.StatusPPIDID == StatusId.MenungguVerifikasi
                                        || item.StatusPPIDID == StatusId.IdentifikasiAwal;
                        bool bisaSuratIzin = item.StatusPPIDID == StatusId.MenungguSuratIzin;

                        string badgeCls = item.StatusPPIDID switch
                        {
                            StatusId.Selesai            => "bg-emerald-100 text-emerald-800",
                            StatusId.DataSiap           => "bg-emerald-50 text-emerald-700",
                            StatusId.MenungguSuratIzin  => "bg-blue-50 text-blue-700",
                            StatusId.MenungguVerifikasi => "bg-violet-50 text-violet-700",
                            StatusId.TerdaftarSistem    => "bg-gray-100 text-gray-500",
                            _                           => "bg-amber-50 text-amber-700"
                        };

                        <tr class="hover:bg-blue-50/30 transition-colors group @(overdue ? "bg-red-50/20" : "")">

                            @* No Permohonan *@
                            <td class="px-4 py-3 font-mono text-xs font-semibold whitespace-nowrap">
                                <div class="flex items-center gap-1.5">
                                    @if (overdue)
                                    {
                                        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse flex-shrink-0"></span>
                                    }
                                    <span class="text-blue-600">@item.NoPermohonan</span>
                                </div>
                            </td>

                            @* Nama *@
                            <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>

                            @* Kategori *@
                            <td class="px-4 py-3 text-xs font-medium
                                @(item.KategoriPemohon == "Mahasiswa" ? "text-blue-600" : "text-emerald-600")">
                                @(item.KategoriPemohon == "Mahasiswa" ? "🎓" : "🏢") @item.KategoriPemohon
                            </td>

                            @* Keperluan *@
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if (item.IsObservasi)      { <span class="tag-badge bg-orange-50 text-orange-700 border-orange-100">Obs</span> }
                                    @if (item.IsPermintaanData) { <span class="tag-badge bg-blue-50 text-blue-700 border-blue-100">Data</span> }
                                    @if (item.IsWawancara)      { <span class="tag-badge bg-violet-50 text-violet-700 border-violet-100">Waw</span> }
                                </div>
                            </td>

                            @* Tgl Permohonan *@
                            <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">
                                @item.TanggalPermohonan?.ToString("dd MMM yyyy")
                            </td>

                            @* Batas Waktu *@
                            <td class="px-4 py-3 whitespace-nowrap">
                                @if (item.BatasWaktu.HasValue)
                                {
                                    <span class="text-xs font-medium @(overdue ? "text-red-600" : item.HariSisa <= 3 ? "text-amber-600" : "text-gray-500")">
                                        @(overdue ? "⚠ " : "")@item.BatasWaktu.Value.ToString("dd MMM yyyy")
                                        @if (item.HariSisa.HasValue && item.StatusPPIDID < StatusId.Selesai)
                                        {
                                            <span class="block text-[10px] @(overdue ? "text-red-400" : "text-gray-400")">
                                                @(overdue
                                                    ? $"Lewat {Math.Abs(item.HariSisa.Value)} hari"
                                                    : $"Sisa {item.HariSisa.Value} hari")
                                            </span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-gray-300 text-xs">—</span>
                                }
                            </td>

                            @* Status *@
                            <td class="px-4 py-3">
                                <span class="text-[11px] @badgeCls px-2.5 py-0.5 rounded-full font-semibold">
                                    @item.Status?.NamaStatusPPID
                                </span>
                            </td>

                            @* Tgl Selesai *@
                            <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">
                                @(item.TanggalSelesai?.ToString("dd MMM yyyy") ?? "—")
                            </td>

                            @* Pengampu *@
                            <td class="px-4 py-3 text-xs text-gray-500">
                                @(string.IsNullOrEmpty(item.Pengampu) ? "—" : item.Pengampu)
                            </td>

                            @* Aksi — pola action-cell (primary + dropdown ⋯) *@
                            <td class="px-4 py-3">
                                <div class="action-cell">
                                    @if (bisaVerif)
                                    {
                                        <a href="/kasubkel-kepegawaian/verifikasi/@item.PermohonanPPIDID"
                                           class="btn-action-primary verif">✅ Verifikasi</a>
                                    }
                                    else if (bisaSuratIzin)
                                    {
                                        <span class="inline-flex items-center text-[11px] font-medium
                                                     bg-blue-50 border border-blue-200 text-blue-500
                                                     px-2.5 py-1 rounded-lg cursor-default select-none"
                                              title="Penerbitan surat izin dilakukan oleh Loket Kepegawaian">
                                            📄 Menunggu Loket
                                        </span>
                                    }
                                    else
                                    {
                                        <a href="/kasubkel-kepegawaian/detail/@item.PermohonanPPIDID"
                                           class="btn-action-primary" style="background:#6b7280">Detail</a>
                                    }

                                    <div class="action-more-wrap">
                                        <button class="btn-action-more" onclick="toggleActionMenu(this)" type="button">⋯</button>
                                        <div class="action-dropdown hidden">
                                            <a href="/kasubkel-kepegawaian/detail/@item.PermohonanPPIDID"
                                               class="action-dd-item">📋 Detail</a>
                                        </div>
                                    </div>
                                </div>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .col-th {
        padding: 12px 16px;
        text-align: left;
        font-size: 10px;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: .05em;
        white-space: nowrap;
    }
    .tag-badge {
        font-size: 10px;
        padding: 1px 7px;
        border-radius: 999px;
        font-weight: 600;
        border: 1px solid;
    }
    .btn-action-primary {
        display: inline-flex;
        align-items: center;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 8px;
        background: #374151;
        color: white;
        white-space: nowrap;
        transition: opacity .15s;
        text-decoration: none;
    }
    .btn-action-primary:hover { opacity: .85; }
    .btn-action-primary.verif { background: #0369a1; }
</style>
