@model List<PermintaanData.Models.LaporanPpidItem>
@{
    ViewData["Title"]     = "Laporan PPID — PPID Dinas Lingkungan Hidup DKI Jakarta";
    ViewData["ActiveNav"] = "laporan";
}

@section Styles {
    <link rel="stylesheet" href="~/css/laporan.css" />
}

@* ══ NAVBAR (shared) ══ *@
<partial name="Partials/_PublicNavBar" />

@* ══ HERO ══ *@
<section class="laporan-hero">
    <div class="laporan-hero-inner">
        <nav class="laporan-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Beranda</a>
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
            </svg>
            <span>Laporan PPID</span>
        </nav>
        <h1>Laporan PPID</h1>
        <p>Kumpulan laporan tahunan pengelolaan informasi dan dokumentasi publik Dinas Lingkungan Hidup Provinsi DKI Jakarta.</p>
    </div>
</section>

@* ══ CONTENT ══ *@
<div class="laporan-section">

    @* Meta bar *@
    @* menghitung laporan tersedia dan menampilkannya *@
    <div class="laporan-meta">
        <p class="laporan-count">
            Menampilkan <strong>@Model.Count laporan</strong> tersedia
        </p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="laporan-empty">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
            <p>Belum ada laporan tersedia</p>
            <span>Laporan akan ditampilkan di sini jika sudah diterbitkan</span>
        </div>
    }
    else
    {
        <div class="laporan-grid">
            @foreach (var item in Model)
            {
                <div class="laporan-card">

                    @* ── Cover area ── *@
                    <div class="laporan-cover">

                        @if (!string.IsNullOrWhiteSpace(item.CoverImageUrl))
                        {
                            @* Gambar sampul nyata *@
                            <img src="@item.CoverImageUrl" alt="Sampul Laporan PPID @item.Tahun" loading="lazy" />
                        }
                        else
                        {
                            @* Placeholder bergaya dokumen PPID *@
                            <div class="laporan-cover-placeholder">
                                <div class="ph-top">
                                    <div class="ph-logo-wrap">
                                        <img src="https://ppid.jakarta.go.id/assets/home/ppidNew/images/logo/logo-ppid-email.png"
                                             alt="Logo PPID"
                                             onerror="this.style.display='none'" />
                                    </div>
                                    <div class="ph-brand">
                                        <span>PPID</span>
                                        <span>Pejabat Pengelola<br/>Informasi dan Dokumentasi</span>
                                    </div>
                                </div>

                                @* Dots dekorasi *@
                                <div class="ph-dots" aria-hidden="true">
                                    @for (int d = 0; d < 9; d++) { <span></span> }
                                </div>

                                <p class="ph-dinas">Pemerintah Provinsi DKI Jakarta</p>

                                <p class="ph-title">Laporan Layanan<br/>Informasi Publik</p>

                                <span class="ph-year">@item.Tahun</span>

                                <div class="ph-bar" aria-hidden="true"></div>
                            </div>
                        }

                        @* Badge halaman *@
                        @if (item.TotalHalaman.HasValue)
                        {
                            <span class="laporan-page-badge">@item.TotalHalaman halaman</span>
                        }

                        @* Hover overlay *@
                        <div class="laporan-cover-overlay" aria-hidden="true">
                            @if (!string.IsNullOrWhiteSpace(item.FileUrl) && item.FileUrl != "#")
                            {
                                <a href="@item.FileUrl" target="_blank" rel="noopener noreferrer"
                                   class="cover-btn cover-btn-view"
                                   aria-label="Lihat laporan @item.Tahun">
                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                    Lihat
                                </a>
                                <a href="@item.FileUrl" download
                                   class="cover-btn cover-btn-dl"
                                   aria-label="Unduh laporan @item.Tahun">
                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                                    </svg>
                                    Unduh
                                </a>
                            }
                            else
                            {
                                <span style="font-size:11px;color:rgba(255,255,255,.7);font-weight:600;">
                                    Segera tersedia
                                </span>
                            }
                        </div>
                    </div>

                    @* ── Card body ── *@
                    <div class="laporan-card-body">
                        <p class="laporan-card-title">Laporan PPID @item.Tahun</p>
                        <p class="laporan-card-sub">Dinas Lingkungan Hidup Provinsi DKI Jakarta</p>
                        <div class="laporan-card-footer">
                            <span class="laporan-card-year">@item.Tahun</span>
                            @if (!string.IsNullOrWhiteSpace(item.FileUrl) && item.FileUrl != "#")
                            {
                                @* di bawah ini belum dipakai *@
                                @* <a href="@item.FileUrl" target="_blank" rel="noopener noreferrer"
                                   class="laporan-card-dl">
                                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                                    </svg>
                                    Unduh PDF
                                </a> *@
                            }
                            else
                            {
                                <span style="font-size:11px;color:#d1d5db;font-weight:600;">Segera hadir</span>
                            }
                        </div>
                    </div>

                </div>
            }
        </div>
    }

</div>
