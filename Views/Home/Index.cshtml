@model LacakViewModel
@{
    ViewData["Title"] = "PPID — Dinas Lingkungan Hidup DKI Jakarta";
}

<style>
    /* ══ DLH PPID COLOR SYSTEM ══ */
    :root {
        --dlh-green: #006B3C;
        --dlh-green-dark: #004D2B;
        --dlh-green-light: #E8F5EE;
        --dlh-green-mid: #00874C;
        --ppid-navy: #1B3B6F;
        --ppid-navy-dark: #122850;
        --ppid-navy-light: #EEF3FB;
        --gold: #D4A017;
        --gold-light: #FDF6E3;
        --text-base: #1A1A2E;
        --text-muted: #6B7280;
        --bg-soft: #F7F9FC;
        --border: #E5E9F0;
    }

    /* ══ ANIMATIONS ══ */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes shimmer {
        0% {
            background-position: -200% center;
        }

        100% {
            background-position: 200% center;
        }
    }

    @@keyframes pulseGreen {

        0%,
        100% {
            box-shadow: 0 0 0 0 rgba(0, 107, 60, .35);
        }

        50% {
            box-shadow: 0 0 0 8px rgba(0, 107, 60, 0);
        }
    }

    @@keyframes tickerScroll {
        0% {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-50%);
        }
    }

    .fade-up-1 {
        animation: fadeUp .55s ease both .1s;
    }

    .fade-up-2 {
        animation: fadeUp .55s ease both .25s;
    }

    .fade-up-3 {
        animation: fadeUp .55s ease both .4s;
    }

    .fade-up-4 {
        animation: fadeUp .55s ease both .55s;
    }

    /* ══ TOPBAR ══ */
    .topbar-strip {
        background: var(--dlh-green-dark);
        padding: 6px 0;
        font-size: 11px;
        color: rgba(255, 255, 255, .7);
        letter-spacing: .02em;
    }

    /* ══ MAIN NAVBAR ══ */
    .main-navbar {
        background: #fff;
        border-bottom: 2px solid var(--dlh-green);
        position: sticky;
        top: 0;
        z-index: 50;
        box-shadow: 0 2px 16px rgba(0, 0, 0, .07);
    }

    /* ══ HERO SECTION ══ */
    .hero-section {
        background:
            linear-gradient(135deg, var(--dlh-green-dark) 0%, var(--ppid-navy) 60%, #0D1F3C 100%);
        position: relative;
        overflow: hidden;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(circle at 10% 20%, rgba(0, 135, 76, .18) 0%, transparent 50%),
            radial-gradient(circle at 90% 80%, rgba(27, 59, 111, .35) 0%, transparent 50%);
        pointer-events: none;
    }

    .hero-grid-pattern {
        position: absolute;
        inset: 0;
        opacity: .06;
        background-image:
            repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(255, 255, 255, .8) 59px, rgba(255, 255, 255, .8) 60px),
            repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(255, 255, 255, .8) 59px, rgba(255, 255, 255, .8) 60px);
    }

    .hero-section::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 70px;
        background: var(--bg-soft);
        clip-path: ellipse(55% 100% at 50% 100%);
    }

    /* ══ SEARCH BOX ══ */
    .search-card {
        background: rgba(255, 255, 255, .08);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, .18);
        border-radius: 20px;
        padding: 28px 32px;
    }

    .search-input {
        background: rgba(255, 255, 255, .95);
        border: 2px solid transparent;
        border-radius: 12px;
        transition: border-color .2s, box-shadow .2s;
    }

    .search-input:focus {
        border-color: var(--dlh-green-mid);
        box-shadow: 0 0 0 4px rgba(0, 107, 60, .15);
        outline: none;
    }

    .btn-search {
        background: var(--dlh-green);
        color: #fff;
        border-radius: 12px;
        font-weight: 700;
        transition: background .18s, transform .1s;
    }

    .btn-search:hover {
        background: var(--dlh-green-mid);
    }

    .btn-search:active {
        transform: scale(.97);
    }

    /* ══ QUICK ACCESS ══ */
    .quick-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px 20px;
        text-align: center;
        transition: transform .18s, box-shadow .18s, border-color .18s;
        cursor: pointer;
        text-decoration: none;
    }

    .quick-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 107, 60, .12);
        border-color: var(--dlh-green);
    }

    .quick-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px;
        font-size: 22px;
    }

    /* ══ STATS BAR ══ */
    .stats-bar {
        background: linear-gradient(90deg, var(--dlh-green-dark), var(--ppid-navy));
        color: #fff;
        border-radius: 20px;
        padding: 28px 32px;
    }

    .stat-divider {
        width: 1px;
        background: rgba(255, 255, 255, .2);
    }

    /* ══ ABOUT SECTION ══ */
    .about-section {
        background: #fff;
    }

    .accent-bar {
        width: 4px;
        height: 100%;
        background: linear-gradient(180deg, var(--dlh-green), var(--ppid-navy));
        border-radius: 4px;
        flex-shrink: 0;
    }

    /* ══ DASAR HUKUM ══ */
    .law-card {
        border-left: 3px solid var(--dlh-green);
        background: var(--dlh-green-light);
        border-radius: 0 12px 12px 0;
        padding: 14px 18px;
        margin-bottom: 10px;
    }

    /* ══ ALUR STEPS — redesigned ══ */
    .steps-wrapper {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        position: relative;
    }

    @@media (max-width: 1023px) {
        .steps-wrapper {
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .step-connector {
            display: none !important;
        }
    }

    @@media (max-width: 639px) {
        .steps-wrapper {
            grid-template-columns: 1fr;
        }
    }

    .step-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 12px;
    }

    /* Horizontal connector line between steps */
    .step-item:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 22px;
        /* aligned to center of circle */
        left: calc(50% + 22px);
        right: calc(-50% + 22px);
        height: 2px;
        background: linear-gradient(90deg, var(--dlh-green), var(--ppid-navy));
        opacity: .25;
    }

    @@media (max-width: 1023px) {
        .step-item:not(:last-child)::after {
            display: none;
        }
    }

    /* Numbered circle */
    .step-circle {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        font-weight: 800;
        color: #fff;
        position: relative;
        z-index: 1;
        flex-shrink: 0;
        margin-bottom: 20px;
        box-shadow: 0 4px 14px rgba(0, 107, 60, .3);
        background: linear-gradient(135deg, var(--dlh-green), var(--ppid-navy));
    }

    .step-card-inner {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 20px 18px 18px;
        width: 100%;
        text-align: left;
        transition: box-shadow .18s, border-color .18s, transform .18s;
        flex: 1;
    }

    .step-card-inner:hover {
        box-shadow: 0 8px 28px rgba(0, 107, 60, .10);
        border-color: rgba(0, 107, 60, .25);
        transform: translateY(-3px);
    }

    .step-emoji {
        font-size: 24px;
        margin-bottom: 10px;
        display: block;
    }

    .step-tag {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 100px;
        background: var(--dlh-green-light);
        color: var(--dlh-green-dark);
        margin-top: 12px;
    }

    /* ══ REQUIREMENTS ══ */
    .req-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 20px;
        overflow: hidden;
        transition: box-shadow .18s;
    }

    .req-card:hover {
        box-shadow: 0 8px 24px rgba(0, 0, 0, .08);
    }

    .req-header {
        padding: 20px 22px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .req-body {
        padding: 0 22px 20px;
    }

    .req-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 0;
        border-bottom: 1px solid var(--border);
        font-size: 13.5px;
        color: var(--text-base);
    }

    .req-item:last-child {
        border-bottom: none;
    }

    .req-check {
        width: 20px;
        height: 20px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 10px;
        font-weight: 800;
    }

    /* ══ TICKER ══ */
    .ticker-wrap {
        overflow: hidden;
        white-space: nowrap;
    }

    .ticker-inner {
        display: inline-block;
        animation: tickerScroll 28s linear infinite;
    }

    /* ══ SECTION LABEL ══ */
    .section-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--dlh-green-light);
        border: 1px solid rgba(0, 107, 60, .2);
        color: var(--dlh-green-dark);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 100px;
        margin-bottom: 12px;
    }

    /* ══ CTA BANNER ══ */
    .cta-banner {
        background: linear-gradient(135deg, var(--dlh-green-dark), var(--ppid-navy));
        border-radius: 24px;
        position: relative;
        overflow: hidden;
    }

    .cta-banner::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: rgba(255, 255, 255, .05);
    }

    /* ══ FOOTER ══ */
    .site-footer {
        background: var(--ppid-navy-dark);
        color: rgba(255, 255, 255, .6);
    }

    /* Pulse dot */
    .pulse-dot {
        animation: pulseGreen 2s infinite;
    }
</style>

<!-- ══════════════════════════════════════════════════════════════════
     TOP STRIP — INFO KONTAK
═══════════════════════════════════════════════════════════════════════ -->
<div class="topbar-strip">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between gap-4">
        <div class="ticker-wrap flex-1">
            <div class="ticker-inner">
                <span class="mx-6">📞 Telepon: (021) 8591-2230</span>
                <span class="mx-6">📧 Email: ppid.dlh@jakarta.go.id</span>
                <span class="mx-6">🕐 Senin – Jumat, 08.00 – 16.00 WIB</span>
                <span class="mx-6">📍 Jl. Mandala V No. 67, Cililitan, Jakarta Timur</span>
                <span class="mx-6">📞 Telepon: (021) 8591-2230</span>
                <span class="mx-6">📧 Email: ppid.dlh@jakarta.go.id</span>
                <span class="mx-6">🕐 Senin – Jumat, 08.00 – 16.00 WIB</span>
                <span class="mx-6">📍 Jl. Mandala V No. 67, Cililitan, Jakarta Timur</span>
            </div>
        </div>
        <a href="/auth/login"
               class="text-white/70 hover:text-white text-[11px] font-semibold flex items-center gap-1.5 flex-shrink-0 transition-colors">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
            Masuk Petugas
        </a>
    </div>
</div>

<!-- ══════════════════════════════════════════════════════════════════
     MAIN NAVBAR
═══════════════════════════════════════════════════════════════════════ -->
<header class="main-navbar">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-6">

        <!-- Logo + Identity -->
        <a href="/" class="flex items-center gap-3 flex-shrink-0">
            <!--
                Latar navy di belakang logo agar tidak nyaru di navbar putih.
                Logo PPID Jakarta berwarna putih/terang → butuh background gelap.
            -->
            <div class="flex items-center justify-center rounded-xl px-2.5 py-1.5 flex-shrink-0"
                 style="background:var(--ppid-navy); min-width:44px; height:44px;">
                <img src="https://ppid.jakarta.go.id/assets/home/ppidNew/images/logo/logo-ppid-email.png"
                     alt="Logo PPID Jakarta" class="h-7 w-auto object-contain" id="ppid-logo" onerror="document.getElementById('ppid-logo').style.display='none';
                document.getElementById('ppid-fallback').style.display='flex';" />
                <!-- Fallback teks jika gambar gagal muat -->
                <span id="ppid-fallback"
                      style="display:none; color:#fff; font-size:11px; font-weight:900; letter-spacing:.05em;">
                    PPID
                </span>
            </div>
            <div class="border-l border-gray-200 pl-3">
                <p class="text-[10px] text-gray-400 uppercase tracking-widest leading-none font-semibold">Dinas
                    Lingkungan Hidup</p>
                    <p class="text-gray-800 font-bold text-[13.5px] leading-tight mt-0.5">PPID DKI Jakarta</p>
                </div>
            </a>

            <!-- Nav Links (desktop) -->
            <nav class="hidden md:flex items-center gap-1">
                <a href="/"
                   class="text-sm font-semibold px-3 py-1.5 rounded-lg text-green-700 bg-green-50 transition-colors">Beranda</a>
                <a href="#tentang"
                       class="text-sm font-medium px-3 py-1.5 rounded-lg text-gray-500 hover:text-gray-800 hover:bg-gray-50 transition-colors">Tentang
                    PPID</a>
                    <a href="#alur"
                           class="text-sm font-medium px-3 py-1.5 rounded-lg text-gray-500 hover:text-gray-800 hover:bg-gray-50 transition-colors">Alur
                        Permohonan</a>
                        <a href="#lacak"
                               class="text-sm font-medium px-3 py-1.5 rounded-lg text-gray-500 hover:text-gray-800 hover:bg-gray-50 transition-colors">Lacak
                            Permohonan</a>
                        </nav>

                        <!-- CTA -->
                        <a href="#lacak"
                               class="hidden sm:inline-flex items-center gap-2 text-sm font-bold px-4 py-2 rounded-xl text-white transition-all flex-shrink-0"
                               style="background:var(--dlh-green)">
                            🔍 Lacak Permohonan
                        </a>
                    </div>
                </header>

                <!-- ══════════════════════════════════════════════════════════════════
     HERO
═══════════════════════════════════════════════════════════════════════ -->
                <section class="hero-section py-20 pb-28">
                    <div class="hero-grid-pattern"></div>

                    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

                            <!-- Left: Copy -->
                            <div>
                                <div class="fade-up-1 inline-flex items-center gap-2 mb-5 border border-white/20 rounded-full px-4 py-1.5"
                                     style="background:rgba(255,255,255,.1)">
                                    <span class="w-2 h-2 rounded-full bg-green-400 pulse-dot"></span>
                                    <span class="text-white/80 text-xs font-semibold tracking-wide">Layanan Aktif · PPID DLH
                                        Jakarta</span>
                                    </div>

                                    <h1 class="fade-up-2 text-white font-extrabold text-4xl sm:text-5xl leading-tight mb-5">
                                        Transparansi<br />
                                        <span
                                            style="background: linear-gradient(90deg,#6EE7A0,#93C5FD); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">
                                            Informasi Publik
                                        </span>
                                    </h1>

                                    <p class="fade-up-3 text-white/65 text-base sm:text-lg leading-relaxed mb-8 max-w-lg">
                                        Pejabat Pengelola Informasi dan Dokumentasi (PPID) Dinas Lingkungan Hidup Provinsi DKI Jakarta
                                        hadir untuk melayani permohonan data dan informasi lingkungan secara cepat, terbuka, dan akuntabel.
                                    </p>

                                    <div class="fade-up-4 flex flex-wrap gap-3">
                                        <a href="#lacak"
                                               class="btn-search inline-flex items-center gap-2 px-6 py-3 text-sm font-bold shadow-lg shadow-green-900/30">
                                            🔍 Lacak Permohonan Saya
                                        </a>
                                        <a href="#tentang"
                                               class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-xl border border-white/25 text-white/80 hover:bg-white/10 transition-colors">
                                            Pelajari Lebih Lanjut →
                                        </a>
                                    </div>
                                </div>

                                <!-- Right: Quick Access Cards -->
                                <div class="fade-up-3 grid grid-cols-2 gap-3">
                                    @{
                                        var qcards = new[]{
                new { Icon="📋", Title="Ajukan Permohonan", Desc="Datang ke loket PPID DLH dengan membawa berkas           persyaratan", Bg="#E8F5EE", Border="rgba(0,107,60,.2)", Color="var(--dlh-green-dark)" },
                new { Icon="🔍", Title="Lacak Status", Desc="Pantau perkembangan permohonan secara real-time",
                Bg="#EEF3FB", Border="rgba(27,59,111,.2)", Color="var(--ppid-navy)" },
                new { Icon="📂", Title="Informasi Publik", Desc="Akses dokumen dan informasi lingkungan hidup DKI",
                Bg="#FDF6E3", Border="rgba(212,160,23,.25)", Color="#92650B" },
                new { Icon="📝", Title="Kuesioner Layanan", Desc="Berikan penilaian atas layanan yang telah diterima",
                Bg="#F0F5FF", Border="rgba(99,102,241,.2)", Color="#3730A3" },
                };
                                    }

                                    @foreach (var q in qcards)
                                    {
                                        <div
                                            class="bg-white/10 backdrop-blur-sm border border-white/15 rounded-2xl p-4 hover:bg-white/18 transition-all cursor-default">
                                            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl mb-3"
                                                 style="background:@q.Bg; border:1px solid @q.Border">
                                                @q.Icon
                                            </div>
                                            <p class="text-white font-bold text-sm mb-1">@q.Title</p>
                                            <p class="text-white/50 text-xs leading-relaxed">@q.Desc</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ══════════════════════════════════════════════════════════════════
     STATS BAR
═══════════════════════════════════════════════════════════════════════ -->
                    <section class="bg-soft" style="background:var(--bg-soft); padding-top:0;">
                        <div class="max-w-5xl mx-auto px-4 sm:px-6 -mt-10 relative z-10">
                            <div class="stats-bar shadow-xl shadow-green-900/20">
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-0 divide-x divide-white/20">
                                    @{
                                        var stats = new[]{
                new { Val="UU No. 14/2008", Sub="Dasar Hukum", Icon="⚖️" },
                new { Val="Senin – Jumat", Sub="Hari Layanan", Icon="📅" },
                new { Val="≤ 10 Hari Kerja", Sub="Waktu Respons", Icon="⚡" },
                new { Val="Gratis", Sub="Biaya Layanan", Icon="✅" },
                };
                                    }
                                    @foreach (var s in stats)
                                    {
                                        <div class="px-6 py-2 text-center first:pl-0 last:pr-0">
                                            <p class="text-2xl mb-0.5">@s.Icon</p>
                                            <p class="text-white font-extrabold text-sm">@s.Val</p>
                                            <p class="text-white/50 text-xs mt-0.5">@s.Sub</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ══════════════════════════════════════════════════════════════════
     TENTANG PPID
═══════════════════════════════════════════════════════════════════════ -->
                    <section id="tentang" class="py-16" style="background:var(--bg-soft)">
                        <div class="max-w-6xl mx-auto px-4 sm:px-6">

                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

                                <!-- Profil & Dasar Hukum -->
                                <div>
                                    <div class="section-eyebrow">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                                        Tentang PPID
                                    </div>
                                    <h2 class="text-2xl font-extrabold text-gray-900 mb-4 leading-snug">
                                        Pejabat Pengelola Informasi<br />dan Dokumentasi (PPID)
                                    </h2>
                                    <div class="flex gap-4 mb-6">
                                        <div class="accent-bar"
                                             style="min-height:100%; width:4px; border-radius:4px; background:linear-gradient(180deg,var(--dlh-green),var(--ppid-navy)); flex-shrink:0;">
                                        </div>
                                        <p class="text-gray-600 text-sm leading-relaxed">
                                            Berdasarkan <strong>Undang-Undang Nomor 14 Tahun 2008</strong> tentang Keterbukaan Informasi
                                            Publik,
                                            setiap Badan Publik wajib menetapkan PPID yang bertanggung jawab dalam penyimpanan,
                                            pendokumentasian, penyediaan, dan pelayanan informasi kepada publik secara cepat dan tepat
                                            waktu.
                                        </p>
                                    </div>
                                    <p class="text-gray-600 text-sm leading-relaxed mb-6">
                                        PPID Dinas Lingkungan Hidup Provinsi DKI Jakarta berkomitmen mewujudkan tata kelola pemerintahan
                                        yang baik melalui transparansi dan akuntabilitas informasi publik di bidang lingkungan hidup.
                                    </p>

                                    <!-- Dasar Hukum -->
                                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Dasar Hukum</p>
                                    @{
                                        var laws = new[]{
                "UU No. 14 Tahun 2008 — Keterbukaan Informasi Publik",
                "PP No. 61 Tahun 2010 — Pelaksanaan UU KIP",
                "Permendagri No. 3 Tahun 2017 — Pedoman PPID Daerah",
                "Pergub DKI Jakarta No. 175 Tahun 2016",
                };
                                    }
                                    @foreach (var law in laws)
                                    {
                                        <div class="law-card">
                                            <p class="text-xs font-semibold text-green-800">@law</p>
                                        </div>
                                    }
                                </div>

                                <!-- Visi, Misi & Fungsi -->
                                <div>
                                    <!-- Visi -->
                                    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-4 shadow-sm">
                                        <div class="flex items-center gap-3 mb-3">
                                            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-lg"
                                                 style="background:var(--dlh-green-light)">🎯</div>
                                            <p class="font-bold text-gray-800 text-sm">Visi PPID</p>
                                        </div>
                                        <p class="text-gray-600 text-sm leading-relaxed italic">
                                            "Jakarta kota maju, lestari dan berbudaya yang warganya terlibat dalam mewujudkan
                                            keberadaban, keadilan, dan kesejahteraan bagi semua."
                                        </p>
                                    </div>

                                    <!-- Fungsi -->
                                    <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                                        <div class="flex items-center gap-3 mb-4">
                                            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-lg"
                                                 style="background:var(--ppid-navy-light)">⚙️</div>
                                            <p class="font-bold text-gray-800 text-sm">Fungsi & Tugas PPID</p>
                                        </div>
                                        <div class="space-y-2.5">
                                            @{
                                                var funcs = new[]{
                        "Melaksanakan kebijakan layanan informasi yang ditetapkan",
                        "Melakukan klasifikasi dan verifikasi informasi publik",
                        "Koordinasi pengumpulan bahan informasi dan dokumentasi",
                        "Menyediakan & memberikan pelayanan informasi kepada publik",
                        "Menjadi media informasi yang mudah diakses masyarakat",
                        "Menyampaikan laporan pengelolaan informasi secara berkala",
                        };
                                            }
                                            @foreach (var (f, i) in funcs.Select((f, i) => (f, i + 1)))
                                            {
                                                <div class="flex items-start gap-3">
                                                    <span
                                                    class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0 mt-0.5"
                                                    style="background:var(--dlh-green)">@i</span>
                                                    <p class="text-gray-600 text-xs leading-relaxed">@f</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ══════════════════════════════════════════════════════════════════
     ALUR PERMOHONAN
═══════════════════════════════════════════════════════════════════════ -->
                    <section id="alur" class="py-16 bg-white">
                        <div class="max-w-6xl mx-auto px-4 sm:px-6">

                            <div class="text-center mb-12">
                                <div class="section-eyebrow mx-auto w-fit">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                                    Panduan Layanan
                                </div>
                                <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Alur Permohonan Informasi</h2>
                                <p class="text-gray-400 text-sm max-w-md mx-auto">
                                    Ikuti langkah berikut untuk mengajukan permohonan data dan informasi di PPID DLH Jakarta
                                </p>
                            </div>

                            <!-- Steps — connected stepper -->
                            <div class="steps-wrapper">
                                @{
                                    var steps = new[]{
            new { Num="1", Icon="🏛️", Title="Datang ke Loket PPID", Desc="Kunjungi loket PPID DLH Jakarta. Bawa KTP        asli, surat permohonan, dan dokumen pendukung sesuai kategori pemohon.", Tag="Senin–Jum'at · 08.00–16.00" },
            new { Num="2", Icon="📋", Title="Identifikasi & Pendaftaran", Desc="Petugas memverifikasi berkas dan    mendaftarkan permohonan. Nomor unik diterbitkan untuk lacak status.", Tag="± 15 menit proses" },
            new { Num="3", Icon="✍️", Title="Tanda Tangan Formulir", Desc="Tanda tangani formulir identifikasi awal.        Nomor permohonan tercetak di formulir — simpan baik-baik.", Tag="⚠ Simpan nomor Anda!" },
            new { Num="4", Icon="📥", Title="Pantau & Unduh Data", Desc="Gunakan nomor permohonan untuk cek status            online. Unduh data saat status berubah menjadi 'Data Siap'.", Tag="Pantau real-time" },
            };
                                }
                                @foreach (var s in steps)
                                {
                                    <div class="step-item">
                                        <!-- Circle -->
                                        <div class="step-circle">@s.Num</div>
                                        <!-- Card -->
                                        <div class="step-card-inner">
                                            <span class="step-emoji">@s.Icon</span>
                                            <h3 class="font-bold text-gray-800 text-sm mb-1.5 leading-snug">@s.Title</h3>
                                            <p class="text-gray-400 text-xs leading-relaxed">@s.Desc</p>
                                            <span class="step-tag">@s.Tag</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>

                    <!-- ══════════════════════════════════════════════════════════════════
     PERSYARATAN DOKUMEN
═══════════════════════════════════════════════════════════════════════ -->
                    <section class="py-16" style="background:var(--bg-soft)">
                        <div class="max-w-6xl mx-auto px-4 sm:px-6">

                            <div class="text-center mb-12">
                                <div class="section-eyebrow mx-auto w-fit">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                                    Persyaratan
                                </div>
                                <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Dokumen yang Diperlukan</h2>
                                <p class="text-gray-400 text-sm">Siapkan berkas sesuai kategori sebelum datang ke loket</p>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

                                <!-- Mahasiswa -->
                                <div class="req-card">
                                    <div class="req-header"
                                         style="background:linear-gradient(135deg,#EFF6FF,#DBEAFE); border-bottom:1px solid #BFDBFE">
                                        <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl"
                                             style="background:#fff; border:1px solid #BFDBFE">🎓</div>
                                        <div>
                                            <p class="font-bold text-blue-900 text-sm">Mahasiswa / Pelajar</p>
                                            <p class="text-blue-500 text-xs font-semibold mt-0.5">3 dokumen wajib</p>
                                        </div>
                                    </div>
                                    <div class="req-body pt-4">
                                        @foreach (var d in new[] { "Fotokopi KTP", "Surat Permohonan Resmi", "Proposal Penelitian" })
                                        {
                                            <div class="req-item">
                                                <div class="req-check" style="background:#DBEAFE; color:#1D4ED8">✓</div>
                                                <span>@d</span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- LSM -->
                                <div class="req-card">
                                    <div class="req-header"
                                         style="background:linear-gradient(135deg,#ECFDF5,#D1FAE5); border-bottom:1px solid #A7F3D0">
                                        <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl"
                                             style="background:#fff; border:1px solid #A7F3D0">🏢</div>
                                        <div>
                                            <p class="font-bold text-green-900 text-sm">LSM / Organisasi</p>
                                            <p class="text-green-600 text-xs font-semibold mt-0.5">3 dokumen wajib</p>
                                        </div>
                                    </div>
                                    <div class="req-body pt-4">
                                        @foreach (var d in new[] { "Fotokopi KTP Perwakilan", "Akta Notaris Lembaga", "Surat Permohonan         Resmi" })
                                        {
                                            <div class="req-item">
                                                <div class="req-check" style="background:#D1FAE5; color:#065F46">✓</div>
                                                <span>@d</span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- Umum / PPID Online -->
                                <div class="req-card">
                                    <div class="req-header"
                                         style="background:linear-gradient(135deg,#F9FAFB,#F3F4F6); border-bottom:1px solid #E5E7EB">
                                        <div class="w-11 h-11 rounded-xl flex items-center justify-center text-2xl"
                                             style="background:#fff; border:1px solid #E5E7EB">🌐</div>
                                        <div>
                                            <p class="font-bold text-gray-800 text-sm">Masyarakat Umum</p>
                                            <p class="text-gray-500 text-xs font-semibold mt-0.5">Via portal PPID online</p>
                                        </div>
                                    </div>
                                    <div class="req-body pt-4">
                                        <p class="text-gray-500 text-xs leading-relaxed mb-4">
                                            Permohonan masyarakat umum dilayani melalui portal resmi PPID Pemprov DKI Jakarta.
                                            Tidak perlu datang ke kantor — semua dilakukan secara digital.
                                        </p>
                                        <a href="https://ppid.jakarta.go.id/permohonan-informasi" target="_blank"
                                               class="flex items-center justify-center gap-2 w-full text-white text-xs font-bold py-2.5 rounded-xl transition-colors"
                                               style="background:var(--ppid-navy)">
                                            🌐 Kunjungi Portal PPID Jakarta
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ══════════════════════════════════════════════════════════════════
     LACAK PERMOHONAN  ← utama
═══════════════════════════════════════════════════════════════════════ -->
                    <section id="lacak" class="py-20 bg-white">
                        <div class="max-w-3xl mx-auto px-4 sm:px-6">

                            <div class="text-center mb-10">
                                <div class="section-eyebrow mx-auto w-fit">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                                    Status Permohonan
                                </div>
                                <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Lacak Permohonan Anda</h2>
                                <p class="text-gray-400 text-sm max-w-sm mx-auto">
                                    Masukkan nomor permohonan yang tertera pada formulir identifikasi awal untuk melihat status terkini.
                                </p>
                            </div>

                            <!-- Search Card -->
                            <div class="bg-white rounded-2xl border border-gray-200 shadow-xl shadow-gray-100 p-8">

                                <!-- Error dari TempData (nomor tidak ditemukan) -->
                                @if (TempData["Error"] != null)
                                {
                                    <div class="mb-6 flex items-start gap-3 bg-red-50 border border-red-200 rounded-xl px-4 py-3">
                                        <span class="text-red-500 text-lg flex-shrink-0">⚠️</span>
                                        <p class="text-red-700 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
                                    </div>
                                }

                                <form asp-action="LacakPost" method="post">
                                    @Html.AntiForgeryToken()

                                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">
                                        Nomor Permohonan
                                    </label>

                                    <div class="flex gap-3 mb-2">
                                        <div class="relative flex-1">
                                            <span
                                            class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-base select-none">🔍</span>
                                            <input asp-for="NoPermohonan"
                                                   class="search-input w-full h-13 pl-11 pr-4 py-3.5 text-gray-800 text-sm font-mono tracking-widest uppercase"
                                                   style="font-size:14px; letter-spacing:.06em" placeholder="Contoh: PPD/2026/A3KX9P7B"
                                                   autocomplete="off" oninput="this.value = this.value.toUpperCase()" />
                                        </div>
                                        <button type="submit" class="btn-search px-7 py-3 text-sm">
                                            Cek Status →
                                        </button>
                                    </div>

                                    <span asp-validation-for="NoPermohonan" class="text-red-500 text-xs block mb-1"></span>

                                    <p class="text-gray-400 text-xs mt-3 text-center">
                                        💡 Nomor permohonan terdiri dari format <code
                                        class="font-mono bg-gray-100 px-1.5 py-0.5 rounded text-gray-600">PPD/TAHUN/XXXXXXXX</code>
                                        dan tertera pada formulir yang diberikan petugas.
                                    </p>
                                </form>
                            </div>

                            <!-- Helper info cards -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
                                <div class="flex items-start gap-3 bg-green-50 border border-green-200 rounded-xl p-4">
                                    <span class="text-xl flex-shrink-0">📄</span>
                                    <div>
                                        <p class="font-bold text-green-800 text-sm">Simpan Formulir Anda</p>
                                        <p class="text-green-600 text-xs mt-0.5 leading-relaxed">Nomor permohonan tercetak di formulir
                                            identifikasi yang ditandatangani di loket. Simpan salinannya.</p>
                                        </div>
                                    </div>
                                    <div class="flex items-start gap-3 bg-blue-50 border border-blue-200 rounded-xl p-4">
                                        <span class="text-xl flex-shrink-0">📞</span>
                                        <div>
                                            <p class="font-bold text-blue-800 text-sm">Butuh Bantuan?</p>
                                            <p class="text-blue-600 text-xs mt-0.5 leading-relaxed">Hubungi loket PPID di <strong>(021)
                                                8591-2230</strong> pada jam kerja untuk bantuan lebih lanjut.</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <!-- ══════════════════════════════════════════════════════════════════
     CTA BANNER
═══════════════════════════════════════════════════════════════════════ -->
                            <section class="py-12" style="background:var(--bg-soft)">
                                <div class="max-w-5xl mx-auto px-4 sm:px-6">
                                    <div class="cta-banner px-8 py-10 text-center">
                                        <p class="text-white/60 text-xs font-bold uppercase tracking-widest mb-2">Punya Pertanyaan?</p>
                                        <h3 class="text-white font-extrabold text-xl sm:text-2xl mb-3">
                                            Hubungi Petugas PPID DLH Jakarta
                                        </h3>
                                        <p class="text-white/60 text-sm mb-6 max-w-md mx-auto">
                                            Kami siap membantu permohonan informasi publik Anda di bidang lingkungan hidup DKI Jakarta.
                                        </p>
                                        <div class="flex flex-wrap justify-center gap-3">
                                            <a href="mailto:ppid.dlh@jakarta.go.id"
                                                   class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold text-white border border-white/25 hover:bg-white/10 transition-colors">
                                                📧 ppid.dlh@jakarta.go.id
                                            </a>
                                            <a href="https://ppid.jakarta.go.id" target="_blank"
                                                   class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-bold bg-white/15 hover:bg-white/25 text-white transition-colors">
                                                🌐 ppid.jakarta.go.id
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </section>
