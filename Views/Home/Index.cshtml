@model LacakViewModel
@{ ViewData["Title"] = "Lacak Permohonan"; }

<section class="bg-gradient-to-br from-[#003876] to-[#0057b8] text-white py-14 px-4">
    <div class="max-w-2xl mx-auto text-center">
        <div class="text-5xl mb-4">📂</div>
        <h2 class="text-2xl font-bold mb-2">Lacak Permohonan Permintaan Data</h2>
        <p class="text-blue-200 text-sm mb-7">Masukkan nomor permohonan yang Anda terima saat pendaftaran untuk melihat status dan mengunduh data.</p>
        <form asp-action="LacakPost" method="post" class="flex flex-col sm:flex-row gap-2 max-w-lg mx-auto">
            @Html.AntiForgeryToken()
            <input asp-for="NoPermohonan"
                   class="flex-1 px-4 py-3 rounded-xl text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-yellow-400"
                   placeholder="Contoh: PPD/2024/0001" autocomplete="off" />
            <button type="submit"
                    class="bg-yellow-400 hover:bg-yellow-300 text-gray-900 font-semibold px-6 py-3 rounded-xl transition-colors text-sm whitespace-nowrap">
                🔍 Cek Status
            </button>
        </form>
        <span asp-validation-for="NoPermohonan" class="text-yellow-300 text-xs mt-1 block"></span>
    </div>
</section>

<!-- Info Cards -->
<section class="max-w-6xl mx-auto px-4 py-12">
    <h3 class="text-center text-gray-500 text-sm uppercase tracking-widest mb-8">Cara Mengajukan Permohonan</h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var (icon, step, title, desc) in new[]{
            ("1️⃣", "Langkah 1", "Datang ke Loket", "Bawa KTP, surat permohonan, dan dokumen pendukung sesuai kategori Anda."),
            ("2️⃣", "Langkah 2", "Identifikasi & Pendaftaran", "Petugas loket akan mendaftarkan Anda dan memberikan nomor permohonan."),
            ("3️⃣", "Langkah 3", "Tandatangani Dokumen", "Tanda tangani dokumen identifikasi awal yang dicetak oleh petugas."),
            ("4️⃣", "Langkah 4", "Pantau & Unduh Data", "Gunakan nomor permohonan untuk memantau status dan mengunduh data.")
        })
        {
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
                <div class="text-3xl mb-3">@icon</div>
                <p class="text-xs text-blue-600 font-semibold uppercase tracking-wide">@step</p>
                <h4 class="font-bold text-gray-800 mt-1 mb-2">@title</h4>
                <p class="text-gray-500 text-sm leading-relaxed">@desc</p>
            </div>
        }
    </div>
</section>

<section class="max-w-5xl mx-auto px-4 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white rounded-2xl border border-blue-100 p-5 bg-blue-50">
            <p class="font-semibold text-blue-800 mb-3">🎓 Mahasiswa / Pelajar</p>
            <ul class="text-sm text-gray-600 space-y-1">
                <li>• Fotokopi KTP</li>
                <li>• Surat Permohonan</li>
                <li>• Proposal Penelitian</li>
            </ul>
        </div>
        <div class="bg-white rounded-2xl border border-green-100 p-5 bg-green-50">
            <p class="font-semibold text-green-800 mb-3">🏢 LSM / Organisasi</p>
            <ul class="text-sm text-gray-600 space-y-1">
                <li>• Fotokopi KTP Perwakilan</li>
                <li>• Akta Notaris Lembaga</li>
                <li>• Surat Permohonan</li>
            </ul>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 p-5 bg-gray-50">
            <p class="font-semibold text-gray-700 mb-3">👤 Umum</p>
            <p class="text-sm text-gray-500 mb-3">Permohonan masyarakat umum melalui:</p>
            <a href="https://ppid.jakarta.go.id/permohonan-informasi" target="_blank" class="text-blue-600 font-semibold text-sm hover:underline">
                🌐 Website PPID Diskominfo →
            </a>
        </div>
    </div>
</section>
