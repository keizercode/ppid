@model LacakViewModel
@{
    ViewData["Title"] = "PPID — Dinas Lingkungan Hidup DKI Jakarta";
}

<style>
    /* ══ DESIGN TOKENS ══ */
    :root {
        --dlh-green:       #006B3C;
        --dlh-green-dark:  #004D2B;
        --dlh-green-light: #E8F5EE;
        --dlh-green-mid:   #00874C;
        --navy:            #1B3B6F;
        --navy-dark:       #122850;
        --navy-light:      #EEF3FB;
        --bg-soft:         #F5F7FA;
        --border:          #E4E9F2;
        --text-main:       #111827;
        --text-muted:      #6B7280;
    }

    /* ══ ANIMATIONS ══ */
    @@keyframes fadeUp   { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes slideIn  { from{opacity:0;transform:translateX(-12px)} to{opacity:1;transform:translateX(0)} }
    @@keyframes ticker   { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
    @@keyframes pulse-dot{ 0%,100%{box-shadow:0 0 0 0 rgba(0,107,60,.35)} 50%{box-shadow:0 0 0 8px rgba(0,107,60,0)} }

    .au-1 { animation: fadeUp .55s ease both .10s }
    .au-2 { animation: fadeUp .55s ease both .22s }
    .au-3 { animation: fadeUp .55s ease both .34s }
    .au-4 { animation: fadeUp .55s ease both .46s }

    /* ══ TOPBAR ══ */
    .topbar {
        background: var(--dlh-green-dark);
        padding: 6px 0;
        font-size: 11px;
        color: rgba(255,255,255,.65);
    }
    .ticker-wrap  { overflow:hidden; white-space:nowrap; }
    .ticker-inner { display:inline-block; animation:ticker 32s linear infinite; }

    /* ══ NAVBAR ══ */
    .main-nav {
        background: #fff;
        border-bottom: 2px solid var(--dlh-green);
        position: sticky;
        top: 0;
        z-index: 50;
        box-shadow: 0 2px 20px rgba(0,0,0,.07);
    }
    .nav-link {
        font-size: 13px;
        font-weight: 500;
        padding: 6px 14px;
        border-radius: 8px;
        color: var(--text-muted);
        transition: all .15s;
        text-decoration: none;
    }
    .nav-link:hover { background: var(--bg-soft); color: var(--text-main); }
    .nav-link.active { background: var(--dlh-green-light); color: var(--dlh-green-dark); font-weight: 600; }

    /* ══ HERO ══ */
    .hero {
        background: linear-gradient(135deg, var(--dlh-green-dark) 0%, var(--navy) 55%, #0D1F3C 100%);
        position: relative;
        overflow: hidden;
    }
    .hero::before {
        content: '';
        position: absolute; inset: 0;
        background:
            radial-gradient(circle at 8% 20%, rgba(0,135,76,.20) 0%, transparent 48%),
            radial-gradient(circle at 92% 80%, rgba(27,59,111,.30) 0%, transparent 48%);
        pointer-events: none;
    }
    .hero-grid {
        position: absolute; inset: 0;
        opacity: .05;
        background-image:
            repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(255,255,255,.9) 59px, rgba(255,255,255,.9) 60px),
            repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(255,255,255,.9) 59px, rgba(255,255,255,.9) 60px);
    }
    .hero::after {
        content: '';
        position: absolute; bottom: -1px; left: 0; right: 0;
        height: 64px;
        background: var(--bg-soft);
        clip-path: ellipse(55% 100% at 50% 100%);
    }

    /* ══ SEARCH ══ */
    .search-card {
        background: rgba(255,255,255,.09);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,.17);
        border-radius: 20px;
        padding: 28px 32px;
    }
    .search-input {
        background: rgba(255,255,255,.96);
        border: 2px solid transparent;
        border-radius: 12px;
        transition: border-color .2s, box-shadow .2s;
    }
    .search-input:focus {
        border-color: var(--dlh-green-mid);
        box-shadow: 0 0 0 4px rgba(0,107,60,.14);
        outline: none;
    }
    .btn-search {
        background: var(--dlh-green);
        color: #fff;
        border-radius: 12px;
        font-weight: 700;
        transition: background .18s, transform .1s;
        border: none;
        cursor: pointer;
    }
    .btn-search:hover  { background: var(--dlh-green-mid); }
    .btn-search:active { transform: scale(.97); }

    /* ══ STAT BAR ══ */
    .stat-bar {
        background: linear-gradient(90deg, var(--dlh-green-dark), var(--navy));
        border-radius: 20px;
        color: #fff;
    }
    .stat-bar .divider { width:1px; background:rgba(255,255,255,.15); align-self:stretch; }

    /* ══ ICON CONTAINER ══ */
    .ic {
        width: 48px; height: 48px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .ic svg { width: 22px; height: 22px; }

    /* ══ SECTION BADGE ══ */
    .section-badge {
        display: inline-flex; align-items: center; gap: 7px;
        background: var(--dlh-green-light);
        border: 1px solid rgba(0,107,60,.18);
        color: var(--dlh-green-dark);
        font-size: 11px; font-weight: 700;
        letter-spacing: .08em; text-transform: uppercase;
        padding: 5px 13px; border-radius: 100px;
        margin-bottom: 10px;
    }
    .badge-dot { width:6px; height:6px; border-radius:50%; background:var(--dlh-green); }

    /* ══ CARDS ══ */
    .feature-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px 20px;
        transition: transform .18s, box-shadow .18s, border-color .18s;
        text-decoration: none;
        display: block;
    }
    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 36px rgba(0,107,60,.11);
        border-color: var(--dlh-green);
    }

    /* ══ STEPS ══ */
    .steps-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        position: relative;
    }
    @@media (max-width: 1023px) { .steps-grid { grid-template-columns: 1fr 1fr; gap: 16px; } }
    @@media (max-width: 639px)  { .steps-grid { grid-template-columns: 1fr; } }

    .step-item {
        position: relative;
        display: flex; flex-direction: column; align-items: center;
        padding: 0 12px;
    }
    .step-item:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 22px;
        left: calc(50% + 22px);
        right: calc(-50% + 22px);
        height: 2px;
        background: linear-gradient(90deg, var(--dlh-green), var(--navy));
        opacity: .20;
    }
    @@media (max-width: 1023px) { .step-item:not(:last-child)::after { display:none; } }

    .step-num {
        width: 44px; height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--dlh-green), var(--navy));
        color: #fff;
        font-weight: 800; font-size: 15px;
        display: flex; align-items: center; justify-content: center;
        position: relative; z-index: 1; flex-shrink: 0;
        margin-bottom: 18px;
        box-shadow: 0 4px 14px rgba(0,107,60,.28);
    }
    .step-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 20px 18px 18px;
        width: 100%;
        transition: box-shadow .18s, border-color .18s, transform .18s;
    }
    .step-card:hover {
        box-shadow: 0 8px 28px rgba(0,107,60,.09);
        border-color: rgba(0,107,60,.22);
        transform: translateY(-3px);
    }
    .step-tag {
        display: inline-block; font-size: 10px; font-weight: 700;
        padding: 3px 10px; border-radius: 100px;
        background: var(--dlh-green-light); color: var(--dlh-green-dark);
        margin-top: 12px;
    }

    /* ══ REQUIREMENTS ══ */
    .req-card { background:#fff; border:1px solid var(--border); border-radius:20px; overflow:hidden; transition:box-shadow .18s; }
    .req-card:hover { box-shadow:0 8px 24px rgba(0,0,0,.07); }
    .req-item { display:flex; align-items:center; gap:10px; padding:9px 0; border-bottom:1px solid var(--border); font-size:13.5px; color:var(--text-main); }
    .req-item:last-child { border-bottom:none; }
    .req-check { width:20px;height:20px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0; }

    /* ══ LAW CARD ══ */
    .law-card {
        border-left: 3px solid var(--dlh-green);
        background: var(--dlh-green-light);
        border-radius: 0 10px 10px 0;
        padding: 12px 16px; margin-bottom: 8px;
    }

    /* ══ CTA ══ */
    .cta-wrap {
        background: linear-gradient(135deg, var(--dlh-green-dark), var(--navy));
        border-radius: 24px;
        position: relative; overflow: hidden;
    }
    .cta-wrap::before {
        content: '';
        position: absolute; top: -40px; right: -40px;
        width: 200px; height: 200px;
        border-radius: 50%; background: rgba(255,255,255,.04);
    }

    /* ══ FOOTER ══ */
    .site-footer { background: var(--navy-dark); color: rgba(255,255,255,.5); }

    .live-dot { animation: pulse-dot 2s infinite; }

    /* ══ UTILITY ══ */
    .accent-bar {
        width: 4px;
        background: linear-gradient(180deg, var(--dlh-green), var(--navy));
        border-radius: 4px; flex-shrink: 0;
    }
</style>

<!-- ══ TOPBAR ══ -->
<div class="topbar">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between gap-4">
        <div class="ticker-wrap flex-1">
            <div class="ticker-inner">
                <span class="mx-6">Telepon: (021) 8591-2230</span>
                <span class="mx-6">Email: ppid.dlh@jakarta.go.id</span>
                <span class="mx-6">Jam Layanan: Senin – Jumat, 08.00 – 16.00 WIB</span>
                <span class="mx-6">Jl. Mandala V No. 67, Cililitan, Jakarta Timur</span>
                <span class="mx-6">Telepon: (021) 8591-2230</span>
                <span class="mx-6">Email: ppid.dlh@jakarta.go.id</span>
                <span class="mx-6">Jam Layanan: Senin – Jumat, 08.00 – 16.00 WIB</span>
                <span class="mx-6">Jl. Mandala V No. 67, Cililitan, Jakarta Timur</span>
            </div>
        </div>
        <a href="/auth/login"
           class="text-white/60 hover:text-white text-[11px] font-semibold flex items-center gap-1.5 flex-shrink-0 transition-colors">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
            Masuk Petugas
        </a>
    </div>
</div>

<!-- ══ NAVBAR ══ -->
<header class="main-nav">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-6">
        <a href="/" class="flex items-center gap-3 flex-shrink-0">
            <div class="flex items-center justify-center rounded-xl px-2.5 py-2 flex-shrink-0"
                 style="background:var(--navy); min-width:44px; height:44px;">
                <img src="https://ppid.jakarta.go.id/assets/home/ppidNew/images/logo/logo-ppid-email.png"
                     alt="Logo PPID Jakarta" class="h-7 w-auto object-contain" id="nav-logo"
                     onerror="document.getElementById('nav-logo').style.display='none';document.getElementById('nav-fallback').style.display='block';" />
                <span id="nav-fallback" class="text-white font-black text-[11px] tracking-widest hidden">PPID</span>
            </div>
            <div class="border-l border-gray-200 pl-3">
                <p class="text-[10px] text-gray-400 uppercase tracking-widest leading-none font-semibold">Dinas Lingkungan Hidup</p>
                <p class="text-gray-800 font-bold text-[13.5px] leading-tight mt-0.5">PPID DKI Jakarta</p>
            </div>
        </a>
        <nav class="hidden md:flex items-center gap-1">
            <a href="/"         class="nav-link active">Beranda</a>
            <a href="#tentang"  class="nav-link">Tentang PPID</a>
            <a href="#alur"     class="nav-link">Alur Permohonan</a>
            <a href="#lacak"    class="nav-link">Lacak Permohonan</a>
        </nav>
        <a href="#lacak"
           class="hidden sm:inline-flex items-center gap-2 text-sm font-bold px-4 py-2 rounded-xl text-white transition-all flex-shrink-0"
           style="background:var(--dlh-green)">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
            </svg>
            Lacak Permohonan
        </a>
    </div>
</header>

<!-- ══ HERO ══ -->
<section class="hero py-20 pb-28">
    <div class="hero-grid"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Left copy -->
            <div>
                <div class="au-1 inline-flex items-center gap-2 mb-5 border border-white/20 rounded-full px-4 py-1.5"
                     style="background:rgba(255,255,255,.10)">
                    <span class="w-2 h-2 rounded-full bg-green-400 live-dot"></span>
                    <span class="text-white/75 text-xs font-semibold tracking-wide">Layanan Aktif &middot; PPID DLH Jakarta</span>
                </div>
                <h1 class="au-2 text-white font-extrabold text-4xl sm:text-5xl leading-tight mb-5">
                    Transparansi<br/>
                    <span style="background:linear-gradient(90deg,#6EE7A0,#93C5FD);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
                        Informasi Publik
                    </span>
                </h1>
                <p class="au-3 text-white/65 text-base sm:text-lg leading-relaxed mb-8 max-w-lg">
                    Pejabat Pengelola Informasi dan Dokumentasi (PPID) Dinas Lingkungan Hidup Provinsi DKI Jakarta
                    hadir melayani permohonan data dan informasi lingkungan secara cepat, terbuka, dan akuntabel.
                </p>
                <div class="au-4 flex flex-wrap gap-3">
                    <a href="#lacak"
                       class="btn-search inline-flex items-center gap-2.5 px-6 py-3 text-sm font-bold rounded-xl shadow-lg">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                        </svg>
                        Lacak Status Permohonan
                    </a>
                    <a href="#tentang"
                       class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-xl border border-white/22 text-white/80 hover:bg-white/10 transition-colors">
                        Pelajari Lebih Lanjut
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                        </svg>
                    </a>
                </div>
            </div>
            <!-- Right feature cards -->
            <div class="au-3 grid grid-cols-2 gap-3">
                @{
                    var heroCards = new[]{
                        new { Icon="<path stroke-linecap='round' stroke-linejoin='round' d='M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z'/>", Title="Ajukan Permohonan", Desc="Datang ke loket PPID DLH dengan membawa kelengkapan berkas persyaratan" },
                        new { Icon="<path stroke-linecap='round' stroke-linejoin='round' d='M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z'/>", Title="Lacak Status", Desc="Pantau perkembangan permohonan secara langsung melalui portal ini" },
                        new { Icon="<path stroke-linecap='round' stroke-linejoin='round' d='M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z'/>", Title="Informasi Publik", Desc="Akses dokumen dan data lingkungan hidup DKI Jakarta yang tersedia" },
                        new { Icon="<path stroke-linecap='round' stroke-linejoin='round' d='M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z'/>", Title="Penilaian Layanan", Desc="Berikan penilaian atas kualitas layanan yang telah Anda terima" },
                    };
                }
                @foreach (var c in heroCards)
                {
                    <div class="bg-white/10 backdrop-blur-sm border border-white/14 rounded-2xl p-4 hover:bg-white/17 transition-all cursor-default">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3 border border-white/15" style="background:rgba(255,255,255,.10)">
                            <svg class="w-5 h-5 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
                                @Html.Raw(c.Icon)
                            </svg>
                        </div>
                        <p class="text-white font-bold text-sm mb-1">@c.Title</p>
                        <p class="text-white/50 text-xs leading-relaxed">@c.Desc</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ══ STATS BAR ══ -->
<section style="background:var(--bg-soft); padding-top:0;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 -mt-10 relative z-10">
        <div class="stat-bar shadow-xl shadow-green-900/18 p-6 sm:p-8">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-0 divide-x divide-white/15">
                @{
                    var statItems = new[]{
                        new { Val="UU No. 14/2008", Sub="Dasar Hukum",
                            Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z'/>" },
                        new { Val="Senin – Jumat", Sub="Hari Layanan",
                            Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5'/>" },
                        new { Val="≤ 10 Hari Kerja", Sub="Waktu Respons",
                            Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z'/>" },
                        new { Val="Tanpa Biaya", Sub="Gratis Sepenuhnya",
                            Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z'/>" },
                    };
                }
                @foreach (var s in statItems)
                {
                    <div class="px-4 sm:px-6 py-1 text-center">
                        <div class="flex justify-center mb-2">
                            <svg class="w-6 h-6 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
                                @Html.Raw(s.Svg)
                            </svg>
                        </div>
                        <p class="text-white font-extrabold text-sm">@s.Val</p>
                        <p class="text-white/45 text-xs mt-0.5">@s.Sub</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ══ TENTANG PPID ══ -->
<section id="tentang" class="py-16" style="background:var(--bg-soft)">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
            <div>
                <div class="section-badge"><span class="badge-dot"></span>Tentang PPID</div>
                <h2 class="text-2xl font-extrabold text-gray-900 mb-4 leading-snug">
                    Pejabat Pengelola Informasi<br/>dan Dokumentasi (PPID)
                </h2>
                <div class="flex gap-4 mb-5">
                    <div class="accent-bar min-h-full" style="min-height:60px"></div>
                    <p class="text-gray-600 text-sm leading-relaxed">
                        Berdasarkan <strong>Undang-Undang Nomor 14 Tahun 2008</strong> tentang Keterbukaan Informasi Publik,
                        setiap Badan Publik wajib menetapkan PPID yang bertanggung jawab dalam penyimpanan,
                        pendokumentasian, penyediaan, dan pelayanan informasi kepada publik secara cepat dan tepat waktu.
                    </p>
                </div>
                <p class="text-gray-600 text-sm leading-relaxed mb-6">
                    PPID Dinas Lingkungan Hidup Provinsi DKI Jakarta berkomitmen mewujudkan tata kelola pemerintahan
                    yang baik melalui transparansi dan akuntabilitas informasi publik di bidang lingkungan hidup.
                </p>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Landasan Hukum</p>
                @{
                    var laws = new[]{
                        "UU No. 14 Tahun 2008 — Keterbukaan Informasi Publik",
                        "PP No. 61 Tahun 2010 — Pelaksanaan UU KIP",
                        "Permendagri No. 3 Tahun 2017 — Pedoman PPID Daerah",
                        "Pergub DKI Jakarta No. 175 Tahun 2016",
                    };
                }
                @foreach (var law in laws)
                {
                    <div class="law-card"><p class="text-xs font-semibold text-green-800">@law</p></div>
                }
            </div>
            <div>
                <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-4 shadow-sm">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="ic" style="background:var(--dlh-green-light);border:1px solid rgba(0,107,60,.15)">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" style="color:var(--dlh-green)">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
                            </svg>
                        </div>
                        <p class="font-bold text-gray-800 text-sm">Visi PPID</p>
                    </div>
                    <p class="text-gray-600 text-sm leading-relaxed italic">
                        "Jakarta kota maju, lestari dan berbudaya yang warganya terlibat dalam mewujudkan
                        keberadaban, keadilan, dan kesejahteraan bagi semua."
                    </p>
                </div>
                <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="ic" style="background:var(--navy-light);border:1px solid rgba(27,59,111,.12)">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" style="color:var(--navy)">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>
                            </svg>
                        </div>
                        <p class="font-bold text-gray-800 text-sm">Fungsi &amp; Tugas PPID</p>
                    </div>
                    <div class="space-y-2.5">
                        @{
                            var funcs = new[]{
                                "Melaksanakan kebijakan layanan informasi yang ditetapkan",
                                "Melakukan klasifikasi dan verifikasi informasi publik",
                                "Koordinasi pengumpulan bahan informasi dan dokumentasi",
                                "Menyediakan & memberikan pelayanan informasi kepada publik",
                                "Menjadi media informasi yang mudah diakses masyarakat",
                                "Menyampaikan laporan pengelolaan informasi secara berkala",
                            };
                        }
                        @foreach (var (f, i) in funcs.Select((f, i) => (f, i + 1)))
                        {
                            <div class="flex items-start gap-3">
                                <span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0 mt-0.5"
                                      style="background:var(--dlh-green)">@i</span>
                                <p class="text-gray-600 text-xs leading-relaxed">@f</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ ALUR PERMOHONAN ══ -->
<section id="alur" class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
            <div class="section-badge" style="margin:0 auto 10px; width:fit-content">
                <span class="badge-dot"></span>Panduan Layanan
            </div>
            <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Alur Permohonan Informasi</h2>
            <p class="text-gray-400 text-sm max-w-md mx-auto">
                Ikuti langkah berikut untuk mengajukan permohonan data dan informasi di PPID DLH Jakarta
            </p>
        </div>
        <div class="steps-grid">
            @{
                var steps = new[]{
                    new { Num="1",
                          Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z'/>",
                          Title="Datang ke Loket PPID",
                          Desc="Kunjungi loket PPID DLH Jakarta. Bawa KTP asli, surat permohonan, dan dokumen pendukung sesuai kategori pemohon.",
                          Tag="Senin–Jum'at · 08.00–16.00" },
                    new { Num="2",
                          Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z'/>",
                          Title="Identifikasi &amp; Pendaftaran",
                          Desc="Petugas memverifikasi berkas dan mendaftarkan permohonan. Nomor unik diterbitkan untuk melacak status.",
                          Tag="± 15 menit proses" },
                    new { Num="3",
                          Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10'/>",
                          Title="Tanda Tangan Formulir",
                          Desc="Tanda tangani formulir identifikasi awal. Nomor permohonan tercetak di formulir — simpan dengan baik.",
                          Tag="Simpan nomor Anda!" },
                    new { Num="4",
                          Svg="<path stroke-linecap='round' stroke-linejoin='round' d='M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3'/>",
                          Title="Pantau &amp; Unduh Data",
                          Desc="Gunakan nomor permohonan untuk cek status secara daring. Unduh data saat status berubah menjadi 'Data Siap'.",
                          Tag="Pantau secara langsung" },
                };
            }
            @foreach (var s in steps)
            {
                <div class="step-item">
                    <div class="step-num">@s.Num</div>
                    <div class="step-card">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-3"
                             style="background:var(--dlh-green-light); border:1px solid rgba(0,107,60,.12)">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" style="color:var(--dlh-green)">
                                @Html.Raw(s.Svg)
                            </svg>
                        </div>
                        <h3 class="font-bold text-gray-800 text-sm mb-1.5 leading-snug">@Html.Raw(s.Title)</h3>
                        <p class="text-gray-400 text-xs leading-relaxed">@s.Desc</p>
                        <span class="step-tag">@s.Tag</span>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ PERSYARATAN DOKUMEN ══ -->
<section class="py-16" style="background:var(--bg-soft)">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
            <div class="section-badge" style="margin:0 auto 10px; width:fit-content">
                <span class="badge-dot"></span>Persyaratan
            </div>
            <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Dokumen yang Diperlukan</h2>
            <p class="text-gray-400 text-sm">Siapkan berkas berikut sebelum datang ke loket</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

            <!-- Mahasiswa -->
            <div class="req-card">
                <div class="p-5" style="background:linear-gradient(135deg,#EFF6FF,#DBEAFE); border-bottom:1px solid #BFDBFE">
                    <div class="flex items-center gap-3">
                        <div class="ic" style="background:#fff; border:1px solid #BFDBFE">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" style="color:#1D4ED8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold text-blue-900 text-sm">Mahasiswa / Pelajar</p>
                            <p class="text-blue-500 text-xs font-semibold mt-0.5">3 dokumen wajib &middot; Kode: <span class="font-mono">MHS</span></p>
                        </div>
                    </div>
                </div>
                <div class="p-5 pt-4">
                    @foreach (var d in new[] { "Fotokopi KTP", "Surat Permohonan Resmi", "Proposal Penelitian" })
                    {
                        <div class="req-item">
                            <div class="req-check" style="background:#DBEAFE; color:#1D4ED8">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                                </svg>
                            </div>
                            <span>@d</span>
                        </div>
                    }
                </div>
            </div>

            <!-- LSM -->
            <div class="req-card">
                <div class="p-5" style="background:linear-gradient(135deg,#ECFDF5,#D1FAE5); border-bottom:1px solid #A7F3D0">
                    <div class="flex items-center gap-3">
                        <div class="ic" style="background:#fff; border:1px solid #A7F3D0">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" style="color:#065F46">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold text-green-900 text-sm">LSM / Organisasi</p>
                            <p class="text-green-600 text-xs font-semibold mt-0.5">3 dokumen wajib &middot; Kode: <span class="font-mono">UMM</span></p>
                        </div>
                    </div>
                </div>
                <div class="p-5 pt-4">
                    @foreach (var d in new[] { "Fotokopi KTP Perwakilan", "Akta Notaris Lembaga", "Surat Permohonan Resmi" })
                    {
                        <div class="req-item">
                            <div class="req-check" style="background:#D1FAE5; color:#065F46">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                                </svg>
                            </div>
                            <span>@d</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Umum -->
            <div class="req-card">
                <div class="p-5" style="background:linear-gradient(135deg,#F9FAFB,#F3F4F6); border-bottom:1px solid #E5E7EB">
                    <div class="flex items-center gap-3">
                        <div class="ic" style="background:#fff; border:1px solid #E5E7EB">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" style="color:#374151">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-bold text-gray-800 text-sm">Masyarakat Umum</p>
                            <p class="text-gray-500 text-xs font-semibold mt-0.5">Via portal PPID daring</p>
                        </div>
                    </div>
                </div>
                <div class="p-5 pt-4">
                    <p class="text-gray-500 text-xs leading-relaxed mb-4">
                        Permohonan masyarakat umum dilayani melalui portal resmi PPID Pemprov DKI Jakarta.
                        Tidak perlu datang ke kantor — semua dapat dilakukan secara digital.
                    </p>
                    <a href="https://ppid.jakarta.go.id/permohonan-informasi" target="_blank"
                       class="flex items-center justify-center gap-2 w-full text-white text-xs font-bold py-2.5 rounded-xl transition-colors"
                       style="background:var(--navy)">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                        </svg>
                        Kunjungi Portal PPID Jakarta
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ══ LACAK PERMOHONAN ══ -->
<section id="lacak" class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
            <div class="section-badge" style="margin:0 auto 10px; width:fit-content">
                <span class="badge-dot"></span>Status Permohonan
            </div>
            <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Lacak Permohonan Anda</h2>
            <p class="text-gray-400 text-sm max-w-sm mx-auto">
                Masukkan nomor permohonan yang tertera pada formulir identifikasi awal untuk melihat status terkini.
            </p>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-xl shadow-gray-100 p-8">

            @if (TempData["Error"] != null)
            {
                <div class="mb-6 flex items-start gap-3 bg-red-50 border border-red-200 rounded-xl px-4 py-3">
                    <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
                    </svg>
                    <p class="text-red-700 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
                </div>
            }

            <form asp-action="LacakPost" method="post">
                @Html.AntiForgeryToken()

                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">
                    Nomor Permohonan
                </label>

                <div class="flex gap-3 mb-2">
                    <div class="relative flex-1">
                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
                            </svg>
                        </div>
                        <input asp-for="NoPermohonan"
                               class="search-input w-full pl-11 pr-4 py-3.5 text-gray-800 text-sm font-mono tracking-widest uppercase"
                               style="font-size:14px; letter-spacing:.06em"
                               placeholder="Contoh: MHS687592/PPID/III/2026"
                               autocomplete="off"
                               oninput="this.value = this.value.toUpperCase()" />
                    </div>
                    <button type="submit" class="btn-search px-7 py-3 text-sm">
                        Cek Status
                    </button>
                </div>

                <span asp-validation-for="NoPermohonan" class="text-red-500 text-xs block mb-1"></span>

                <div class="mt-4 bg-gray-50 border border-gray-100 rounded-xl p-4">
                    <p class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-2">Format Nomor Permohonan</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div class="bg-blue-50 border border-blue-100 rounded-lg px-3 py-2.5">
                            <p class="text-[10px] text-blue-500 font-bold uppercase mb-1">Mahasiswa / Pelajar</p>
                            <p class="font-mono text-blue-800 font-bold text-sm">MHS687592/PPID/III/2026</p>
                            <p class="text-[10px] text-blue-400 mt-1">MHS + 6 digit / PPID / Bulan Romawi / Tahun</p>
                        </div>
                        <div class="bg-emerald-50 border border-emerald-100 rounded-lg px-3 py-2.5">
                            <p class="text-[10px] text-emerald-500 font-bold uppercase mb-1">LSM / Organisasi / Umum</p>
                            <p class="font-mono text-emerald-800 font-bold text-sm">UMM423187/PPID/III/2026</p>
                            <p class="text-[10px] text-emerald-400 mt-1">UMM + 6 digit / PPID / Bulan Romawi / Tahun</p>
                        </div>
                    </div>
                    <p class="text-gray-400 text-xs mt-2.5">
                        Nomor ini tertera pada formulir identifikasi yang diberikan petugas loket saat mendaftar.
                        Simpan formulir tersebut sebagai referensi.
                    </p>
                </div>
            </form>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
            <div class="flex items-start gap-3 bg-green-50 border border-green-200 rounded-xl p-4">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
                     style="background:var(--dlh-green-light); border:1px solid rgba(0,107,60,.15)">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--dlh-green)">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                    </svg>
                </div>
                <div>
                    <p class="font-bold text-green-800 text-sm">Simpan Formulir Anda</p>
                    <p class="text-green-600 text-xs mt-0.5 leading-relaxed">Nomor permohonan tercetak di formulir identifikasi yang ditandatangani di loket. Simpan salinannya.</p>
                </div>
            </div>
