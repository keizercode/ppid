                        <dd class="text-gray-700 text-sm leading-snug">@p.JudulPenelitian</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(p.Pengampu)) {
                        <div>
                            <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Pengampu / PIC</dt>
                            <dd class="text-gray-700 text-sm">@p.Pengampu
                                @if (!string.IsNullOrEmpty(p.TeleponPengampu)) {
                                    <a href="tel:@p.TeleponPengampu" class="ml-2 text-blue-500 text-xs hover:underline">📞 @p.TeleponPengampu</a>
                                }
                            </dd>
                        </div>
                    }
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-1.5">Keperluan</dt>
                        <dd class="flex flex-wrap gap-1.5">
                            @if (p.IsObservasi)      { <span class="bg-orange-50 border border-orange-200 text-orange-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Observasi</span> }
                            @if (p.IsPermintaanData) { <span class="bg-blue-50 border border-blue-200 text-blue-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Permintaan Data</span> }
                            @if (p.IsWawancara)      { <span class="bg-violet-50 border border-violet-200 text-violet-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Wawancara</span> }
                        </dd>
                    </div>
                </dl>
            </div>

            @* Jadwal aktif cards *@
            @foreach (var jenis in new[] { "Observasi", "Wawancara" })
            {
                var jadwal = Model.GetJadwalAktif(jenis);
                if (jadwal is null) continue;

                bool isWaw      = jenis == "Wawancara";
                bool isNewJad   = Model.IsJadwalBaru(jenis);
                var  stTask     = jenis == "Wawancara" ? stWaw : stObs;
                int  rescCount  = stTask?.RescheduleCount ?? 0;
                bool isOverdueCard = IsOverdueTask(stTask);

                string cardBd  = isOverdueCard ? "border-amber-300" : isWaw ? "border-violet-200" : "border-orange-200";
                string icon    = isWaw ? "🎤" : "📅";
                string itemBg  = isOverdueCard ? "bg-amber-50 border-amber-100" : isWaw ? "bg-violet-50 border-violet-100" : "bg-orange-50 border-orange-100";
                string titleC  = isOverdueCard ? "text-amber-700" : isWaw ? "text-violet-800" : "text-orange-800";
                string timeC   = isOverdueCard ? "text-amber-600" : isWaw ? "text-violet-600" : "text-orange-600";
                string picLabel = isWaw ? "Narasumber" : "PIC";

                <div class="bg-white rounded-2xl border @cardBd shadow-sm p-5">
                    <div class="flex items-center justify-between gap-2 mb-3">
                        <div class="flex items-center gap-2">
                            <div class="w-7 h-7 @(isOverdueCard ? "bg-amber-50 border-amber-200" : isWaw ? "bg-violet-50 border-violet-200" : "bg-orange-50 border-orange-200") rounded-lg flex items-center justify-center text-sm border">@icon</div>
                            <p class="font-bold text-gray-800 text-sm">Jadwal @jenis</p>
                        </div>
                        <div class="flex gap-1 flex-wrap justify-end">
                            @if (isOverdueCard)
                            { <span class="text-[10px] bg-amber-100 text-amber-700 border border-amber-200 px-1.5 py-0.5 rounded-full font-bold">⏰ Lewat Jadwal</span> }
                            else if (isNewJad)
                            { <span class="text-[10px] bg-green-100 text-green-700 border border-green-200 px-1.5 py-0.5 rounded-full font-bold animate-pulse">BARU</span> }
                            @if (rescCount > 0)
                            { <span class="text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-1.5 py-0.5 rounded-full font-semibold">🔄 Diubah @rescCount×</span> }
                        </div>
                    </div>

                    <div class="@itemBg rounded-xl px-3 py-2.5 border">
                        <p class="text-sm font-bold @titleC">@jadwal.Tanggal?.ToString("dddd, dd MMM yyyy")</p>
                        <p class="text-xs @timeC font-medium">Pukul @jadwal.Waktu?.ToString("HH:mm") WIB</p>

                        @* Lokasi *@
                        @if (!string.IsNullOrEmpty(jadwal.LokasiJenis))
                        {
                            <p class="text-xs @timeC mt-1">
                                @(jadwal.LokasiJenis == "Online" ? "🌐 Online" : "📍 Offline"):
                                @if (jadwal.LokasiJenis == "Online" && !string.IsNullOrEmpty(jadwal.LokasiDetail)
                                     && (jadwal.LokasiDetail.StartsWith("http")))
                                {
                                    <a href="@jadwal.LokasiDetail" target="_blank" class="underline font-medium">Buka Link Meeting →</a>
                                }
                                else if (!string.IsNullOrEmpty(jadwal.LokasiDetail))
                                {
                                    <strong>@jadwal.LokasiDetail</strong>
                                }
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(jadwal.NamaPIC))
                        {
                            <p class="text-xs @(isWaw ? "text-violet-600" : "text-orange-600") mt-0.5">@picLabel: <strong>@jadwal.NamaPIC</strong></p>
                            @if (!string.IsNullOrEmpty(jadwal.TeleponPIC))
                            {
                                <a href="tel:@jadwal.TeleponPIC"
                                   class="mt-1 inline-flex items-center gap-1 text-[11px] @(isWaw ? "text-violet-500" : "text-orange-500") hover:underline">
                                    📞 @jadwal.TeleponPIC
                                </a>
                            }
                        }
                    </div>

                    @if (isOverdueCard)
                    {
                        <p class="text-[11px] text-amber-600 mt-1.5 font-medium">
                            ⏰ Jadwal sudah lewat — hubungi petugas untuk konfirmasi pelaksanaan.
                        </p>
                    }
                    else if (rescCount > 0)
                    { <p class="text-[11px] text-amber-600 mt-1.5">ℹ️ Jadwal sudah diubah @rescCount× — gunakan jadwal terbaru di atas.</p> }
                </div>
            }

            @* Data Tersedia — per keperluan *@
@{
