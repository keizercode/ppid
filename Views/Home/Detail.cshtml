            stObs.FilePath!,
            "bg-orange-500 hover:bg-orange-600"));

    if (p.IsWawancara && stWaw?.IsSelesai == true && !string.IsNullOrEmpty(stWaw.FilePath))
        fileItems.Add(("🎤",
