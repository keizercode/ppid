@* ════════════════════════════════════════════════════════════════════════════
   Views/Home/Detail.cshtml — FULL REPLACEMENT
   PERUBAHAN:
   1. Realtime polling (30 detik) → banner "Status diperbarui"
   2. Timeline informatif dengan sub-step jadwal/reschedule/PIC
   3. Badge "BARU" jika jadwal atau PIC baru diperbarui
   4. Per-subtask detail di step aktif (reschedule count, PIC, jam)
   5. Refresh otomatis jika status atau data berubah
════════════════════════════════════════════════════════════════════════════ *@
@model DetailLacakViewModel
@{
    ViewData["Title"] = "Status " + Model.Permohonan.NoPermohonan;
    var p  = Model.Permohonan;
    var pr = Model.Pribadi;
    var dokDataHasil = p.Dokumen.FirstOrDefault(d => d.JenisDokumenPPIDID == JenisDokumenId.DataHasil);

    bool bisaKuesioner = p.StatusPPIDID == StatusId.DataSiap
                      || p.StatusPPIDID == StatusId.FeedbackPemohon
                      || p.StatusPPIDID == StatusId.WawancaraSelesai;

    string statusBg = p.StatusPPIDID == StatusId.Selesai  ? "bg-emerald-50 text-emerald-700 border-emerald-200" :
                      p.StatusPPIDID == StatusId.DataSiap  ? "bg-blue-50 text-blue-700 border-blue-200" :
                      p.StatusPPIDID == StatusId.Baru       ? "bg-gray-100 text-gray-500 border-gray-200" :
                                                               "bg-amber-50 text-amber-700 border-amber-200";
    string statusDot = p.StatusPPIDID == StatusId.Selesai  ? "bg-emerald-500" :
                       p.StatusPPIDID == StatusId.DataSiap  ? "bg-blue-500" :
                       p.StatusPPIDID == StatusId.Baru       ? "bg-gray-400" : "bg-amber-500";

    // SubTask helpers
    var stData = Model.GetSubTask(JenisTask.PermintaanData);
    var stObs  = Model.GetSubTask(JenisTask.Observasi);
    var stWaw  = Model.GetSubTask(JenisTask.Wawancara);

    var jadData = Model.GetJadwalAktif(JenisTask.PermintaanData);
    var jadObs  = Model.GetJadwalAktif("Observasi");
    var jadWaw  = Model.GetJadwalAktif("Wawancara");

    bool isParallelActive = p.StatusPPIDID >= StatusId.Didisposisi
                         && p.StatusPPIDID < StatusId.DataSiap
                         && (p.IsPermintaanData || p.IsObservasi || p.IsWawancara);

    // Badge helper
    string BadgeReschedule(SubTaskPPID? st) =>
        st != null && st.RescheduleCount > 0
            ? $"Dijadwal Ulang {st.RescheduleCount}×"
            : string.Empty;
}

@* ══ BANNER: status update (ditampilkan JS saat polling menemukan perubahan) ══ *@
<div id="update-banner"
     class="hidden fixed top-0 left-0 right-0 z-50 bg-blue-600 text-white text-sm font-bold text-center py-3 shadow-lg cursor-pointer"
     onclick="window.location.reload()">
    🔄 Status permohonan telah diperbarui — klik di sini untuk memuat ulang halaman
</div>

<div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

    <a href="/"
       class="inline-flex items-center gap-1.5 text-gray-500 hover:text-gray-800 text-sm font-medium mb-6 transition-colors">
        ← Cek Nomor Lain
    </a>

    @* Header Card *@
    <div class="bg-white rounded-2xl border border-gray-200 p-5 mb-5 shadow-sm">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold mb-1">Nomor Permohonan</p>
                <h2 class="text-2xl font-extrabold font-mono text-gray-900 tracking-tight">@p.NoPermohonan</h2>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1.5">
                    <span class="text-gray-400 text-xs">📅 @p.TanggalPermohonan?.ToString("dd MMMM yyyy")</span>
                    <span class="text-gray-200 text-xs hidden sm:inline">·</span>
                    <span class="text-xs font-semibold @(p.KategoriPemohon == "Mahasiswa" ? "text-blue-600" : "text-emerald-600")">
                        @(p.KategoriPemohon == "Mahasiswa" ? "🎓 Mahasiswa/Pelajar" : "🏢 LSM / Umum")
                    </span>
                    @if (p.BatasWaktu.HasValue && p.StatusPPIDID < StatusId.DataSiap) {
                        <span class="text-gray-200 text-xs hidden sm:inline">·</span>
                        <span class="text-xs @(p.IsOverdue ? "text-red-500 font-semibold" : p.HariSisa <= 3 ? "text-amber-500" : "text-gray-400")">
                            @(p.IsOverdue ? $"⚠ Lewat {Math.Abs(p.HariSisa??0)} hari" : $"Sisa {p.HariSisa} hari")
                        </span>
                    }
                </div>
            </div>
            <div class="flex flex-col items-start sm:items-end gap-2">
                <div class="flex items-center gap-2 border @statusBg rounded-full px-4 py-2">
                    <span class="w-2 h-2 rounded-full @statusDot flex-shrink-0"></span>
                    <span class="text-sm font-semibold">@(p.Status?.NamaStatusPPID ?? "—")</span>
                </div>
                @* Indikator realtime *@
                <div class="flex items-center gap-1.5 text-[10px] text-gray-400" id="refresh-indicator">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
                    <span>Pembaruan otomatis aktif</span>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">

        @* ══ TIMELINE (kiri, 3/5) ══ *@
        <div class="lg:col-span-3 bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6">Alur Proses</p>

            <ol class="space-y-0">
                @foreach (var step in Model.Riwayat)
                {
                    bool isLast = step == Model.Riwayat.Last();
                    string lineColor = step.Selesai ? "bg-emerald-200" : "bg-gray-100";
                    bool isParallelStep = step.StatusId == StatusId.Didisposisi
                                      || step.StatusId == StatusId.DiProses;

                    <li class="flex gap-4 pb-0 relative">
                        @if (!isLast)
                        {
                            <div class="absolute left-4 top-9 w-0.5 @lineColor" style="height:calc(100% - 36px + 8px)"></div>
                        }

                        @* Circle *@
                        <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold z-10 mt-1
                            @(step.Selesai ? "bg-emerald-500 text-white" :
                              step.AktifSekarang ? "bg-[#1B3B6F] text-white ring-4 ring-[#1B3B6F]/15" :
                                                   "bg-gray-100 text-gray-400")">
                            @(step.Selesai ? "✓" : step.AktifSekarang ? "●" : "○")
                        </div>

                        @* Card *@
                        <div class="flex-1 mb-3">
                            <div class="rounded-xl px-4 py-3 border
                                @(step.AktifSekarang ? "bg-blue-50 border-blue-100" :
                                  step.Selesai       ? "bg-emerald-50 border-emerald-100" :
                                                       "bg-gray-50 border-gray-100")">
                                <p class="font-semibold text-sm
                                    @(step.AktifSekarang ? "text-blue-800" :
                                      step.Selesai       ? "text-emerald-700" : "text-gray-400")">
                                    @step.Label
                                </p>

                                @* Sub-label opsional (jenis keperluan, dll) *@
                                @if (!string.IsNullOrEmpty(step.SubLabel) && !step.AktifSekarang && !step.Selesai)
                                {
                                    <p class="text-[11px] text-gray-400 mt-0.5">@step.SubLabel</p>
                                }

                                @* ═══ PARALLEL STEP — info per-subtask ═══ *@
                                @if (step.AktifSekarang && isParallelActive)
                                {
                                    <div class="mt-3 space-y-2">
                                        @if (p.IsPermintaanData)
                                        {
                                            bool done = stData?.IsSelesai ?? false;
                                            bool canc = stData?.IsDibatalkan ?? false;
                                            <div class="bg-white border @(done ? "border-emerald-200" : canc ? "border-red-100" : "border-blue-100") rounded-lg px-3 py-2">
                                                <div class="flex items-center justify-between gap-2">
                                                    <div class="flex items-center gap-2">
                                                        <span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] flex-shrink-0
                                                            @(done ? "bg-emerald-100 text-emerald-600" : canc ? "bg-red-100 text-red-500" : "bg-blue-100 text-blue-600")">
                                                            @(done ? "✓" : canc ? "✗" : "◑")
                                                        </span>
                                                        <span class="text-xs font-semibold @(done ? "text-emerald-700" : canc ? "text-red-500" : "text-blue-700")">
                                                            📊 Permintaan Data
                                                        </span>
                                                    </div>
                                                    <div class="flex items-center gap-1">
                                                        @if (done)
                                                        { <span class="text-[10px] bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded font-bold">Selesai</span> }
                                                        else if (canc)
                                                        { <span class="text-[10px] bg-red-50 text-red-500 px-1.5 py-0.5 rounded font-bold">Dibatalkan</span> }
                                                        else
                                                        { <span class="text-[10px] bg-blue-50 text-blue-600 px-1.5 py-0.5 rounded font-bold">Diproses</span> }
                                                    </div>
                                                </div>
                                            </div>
                                        }

                                        @if (p.IsObservasi)
                                        {
                                            bool done  = stObs?.IsSelesai ?? false;
                                            bool canc  = stObs?.IsDibatalkan ?? false;
                                            bool sched = stObs?.IsInProgress ?? false;
                                            bool isNew = Model.IsJadwalBaru("Observasi");
                                            string rescBadge = BadgeReschedule(stObs);

                                            <div class="bg-white border @(done ? "border-emerald-200" : canc ? "border-red-100" : sched ? "border-orange-200" : "border-gray-100") rounded-lg px-3 py-2">
                                                <div class="flex items-start justify-between gap-2">
                                                    <div class="flex items-center gap-2">
                                                        <span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] flex-shrink-0
                                                            @(done ? "bg-emerald-100 text-emerald-600" : canc ? "bg-red-100 text-red-500" : sched ? "bg-orange-100 text-orange-600" : "bg-gray-100 text-gray-400")">
                                                            @(done ? "✓" : canc ? "✗" : sched ? "⏳" : "○")
                                                        </span>
                                                        <span class="text-xs font-semibold @(done ? "text-emerald-700" : canc ? "text-red-500" : sched ? "text-orange-700" : "text-gray-400")">
                                                            🔍 Observasi
                                                        </span>
                                                    </div>
                                                    <div class="flex flex-wrap items-center gap-1 justify-end">
                                                        @if (isNew && sched)
                                                        { <span class="text-[10px] bg-green-100 text-green-700 px-1.5 py-0.5 rounded font-bold animate-pulse">BARU</span> }
                                                        @if (!string.IsNullOrEmpty(rescBadge))
                                                        { <span class="text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-1.5 py-0.5 rounded font-semibold">🔄 @rescBadge</span> }
                                                        @if (done)
                                                        { <span class="text-[10px] bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded font-bold">Selesai</span> }
                                                        else if (canc)
                                                        { <span class="text-[10px] bg-red-50 text-red-500 px-1.5 py-0.5 rounded font-bold">Dibatalkan</span> }
                                                    </div>
                                                </div>
                                                @if (jadObs != null && !canc)
                                                {
                                                    <div class="mt-1.5 pl-7 space-y-0.5">
                                                        <p class="text-[11px] text-orange-700 font-medium">
                                                            📅 @jadObs.Tanggal?.ToString("dddd, dd MMM yyyy") pukul @jadObs.Waktu?.ToString("HH:mm") WIB
                                                        </p>
                                                        @if (!string.IsNullOrEmpty(jadObs.NamaPIC))
                                                        {
                                                            <p class="text-[11px] text-gray-500">PIC: <strong>@jadObs.NamaPIC</strong>
                                                            @if (!string.IsNullOrEmpty(jadObs.TeleponPIC)) {
                                                                <a href="tel:@jadObs.TeleponPIC" class="ml-1 text-blue-500 hover:underline">📱 @jadObs.TeleponPIC</a>
                                                            }
                                                            </p>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }

                                        @if (p.IsWawancara)
                                        {
                                            bool done  = stWaw?.IsSelesai ?? false;
                                            bool canc  = stWaw?.IsDibatalkan ?? false;
                                            bool sched = stWaw?.IsInProgress ?? false;
                                            bool isNew = Model.IsJadwalBaru("Wawancara");
                                            string rescBadge = BadgeReschedule(stWaw);

                                            <div class="bg-white border @(done ? "border-emerald-200" : canc ? "border-red-100" : sched ? "border-violet-200" : "border-gray-100") rounded-lg px-3 py-2">
                                                <div class="flex items-start justify-between gap-2">
                                                    <div class="flex items-center gap-2">
                                                        <span class="w-5 h-5 rounded-full flex items-center justify-center text-[10px] flex-shrink-0
                                                            @(done ? "bg-emerald-100 text-emerald-600" : canc ? "bg-red-100 text-red-500" : sched ? "bg-violet-100 text-violet-600" : "bg-gray-100 text-gray-400")">
                                                            @(done ? "✓" : canc ? "✗" : sched ? "⏳" : "○")
                                                        </span>
                                                        <span class="text-xs font-semibold @(done ? "text-emerald-700" : canc ? "text-red-500" : sched ? "text-violet-700" : "text-gray-400")">
                                                            🎤 Wawancara
                                                        </span>
                                                    </div>
                                                    <div class="flex flex-wrap items-center gap-1 justify-end">
                                                        @if (isNew && sched)
                                                        { <span class="text-[10px] bg-green-100 text-green-700 px-1.5 py-0.5 rounded font-bold animate-pulse">BARU</span> }
                                                        @if (!string.IsNullOrEmpty(rescBadge))
                                                        { <span class="text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-1.5 py-0.5 rounded font-semibold">🔄 @rescBadge</span> }
                                                        @if (done)
                                                        { <span class="text-[10px] bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded font-bold">Selesai</span> }
                                                        else if (canc)
                                                        { <span class="text-[10px] bg-red-50 text-red-500 px-1.5 py-0.5 rounded font-bold">Dibatalkan</span> }
                                                    </div>
                                                </div>
                                                @if (jadWaw != null && !canc)
                                                {
                                                    <div class="mt-1.5 pl-7 space-y-0.5">
                                                        <p class="text-[11px] text-violet-700 font-medium">
                                                            📅 @jadWaw.Tanggal?.ToString("dddd, dd MMM yyyy") pukul @jadWaw.Waktu?.ToString("HH:mm") WIB
                                                        </p>
                                                        @if (!string.IsNullOrEmpty(jadWaw.NamaPIC))
                                                        {
                                                            <p class="text-[11px] text-gray-500">Narasumber: <strong>@jadWaw.NamaPIC</strong>
                                                            @if (!string.IsNullOrEmpty(jadWaw.TeleponPIC)) {
                                                                <a href="tel:@jadWaw.TeleponPIC" class="ml-1 text-blue-500 hover:underline">📱 @jadWaw.TeleponPIC</a>
                                                            }
                                                            </p>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <p class="text-blue-500 text-[11px] mt-2 font-medium">⏳ Sedang diproses secara paralel</p>
                                }

                                @* Step wawancara-only scheduled *@
                                @if (step.AktifSekarang && p.IsWawancara && !p.IsPermintaanData && !p.IsObservasi
                                     && p.StatusPPIDID == StatusId.WawancaraDijadwalkan)
                                {
                                    bool isNew = Model.IsJadwalBaru("Wawancara");
                                    string rescBadge = BadgeReschedule(stWaw);
                                    <div class="mt-2 space-y-1">
                                        @if (isNew)
                                        { <span class="inline-block text-[10px] bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-bold animate-pulse mb-1">✨ JADWAL BARU</span> }
                                        @if (!string.IsNullOrEmpty(rescBadge))
                                        { <span class="inline-block text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-2 py-0.5 rounded-full font-semibold mb-1">🔄 @rescBadge</span> }
                                        @if (jadWaw != null)
                                        {
                                            <p class="text-xs text-violet-700 font-medium">📅 @jadWaw.Tanggal?.ToString("dddd, dd MMM yyyy") pukul @jadWaw.Waktu?.ToString("HH:mm") WIB</p>
                                            @if (!string.IsNullOrEmpty(jadWaw.NamaPIC))
                                            {
                                                <p class="text-xs text-gray-500">Narasumber: <strong>@jadWaw.NamaPIC</strong>
                                                @if (!string.IsNullOrEmpty(jadWaw.TeleponPIC)) {
                                                    <a href="tel:@jadWaw.TeleponPIC" class="ml-1 text-blue-500">📱 @jadWaw.TeleponPIC</a>
                                                }
                                                </p>
                                            }
                                        }
                                    </div>
                                }

                                @* Step aktif lainnya — kecuali Selesai *@
                                @if (step.AktifSekarang && !isParallelActive && step.StatusId != StatusId.Selesai
                                     && !(p.IsWawancara && !p.IsPermintaanData && !p.IsObservasi
                                          && p.StatusPPIDID == StatusId.WawancaraDijadwalkan))
                                {
                                    <p class="text-blue-500 text-xs mt-1 font-medium">⏳ Sedang dalam proses</p>
                                }

                                @* Step Selesai aktif: tampilkan info selesai *@
                                @if (step.AktifSekarang && step.StatusId == StatusId.Selesai)
                                {
                                    <p class="text-emerald-600 text-xs mt-1 font-semibold">
                                        🏁 Permohonan telah selesai@(p.TanggalSelesai.HasValue ? $" — {p.TanggalSelesai.Value:dd MMM yyyy}" : "")
                                    </p>
                                }
                            </div>
                        </div>
                    </li>
                }
            </ol>
        </div>

        @* ══ INFO PANELS (kanan, 2/5) ══ *@
        <div class="lg:col-span-2 space-y-4">

            @* Detail Permohonan *@
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Detail Permohonan</p>
                <dl class="space-y-3.5">
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Pemohon</dt>
                        <dd class="font-semibold text-gray-800 text-sm">@pr?.Nama</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.PribadiPPID?.Lembaga)) {
                        <div>
                            <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Lembaga</dt>
                            <dd class="text-gray-700 text-sm">@Model.PribadiPPID.Lembaga</dd>
                        </div>
                    }
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Judul Penelitian</dt>
                        <dd class="text-gray-700 text-sm leading-snug">@p.JudulPenelitian</dd>
                    </div>
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-1.5">Keperluan</dt>
                        <dd class="flex flex-wrap gap-1.5">
                            @if (p.IsObservasi)      { <span class="bg-orange-50 border border-orange-200 text-orange-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Observasi</span> }
                            @if (p.IsPermintaanData) { <span class="bg-blue-50 border border-blue-200 text-blue-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Permintaan Data</span> }
                            @if (p.IsWawancara)      { <span class="bg-violet-50 border border-violet-200 text-violet-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Wawancara</span> }
                        </dd>
                    </div>
                    @if (!string.IsNullOrEmpty(p.Pengampu)) {
                        <div>
                            <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Pengampu</dt>
                            <dd class="text-gray-700 text-sm">@p.Pengampu
                                @if (!string.IsNullOrEmpty(p.TeleponPengampu)) {
                                    <a href="tel:@p.TeleponPengampu" class="ml-2 text-blue-500 text-xs hover:underline">📱 @p.TeleponPengampu</a>
                                }
                            </dd>
                        </div>
                    }
                </dl>
            </div>

            @* Jadwal aktif (jika ada, ditampilkan per jenis) *@
            @foreach (var jenis in new[] { "Observasi", "Wawancara" })
            {
                var jadwal = Model.GetJadwalAktif(jenis);
                if (jadwal is null) continue;

                bool isWaw     = jenis == "Wawancara";
                bool isNewJad  = Model.IsJadwalBaru(jenis);
                var  stTask    = jenis == "Wawancara" ? stWaw : stObs;
                int  rescCount = stTask?.RescheduleCount ?? 0;

                string cardBd  = isWaw ? "border-violet-200" : "border-orange-200";
                string iconBg  = isWaw ? "bg-violet-50 border-violet-200" : "bg-orange-50 border-orange-200";
                string icon    = isWaw ? "🎤" : "🗓";
                string itemBg  = isWaw ? "bg-violet-50 border-violet-100" : "bg-orange-50 border-orange-100";
                string titleC  = isWaw ? "text-violet-800" : "text-orange-800";
                string timeC   = isWaw ? "text-violet-600" : "text-orange-600";
                string picC    = isWaw ? "text-violet-500" : "text-orange-500";
                string noteC   = isWaw ? "text-violet-400" : "text-orange-400";
                string picLabel = isWaw ? "Narasumber" : "PIC";

                <div class="bg-white rounded-2xl border @cardBd shadow-sm p-5">
                    <div class="flex items-center justify-between gap-2 mb-3">
                        <div class="flex items-center gap-2">
                            <div class="w-7 h-7 @iconBg rounded-lg flex items-center justify-center text-sm border">@icon</div>
                            <p class="font-bold text-gray-800 text-sm">Jadwal @jenis</p>
                        </div>
                        <div class="flex gap-1 flex-wrap justify-end">
                            @if (isNewJad)
                            {
                                <span class="text-[10px] bg-green-100 text-green-700 border border-green-200 px-1.5 py-0.5 rounded-full font-bold animate-pulse">✨ BARU</span>
                            }
                            @if (rescCount > 0)
                            {
                                <span class="text-[10px] bg-amber-50 text-amber-700 border border-amber-200 px-1.5 py-0.5 rounded-full font-semibold">🔄 Diubah @rescCount×</span>
                            }
                        </div>
                    </div>
                    <div class="@itemBg rounded-xl px-3 py-2.5 border">
                        <p class="text-sm font-bold @titleC">@jadwal.Tanggal?.ToString("dddd, dd MMM yyyy")</p>
                        <p class="text-xs @timeC font-medium">Pukul @jadwal.Waktu?.ToString("HH:mm") WIB</p>
                        @if (!string.IsNullOrEmpty(jadwal.NamaPIC))
                        {
                            <p class="text-xs @picC mt-0.5">@picLabel: <strong>@jadwal.NamaPIC</strong></p>
                            @if (!string.IsNullOrEmpty(jadwal.TeleponPIC))
                            {
                                <a href="tel:@jadwal.TeleponPIC"
                                   class="mt-1 inline-flex items-center gap-1 text-[11px] @picC hover:underline">
                                    📱 @jadwal.TeleponPIC
                                </a>
                            }
                        }
                    </div>
                    @if (rescCount > 0)
                    {
                        <p class="text-[10px] text-amber-600 mt-1.5">
                            ℹ️ Jadwal ini sudah diubah @rescCount× — gunakan jadwal terbaru di atas.
                        </p>
                    }
                    else
                    {
                        <p class="text-[11px] @noteC mt-2">⚠️ Hadir tepat waktu sesuai jadwal.</p>
                    }
                </div>
            }

            @* Data Tersedia *@
            @if (p.StatusPPIDID == StatusId.DataSiap || p.StatusPPIDID == StatusId.Selesai
                 || p.StatusPPIDID == StatusId.FeedbackPemohon)
            {
                <div class="bg-white rounded-2xl border border-emerald-200 shadow-sm p-5">
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-7 h-7 bg-emerald-50 border border-emerald-200 rounded-lg flex items-center justify-center text-sm">✅</div>
                        <p class="font-bold text-gray-800 text-sm">Data Siap Diunduh</p>
                    </div>
                    @if (dokDataHasil != null) {
                        <a href="@dokDataHasil.UploadDokumenPPID"
                           class="flex items-center justify-center gap-2 w-full bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-bold py-2.5 rounded-xl transition-colors">
                            ⬇ Unduh Data
                        </a>
                    }
                    @if (bisaKuesioner && p.StatusPPIDID != StatusId.Selesai) {
                        <a asp-action="Kuesioner" asp-route-id="@p.PermohonanPPIDID"
                           class="flex items-center justify-center gap-2 w-full mt-2.5 bg-white text-emerald-700 border border-emerald-200 text-sm font-semibold py-2 rounded-xl hover:bg-emerald-50 transition-colors">
                            📝 Isi Kuesioner Kepuasan
                        </a>
                    }
                </div>
            }

            @* Wawancara selesai tanpa file *@
            @if (p.StatusPPIDID == StatusId.WawancaraSelesai && dokDataHasil == null)
            {
                <div class="bg-white rounded-2xl border border-violet-200 shadow-sm p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-7 h-7 bg-violet-50 border border-violet-200 rounded-lg flex items-center justify-center text-sm">🎤</div>
                        <p class="font-bold text-gray-800 text-sm">Wawancara Selesai</p>
                    </div>
                    <p class="text-violet-600 text-xs mb-3">Wawancara telah dilaksanakan. Silakan isi kuesioner kepuasan layanan.</p>
                    @if (bisaKuesioner) {
                        <a asp-action="Kuesioner" asp-route-id="@p.PermohonanPPIDID"
                           class="flex items-center justify-center gap-2 w-full bg-violet-600 hover:bg-violet-700 text-white text-sm font-bold py-2.5 rounded-xl transition-colors">
                            📝 Isi Kuesioner Kepuasan
                        </a>
                    }
                </div>
            }

            @* Upload Laporan / Tugas Final *@
            @{
                var dokTugas   = p.Dokumen.Where(d => d.JenisDokumenPPIDID == JenisDokumenId.TugasFinal)
                                          .OrderByDescending(d => d.CreatedAt).ToList();
                bool canUpload = p.StatusPPIDID >= StatusId.DataSiap;
            }
            @if (canUpload)
            {
                <div class="bg-white rounded-2xl border border-indigo-200 shadow-sm p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-7 h-7 bg-indigo-50 border border-indigo-200 rounded-lg flex items-center justify-center text-sm">📤</div>
                        <p class="font-bold text-gray-800 text-sm">Laporan / Tugas Final</p>
                    </div>

                    @if (dokTugas.Any())
                    {
                        <div class="space-y-1.5 mb-3">
                            @foreach (var f in dokTugas)
                            {
                                <div class="flex items-center gap-2 bg-indigo-50 border border-indigo-100 rounded-lg px-3 py-2">
                                    <span class="text-indigo-500 text-sm flex-shrink-0">📎</span>
                                    <p class="text-xs text-indigo-700 flex-1 truncate font-medium">
                                        @f.NamaDokumenPPID
                                    </p>
                                    <a href="@f.UploadDokumenPPID" target="_blank"
                                       class="text-[10px] text-indigo-500 hover:underline flex-shrink-0">Lihat</a>
                                </div>
                            }
                        </div>
                        <p class="text-[10px] text-gray-400 mb-3">Sudah diunggah @dokTugas.Count berkas. Klik tombol di bawah untuk revisi.</p>
                    }
                    else
                    {
                        <p class="text-indigo-600 text-xs mb-3 leading-relaxed">
                            Data sudah tersedia. Setelah penelitian selesai, unggah laporan / tugas akhir Anda di sini.
                        </p>
                    }

                    <a asp-action="UploadTugas" asp-controller="Home" asp-route-id="@p.PermohonanPPIDID"
                       class="flex items-center justify-center gap-2 w-full bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold py-2.5 rounded-xl transition-colors">
                        📤 @(dokTugas.Any() ? "Unggah Revisi Laporan" : "Unggah Laporan")
                    </a>
                </div>
            }

            @* Info Umum *@
            <div class="bg-gray-50 border border-gray-200 rounded-2xl p-4">
                <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Butuh Bantuan?</p>
                <p class="text-xs text-gray-500 leading-relaxed mb-2">
                    Hubungi loket PPID DLH di <strong>(021) 8591-2230</strong> pada jam kerja (Senin–Jumat, 08.00–16.00 WIB).
                </p>
                <p class="text-[11px] text-gray-400">Simpan nomor <span class="font-mono font-bold">@p.NoPermohonan</span> untuk referensi.</p>
            </div>
        </div>
    </div>
</div>

@* ══ REALTIME POLLING SCRIPT ══ *@
<script>
(function () {
    'use strict';

    // Data awal dari server (ISO 8601 UTC)
    const noPermohonan   = @Json.Serialize(p.NoPermohonan);
    const initStatusId   = @(p.StatusPPIDID?.ToString() ?? "null");
    const initChangedAt  = @Json.Serialize(Model.LastChangedAt.ToString("O"));

    let lastChangedAt = initChangedAt;
    let pollTimer     = null;
    let failCount     = 0;
    const MAX_FAIL    = 5;   // stop polling after 5 consecutive failures
    const INTERVAL_MS = 30_000; // 30 seconds

    function showBanner(message) {
        const banner = document.getElementById('update-banner');
        if (banner) {
            if (message) banner.textContent = message;
            banner.classList.remove('hidden');
            // Shift page content down
            document.body.style.paddingTop = banner.offsetHeight + 'px';
        }
    }

    function setIndicator(active, text) {
        const el = document.getElementById('refresh-indicator');
        if (!el) return;
        const dot = el.querySelector('span:first-child');
        const lbl = el.querySelector('span:last-child');
        if (dot) dot.className = active
            ? 'w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse'
            : 'w-1.5 h-1.5 rounded-full bg-gray-300';
        if (lbl) lbl.textContent = text;
    }

    async function poll() {
        try {
            const resp = await fetch(
                '/cek-status?no=' + encodeURIComponent(noPermohonan),
                { cache: 'no-store' }
            );
            if (!resp.ok) throw new Error('HTTP ' + resp.status);

            const data = await resp.json();
            if (!data) return;

            failCount = 0; // reset failure count on success

            const statusChanged  = data.statusId !== initStatusId;
            const dataChanged    = data.lastChangedAt !== lastChangedAt;

            if (statusChanged) {
                showBanner('🔔 Status permohonan telah diperbarui — klik untuk memuat ulang');
                clearInterval(pollTimer); // stop further polling, user should reload
                setIndicator(false, 'Status berubah — klik banner untuk refresh');
                return;
            }

            if (dataChanged && data.lastChangedAt > lastChangedAt) {
                lastChangedAt = data.lastChangedAt;
                showBanner('📋 Informasi jadwal / PIC telah diperbarui — klik untuk melihat');
                setIndicator(true, 'Ada pembaruan — klik banner');
                return;
            }

            // no change
            setIndicator(true, 'Pembaruan otomatis aktif');

        } catch (err) {
            failCount++;
            if (failCount >= MAX_FAIL) {
                clearInterval(pollTimer);
                setIndicator(false, 'Koneksi terputus — muat ulang halaman');
            } else {
                setIndicator(false, `Coba lagi... (${failCount}/${MAX_FAIL})`);
            }
        }
    }

    // Jangan poll jika permohonan sudah selesai — tidak akan berubah lagi
    const isFinished = initStatusId === @StatusId.Selesai;
    if (!isFinished) {
        // Tunda polling pertama 5 detik setelah halaman dimuat
        setTimeout(() => {
            poll();
            pollTimer = setInterval(poll, INTERVAL_MS);
        }, 5_000);
    } else {
        setIndicator(false, 'Permohonan selesai');
    }

    // Pause polling saat tab tidak aktif, resume saat aktif kembali
    document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
            clearInterval(pollTimer);
        } else if (!isFinished) {
            poll();
            pollTimer = setInterval(poll, INTERVAL_MS);
        }
    });
})();
</script>
