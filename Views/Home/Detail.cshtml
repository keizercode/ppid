@* ════════════════════════════════════════════════════════════════════════════
   Views/Home/Detail.cshtml — FULL REPLACEMENT
   UPDATE:
   1. Timeline 9-step sesuai alur baru (termasuk parallel display)
   2. Jadwal: tampilkan TeleponPIC (sebagai sarana kontak pemohon)
   ════════════════════════════════════════════════════════════════════════════ *@
@model DetailLacakViewModel
@{
    ViewData["Title"] = "Status " + Model.Permohonan.NoPermohonan;
    var p  = Model.Permohonan;
    var pr = Model.Pribadi;
    var dokDataHasil = p.Dokumen.FirstOrDefault(d => d.JenisDokumenPPIDID == JenisDokumenId.DataHasil);

    bool bisaKuesioner = p.StatusPPIDID == StatusId.DataSiap
                      || p.StatusPPIDID == StatusId.WawancaraSelesai;

    string statusBg = p.StatusPPIDID == StatusId.Selesai  ? "bg-emerald-50 text-emerald-700 border-emerald-200" :
                      p.StatusPPIDID == StatusId.DataSiap  ? "bg-blue-50 text-blue-700 border-blue-200" :
                      p.StatusPPIDID == StatusId.Baru       ? "bg-gray-100 text-gray-500 border-gray-200" :
                                                               "bg-amber-50 text-amber-700 border-amber-200";
    string statusDot = p.StatusPPIDID == StatusId.Selesai  ? "bg-emerald-500" :
                       p.StatusPPIDID == StatusId.DataSiap  ? "bg-blue-500" :
                       p.StatusPPIDID == StatusId.Baru       ? "bg-gray-400" : "bg-amber-500";
}

<div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

    <a href="/"
       class="inline-flex items-center gap-1.5 text-gray-500 hover:text-gray-800 text-sm font-medium mb-6 transition-colors">
        ← Cek Nomor Lain
    </a>

    @* Header Card *@
    <div class="bg-white rounded-2xl border border-gray-200 p-5 mb-5 shadow-sm">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold mb-1">Nomor Permohonan</p>
                <h2 class="text-2xl font-extrabold font-mono text-gray-900 tracking-tight">@p.NoPermohonan</h2>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1.5">
                    <span class="text-gray-400 text-xs">📅 @p.TanggalPermohonan?.ToString("dd MMMM yyyy")</span>
                    <span class="text-gray-200 text-xs hidden sm:inline">·</span>
                    <span class="text-xs font-semibold @(p.KategoriPemohon == "Mahasiswa" ? "text-blue-600" : "text-emerald-600")">
                        @(p.KategoriPemohon == "Mahasiswa" ? "🎓 Mahasiswa/Pelajar" : "🏢 LSM / Umum")
                    </span>
                    @if (p.BatasWaktu.HasValue && p.StatusPPIDID < StatusId.DataSiap) {
                        <span class="text-gray-200 text-xs hidden sm:inline">·</span>
                        <span class="text-xs @(p.IsOverdue ? "text-red-500 font-semibold" : p.HariSisa <= 3 ? "text-amber-500" : "text-gray-400")">
                            @(p.IsOverdue ? $"⚠ Lewat {Math.Abs(p.HariSisa??0)} hari" : $"Sisa {p.HariSisa} hari")
                        </span>
                    }
                </div>
            </div>
            <div class="flex items-center gap-2 border @statusBg rounded-full px-4 py-2 self-start sm:self-center">
                <span class="w-2 h-2 rounded-full @statusDot flex-shrink-0"></span>
                <span class="text-sm font-semibold">@(p.Status?.NamaStatusPPID ?? "—")</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">

        @* ══ TIMELINE (kiri, 3/5) ══ *@
        <div class="lg:col-span-3 bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6">Alur Proses</p>

            @{
                var current    = p.StatusPPIDID ?? StatusId.TerdaftarSistem;
                bool isWawOnly = p.IsWawancara && !p.IsPermintaanData && !p.IsObservasi;

                // Build steps (sama dengan Model.Riwayat tapi dengan parallel info)
                var riwayat = Model.Riwayat;
            }

            <ol class="space-y-0">
                @foreach (var step in riwayat)
                {
                    bool isLast = step == riwayat.Last();
                    string lineColor = step.Selesai ? "bg-emerald-200" : "bg-gray-100";

                    <li class="flex gap-4 pb-0 relative">
                        @if (!isLast)
                        {
                            <div class="absolute left-4 top-9 w-0.5 @lineColor" style="height:calc(100% - 36px + 8px)"></div>
                        }

                        @* Circle *@
                        <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold z-10 mt-1
                            @(step.Selesai ? "bg-emerald-500 text-white" :
                              step.AktifSekarang ? "bg-[#1B3B6F] text-white ring-4 ring-[#1B3B6F]/15" :
                                                   "bg-gray-100 text-gray-400")">
                            @(step.Selesai ? "✓" : step.AktifSekarang ? "●" : "○")
                        </div>

                        @* Card *@
                        <div class="flex-1 mb-3">
                            <div class="rounded-xl px-4 py-3 border
                                @(step.AktifSekarang ? "bg-blue-50 border-blue-100" :
                                  step.Selesai       ? "bg-emerald-50 border-emerald-100" :
                                                       "bg-gray-50 border-gray-100")">
                                <p class="font-semibold text-sm
                                    @(step.AktifSekarang ? "text-blue-800" :
                                      step.Selesai       ? "text-emerald-700" : "text-gray-400")">
                                    @step.Label
                                </p>

                                @* Step 6: Parallel info untuk pemohon *@
                                @if (step.AktifSekarang && (p.StatusPPIDID >= StatusId.Didisposisi && p.StatusPPIDID <= StatusId.WawancaraSelesai) && !isWawOnly)
                                {
                                    <div class="mt-2 space-y-1.5">
                                        @if (p.IsPermintaanData)
                                        {
                                            bool dataSelesai = p.StatusPPIDID == StatusId.DataSiap || p.Dokumen.Any(d => d.JenisDokumenPPIDID == JenisDokumenId.DataHasil);
                                            <div class="flex items-center gap-2 text-xs">
                                                <span class="w-4 h-4 rounded-full flex items-center justify-center text-[10px] flex-shrink-0 @(dataSelesai ? "bg-emerald-100 text-emerald-600" : "bg-gray-100 text-gray-400")">
                                                    @(dataSelesai ? "✓" : "○")
                                                </span>
                                                <span class="@(dataSelesai ? "text-emerald-600" : "text-gray-400")">📊 Permintaan Data</span>
                                            </div>
                                        }
                                        @if (p.IsObservasi)
                                        {
                                            bool obsSelesai = p.StatusPPIDID >= StatusId.ObservasiSelesai;
                                            bool obsDijadwal = p.StatusPPIDID >= StatusId.ObservasiDijadwalkan;
                                            <div class="flex items-center gap-2 text-xs">
                                                <span class="w-4 h-4 rounded-full flex items-center justify-center text-[10px] flex-shrink-0 @(obsSelesai ? "bg-emerald-100 text-emerald-600" : obsDijadwal ? "bg-amber-100 text-amber-600" : "bg-gray-100 text-gray-400")">
                                                    @(obsSelesai ? "✓" : obsDijadwal ? "⏳" : "○")
                                                </span>
                                                <span class="@(obsSelesai ? "text-emerald-600" : obsDijadwal ? "text-amber-600" : "text-gray-400")">
                                                    🔍 Observasi @(obsDijadwal && !obsSelesai ? "— Dijadwalkan" : "")
                                                </span>
                                            </div>
                                        }
                                        @if (p.IsWawancara)
                                        {
                                            bool wawSelesai = p.StatusPPIDID >= StatusId.WawancaraSelesai;
                                            bool wawDijadwal = p.StatusPPIDID >= StatusId.WawancaraDijadwalkan;
                                            <div class="flex items-center gap-2 text-xs">
                                                <span class="w-4 h-4 rounded-full flex items-center justify-center text-[10px] flex-shrink-0 @(wawSelesai ? "bg-emerald-100 text-emerald-600" : wawDijadwal ? "bg-violet-100 text-violet-600" : "bg-gray-100 text-gray-400")">
                                                    @(wawSelesai ? "✓" : wawDijadwal ? "⏳" : "○")
                                                </span>
                                                <span class="@(wawSelesai ? "text-emerald-600" : wawDijadwal ? "text-violet-600" : "text-gray-400")">
                                                    🎤 Wawancara @(wawDijadwal && !wawSelesai ? "— Dijadwalkan" : "")
                                                </span>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (step.AktifSekarang && !(p.StatusPPIDID >= StatusId.Didisposisi && !isWawOnly))
                                {
                                    <p class="text-blue-500 text-xs mt-1 font-medium">⏳ Sedang dalam proses</p>
                                }
                            </div>
                        </div>
                    </li>
                }
            </ol>
        </div>

        @* ══ INFO PANELS (kanan, 2/5) ══ *@
        <div class="lg:col-span-2 space-y-4">

            <!-- Detail Permohonan -->
            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-5">
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Detail Permohonan</p>
                <dl class="space-y-3.5">
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Pemohon</dt>
                        <dd class="font-semibold text-gray-800 text-sm">@pr?.Nama</dd>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.PribadiPPID?.Lembaga)) {
                        <div>
                            <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Lembaga</dt>
                            <dd class="text-gray-700 text-sm">@Model.PribadiPPID.Lembaga</dd>
                        </div>
                    }
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Judul Penelitian</dt>
                        <dd class="text-gray-700 text-sm leading-snug">@p.JudulPenelitian</dd>
                    </div>
                    <div>
                        <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-1.5">Keperluan</dt>
                        <dd class="flex flex-wrap gap-1.5">
                            @if (p.IsObservasi)      { <span class="bg-orange-50 border border-orange-200 text-orange-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Observasi</span> }
                            @if (p.IsPermintaanData) { <span class="bg-blue-50 border border-blue-200 text-blue-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Permintaan Data</span> }
                            @if (p.IsWawancara)      { <span class="bg-violet-50 border border-violet-200 text-violet-700 text-xs px-2.5 py-0.5 rounded-full font-semibold">Wawancara</span> }
                        </dd>
                    </div>
                    @if (!string.IsNullOrEmpty(p.Pengampu)) {
                        <div>
                            <dt class="text-[10px] text-gray-400 uppercase tracking-wide font-bold mb-0.5">Pengampu</dt>
                            <dd class="text-gray-700 text-sm">@p.Pengampu</dd>
                        </div>
                    }
                </dl>
            </div>

            @* ── Jadwal (per jenis, dengan TeleponPIC) ── *@
            @if (Model.Jadwal.Any())
            {
                @foreach (var jenisGroup in Model.Jadwal.GroupBy(j => j.JenisJadwal))
                {
                    bool isWaw     = jenisGroup.Key == "Wawancara";
                    string cardBd  = isWaw ? "border-violet-200" : "border-orange-200";
                    string iconBg  = isWaw ? "bg-violet-50 border-violet-200" : "bg-orange-50 border-orange-200";
                    string icon    = isWaw ? "🎤" : "🗓";
                    string itemBg  = isWaw ? "bg-violet-50 border-violet-100" : "bg-orange-50 border-orange-100";
                    string titleC  = isWaw ? "text-violet-800" : "text-orange-800";
                    string timeC   = isWaw ? "text-violet-600" : "text-orange-600";
                    string picC    = isWaw ? "text-violet-500" : "text-orange-500";
                    string noteC   = isWaw ? "text-violet-400" : "text-orange-400";

                    <div class="bg-white rounded-2xl border @cardBd shadow-sm p-5">
                        <div class="flex items-center gap-2 mb-3">
                            <div class="w-7 h-7 @iconBg rounded-lg flex items-center justify-center text-sm border">@icon</div>
                            <p class="font-bold text-gray-800 text-sm">Jadwal @jenisGroup.Key</p>
                        </div>
                        @foreach (var j in jenisGroup.OrderByDescending(j => j.CreatedAt).Take(1))
                        {
                            <div class="@itemBg rounded-xl px-3 py-2.5 border">
                                <p class="text-sm font-bold @titleC">@j.Tanggal?.ToString("dddd, dd MMM yyyy")</p>
                                <p class="text-xs @timeC font-medium">Pukul @j.Waktu?.ToString("HH:mm") WIB</p>
                                @if (!string.IsNullOrEmpty(j.NamaPIC))
                                {
                                    <p class="text-xs @picC mt-0.5">
                                        @(isWaw ? "Narasumber" : "PIC"): <strong>@j.NamaPIC</strong>
                                    </p>
                                    @* TeleponPIC: tampilkan ke pemohon sebagai kontak konfirmasi *@
                                    @if (!string.IsNullOrEmpty(j.TeleponPIC))
                                    {
                                        <a href="tel:@j.TeleponPIC"
                                           class="mt-1 inline-flex items-center gap-1 text-[11px] @picC hover:underline">
                                            📱 @j.TeleponPIC
                                        </a>
                                    }
                                }
                            </div>
                        }
                        <p class="text-[11px] @noteC mt-2">⚠️ Hadir tepat waktu sesuai jadwal.</p>
                    </div>
                }
            }

            @* ── Data Tersedia ── *@
            @if (p.StatusPPIDID == StatusId.DataSiap || p.StatusPPIDID == StatusId.Selesai)
            {
                <div class="bg-white rounded-2xl border border-emerald-200 shadow-sm p-5">
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-7 h-7 bg-emerald-50 border border-emerald-200 rounded-lg flex items-center justify-center text-sm">✅</div>
                        <p class="font-bold text-gray-800 text-sm">Data Siap Diunduh</p>
                    </div>
                    @if (dokDataHasil != null) {
                        <a href="@dokDataHasil.UploadDokumenPPID"
                           class="flex items-center justify-center gap-2 w-full bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-bold py-2.5 rounded-xl transition-colors">
                            ⬇ Unduh Data
                        </a>
                    }
                    @if (bisaKuesioner) {
                        <a asp-action="Kuesioner" asp-route-id="@p.PermohonanPPIDID"
                           class="flex items-center justify-center gap-2 w-full mt-2.5 bg-white text-emerald-700 border border-emerald-200 text-sm font-semibold py-2 rounded-xl hover:bg-emerald-50 transition-colors">
                            📝 Isi Kuesioner Kepuasan
                        </a>
                    }
                </div>
            }

            @* ── Wawancara selesai tanpa file ── *@
            @if (p.StatusPPIDID == StatusId.WawancaraSelesai && dokDataHasil == null)
            {
                <div class="bg-white rounded-2xl border border-violet-200 shadow-sm p-5">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-7 h-7 bg-violet-50 border border-violet-200 rounded-lg flex items-center justify-center text-sm">🎤</div>
                        <p class="font-bold text-gray-800 text-sm">Wawancara Selesai</p>
                    </div>
                    <p class="text-violet-600 text-xs mb-3">Wawancara telah dilaksanakan. Silakan isi kuesioner kepuasan layanan.</p>
                    @if (bisaKuesioner) {
                        <a asp-action="Kuesioner" asp-route-id="@p.PermohonanPPIDID"
                           class="flex items-center justify-center gap-2 w-full bg-violet-600 hover:bg-violet-700 text-white text-sm font-bold py-2.5 rounded-xl transition-colors">
                            📝 Isi Kuesioner Kepuasan
                        </a>
                    }
                </div>
            }

            @* ── Info Umum ── *@
            <div class="bg-gray-50 border border-gray-200 rounded-2xl p-4">
                <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Butuh Bantuan?</p>
                <p class="text-xs text-gray-500 leading-relaxed mb-2">
                    Hubungi loket PPID DLH di <strong>(021) 8591-2230</strong> pada jam kerja (Senin–Jumat, 08.00–16.00 WIB).
                </p>
                <p class="text-[11px] text-gray-400">Simpan nomor <span class="font-mono font-bold">@p.NoPermohonan</span> untuk referensi.</p>
            </div>
        </div>
    </div>
</div>
