            stWaw.FilePath!,
            "bg-violet-600 hover:bg-violet-700"));

    if (!fileItems.Any() && dokDataHasil != null)
        fileItems.Add(("📄", "Data Hasil", dokDataHasil.UploadDokumenPPID!, "bg-emerald-600 hover:bg-emerald-700"));

    var tidakAdaFile = new List<string>();
    if (p.IsPermintaanData && stData?.IsSelesai == true && string.IsNullOrEmpty(stData.FilePath))
        tidakAdaFile.Add("📊 Permintaan Data");
    if (p.IsObservasi && stObs?.IsSelesai == true && string.IsNullOrEmpty(stObs.FilePath))
        tidakAdaFile.Add("🔍 Observasi");
    if (p.IsWawancara && stWaw?.IsSelesai == true && string.IsNullOrEmpty(stWaw.FilePath))
        tidakAdaFile.Add("🎤 Wawancara");

    bool tampilkanPanelData = fileItems.Any()
        && (p.StatusPPIDID == StatusId.DataSiap
            || p.StatusPPIDID == StatusId.FeedbackPemohon
            || p.StatusPPIDID == StatusId.Selesai);
