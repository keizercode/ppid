                        <span class="text-xs @(p.IsOverdue ? "text-red-500 font-semibold" : p.HariSisa <= 3 ? "text-amber-500" : "text-gray-400")">
                            @(p.IsOverdue ? $"⚠ Lewat {Math.Abs(p.HariSisa??0)} hari" : $"Sisa {p.HariSisa} hari")
                        </span>
                    }
