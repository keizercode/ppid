@* ════════════════════════════════════════════════════════════════════════════
   Views/Home/Detail.cshtml  — VERSI TERBARU
   Perubahan utama:
   1. Kuesioner Kepuasan Umum DIHAPUS — digantikan feedback per-task
   2. Tombol feedback per task muncul di step 6 (saat proses), step 7 (DataSiap),
      dan step 8 (FeedbackPemohon) sesuai kondisi
   3. Status Selesai otomatis saat semua feedback terisi (tidak perlu kuesioner umum)
   4. Overdue: hanya reminder, tidak auto-selesai
   5. Lokasi jadwal (online/offline + detail) ditampilkan lengkap
════════════════════════════════════════════════════════════════════════════ *@
@model DetailLacakViewModel
@{
    ViewData["Title"] = "Status " + Model.Permohonan.NoPermohonan;
    var p  = Model.Permohonan;
    var pr = Model.Pribadi;

    // Dokumen data hasil (untuk diunduh)
    var dokDataHasil = p.Dokumen
        .Where(d => d.JenisDokumenPPIDID == JenisDokumenId.DataHasil)
        .OrderByDescending(d => d.CreatedAt)
        .FirstOrDefault();

    // Badge status utama
    string statusBg = p.StatusPPIDID == StatusId.Selesai  ? "bg-emerald-50 text-emerald-700 border-emerald-200" :
                      p.StatusPPIDID == StatusId.DataSiap  ? "bg-blue-50 text-blue-700 border-blue-200" :
                      p.StatusPPIDID == StatusId.Baru       ? "bg-gray-100 text-gray-500 border-gray-200" :
                                                               "bg-amber-50 text-amber-700 border-amber-200";
    string statusDot = p.StatusPPIDID == StatusId.Selesai  ? "bg-emerald-500" :
                       p.StatusPPIDID == StatusId.DataSiap  ? "bg-blue-500" :
                       p.StatusPPIDID == StatusId.Baru       ? "bg-gray-400" : "bg-amber-500";

    // Sub-tasks per jenis
    var stData = Model.GetSubTask(JenisTask.PermintaanData);
    var stObs  = Model.GetSubTask(JenisTask.Observasi);
    var stWaw  = Model.GetSubTask(JenisTask.Wawancara);

    // Jadwal aktif
    var jadObs = Model.GetJadwalAktif("Observasi");
    var jadWaw = Model.GetJadwalAktif("Wawancara");

    // Kondisi paralel aktif (sedang diproses step 6)
    bool isParallelActive =
        (p.StatusPPIDID == StatusId.Didisposisi
         || p.StatusPPIDID == StatusId.DiProses
         || p.StatusPPIDID == StatusId.ObservasiDijadwalkan
         || p.StatusPPIDID == StatusId.ObservasiSelesai
         || p.StatusPPIDID == StatusId.WawancaraDijadwalkan
         || p.StatusPPIDID == StatusId.WawancaraSelesai)
        && (p.IsPermintaanData || p.IsObservasi || p.IsWawancara);




    // Feedback aktif otomatis sejak DataSiap — tidak perlu tunggu Loket klik "Minta Feedback".
// Loket tetap bisa mengubah status ke FeedbackPemohon untuk tracking, tapi bukan syarat.
bool bisaFeedback = p.StatusPPIDID == StatusId.DataSiap
                 || p.StatusPPIDID == StatusId.FeedbackPemohon;

    // Feedback yang sudah terisi
    var feedbackMap = ViewData["FeedbackMap"] as Dictionary<string, bool> ?? new();
    bool FeedbackDiisi(string jenis) => feedbackMap.ContainsKey(jenis) && feedbackMap[jenis];

    // Helper: reschedule badge
    string BadgeReschedule(SubTaskPPID? st) =>
        st != null && st.RescheduleCount > 0 ? $"Dijadwal Ulang {st.RescheduleCount}×" : string.Empty;

    // Helper: overdue task (sudah lewat jadwal tapi belum selesai — HANYA REMINDER)
    bool IsOverdueTask(SubTaskPPID? st) =>
        st != null && st.IsInProgress
        && st.TanggalJadwal.HasValue
        && st.TanggalJadwal.Value < DateOnly.FromDateTime(DateTime.Today)
        && !st.IsSelesai;

    // Hitung sisa feedback yang perlu diisi (untuk pesan di step 8)
    int totalFeedbackDibutuhkan = (p.IsPermintaanData && (stData?.IsSelesai ?? false) ? 1 : 0)
                                + (p.IsObservasi      && (stObs?.IsSelesai ?? false)  ? 1 : 0)
                                + (p.IsWawancara      && (stWaw?.IsSelesai ?? false)  ? 1 : 0);

    int totalFeedbackTerisi = (FeedbackDiisi(JenisTask.PermintaanData) && p.IsPermintaanData && (stData?.IsSelesai ?? false) ? 1 : 0)
                            + (FeedbackDiisi(JenisTask.Observasi)      && p.IsObservasi      && (stObs?.IsSelesai ?? false)  ? 1 : 0)
                            + (FeedbackDiisi(JenisTask.Wawancara)      && p.IsWawancara      && (stWaw?.IsSelesai ?? false)  ? 1 : 0);

    int sisaFeedback = totalFeedbackDibutuhkan - totalFeedbackTerisi;
}

<div id="update-banner"
     class="hidden fixed top-0 left-0 right-0 z-50 bg-blue-600 text-white text-sm font-bold text-center py-3 shadow-lg cursor-pointer"
     onclick="window.location.reload()">
