@model DetailLacakViewModel
@{
    ViewData["Title"] = "Status " + Model.Permohonan.NoPermohonan;
    var p  = Model.Permohonan;
    var pr = Model.Pribadi;
    var dokDataHasil = p.Dokumen.FirstOrDefault(d => d.JenisDokumenPPIDID == JenisDokumenId.DataHasil);
}

<div class="max-w-4xl mx-auto px-4 py-8">
    <a href="/" class="text-blue-600 hover:text-blue-800 text-sm">← Cek Nomor Lain</a>

    <!-- Header -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 my-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <p class="text-xs text-gray-400 uppercase tracking-widest">Nomor Permohonan</p>
            <h2 class="text-xl font-bold font-mono text-gray-800">@p.NoPermohonan</h2>
            <p class="text-sm text-gray-500 mt-0.5">
                Diajukan: @p.TanggalPermohonan?.ToString("dd MMMM yyyy") &nbsp;·&nbsp;
                <span class="@(p.KategoriPemohon == "Mahasiswa" ? "text-blue-600" : "text-green-600")">
                    @(p.KategoriPemohon == "Mahasiswa" ? "🎓 Mahasiswa/Pelajar" : "🏢 LSM")
                </span>
            </p>
        </div>
        <span class="px-4 py-1.5 rounded-full text-sm font-semibold
            @(p.StatusPPIDID == StatusId.Selesai    ? "bg-green-100 text-green-700" :
              p.StatusPPIDID == StatusId.DataSiap   ? "bg-blue-100 text-blue-700"  :
              p.StatusPPIDID == StatusId.Baru       ? "bg-gray-100 text-gray-600"  : "bg-yellow-100 text-yellow-700")">
            @(p.Status?.NamaStatusPPID ?? "—")
        </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

        <!-- Timeline -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
            <h3 class="font-semibold text-gray-700 mb-5 text-sm">📊 Alur Proses</h3>
            <ol class="relative border-l-2 border-gray-200 ml-3 space-y-5">
                @foreach (var step in Model.Riwayat)
                {
                    <li class="ml-6 relative">
                        <span class="absolute -left-9 flex items-center justify-center w-7 h-7 rounded-full ring-2 ring-white text-xs font-bold
                            @(step.Selesai ? "bg-green-500 text-white" : step.AktifSekarang ? "bg-blue-600 text-white" : "bg-gray-200 text-gray-400")">
                            @(step.Selesai ? "✓" : step.AktifSekarang ? "●" : "○")
                        </span>
                        <div class="rounded-xl px-4 py-2.5 border
                            @(step.AktifSekarang ? "bg-blue-50 border-blue-200" : step.Selesai ? "bg-green-50 border-green-100" : "bg-gray-50 border-gray-100")">
                            <p class="font-semibold text-sm
                                @(step.AktifSekarang ? "text-blue-800" : step.Selesai ? "text-green-700" : "text-gray-400")">
                                @step.Label
                            </p>
                            @if (step.AktifSekarang)
                            {
                                <p class="text-blue-500 text-xs mt-0.5">⏳ Sedang dalam proses</p>
                            }
                        </div>
                    </li>
                }
            </ol>
        </div>

        <!-- Info Panel -->
        <div class="space-y-4">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
                <h3 class="font-semibold text-gray-700 mb-3 text-sm">📋 Detail</h3>
                <dl class="space-y-2 text-sm">
                    <div><dt class="text-xs text-gray-400">Nama</dt><dd class="font-medium text-gray-800">@pr?.Nama</dd></div>
                    @if (!string.IsNullOrEmpty(Model.PribadiPPID?.Lembaga))
                    {
                        <div><dt class="text-xs text-gray-400">Lembaga</dt><dd class="text-gray-700">@Model.PribadiPPID.Lembaga</dd></div>
                    }
                    <div><dt class="text-xs text-gray-400">Judul Penelitian</dt><dd class="text-gray-700">@p.JudulPenelitian</dd></div>
                    <div>
                        <dt class="text-xs text-gray-400">Keperluan</dt>
                        <dd class="flex flex-wrap gap-1 mt-0.5">
                            @if (p.IsObservasi)      { <span class="bg-orange-100 text-orange-700 text-xs px-2 py-0.5 rounded-full">Observasi</span> }
                            @if (p.IsPermintaanData) { <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full">Permintaan Data</span> }
                            @if (p.IsWawancara)      { <span class="bg-purple-100 text-purple-700 text-xs px-2 py-0.5 rounded-full">Wawancara</span> }
                        </dd>
                    </div>
                </dl>
            </div>

            @if (Model.Jadwal.Any())
            {
                <div class="bg-orange-50 border border-orange-200 rounded-2xl p-4">
                    <h3 class="font-semibold text-orange-700 mb-2 text-sm">🗓 Jadwal Observasi</h3>
                    @foreach (var j in Model.Jadwal)
                    {
                        <p class="text-sm font-bold text-orange-800">@j.Tanggal?.ToString("dddd, dd MMM yyyy")</p>
                        <p class="text-xs text-orange-600">Pukul @j.Waktu?.ToString("HH:mm") WIB</p>
                        @if (!string.IsNullOrEmpty(j.NamaPIC))
                        { <p class="text-xs text-orange-500 mt-0.5">PIC: @j.NamaPIC</p> }
                    }
                    <p class="text-xs text-orange-400 mt-2">Hadir tepat waktu sesuai jadwal.</p>
                </div>
            }

            @if (p.StatusPPIDID >= StatusId.DataSiap)
            {
                <div class="bg-green-50 border border-green-200 rounded-2xl p-4">
                    <h3 class="font-semibold text-green-700 mb-2 text-sm">✅ Data Tersedia</h3>
                    @if (dokDataHasil != null)
                    {
                        <a href="@dokDataHasil.UploadDokumenPPID"
                           class="block w-full bg-green-600 hover:bg-green-700 text-white text-center text-sm font-semibold py-2.5 rounded-xl transition-colors">
                            ⬇ Unduh Data
                        </a>
                    }
                    @if (p.StatusPPIDID < StatusId.Selesai)
                    {
                        <a asp-action="Kuesioner" asp-route-id="@p.PermohonanPPIDID"
                           class="block w-full mt-2 bg-white text-green-700 border border-green-300 text-center text-sm font-semibold py-2 rounded-xl hover:bg-gray-50 transition-colors">
                            📝 Isi Kuesioner Kepuasan
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
