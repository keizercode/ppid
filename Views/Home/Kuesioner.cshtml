@model KuesionerVm
@{ ViewData["Title"] = "Kuesioner Kepuasan"; }

<div class="max-w-md mx-auto px-4 py-10">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
        <div class="text-center mb-6">
            <div class="text-4xl mb-2">📝</div>
            <h2 class="text-lg font-bold text-gray-800">Kuesioner Kepuasan Layanan</h2>
            <p class="text-gray-500 text-sm mt-0.5">No. Permohonan: <strong>@Model.NoPermohonan</strong></p>
        </div>
        <form asp-action="KuesionerPost" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PermohonanPPIDID" />
            <input type="hidden" asp-for="NoPermohonan" />
            <div class="mb-5">
                <p class="text-sm font-semibold text-gray-700 mb-3">Penilaian layanan secara keseluruhan:</p>
                <div class="flex gap-2 justify-center">
                    @foreach (var (val, emoji, lbl) in new[]{(1,"😞","Buruk"),(2,"😕","Kurang"),(3,"😐","Cukup"),(4,"😊","Baik"),(5,"😁","Sangat Baik")})
                    {
                        <label class="cursor-pointer">
                            <input type="radio" asp-for="NilaiKepuasan" value="@val" class="sr-only peer" />
                            <div class="w-14 peer-checked:ring-2 peer-checked:ring-blue-500 peer-checked:bg-blue-50 flex flex-col items-center gap-1 p-2 rounded-xl border border-gray-200 hover:bg-gray-50 transition-all">
                                <span class="text-2xl">@emoji</span>
                                <span class="text-xs text-gray-500">@lbl</span>
                            </div>
                        </label>
                    }
                </div>
                <span asp-validation-for="NilaiKepuasan" class="text-red-500 text-xs mt-1 block text-center"></span>
            </div>
            <div class="mb-5">
                <label asp-for="Catatan" class="block text-sm font-semibold text-gray-700 mb-1">Masukan / Saran (opsional)</label>
                <textarea asp-for="Catatan" rows="3" class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none" placeholder="Tuliskan masukan Anda..."></textarea>
            </div>
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors">
                Kirim Kuesioner
            </button>
        </form>
    </div>
</div>
