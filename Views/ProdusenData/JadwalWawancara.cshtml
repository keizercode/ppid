@model JadwalWawancaraVm
@{
    ViewData["Title"] = "Jadwal Wawancara";
    ViewData["Role"] = "Produsen Data";
    Layout = "_LayoutAdmin";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

        <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
            <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center text-xl">🎤</div>
            <div>
                <h3 class="font-bold text-gray-800">
                    @(Model.JadwalSudahAda ? "Jadwal Wawancara (dari KDI)" : "Buat Jadwal Wawancara")
                </h3>
                <p class="text-xs text-gray-400 mt-0.5">
                    @Model.NamaPemohon · <span class="font-mono">@Model.NoPermohonan</span>
                </p>
            </div>
        </div>

        <div class="p-6">

            @* Info penelitian *@
            <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 mb-5">
                <span class="text-[10px] text-gray-400 uppercase font-bold">Judul</span>
                <p class="font-semibold text-gray-800 text-sm mt-0.5">@Model.JudulPenelitian</p>
                @if (!string.IsNullOrEmpty(Model.DetailWawancara))
                {
                    <span class="text-[10px] text-gray-400 uppercase font-bold mt-2 block">Topik Wawancara</span>
                    <p class="text-gray-600 text-xs mt-0.5">@Model.DetailWawancara</p>
                }
            </div>

            @* Banner: jadwal sudah ada dari KDI *@
            @if (Model.JadwalSudahAda)
            {
                <div
                    class="bg-blue-50 border border-blue-200 rounded-xl p-3 mb-5 text-xs text-blue-700 flex gap-2 items-start">
                    <span class="mt-0.5 text-base">ℹ️</span>
                    <div>
                        <p class="font-semibold mb-0.5">Jadwal sudah dibuat oleh KDI</p>
                        <p>Data di bawah sudah terisi dari jadwal KDI. Anda bisa langsung menuju halaman
                            <strong>Selesai Wawancara</strong> setelah sesi selesai, atau perbarui jadwal jika ada
                            perubahan.
                        </p>
                    </div>
                </div>
            }
            else
            {
                <div
                    class="bg-violet-50 border border-violet-200 rounded-xl p-3 mb-5 text-xs text-violet-700 flex gap-2 items-start">
                    <span class="mt-0.5">💡</span>
                    <p>Jadwal ini akan ditampilkan kepada pemohon melalui halaman lacak permohonan.</p>
                </div>
            }

            <form asp-action="JadwalWawancaraPost" asp-controller="ProdusenData" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PermohonanPPIDID" />
                <input type="hidden" asp-for="NoPermohonan" />
                <input type="hidden" asp-for="NamaPemohon" />
                <input type="hidden" asp-for="JadwalSudahAda" />

                <div class="grid grid-cols-2 gap-3 mb-4">
                    <div>
                        <label class="lbl">Tanggal <span class="text-red-400">*</span></label>
                        <input asp-for="TanggalWawancara" type="date" class="fld" readonly="@(Model.JadwalSudahAda)" />
                        <span asp-validation-for="TanggalWawancara" class="err"></span>
                    </div>
                    <div>
                        <label class="lbl">Jam <span class="text-red-400">*</span></label>
                        <input asp-for="WaktuWawancara" type="time" class="fld" readonly="@(Model.JadwalSudahAda)" />
                        <span asp-validation-for="WaktuWawancara" class="err"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="lbl">Nama Narasumber / PIC <span class="text-red-400">*</span></label>
                    <input asp-for="NamaPIC" class="fld" placeholder="Nama narasumber yang akan diwawancara"
                           readonly="@(Model.JadwalSudahAda)" />
                    <span asp-validation-for="NamaPIC" class="err"></span>
                </div>

                <div class="mb-5">
                    <label class="lbl">Lokasi / Platform</label>
                    <input asp-for="Lokasi" class="fld" placeholder="Contoh: Ruang Rapat Lt. 3 / Google Meet" />
                </div>

                <div class="flex gap-3">
                    <a href="/produsen-data"
                           class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50 transition-colors">
                        Batal
                    </a>

                    @if (Model.JadwalSudahAda)
                    {
                        @* Jadwal sudah ada → tombol utama ke Selesai Wawancara *@
                        <a href="/produsen-data/selesai/@Model.PermohonanPPIDID"
                               class="flex-grow text-center bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2.5 px-6 rounded-xl text-sm shadow-sm transition-colors">
                            ✅ Catat Selesai Wawancara →
                        </a>
                    }
                    else
                    {
                        @* Jadwal belum ada → tombol simpan jadwal *@
                        <button type="submit"
                                class="flex-grow bg-violet-600 hover:bg-violet-700 text-white font-bold py-2.5 px-8 rounded-xl text-sm shadow-sm transition-colors">
                            📅 Simpan Jadwal
                        </button>
                    }
                </div>
            </form>

        </div>
    </div>
</div>

<style>
    .lbl {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 4px;
    }

    .fld {
        display: block;
        width: 100%;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 9px 14px;
        font-size: 13.5px;
        background: #fafafa;
        outline: none;
        transition: all .15s;
    }

    .fld:focus {
        box-shadow: 0 0 0 2.5px #7c3aed;
        border-color: transparent;
        background: white;
    }

    .fld[readonly] {
        background: #f3f4f6;
        color: #6b7280;
        cursor: default;
    }

    .err {
        color: #ef4444;
        font-size: 11px;
        margin-top: 3px;
        display: block;
    }
</style>
