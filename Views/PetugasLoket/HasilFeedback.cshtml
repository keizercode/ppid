@* ════════════════════════════════════════════════════════════════════════════
   Views/PetugasLoket/HasilFeedback.cshtml
   Loket Kepegawaian — menerima dan melihat feedback pemohon beserta laporan.

   Alur:
   1. Status DataSiap  → feedback sudah bisa diisi pemohon (otomatis aktif)
   2. Status FeedbackPemohon → Loket membuka akses secara eksplisit (tracking)
   3. View ini menampilkan hasil feedback per task + laporan yang diunggah
   4. Loket dapat menandai selesai manual jika pemohon tidak merespons
════════════════════════════════════════════════════════════════════════════ *@
@model HasilFeedbackVm
@{
    ViewData["Title"] = $"Hasil Feedback — {Model.Permohonan.NoPermohonan}";
    ViewData["Role"]  = "Petugas Loket";
    Layout = "_LayoutAdmin";

    var p         = Model.Permohonan;
    var pr        = p.Pribadi;
    var tugasDocs = ViewData["TugasDocs"] as List<DokumenPPID> ?? new();

    bool isSelesai    = p.StatusPPIDID == StatusId.Selesai;
    bool isFeedback   = p.StatusPPIDID == StatusId.FeedbackPemohon;
    bool isDataSiap   = p.StatusPPIDID == StatusId.DataSiap;
    bool canForceClose = isDataSiap || isFeedback;

    // Hitung completeness feedback
    int totalTaskSelesai = Model.SubTasks.Count(t => t.IsSelesai);
    int fbTerisi         = Model.JumlahFeedback;
    bool semua_fb_done   = totalTaskSelesai > 0 && fbTerisi >= totalTaskSelesai;
    int sisaFb           = Math.Max(0, totalTaskSelesai - fbTerisi);
}

@if (TempData["Success"] != null)
{
    <div class="bg-emerald-50 border border-emerald-300 rounded-2xl px-5 py-3 mb-4 flex items-start gap-3">
        <span class="text-emerald-500 text-lg flex-shrink-0">✅</span>
        <p class="text-emerald-800 text-sm font-medium">@Html.Raw(TempData["Success"])</p>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-50 border border-red-300 rounded-2xl px-5 py-3 mb-4 flex items-start gap-3">
        <span class="text-red-500 text-lg flex-shrink-0">⚠️</span>
        <p class="text-red-800 text-sm font-medium">@Html.Raw(TempData["Error"])</p>
    </div>
}

<div class="max-w-3xl mx-auto">

    <a href="/petugas-loket/subtasks/@p.PermohonanPPIDID"
       class="inline-flex items-center gap-1.5 text-blue-600 hover:text-blue-800 text-sm font-medium mb-5 transition-colors">
        ← Kembali ke Sub-tugas
    </a>

    @* ── Header Card ──────────────────────────────────────────────────────── *@
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-5">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1">
                <p class="text-[10px] text-gray-400 uppercase tracking-widest font-semibold mb-1">Hasil Feedback Pemohon</p>
                <h2 class="text-xl font-extrabold font-mono text-gray-800">@p.NoPermohonan</h2>
                <p class="text-sm text-gray-500 mt-0.5">@pr?.Nama</p>
                <p class="text-xs text-gray-400 mt-0.5 leading-snug">@p.JudulPenelitian</p>
            </div>
            <div class="flex flex-col items-start sm:items-end gap-2.5 flex-shrink-0">
                @* Rating bintang keseluruhan *@
                @if (Model.JumlahFeedback > 0)
                {
                    <div class="flex items-center gap-1.5">
                        <div class="flex gap-0.5">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="text-lg @(i <= Math.Round(Model.RataRata) ? "text-amber-400" : "text-gray-200")">★</span>
                            }
                        </div>
                        <span class="text-sm font-bold text-gray-700">@Model.RataRata.ToString("F1")</span>
                        <span class="text-xs text-gray-400">/ 5</span>
                    </div>
                    <p class="text-[10px] text-gray-400">dari @Model.JumlahFeedback feedback</p>
                }
                @* Badge status permohonan *@
                <div class="flex items-center gap-2 border rounded-full px-3 py-1.5
                    @(isSelesai ? "bg-emerald-50 border-emerald-200 text-emerald-700" :
                      isFeedback ? "bg-amber-50 border-amber-200 text-amber-700" :
                      isDataSiap ? "bg-blue-50 border-blue-200 text-blue-700" :
                                   "bg-gray-100 border-gray-200 text-gray-500")">
                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0
                        @(isSelesai ? "bg-emerald-400" : isFeedback ? "bg-amber-400" : isDataSiap ? "bg-blue-500" : "bg-gray-400")"></span>
                    <span class="text-xs font-semibold">@(p.Status?.NamaStatusPPID ?? "—")</span>
                </div>
            </div>
        </div>

        @* Progress bar feedback *@
        @if (totalTaskSelesai > 0)
        {
            int pct = (int)Math.Round(fbTerisi * 100.0 / totalTaskSelesai);
            <div class="mt-4 pt-4 border-t border-gray-50">
                <div class="flex items-center justify-between mb-1.5">
                    <p class="text-xs font-semibold text-gray-600">Progress Feedback</p>
                    <span class="text-xs font-bold @(semua_fb_done ? "text-emerald-600" : "text-amber-600")">
                        @fbTerisi / @totalTaskSelesai terisi
                    </span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2 overflow-hidden">
                    <div class="h-full rounded-full transition-all duration-700 @(semua_fb_done ? "bg-emerald-500" : "bg-amber-400")"
                         style="width:@pct%"></div>
                </div>
                @if (semua_fb_done)
                {
                    <p class="text-xs text-emerald-600 font-semibold mt-1.5">Semua feedback telah diterima!</p>
                }
                else
                {
                    <p class="text-xs text-amber-600 mt-1.5">⏳ Menunggu @sisaFb feedback lagi dari pemohon.</p>
                }
            </div>
        }
    </div>

    @* ── Alert: Belum ada feedback ─────────────────────────────────────────── *@
    @if (Model.JumlahFeedback == 0 && totalTaskSelesai > 0)
    {
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 mb-5 flex gap-3 items-start">
            <span class="text-amber-500 text-xl flex-shrink-0 mt-0.5">⏳</span>
            <div>
                <p class="font-bold text-amber-800 text-sm">Menunggu Feedback dari Pemohon</p>
                <p class="text-amber-700 text-xs mt-1 leading-relaxed">
                    Belum ada feedback yang diterima. Ingatkan pemohon untuk membuka portal publik
                    dan memasukkan nomor <strong class="font-mono">@p.NoPermohonan</strong>
                    untuk mengisi feedback.
                </p>
            </div>
        </div>
    }

    @* ── Feedback per Jenis Task ───────────────────────────────────────────── *@
    @{
        var taskTypes = new[]
        {
            (JenisTask.PermintaanData, "📊", "Permintaan Data", "blue",   p.IsPermintaanData),
            (JenisTask.Observasi,      "🔍", "Observasi",       "orange", p.IsObservasi),
            (JenisTask.Wawancara,      "🎤", "Wawancara",       "violet", p.IsWawancara),
        };
    }

    <div class="space-y-4 mb-5">
        @foreach (var (jenis, icon, label, color, isActive) in taskTypes)
        {
            var st = Model.SubTasks.FirstOrDefault(t => t.JenisTask == jenis);
            var fb = Model.GetFeedback(jenis);

            if (!isActive || st is null) continue;

            string cardBorder = fb != null ? "border-emerald-200" :
                                st.IsSelesai ? "border-amber-200" :
                                st.IsDibatalkan ? "border-gray-200" : "border-gray-100";

            string headerBg = color switch {
                "blue"   => "bg-blue-50 border-blue-100",
                "orange" => "bg-orange-50 border-orange-100",
                "violet" => "bg-violet-50 border-violet-100",
                _        => "bg-gray-50 border-gray-100"
            };

            string iconBg = color switch {
                "blue"   => "bg-blue-100 border-blue-200",
                "orange" => "bg-orange-100 border-orange-200",
                "violet" => "bg-violet-100 border-violet-200",
                _        => "bg-gray-100 border-gray-200"
            };

            string labelColor = color switch {
                "blue"   => "text-blue-800",
                "orange" => "text-orange-800",
                "violet" => "text-violet-800",
                _        => "text-gray-800"
            };

            <div class="bg-white rounded-2xl border @cardBorder shadow-sm overflow-hidden">
                @* Task header *@
                <div class="px-5 py-4 @headerBg border-b flex items-center justify-between gap-3">
                    <div class="flex items-center gap-3">
                        <div class="w-9 h-9 @iconBg border rounded-xl flex items-center justify-center text-lg flex-shrink-0">@icon</div>
                        <div>
                            <p class="font-bold @labelColor text-sm">@label</p>
                            <div class="flex items-center gap-2 mt-0.5">
                                <span class="text-[10px] text-gray-400">Sub-tugas:</span>
                                <span class="text-[10px] font-semibold @(st.IsSelesai ? "text-emerald-600" : st.IsDibatalkan ? "text-red-500" : "text-amber-600")">
                                    @SubTaskStatus.GetLabel(st.StatusTask)
                                </span>
                                @if (st.TanggalJadwal.HasValue)
                                {
                                    <span class="text-[10px] text-gray-400">| 📅 @st.TanggalJadwal.Value.ToString("dd MMM yyyy")</span>
                                }
                            </div>
                        </div>
                    </div>
                    @* Nilai bintang per task *@
                    @if (fb != null)
                    {
                        <div class="flex items-center gap-1 flex-shrink-0">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="text-base @(i <= fb.NilaiKepuasan ? "text-amber-400" : "text-gray-200")">★</span>
                            }
                            <span class="ml-1 text-sm font-bold text-gray-700">@fb.NilaiKepuasan/5</span>
                        </div>
                    }
                    else if (st.IsSelesai)
                    {
                        <span class="text-xs bg-amber-50 border border-amber-200 text-amber-700 px-2.5 py-1 rounded-full font-medium flex-shrink-0">
                            ⏳ Belum diisi
                        </span>
                    }
                    else if (st.IsDibatalkan)
                    {
                        <span class="text-xs bg-gray-100 text-gray-400 px-2.5 py-1 rounded-full font-medium flex-shrink-0">
                            Tidak relevan
                        </span>
                    }
                </div>

                @* Konten feedback *@
                <div class="p-5">
                    @if (fb != null)
                    {
                        <div class="space-y-4">
                            @* Nilai dengan emoji *@
                            <div>
                                <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest mb-1.5">Nilai Kepuasan</p>
                                @{
                                    var (emoji, nilaiLabel) = fb.NilaiKepuasan switch {
                                        1 => ("😞", "Buruk"),
                                        2 => ("😕", "Kurang"),
                                        3 => ("😐", "Cukup"),
                                        4 => ("😊", "Baik"),
                                        5 => ("😁", "Sangat Baik"),
                                        _ => ("—",  "—")
                                    };
                                    string valueBg = fb.NilaiKepuasan switch {
                                        1 => "bg-red-50 border-red-100 text-red-700",
                                        2 => "bg-orange-50 border-orange-100 text-orange-700",
                                        3 => "bg-amber-50 border-amber-100 text-amber-700",
                                        4 => "bg-blue-50 border-blue-100 text-blue-700",
                                        5 => "bg-emerald-50 border-emerald-100 text-emerald-700",
                                        _ => "bg-gray-50 border-gray-100 text-gray-500"
                                    };
                                }
                                <div class="inline-flex items-center gap-2 @valueBg border rounded-xl px-3 py-2">
                                    <span class="text-xl">@emoji</span>
                                    <div>
                                        <p class="text-sm font-bold">@nilaiLabel</p>
                                        <p class="text-[10px] opacity-70">@fb.NilaiKepuasan dari 5</p>
                                    </div>
                                </div>
                            </div>

                            @* Catatan pemohon *@
                            @if (!string.IsNullOrEmpty(fb.Catatan))
                            {
                                <div>
                                    <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest mb-1.5">Masukan / Saran Pemohon</p>
                                    <div class="bg-gray-50 border border-gray-100 rounded-xl px-4 py-3">
                                        <p class="text-sm text-gray-700 leading-relaxed">@fb.Catatan</p>
                                    </div>
                                </div>
                            }

                            @* File laporan per task *@
                            @if (!string.IsNullOrEmpty(fb.FileLaporan))
                            {
                                <div>
                                    <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest mb-1.5">Laporan Diunggah Pemohon</p>
                                    <div class="flex items-center gap-2.5 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-2.5">
                                        <span class="text-emerald-500 flex-shrink-0">📎</span>
                                        <p class="text-xs font-medium text-emerald-800 flex-1 truncate">@(fb.NamaFile ?? "File laporan")</p>
                                        <a href="@fb.FileLaporan" target="_blank"
                                           class="text-[11px] bg-emerald-100 hover:bg-emerald-200 text-emerald-700 px-2.5 py-1 rounded-lg font-bold flex-shrink-0 transition-colors">
                                            Unduh
                                        </a>
                                    </div>
                                </div>
                            }

                            <p class="text-[10px] text-gray-300">
                                Diisi: @fb.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </p>
                        </div>
                    }
                    else if (st.IsSelesai)
                    {
                        <div class="bg-amber-50 border border-amber-100 rounded-xl p-3 flex gap-2 items-start">
                            <span class="text-amber-500 flex-shrink-0">⏳</span>
                            <div>
                                <p class="text-xs text-amber-700 leading-relaxed font-medium">
                                    Tugas <strong>@label</strong> sudah selesai, namun pemohon belum mengisi feedback.
                                </p>
                                <p class="text-[11px] text-amber-600 mt-1">
                                    Ingatkan pemohon menggunakan nomor <span class="font-mono font-bold">@p.NoPermohonan</span>.
                                </p>
                            </div>
                        </div>
                    }
                    else if (st.IsDibatalkan)
                    {
                        <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 flex gap-2 items-center">
                            <span class="text-gray-400 flex-shrink-0">🚫</span>
                            <p class="text-xs text-gray-500">Sub-tugas @label dibatalkan — tidak ada feedback yang diperlukan.</p>
                        </div>
                    }
                    else
                    {
                        <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 flex gap-2 items-center">
                            <span class="text-gray-400 flex-shrink-0">⏳</span>
                            <p class="text-xs text-gray-500">Sub-tugas @label belum selesai — feedback belum tersedia.</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* ── Laporan / Tugas Final Pemohon ────────────────────────────────────── *@
    @if (tugasDocs.Any())
    {
        <div class="bg-white rounded-2xl border border-indigo-200 shadow-sm p-5 mb-5">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 bg-indigo-50 border border-indigo-200 rounded-lg flex items-center justify-center text-sm">📤</div>
                <div>
                    <p class="font-bold text-gray-800 text-sm">Laporan Final Pemohon</p>
                    <p class="text-xs text-gray-400 mt-0.5">Diunggah langsung oleh pemohon via portal publik</p>
                </div>
                <span class="ml-auto text-xs font-bold bg-indigo-100 text-indigo-700 px-2.5 py-0.5 rounded-full">
                    @tugasDocs.Count file
                </span>
            </div>
            <div class="space-y-2">
                @foreach (var f in tugasDocs)
                {
                    <div class="flex items-center gap-3 bg-indigo-50 border border-indigo-100 rounded-xl px-4 py-2.5">
                        <span class="text-indigo-500 flex-shrink-0">📎</span>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-semibold text-indigo-800 truncate">@f.NamaDokumenPPID</p>
                            <p class="text-[10px] text-indigo-400 mt-0.5">
                                Diunggah: @f.CreatedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </p>
                        </div>
                        <a href="@f.UploadDokumenPPID" target="_blank"
                           class="flex-shrink-0 text-[11px] bg-indigo-100 hover:bg-indigo-200 text-indigo-700 px-2.5 py-1 rounded-lg font-bold transition-colors">
                            Unduh
                        </a>
                    </div>
                }
            </div>
        </div>
    }
    else if (p.StatusPPIDID >= StatusId.DataSiap)
{
    // Cek apakah ada file laporan yang sudah masuk via feedback per-task
    bool adaFileDariFeedback = Model.Feedbacks.Any(f => !string.IsNullOrEmpty(f.FileLaporan));
    if (!adaFileDariFeedback)
    {
        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-4 mb-5 flex gap-2 items-start">
            <span class="text-gray-400 flex-shrink-0 mt-0.5">ℹ️</span>
            <p class="text-xs text-gray-500 leading-relaxed">
                Pemohon belum mengunggah laporan/tugas final. Laporan dapat diunggah melalui portal publik
                menggunakan nomor <strong class="font-mono">@p.NoPermohonan</strong>.
            </p>
        </div>
    }
}

    @* ── Panduan: ingatkan pemohon ────────────────────────────────────────── *@
    @if (sisaFb > 0 && !isSelesai)
    {
        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-4 mb-5">
            <div class="flex items-start gap-3">
                <span class="text-blue-500 flex-shrink-0 mt-0.5">ℹ️</span>
                <div class="flex-1">
                    <p class="font-bold text-blue-800 text-sm">@sisaFb Feedback Belum Diterima</p>
                    <p class="text-blue-700 text-xs mt-1 leading-relaxed">
                        Ingatkan pemohon untuk membuka portal PPID DLH dan memasukkan nomor permohonan
                        di bawah, kemudian klik tombol "Isi Feedback" pada setiap tugas yang sudah selesai.
                    </p>
                    <div class="mt-2 bg-white border-2 border-dashed border-blue-300 rounded-xl px-3 py-2 flex items-center gap-3">
                        <div class="flex-1">
                            <p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest mb-0.5">Nomor Permohonan</p>
                            <p id="noPermFb" class="font-mono font-extrabold text-blue-700 text-base">@p.NoPermohonan</p>
                        </div>
                        <button type="button" id="copyFbBtn"
                                onclick="copyNomor('@p.NoPermohonan')"
                                class="flex-shrink-0 text-xs font-bold bg-blue-100 hover:bg-blue-200 text-blue-700 px-3 py-1.5 rounded-lg transition-colors">
                            Salin
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Tandai Selesai (manual override) ─────────────────────────────────── *@
    @if (canForceClose && !isSelesai)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-5">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Tindakan Manual</p>
            @if (semua_fb_done)
            {
                <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-3 mb-3 flex gap-2 items-start">
                    <span class="text-emerald-500 flex-shrink-0">✅</span>
                    <p class="text-xs text-emerald-700 leading-relaxed">
                        Semua feedback sudah diterima. Permohonan akan otomatis diselesaikan saat feedback
                        terakhir masuk, atau Anda dapat menandai selesai secara manual.
                    </p>
                </div>
            }
            else
            {
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 mb-3 flex gap-2 items-start">
                    <span class="text-amber-500 flex-shrink-0">⚠️</span>
                    <p class="text-xs text-amber-700 leading-relaxed">
                        Gunakan opsi ini <strong>hanya jika pemohon tidak merespons</strong> dalam waktu yang wajar.
                        Permohonan akan ditandai selesai tanpa menunggu sisa feedback.
                    </p>
                </div>
            }
            <form asp-action="TandaiSelesaiFeedback" asp-controller="PetugasLoket" method="post"
                  onsubmit="return confirm('Tandai permohonan ini selesai secara manual?')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="permohonanId" value="@p.PermohonanPPIDID" />
                <button type="submit"
                        class="inline-flex items-center gap-2 @(semua_fb_done ? "bg-emerald-600 hover:bg-emerald-700 text-white" : "border border-gray-300 text-gray-600 hover:bg-gray-50") text-xs font-semibold px-4 py-2.5 rounded-xl transition-colors">
                    @(semua_fb_done ? "🏁 Tandai Selesai" : "✓ Tandai Selesai (Manual)")
                </button>
            </form>
        </div>
    }

    @* ── Status Selesai ───────────────────────────────────────────────────── *@
    @if (isSelesai)
    {
        <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-5 mb-5 flex items-center gap-4">
            <div class="w-12 h-12 bg-emerald-500 rounded-xl flex items-center justify-center text-white text-2xl flex-shrink-0">🏁</div>
            <div>
                <p class="font-bold text-emerald-800">Permohonan Selesai</p>
                <p class="text-emerald-600 text-sm mt-0.5">
                    Tanggal selesai: <strong>@(p.TanggalSelesai?.ToString("dd MMMM yyyy") ?? "—")</strong>
                </p>
                @if (Model.JumlahFeedback > 0)
                {
                    <p class="text-emerald-600 text-xs mt-0.5">
                        Rata-rata kepuasan: <strong>@Model.RataRata.ToString("F1") / 5</strong>
                    </p>
                }
            </div>
        </div>
    }

    @* ── Navigasi bawah ───────────────────────────────────────────────────── *@
    <div class="flex flex-wrap gap-3">
        <a href="/petugas-loket/subtasks/@p.PermohonanPPIDID"
           class="inline-flex items-center gap-2 border border-gray-200 text-gray-600 text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-gray-50 transition-colors">
            ← Kembali ke Sub-tugas
        </a>
        <a href="/petugas-loket/detail/@p.PermohonanPPIDID"
           class="inline-flex items-center gap-2 border border-gray-200 text-gray-600 text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-gray-50 transition-colors">
            📋 Detail & Audit Log
        </a>
    </div>
</div>

@section Scripts {
<script>
function copyNomor(nomor) {
    navigator.clipboard.writeText(nomor).then(() => {
        const btn = document.getElementById('copyFbBtn');
        if (!btn) return;
        const orig = btn.textContent;
        btn.textContent = '✓ Tersalin!';
        btn.classList.replace('bg-blue-100','bg-emerald-100');
        btn.classList.replace('text-blue-700','text-emerald-700');
        setTimeout(() => {
            btn.textContent = orig;
            btn.classList.replace('bg-emerald-100','bg-blue-100');
            btn.classList.replace('text-emerald-700','text-blue-700');
        }, 2500);
    }).catch(() => {
        const el = document.getElementById('noPermFb');
        if (!el) return;
        const range = document.createRange();
        range.selectNode(el);
        window.getSelection()?.removeAllRanges();
        window.getSelection()?.addRange(range);
    });
}
</script>
}
