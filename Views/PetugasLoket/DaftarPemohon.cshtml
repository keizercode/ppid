@model DaftarPemohonVm
@{
    ViewData["Title"] = "Formulir Permohonan";
    ViewData["Role"]  = "Petugas Loket";
    Layout = "_LayoutAdmin";
    bool isMahasiswa = Model.Kategori == "Mahasiswa";
}

<div class="max-w-3xl mx-auto">

    <!-- Category badge -->
    <div class="flex items-center gap-3 bg-blue-50 border border-blue-200 rounded-xl px-4 py-3 mb-5 text-sm">
        <span class="text-xl">@(isMahasiswa ? "🎓" : "🏢")</span>
        <div>
            <p class="text-xs text-blue-500 font-medium">Kategori Pemohon</p>
            <p class="text-blue-800 font-bold">@(isMahasiswa ? "Mahasiswa / Pelajar" : "LSM / Organisasi")</p>
        </div>
    </div>

    <!-- NIK Lookup -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Cari Data via NIK</p>
        <div class="flex gap-2 mb-3">
            <button type="button" id="tab-nik"
                class="px-3.5 py-1.5 text-xs font-bold rounded-lg bg-[#002d7a] text-white transition-colors"
                onclick="switchTab('nik')">🔍 Cari via NIK</button>
            <button type="button" id="tab-manual"
                class="px-3.5 py-1.5 text-xs font-bold rounded-lg bg-gray-100 text-gray-500 hover:bg-gray-200 transition-colors"
                onclick="switchTab('manual')">✏️ Isi Manual</button>
        </div>
        <div id="panel-nik">
            <div class="flex gap-2">
                <input type="text" id="nik-input" maxlength="16" placeholder="Masukkan 16 digit NIK..."
                       class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-blue-300 bg-gray-50" />
                <button type="button" onclick="cariNik()"
                        class="bg-[#002d7a] hover:bg-blue-900 text-white px-5 py-2.5 rounded-xl text-xs font-bold transition-colors">Cari</button>
            </div>
            <div id="nik-status" class="mt-2 text-xs hidden"></div>
        </div>
    </div>

    <form asp-action="DaftarPemohonPost" method="post" enctype="multipart/form-data" id="mainForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Kategori" />
        <input type="hidden" asp-for="LoketJenis" />

        <!-- Section helper macro — we use a styled div pattern -->

        <!-- ── 1. DATA PRIBADI ── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-gray-50">
                <span class="w-6 h-6 bg-blue-600 rounded-md text-white text-[11px] font-black flex items-center justify-center">1</span>
                <p class="font-bold text-gray-700 text-sm">Data Pribadi</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="lbl">NIK <span class="text-red-400">*</span></label>
                    <input asp-for="NIK" id="f-nik" maxlength="16" class="fld font-mono" placeholder="16 digit NIK" />
                    <span asp-validation-for="NIK" class="err"></span>
                </div>
                <div>
                    <label class="lbl">Nama Lengkap <span class="text-red-400">*</span></label>
                    <input asp-for="Nama" id="f-nama" class="fld" placeholder="Nama sesuai KTP" />
                    <span asp-validation-for="Nama" class="err"></span>
                </div>
                <div>
                    <label class="lbl">No. Telepon</label>
                    <input asp-for="Telepon" id="f-telepon" class="fld" placeholder="08xxxxxxxxxx" />
                </div>
                <div>
                    <label class="lbl">Email</label>
                    <input asp-for="Email" id="f-email" type="email" class="fld" placeholder="email@contoh.com" />
                </div>
            </div>
        </div>

        <!-- ── 2. ALAMAT ── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-gray-50">
                <span class="w-6 h-6 bg-blue-600 rounded-md text-white text-[11px] font-black flex items-center justify-center">2</span>
                <p class="font-bold text-gray-700 text-sm">Alamat</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="lbl">Provinsi</label>
                    <select id="sel-provinsi" onchange="onProvinsiChange()" class="fld">
                        <option value="">— Pilih Provinsi —</option>
                    </select>
                    <input type="hidden" asp-for="ProvinsiID"   id="f-provinsiID" />
                    <input type="hidden" asp-for="NamaProvinsi" id="f-namaProvinsi" />
                </div>
                <div>
                    <label class="lbl">Kabupaten / Kota</label>
                    <select id="sel-kabupaten" onchange="onKabupatenChange()" disabled class="fld">
                        <option value="">— Pilih Kabupaten —</option>
                    </select>
                    <input type="hidden" asp-for="KabupatenID"   id="f-kabupatenID" />
                    <input type="hidden" asp-for="NamaKabupaten" id="f-namaKabupaten" />
                </div>
                <div>
                    <label class="lbl">Kecamatan</label>
                    <select id="sel-kecamatan" onchange="onKecamatanChange()" disabled class="fld">
                        <option value="">— Pilih Kecamatan —</option>
                    </select>
                    <input type="hidden" asp-for="KecamatanID"   id="f-kecamatanID" />
                    <input type="hidden" asp-for="NamaKecamatan" id="f-namaKecamatan" />
                </div>
                <div>
                    <label class="lbl">Kelurahan</label>
                    <select id="sel-kelurahan" onchange="onKelurahanChange()" disabled class="fld">
                        <option value="">— Pilih Kelurahan —</option>
                    </select>
                    <input type="hidden" asp-for="KelurahanID"   id="f-kelurahanID" />
                    <input type="hidden" asp-for="NamaKelurahan" id="f-namaKelurahan" />
                </div>
                <div>
                    <label class="lbl">RT</label>
                    <input asp-for="RT" id="f-rt" class="fld" placeholder="001" maxlength="5" />
                </div>
                <div>
                    <label class="lbl">RW</label>
                    <input asp-for="RW" id="f-rw" class="fld" placeholder="001" maxlength="5" />
                </div>
                <div class="md:col-span-2">
                    <label class="lbl">Alamat Lengkap</label>
                    <textarea asp-for="Alamat" id="f-alamat" rows="2" class="fld resize-none" placeholder="Nama jalan, nomor rumah..."></textarea>
                </div>
            </div>
        </div>

        <!-- ── 3. INSTITUSI ── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-gray-50">
                <span class="w-6 h-6 bg-blue-600 rounded-md text-white text-[11px] font-black flex items-center justify-center">3</span>
                <p class="font-bold text-gray-700 text-sm">@(isMahasiswa ? "Institusi Pendidikan" : "Lembaga / Organisasi")</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div class="md:col-span-2">
                    <label class="lbl">@(isMahasiswa ? "Nama Universitas / Sekolah" : "Nama Lembaga")</label>
                    <input asp-for="Lembaga" class="fld" placeholder="@(isMahasiswa ? "Universitas Indonesia" : "LSM Transparansi")" />
                </div>
                @if (isMahasiswa) {
                    <div>
                        <label class="lbl">Fakultas</label>
                        <input asp-for="Fakultas" class="fld" placeholder="Fakultas Ilmu Komputer" />
                    </div>
                    <div>
                        <label class="lbl">Program Studi</label>
                        <input asp-for="Jurusan" class="fld" placeholder="Sistem Informasi" />
                    </div>
                } else {
                    <div class="md:col-span-2">
                        <label class="lbl">Jabatan / Pekerjaan</label>
                        <input asp-for="Pekerjaan" class="fld" placeholder="Peneliti / Koordinator" />
                    </div>
                }
            </div>
        </div>

        <!-- ── 4. DATA PERMOHONAN ── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-gray-50">
                <span class="w-6 h-6 bg-blue-600 rounded-md text-white text-[11px] font-black flex items-center justify-center">4</span>
                <p class="font-bold text-gray-700 text-sm">Data Permohonan</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="lbl">No. Surat Permohonan <span class="text-red-400">*</span></label>
                    <input asp-for="NoSuratPermohonan" class="fld" placeholder="001/SURAT/2024" />
                    <span asp-validation-for="NoSuratPermohonan" class="err"></span>
                </div>
                <div>
                    <label class="lbl">Tanggal Permohonan <span class="text-red-400">*</span></label>
                    <input asp-for="TanggalPermohonan" type="date" class="fld" />
                    <span asp-validation-for="TanggalPermohonan" class="err"></span>
                </div>
                <div class="md:col-span-2">
                    <label class="lbl">Judul Penelitian <span class="text-red-400">*</span></label>
                    <input asp-for="JudulPenelitian" class="fld" placeholder="Judul penelitian / tujuan permintaan data" />
                    <span asp-validation-for="JudulPenelitian" class="err"></span>
                </div>
                <div class="md:col-span-2">
                    <label class="lbl">Latar Belakang Penelitian <span class="text-red-400">*</span></label>
                    <textarea asp-for="LatarBelakang" rows="3" class="fld resize-none" placeholder="Jelaskan latar belakang penelitian..."></textarea>
                    <span asp-validation-for="LatarBelakang" class="err"></span>
                </div>
                <div class="md:col-span-2">
                    <label class="lbl">Tujuan Permohonan <span class="text-red-400">*</span></label>
                    <div class="flex flex-wrap gap-2 mt-1.5 mb-2">
                        @foreach (var (val, lbl) in new[]{
                            ("Tugas Mata Kuliah","Tugas Mata Kuliah"),
                            ("Pembuatan Tugas Akhir","Tugas Akhir"),
                            ("Pembuatan Skripsi","Skripsi"),
                        }) {
                            <button type="button" class="tujuan-btn px-3 py-1.5 rounded-lg border border-gray-200 text-xs font-semibold text-gray-600 hover:bg-blue-50 hover:border-blue-400 hover:text-blue-700 transition-colors" data-value="@val" onclick="setTujuan(this)">@lbl</button>
                        }
                    </div>
                    <input asp-for="TujuanPermohonan" id="f-tujuan" class="fld" placeholder="Atau ketik tujuan lainnya..." />
                    <span asp-validation-for="TujuanPermohonan" class="err"></span>
                </div>
            </div>
        </div>

        <!-- ── 5. KEPERLUAN ── -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
    <div class="flex items-center gap-2.5 mb-1 pb-3 border-b border-gray-50">
        <span class="w-6 h-6 bg-blue-600 rounded-md text-white text-[11px] font-black flex items-center justify-center">5</span>
        <p class="font-bold text-gray-700 text-sm">Keperluan <span class="text-gray-400 font-normal text-xs">(bisa lebih dari 1)</span></p>
    </div>
    <p class="text-xs text-gray-400 mb-4">Berikan tanda "-" pada deskripsi jika tidak dibutuhkan</p>
    <div class="space-y-3">

        <div class="border border-gray-100 rounded-xl overflow-hidden">
            <label class="flex items-center gap-3 cursor-pointer p-4 hover:bg-gray-50 transition-colors">
                <input asp-for="IsObservasi" type="checkbox" id="chk-obs"
                       onchange="toggleDetail('obs-detail', this)" class="w-4 h-4 rounded accent-blue-600" />
                <span class="font-semibold text-gray-700 text-sm">🔍 Observasi</span>
            </label>
            <div id="obs-detail" class="@(Model.IsObservasi ? "" : "hidden") px-4 pb-4">
                <textarea asp-for="DetailObservasi" rows="2" class="fld resize-none text-sm"
                    placeholder="Jelaskan observasi yang diperlukan..."></textarea>
            </div>
        </div>

        <div class="border border-gray-100 rounded-xl overflow-hidden">
            <label class="flex items-center gap-3 cursor-pointer p-4 hover:bg-gray-50 transition-colors">
                <input asp-for="IsPermintaanData" type="checkbox" id="chk-data"
                       onchange="toggleDetail('data-detail', this)" class="w-4 h-4 rounded accent-blue-600" />
                <span class="font-semibold text-gray-700 text-sm">📊 Permintaan Data</span>
            </label>
            <div id="data-detail" class="@(Model.IsPermintaanData ? "" : "hidden") px-4 pb-4">
                <textarea asp-for="DetailPermintaanData" rows="2" class="fld resize-none text-sm"
                    placeholder="Jelaskan data yang diperlukan..."></textarea>
            </div>
        </div>

        <div class="border border-gray-100 rounded-xl overflow-hidden">
            <label class="flex items-center gap-3 cursor-pointer p-4 hover:bg-gray-50 transition-colors">
                <input asp-for="IsWawancara" type="checkbox" id="chk-waw"
                       onchange="toggleDetail('waw-detail', this)" class="w-4 h-4 rounded accent-blue-600" />
                <span class="font-semibold text-gray-700 text-sm">🎤 Wawancara</span>
            </label>
            <div id="waw-detail" class="@(Model.IsWawancara ? "" : "hidden") px-4 pb-4">
                <textarea asp-for="DetailWawancara" rows="2" class="fld resize-none text-sm"
                    placeholder="Jelaskan topik wawancara yang diperlukan..."></textarea>
            </div>
        </div>

    </div>
</div>

        <!-- ── 6. UNIT KERJA ── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-4">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-gray-50">
                <span class="w-6 h-6 bg-blue-600 rounded-md text-white text-[11px] font-black flex items-center justify-center">6</span>
                <p class="font-bold text-gray-700 text-sm">Unit Kerja <span class="text-gray-400 font-normal text-xs">(Diisi Subkelompok Kepegawaian)</span></p>
            </div>
            <label class="lbl">Pilih Bidang / Unit Kerja</label>
            <select id="sel-bidang" onchange="onBidangChange()" class="fld">
                <option value="">— Memuat daftar bidang... —</option>
            </select>
            <input type="hidden" asp-for="BidangID"   id="f-bidangID" />
            <input type="hidden" asp-for="NamaBidang" id="f-namaBidang" />
        </div>

        <!-- ── 7. DOKUMEN ── -->
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-5">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-gray-50">
                <span class="w-6 h-6 bg-blue-600 rounded-md text-white text-[11px] font-black flex items-center justify-center">7</span>
                <p class="font-bold text-gray-700 text-sm">Upload Dokumen Persyaratan</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="lbl">📄 KTP</label>
                    <input asp-for="FileKTP" type="file" accept=".pdf,.jpg,.jpeg,.png" class="file-fld" />
                </div>
                <div>
                    <label class="lbl">📄 Surat Permohonan</label>
                    <input asp-for="FileSuratPermohonan" type="file" accept=".pdf" class="file-fld" />
                </div>
                @if (isMahasiswa) {
                    <div class="md:col-span-2">
                        <label class="lbl">📄 Proposal Penelitian</label>
                        <input asp-for="FileProposal" type="file" accept=".pdf" class="file-fld" />
                    </div>
                } else {
                    <div class="md:col-span-2">
                        <label class="lbl">📄 Akta Notaris Lembaga</label>
                        <input asp-for="FileAktaNotaris" type="file" accept=".pdf" class="file-fld" />
                    </div>
                }
            </div>
        </div>


<div asp-validation-summary="ModelOnly"
id="val-summary"
     class="bg-red-50 border border-red-200 rounded-xl px-4 py-3 mb-4 text-red-700 text-xs">
</div>

<div class="flex gap-3 mb-10">
            <a asp-action="Index" asp-controller="PetugasLoket"
               class="flex-1 text-center border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-3 rounded-xl text-sm transition-colors">
                Batal
            </a>
            <button type="submit"
                    class="flex-grow bg-[#002d7a] hover:bg-blue-900 text-white font-bold py-3 px-8 rounded-xl text-sm transition-colors shadow-sm">
                💾 Simpan & Lanjutkan →
            </button>
        </div>
    </form>
</div>

<style>
    .lbl      { display:block; font-size:11px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px; }
    .fld      { display:block; width:100%; border:1px solid #e5e7eb; border-radius:10px; padding:9px 14px; font-size:13.5px; background:#fafafa; outline:none; transition:all .15s; }
    .fld:focus{ box-shadow:0 0 0 2.5px #3b82f6; border-color:transparent; background:white; }
    select.fld{ appearance:none; background-image:url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e"); background-repeat:no-repeat; background-position:right 10px center; background-size:16px; padding-right:2.5rem; }
    .err      { color:#ef4444; font-size:11px; margin-top:3px; display:block; }
    .file-fld { width:100%; font-size:12px; color:#6b7280; border:1px solid #e5e7eb; border-radius:10px; padding:6px 10px; background:#fafafa; }
    .file-fld::file-selector-button { margin-right:8px; padding:4px 10px; border-radius:6px; border:none; font-size:11px; font-weight:700; background:#eff6ff; color:#1d4ed8; cursor:pointer; }
</style>

@section Scripts {
<script>
function switchTab(t) {
    const isNik = t === 'nik';
    document.getElementById('panel-nik').style.display = isNik ? 'block' : 'none';
    document.getElementById('tab-nik').className    = 'px-3.5 py-1.5 text-xs font-bold rounded-lg transition-colors ' + (isNik ? 'bg-[#002d7a] text-white' : 'bg-gray-100 text-gray-500 hover:bg-gray-200');
    document.getElementById('tab-manual').className = 'px-3.5 py-1.5 text-xs font-bold rounded-lg transition-colors ' + (!isNik ? 'bg-[#002d7a] text-white' : 'bg-gray-100 text-gray-500 hover:bg-gray-200');
}
switchTab('nik');

async function cariNik() {
    const nik = document.getElementById('nik-input').value.trim();
    if (nik.length !== 16) { showNikStatus('NIK harus 16 digit', 'red'); return; }
    showNikStatus('⏳ Mencari data...', 'blue');
    try {
        const res = await fetch(`/api/cek-nik?nik=${nik}`);
        const d   = await res.json();
        if (d && d.nama) {
            setVal('f-nik', nik); setVal('f-nama', d.nama||'');
            setVal('f-rt', d.rt||''); setVal('f-rw', d.rw||'');
            if (d.kecamatanID) {
                setVal('f-kabupatenID', d.kabupatenID||''); setVal('f-namaKabupaten', d.kota||'');
                setVal('f-kecamatanID', d.kecamatanID||''); setVal('f-namaKecamatan', d.kecamatan||'');
                setVal('f-kelurahanID', d.kelurahanID||''); setVal('f-namaKelurahan', d.kelurahan||'');
                await loadKabupaten(); setSelectByValue('sel-kabupaten', d.kabupatenID);
                if (d.kabupatenID) { await loadKecamatan(d.kabupatenID); setSelectByValue('sel-kecamatan', d.kecamatanID); }
                if (d.kecamatanID) { await loadKelurahan(d.kecamatanID); setSelectByValue('sel-kelurahan', d.kelurahanID); }
            }
            showNikStatus('✅ Data ditemukan: ' + d.nama, 'green');
            switchTab('manual');
        } else {
            showNikStatus('⚠️ NIK tidak ditemukan. Silakan isi manual.', 'yellow');
            setVal('f-nik', nik); switchTab('manual');
        }
    } catch(e) { showNikStatus('❌ Gagal terhubung. Isi manual.', 'red'); setVal('f-nik', nik); switchTab('manual'); }
}

function showNikStatus(msg, color) {
    const el = document.getElementById('nik-status');
    const m = { red:'text-red-600', green:'text-green-600', blue:'text-blue-600', yellow:'text-amber-600' };
    el.className = 'mt-2 text-xs ' + (m[color]||'text-gray-600');
    el.textContent = msg; el.classList.remove('hidden');
}
function toggleDetail(id, cb) { document.getElementById(id).classList.toggle('hidden', !cb.checked); }
function setTujuan(btn) {
    document.getElementById('f-tujuan').value = btn.dataset.value;
    document.querySelectorAll('.tujuan-btn').forEach(b => b.classList.remove('bg-blue-600','text-white','border-blue-600'));
    btn.classList.add('bg-blue-600','text-white','border-blue-600');
}

async function loadProvinsi() {
    const res = await fetch('/api/provinsi'); const data = await res.json();
    fillSelect('sel-provinsi', data, '— Pilih Provinsi —');
    document.getElementById('sel-provinsi').disabled = false;
}
async function loadKabupaten() {
    const res = await fetch('/api/kabupaten'); const data = await res.json();
    fillSelect('sel-kabupaten', data, '— Pilih Kabupaten —');
    document.getElementById('sel-kabupaten').disabled = false;
}
async function onProvinsiChange() {
    const el = document.getElementById('sel-provinsi'); const opt = el.options[el.selectedIndex];
    setVal('f-provinsiID', opt.value); setVal('f-namaProvinsi', opt.text);
    resetSelect('sel-kabupaten','— Pilih Kabupaten —'); resetSelect('sel-kecamatan','— Pilih Kecamatan —'); resetSelect('sel-kelurahan','— Pilih Kelurahan —');
    if (!opt.value) return; await loadKabupaten();
}
async function onKabupatenChange() {
    const el = document.getElementById('sel-kabupaten'); const opt = el.options[el.selectedIndex];
    setVal('f-kabupatenID', opt.value); setVal('f-namaKabupaten', opt.text);
    resetSelect('sel-kecamatan','— Pilih Kecamatan —'); resetSelect('sel-kelurahan','— Pilih Kelurahan —');
    if (!opt.value) return;
    const res = await fetch(`/api/kecamatan?kab=${opt.value}`); const data = await res.json();
    fillSelect('sel-kecamatan', data, '— Pilih Kecamatan —'); document.getElementById('sel-kecamatan').disabled = false;
}
async function onKecamatanChange() {
    const el = document.getElementById('sel-kecamatan'); const opt = el.options[el.selectedIndex];
    setVal('f-kecamatanID', opt.value); setVal('f-namaKecamatan', opt.text);
    resetSelect('sel-kelurahan','— Pilih Kelurahan —');
    if (!opt.value) return;
    const res = await fetch(`/api/kelurahan?kec=${opt.value}`); const data = await res.json();
    fillSelect('sel-kelurahan', data, '— Pilih Kelurahan —'); document.getElementById('sel-kelurahan').disabled = false;
}
function onKelurahanChange() {
    const el = document.getElementById('sel-kelurahan'); const opt = el.options[el.selectedIndex];
    setVal('f-kelurahanID', opt.value); setVal('f-namaKelurahan', opt.text);
}
async function loadBidang() {
    const res = await fetch('/api/bidang'); const data = await res.json();
    const sel = document.getElementById('sel-bidang');
    sel.innerHTML = '<option value="">— Pilih Unit Kerja / Bidang —</option>';
    data.forEach(d => { const o = document.createElement('option'); o.value = d.id; o.text = d.namaBidang; o.dataset.nama = d.namaBidang; sel.appendChild(o); });
    const hid = document.getElementById('f-bidangID').value; if (hid) setSelectByValue('sel-bidang', hid);
}
function onBidangChange() {
    const el = document.getElementById('sel-bidang'); const opt = el.options[el.selectedIndex];
    setVal('f-bidangID', opt.value); setVal('f-namaBidang', opt.dataset.nama || opt.text);
}
function setVal(id, val) { const el = document.getElementById(id); if(el) el.value = val; }
function fillSelect(id, data, ph) {
    const sel = document.getElementById(id); sel.innerHTML = `<option value="">${ph}</option>`;
    data.forEach(d => { const o = document.createElement('option'); o.value = d.id; o.text = d.data || d.namaBidang || d.id; sel.appendChild(o); });
}
function resetSelect(id, ph) {
    const sel = document.getElementById(id); sel.innerHTML = `<option value="">${ph}</option>`; sel.disabled = true;
    const fm = {'sel-kabupaten':'f-kabupatenID','sel-kecamatan':'f-kecamatanID','sel-kelurahan':'f-kelurahanID'};
    const nm = {'sel-kabupaten':'f-namaKabupaten','sel-kecamatan':'f-namaKecamatan','sel-kelurahan':'f-namaKelurahan'};
    if(fm[id]) setVal(fm[id],''); if(nm[id]) setVal(nm[id],'');
}
function setSelectByValue(id, val) {
    const sel = document.getElementById(id);
    for(let o of sel.options) { if(o.value === val) { sel.value = val; break; } }
}
loadProvinsi(); loadBidang();

document.getElementById('mainForm').addEventListener('submit', function() {
    const summary = document.getElementById('val-summary');
    const errors  = document.querySelectorAll('[data-valmsg-for]');
    // Show jika ada error setelah re-render
    if (document.querySelectorAll('.err:not(:empty)').length > 0) {
        summary.style.display = 'block';
    }
});
</script>
