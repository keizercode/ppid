@model PermohonanPPID
@{
    ViewData["Title"] = $"Detail {Model.NoPermohonan}";
    ViewData["Role"]  = "Petugas Loket";
    Layout = "_LayoutAdmin";
    var pr  = Model.Pribadi;
    var ppid = pr?.PribadiPPID;
}
<div class="max-w-3xl mx-auto">
    <a href="/petugas-loket" class="text-blue-600 text-sm hover:text-blue-800 inline-block mb-4">← Kembali</a>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <p class="text-xs text-gray-400 uppercase tracking-widest">Nomor Permohonan (Sistem)</p>
            <h2 class="text-xl font-bold font-mono">@Model.NoPermohonan</h2>
            <p class="text-xs text-gray-400 mt-0.5">
                No. Surat: <span class="font-mono text-gray-600">@(Model.NoSuratPermohonan ?? "-")</span>
                &nbsp;·&nbsp; Masuk: @Model.CratedAt?.ToString("dd MMM yyyy HH:mm")
            </p>
        </div>
        <span class="px-3 py-1 rounded-full text-sm font-semibold bg-yellow-100 text-yellow-700">
            @Model.Status?.NamaStatusPPID
        </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Data Pribadi</p>
            <dl class="space-y-2 text-sm">
                <div><dt class="text-xs text-gray-400">NIK</dt><dd class="font-mono font-medium">@pr?.NIK</dd></div>
                <div><dt class="text-xs text-gray-400">Nama</dt><dd class="font-medium">@pr?.Nama</dd></div>
                <div><dt class="text-xs text-gray-400">Kategori</dt><dd>@Model.KategoriPemohon</dd></div>
                @if (!string.IsNullOrEmpty(ppid?.Lembaga)) { <div><dt class="text-xs text-gray-400">Lembaga</dt><dd>@ppid.Lembaga</dd></div> }
                @if (!string.IsNullOrEmpty(ppid?.Jurusan)) { <div><dt class="text-xs text-gray-400">Program Studi</dt><dd>@ppid.Jurusan</dd></div> }
                <div><dt class="text-xs text-gray-400">Telepon</dt><dd>@pr?.Telepon</dd></div>
                <div><dt class="text-xs text-gray-400">Email</dt><dd>@pr?.Email</dd></div>
            </dl>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Data Permohonan</p>
            <dl class="space-y-2 text-sm">
                <div><dt class="text-xs text-gray-400">No. Permohonan (Sistem)</dt><dd class="font-mono font-bold text-blue-700">@Model.NoPermohonan</dd></div>
                <div><dt class="text-xs text-gray-400">No. Surat Permohonan</dt><dd class="font-mono">@(Model.NoSuratPermohonan ?? "-")</dd></div>
                <div><dt class="text-xs text-gray-400">Tanggal</dt><dd>@Model.TanggalPermohonan?.ToString("dd MMM yyyy")</dd></div>
                <div><dt class="text-xs text-gray-400">Judul</dt><dd>@Model.JudulPenelitian</dd></div>
                <div><dt class="text-xs text-gray-400">Keperluan</dt>
                    <dd class="flex flex-wrap gap-1 mt-0.5">
                        @if (Model.IsObservasi)      { <span class="bg-orange-100 text-orange-700 text-xs px-2 py-0.5 rounded-full">Observasi</span> }
                        @if (Model.IsPermintaanData) { <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full">Permintaan Data</span> }
                        @if (Model.IsWawancara)      { <span class="bg-purple-100 text-purple-700 text-xs px-2 py-0.5 rounded-full">Wawancara</span> }
                    </dd>
                </div>
                @if (!string.IsNullOrEmpty(Model.NamaBidang)) { <div><dt class="text-xs text-gray-400">Bidang</dt><dd class="text-xs">@Model.NamaBidang</dd></div> }
            </dl>
        </div>
    </div>

    @if (Model.Detail.Any()) {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 mt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Detail Keperluan</p>
            @foreach (var d in Model.Detail) {
                <div class="mb-3">
                    <p class="text-xs font-semibold text-gray-600">@d.Keperluan?.NamaKeperluan</p>
                    <p class="text-sm text-gray-700 mt-0.5">@d.DetailKeperluan</p>
                </div>
            }
        </div>
    }

    @if (Model.Dokumen.Any()) {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 mt-4">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Dokumen</p>
            <div class="space-y-2">
                @foreach (var d in Model.Dokumen) {
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-700">📄 @d.NamaDokumenPPID</span>
                        <a href="@d.UploadDokumenPPID" target="_blank" class="text-blue-600 text-xs hover:underline">Lihat</a>
                    </div>
                }
            </div>
        </div>
    }

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 mt-4 flex flex-wrap gap-3">
        @if (Model.StatusPPIDID == StatusId.TerdaftarSistem) {
            <a href="/petugas-loket/input-identifikasi/@Model.PermohonanPPIDID"
               class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg">
                📝 Input Identifikasi Awal
            </a>
        }
        @if (Model.StatusPPIDID >= StatusId.IdentifikasiAwal) {
            <a href="/petugas-loket/cetak-identifikasi/@Model.PermohonanPPIDID"
               class="bg-gray-600 hover:bg-gray-700 text-white text-sm font-semibold px-4 py-2 rounded-lg">
                🖨️ Cetak Formulir Identifikasi
            </a>
        }
        @if (Model.StatusPPIDID == StatusId.IdentifikasiAwal) {
            <a href="/petugas-loket/upload-ttd/@Model.PermohonanPPIDID"
               class="bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-semibold px-4 py-2 rounded-lg">
                ✍️ Upload Dokumen TTD
            </a>
        }
    </div>
</div>
