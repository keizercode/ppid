@model PermohonanPPID
@{
    ViewData["Title"] = "Input Identifikasi Awal";
    ViewData["Role"]  = "Petugas Loket";
    Layout = "_LayoutAdmin";
    var pr   = Model.Pribadi;
    var ppid = pr?.PribadiPPID;

    // Detail keperluan
    var detailObs  = Model.Detail.FirstOrDefault(d => d.KeperluanID == KeperluanId.Observasi)?.DetailKeperluan;
    var detailData = Model.Detail.FirstOrDefault(d => d.KeperluanID == KeperluanId.PermintaanData)?.DetailKeperluan;
    var detailWaw  = Model.Detail.FirstOrDefault(d => d.KeperluanID == KeperluanId.Wawancara)?.DetailKeperluan;

    // Alamat
    var alamat = string.Join(", ", new[] {
        pr?.Alamat,
        !string.IsNullOrEmpty(pr?.RT) ? $"RT {pr!.RT}" : null,
        !string.IsNullOrEmpty(pr?.RW) ? $"RW {pr!.RW}" : null,
        pr?.NamaKelurahan, pr?.NamaKecamatan, pr?.NamaKabupaten
    }.Where(s => !string.IsNullOrEmpty(s)));
}
<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
        <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 bg-yellow-100 rounded-xl flex items-center justify-center text-xl">📝</div>
            <div>
                <h3 class="font-bold text-gray-800">Input Identifikasi Awal</h3>
                <p class="text-xs font-mono text-gray-400">@Model.NoPermohonan · @pr?.Nama</p>
            </div>
        </div>

        <!-- Ringkasan Permohonan -->
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-5 text-sm">
            <p class="font-semibold text-blue-800 mb-3">📋 Ringkasan Permohonan</p>
            <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div>
                    <span class="text-blue-400 text-xs block">No. Permohonan (Sistem)</span>
                    <p class="text-blue-800 font-mono font-bold">@Model.NoPermohonan</p>
                </div>
                <div>
                    <span class="text-blue-400 text-xs block">No. Surat Permohonan</span>
                    <p class="text-blue-800 font-medium">@(Model.NoSuratPermohonan ?? "-")</p>
                </div>
                <div>
                    <span class="text-blue-400 text-xs block">Tanggal Permohonan</span>
                    <p class="text-blue-800 font-medium">@(Model.TanggalPermohonan?.ToString("dd MMMM yyyy") ?? "-")</p>
                </div>
                <div>
                    <span class="text-blue-400 text-xs block">Kategori</span>
                    <p class="text-blue-800 font-medium">@Model.KategoriPemohon</p>
                </div>
                <div class="col-span-2">
                    <span class="text-blue-400 text-xs block">Nama Pemohon</span>
                    <p class="text-blue-800 font-medium">@pr?.Nama &nbsp;·&nbsp; <span class="font-mono">@pr?.NIK</span></p>
                </div>
                @if (!string.IsNullOrEmpty(pr?.Telepon)) {
                    <div>
                        <span class="text-blue-400 text-xs block">Telepon</span>
                        <p class="text-blue-800">@pr.Telepon</p>
                    </div>
                }
                @if (!string.IsNullOrEmpty(alamat)) {
                    <div class="col-span-2">
                        <span class="text-blue-400 text-xs block">Alamat</span>
                        <p class="text-blue-700 text-xs">@alamat</p>
                    </div>
                }
                @if (!string.IsNullOrEmpty(ppid?.Lembaga)) {
                    <div class="col-span-2">
                        <span class="text-blue-400 text-xs block">Lembaga</span>
                        <p class="text-blue-700">@ppid.Lembaga @(!string.IsNullOrEmpty(ppid.Jurusan) ? $"/ {ppid.Jurusan}" : "")</p>
                    </div>
                }
                <div class="col-span-2">
                    <span class="text-blue-400 text-xs block">Judul Penelitian</span>
                    <p class="text-blue-700">@Model.JudulPenelitian</p>
                </div>
                <div class="col-span-2">
                    <span class="text-blue-400 text-xs block">Keperluan</span>
                    <div class="flex gap-1 mt-0.5 flex-wrap">
                        @if (Model.IsObservasi)      { <span class="bg-orange-100 text-orange-700 text-xs px-2 py-0.5 rounded-full">Observasi</span> }
                        @if (Model.IsPermintaanData) { <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full">Permintaan Data</span> }
                        @if (Model.IsWawancara)      { <span class="bg-purple-100 text-purple-700 text-xs px-2 py-0.5 rounded-full">Wawancara</span> }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.NamaBidang)) {
                    <div class="col-span-2">
                        <span class="text-blue-400 text-xs block">Unit Kerja / Bidang</span>
                        <p class="text-blue-700 text-xs">@Model.NamaBidang</p>
                    </div>
                }
            </div>
        </div>

        <!-- Detail keperluan jika ada -->
        @if ((Model.IsObservasi && !string.IsNullOrEmpty(detailObs)) ||
             (Model.IsPermintaanData && !string.IsNullOrEmpty(detailData)) ||
             (Model.IsWawancara && !string.IsNullOrEmpty(detailWaw))) {
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-5 text-sm space-y-2">
                @if (Model.IsObservasi && !string.IsNullOrEmpty(detailObs)) {
                    <div><span class="text-xs text-gray-400 block">Deskripsi Observasi</span><p class="text-gray-700 text-xs">@detailObs</p></div>
                }
                @if (Model.IsPermintaanData && !string.IsNullOrEmpty(detailData)) {
                    <div><span class="text-xs text-gray-400 block">Data yang Diperlukan</span><p class="text-gray-700 text-xs">@detailData</p></div>
                }
                @if (Model.IsWawancara && !string.IsNullOrEmpty(detailWaw)) {
                    <div><span class="text-xs text-gray-400 block">Materi Wawancara</span><p class="text-gray-700 text-xs">@detailWaw</p></div>
                }
            </div>
        }

        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 mb-5 text-sm text-amber-700 flex gap-2">
            <span>⚠️</span>
            <p>Setelah dikonfirmasi, sistem akan mengubah status ke <strong>Identifikasi Awal</strong>.
               Anda akan diarahkan ke halaman <strong>cetak formulir</strong> untuk dicetak dan ditandatangani pemohon.</p>
        </div>

        <form asp-action="InputIdentifikasiPost" asp-controller="PetugasLoket" asp-route-id="@Model.PermohonanPPIDID" method="post">
            @Html.AntiForgeryToken()
            <div class="flex gap-3">
                <a href="/petugas-loket" class="flex-1 text-center border border-gray-300 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
                <button type="submit" class="flex-grow bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-8 rounded-xl text-sm">
                    📄 Konfirmasi & Cetak Formulir →
                </button>
            </div>
        </form>

        @* Jika sudah di status identifikasi awal, tampilkan link cetak ulang *@
        @if (Model.StatusPPIDID >= StatusId.IdentifikasiAwal) {
            <div class="mt-3 text-center">
                <a href="/petugas-loket/cetak-identifikasi/@Model.PermohonanPPIDID"
                   class="text-blue-600 text-xs hover:underline">🖨️ Cetak ulang formulir</a>
            </div>
        }
    </div>
</div>
