@* ─── Views/KasubkelUmum/Index.cshtml ────────────────────────────────────── *@
@model DashboardVm
@{
    ViewData["Title"] = "Dashboard Kasubkel Umum";
    ViewData["Role"]  = "Kasubkel Umum";
    Layout = "_LayoutAdmin";
    var menunggu = ViewData["MenungguVerifikasi"] as List<PermohonanPPID> ?? new();
    int pctP = Model.Total>0?(int)Math.Round(Model.Proses*100.0/Model.Total):0;
    int pctS = Model.Total>0?(int)Math.Round(Model.Selesai*100.0/Model.Total):0;
}

<!-- CARDS -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="rounded-2xl p-5 relative overflow-hidden shadow-md min-h-[110px] flex flex-col justify-between" style="background:#0f1f4a">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-emerald-300/70 mb-1">Total Permohonan</p>
        <p class="text-5xl font-black text-white leading-none">@Model.Total</p>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-emerald-400 to-transparent"></div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Proses</p>
        <p class="text-4xl font-black text-amber-600 leading-none mb-2">@Model.Proses</p>
        <div class="w-full bg-amber-50 rounded-full h-1.5"><div class="bg-amber-400 h-full rounded-full" style="width:@pctP%"></div></div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
        <p class="text-[10px] font-bold uppercase tracking-[.15em] text-gray-400 mb-1">Selesai</p>
        <p class="text-4xl font-black text-emerald-600 leading-none mb-2">@Model.Selesai</p>
        <div class="w-full bg-emerald-50 rounded-full h-1.5"><div class="bg-emerald-500 h-full rounded-full" style="width:@pctS%"></div></div>
    </div>
</div>

<!-- CHARTS -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Total per Bulan</p>
        <div style="height:180px"><canvas id="chartTotal"></canvas></div>
    </div>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">Proses & Selesai per Bulan</p>
        <div style="height:180px"><canvas id="chartStatus"></canvas></div>
    </div>
</div>

<!-- ANTRIAN VERIFIKASI -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-50 flex items-center justify-between">
        <div>
            <p class="font-bold text-gray-700 text-sm">Antrian Verifikasi — Loket Umum</p>
            <p class="text-xs text-gray-400 mt-0.5">Form identifikasi menunggu verifikasi Kasubkel Umum</p>
        </div>
        @if(menunggu.Any()){<span class="bg-emerald-100 text-emerald-700 text-xs font-bold px-3 py-1.5 rounded-full">@menunggu.Count menunggu</span>}
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead><tr class="border-b border-gray-50">
                <th class="col-th">No Permohonan</th><th class="col-th">Nama Pemohon</th><th class="col-th">Kategori</th>
                <th class="col-th">Keperluan</th><th class="col-th">Tgl Permohonan</th><th class="col-th">Batas Waktu</th>
                <th class="col-th">Status</th><th class="col-th">Tgl Selesai</th><th class="col-th">Pengampu</th><th class="col-th">Action</th>
            </tr></thead>
            <tbody class="divide-y divide-gray-50">
                @if(!menunggu.Any()){
                    <tr><td colspan="10" class="px-6 py-12 text-center"><div class="text-3xl mb-2">✅</div><p class="text-sm text-gray-500 font-semibold">Semua form sudah diverifikasi</p></td></tr>
                } else {
                    @foreach(var item in menunggu){
                        <tr class="hover:bg-emerald-50/30 group">
                            <td class="px-4 py-3 font-mono text-xs text-blue-600 font-semibold">@item.NoPermohonan</td>
                            <td class="px-4 py-3 font-semibold text-gray-800 text-sm">@item.Pribadi?.Nama</td>
                            <td class="px-4 py-3 text-xs text-emerald-600 font-medium">🏢 @item.KategoriPemohon</td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if(item.IsObservasi){<span class="tag bg-orange-50 text-orange-700 border-orange-100">Obs</span>}
                                    @if(item.IsPermintaanData){<span class="tag bg-blue-50 text-blue-700 border-blue-100">Data</span>}
                                    @if(item.IsWawancara){<span class="tag bg-violet-50 text-violet-700 border-violet-100">Waw</span>}
                                </div>
                            </td>
                            <td class="px-4 py-3 text-xs text-gray-400">@item.TanggalPermohonan?.ToString("dd MMM yyyy")</td>
                            <td class="px-4 py-3 text-xs @(item.IsOverdue?"text-red-600 font-semibold":"text-gray-500")">@(item.BatasWaktu?.ToString("dd MMM yyyy")??"—")@(item.IsOverdue?" ⚠":"")</td>
                            <td class="px-4 py-3"><span class="text-[11px] bg-violet-50 text-violet-700 px-2 py-0.5 rounded-full font-medium">@item.Status?.NamaStatusPPID</span></td>
                            <td class="px-4 py-3 text-xs text-gray-400">@(item.TanggalSelesai?.ToString("dd MMM yyyy")??"—")</td>
                            <td class="px-4 py-3 text-xs text-gray-500">@(item.Pengampu??"—")</td>
                            <td class="px-4 py-3">
                                <div class="flex gap-1.5 opacity-80 group-hover:opacity-100">
                                    <a href="/kasubkel-umum/detail/@item.PermohonanPPIDID" class="text-[11px] bg-gray-100 hover:bg-gray-200 text-gray-700 px-2 py-1 rounded-lg font-medium">Detail</a>
                                    <a href="/kasubkel-umum/verifikasi/@item.PermohonanPPIDID" class="text-[11px] bg-[#002d7a] hover:bg-blue-900 text-white px-2.5 py-1 rounded-lg font-semibold">Verifikasi</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .col-th{padding:12px 16px;text-align:left;font-size:10px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em}
    .tag{font-size:10px;padding:1px 6px;border-radius:999px;font-weight:600;border:1px solid}
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const labels=@Html.Raw(Model.LabelsJson),totals=@Html.Raw(Model.TotalJson),proses=@Html.Raw(Model.ProsesJson),selesai=@Html.Raw(Model.SelesaiJson);
const o={responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#9ca3af',font:{size:11},boxWidth:12}}},scales:{x:{grid:{color:'rgba(0,0,0,.06)'},ticks:{color:'#9ca3af',font:{size:10}}},y:{grid:{color:'rgba(0,0,0,.06)'},ticks:{color:'#9ca3af',font:{size:10},stepSize:1},beginAtZero:true}}};
new Chart(document.getElementById('chartTotal'),{type:'bar',data:{labels,datasets:[{label:'Total',data:totals,backgroundColor:'rgba(16,185,129,.7)',borderRadius:6}]},options:o});
new Chart(document.getElementById('chartStatus'),{type:'line',data:{labels,datasets:[{label:'Proses',data:proses,borderColor:'#F59E0B',backgroundColor:'rgba(245,158,11,.12)',fill:true,tension:.4,pointRadius:4},{label:'Selesai',data:selesai,borderColor:'#10B981',backgroundColor:'rgba(16,185,129,.12)',fill:true,tension:.4,pointRadius:4}]},options:o});
</script>
}
