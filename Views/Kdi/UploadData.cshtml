@model UploadDataVm
@{
    ViewData["Title"] = "Upload Data Hasil";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}
<div class="max-w-lg mx-auto">
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
        <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center text-xl">📤</div>
        <div>
            <h3 class="font-bold text-gray-800">Upload Data Hasil Permohonan</h3>
            <p class="text-xs text-gray-400 mt-0.5 font-mono">@Model.NoPermohonan · @Model.NamaPemohon</p>
        </div>
    </div>
    <div class="p-6">
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 mb-5">
            <span class="text-[10px] text-gray-400 uppercase font-bold">Judul</span>
            <p class="font-semibold text-gray-800 text-sm mt-0.5">@Model.JudulPenelitian</p>
        </div>

        <form asp-action="UploadDataPost" asp-controller="Kdi" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PermohonanPPIDID" />
            <input type="hidden" asp-for="NoPermohonan" />
            <input type="hidden" asp-for="NamaPemohon" />
            <input type="hidden" asp-for="JudulPenelitian" />

            <!-- File upload -->
            <div class="mb-4">
                <label class="lbl">File Data / Dokumen Hasil <span class="text-red-400">*</span></label>
                <div id="dropzone" class="border-2 border-dashed border-gray-200 hover:border-blue-400 rounded-xl p-8 text-center transition-colors cursor-pointer bg-gray-50 hover:bg-blue-50">
                    <div class="text-3xl mb-2">📁</div>
                    <p class="text-sm font-semibold text-gray-600 mb-0.5">Klik untuk pilih file</p>
                    <p class="text-xs text-gray-400">PDF, Excel, ZIP — maks. 50MB</p>
                    <input asp-for="FileData" type="file" id="fileData" class="hidden" />
                    <p id="fileName" class="text-xs text-blue-600 mt-2 font-semibold hidden"></p>
                </div>
                <span asp-validation-for="FileData" class="err"></span>
            </div>

            <!-- Catatan -->
            <div class="mb-5">
                <label class="lbl">Catatan untuk Pemohon</label>
                <textarea asp-for="Catatan" rows="3"
                          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 resize-none bg-gray-50 focus:bg-white transition-colors"
                          placeholder="Petunjuk cara buka file, catatan penting..."></textarea>
            </div>

            <!-- Info box -->
            <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-3 mb-5 text-xs text-emerald-700 flex gap-2 items-start">
                <span class="mt-0.5">✅</span>
                <p>Setelah upload, status berubah ke <strong>Data Siap</strong> dan pemohon dapat mengunduh data serta mengisi kuesioner kepuasan.</p>
            </div>

            <div class="flex gap-3">
                <a href="/kdi" class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50 transition-colors">Batal</a>
                <button type="submit" class="flex-grow bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-2.5 px-8 rounded-xl text-sm shadow-sm transition-colors">⬆ Upload & Selesaikan</button>
            </div>
        </form>
    </div>
</div>
</div>

<style>
    .lbl { display:block; font-size:11px; font-weight:700; color:#6b7280; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px; }
    .err { color:#ef4444; font-size:11px; margin-top:3px; display:block; }
</style>

@section Scripts {
<script>
const dropzone = document.getElementById('dropzone');
const fileInput = document.getElementById('fileData');
const fileName  = document.getElementById('fileName');

dropzone.addEventListener('click', () => fileInput.click());
fileInput.addEventListener('change', function() {
    if (this.files[0]) {
        fileName.textContent = '✓ ' + this.files[0].name;
        fileName.classList.remove('hidden');
        dropzone.classList.add('border-blue-400', 'bg-blue-50');
    }
});
</script>
}
