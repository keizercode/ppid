@model UploadDataVm
@{
    ViewData["Title"] = "Upload Data Hasil";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}
<div class="max-w-lg mx-auto">
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
    <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center text-xl">📤</div>
        <div>
            <h3 class="font-bold text-gray-800">Upload Data Hasil Permohonan</h3>
            <p class="text-xs font-mono text-gray-400">@Model.NoPermohonan · @Model.NamaPemohon</p>
        </div>
    </div>
    <div class="bg-gray-50 rounded-xl p-3 mb-5 text-sm">
        <span class="text-xs text-gray-400">Judul</span>
        <p class="font-medium text-gray-800">@Model.JudulPenelitian</p>
    </div>
    <form asp-action="UploadDataPost" asp-controller="Kdi" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PermohonanPPIDID" />
        <input type="hidden" asp-for="NoPermohonan" />
        <input type="hidden" asp-for="NamaPemohon" />
        <input type="hidden" asp-for="JudulPenelitian" />
        <div class="mb-4">
            <label class="block text-xs font-semibold text-gray-700 mb-2">File Data / Dokumen Hasil <span class="text-red-500">*</span></label>
            <div class="border-2 border-dashed border-gray-300 rounded-xl p-5 text-center hover:border-blue-400 transition-colors">
                <div class="text-3xl mb-1">📁</div>
                <input asp-for="FileData" type="file" id="fileData" class="hidden" />
                <p class="text-xs text-gray-500">PDF, Excel, ZIP, dll — maks. 50MB</p>
                <button type="button" onclick="document.getElementById('fileData').click()"
                        class="mt-2 bg-blue-50 text-blue-600 text-xs font-medium px-4 py-1.5 rounded-lg hover:bg-blue-100">
                    Pilih File
                </button>
                <p id="fileName" class="text-xs text-blue-600 mt-1 hidden"></p>
            </div>
            <span asp-validation-for="FileData" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        <div class="mb-5">
            <label class="block text-xs font-semibold text-gray-700 mb-1">Catatan untuk Pemohon</label>
            <textarea asp-for="Catatan" rows="3" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none" placeholder="Petunjuk cara buka file, catatan penting..."></textarea>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-3 mb-5 text-xs text-green-700 flex gap-2">
            <span>✅</span>
            <p>Setelah upload, status berubah ke <strong>Data Siap</strong> dan pemohon bisa mengunduh data serta mengisi kuesioner.</p>
        </div>
        <div class="flex gap-3">
            <a href="/kdi" class="flex-1 text-center border border-gray-300 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
            <button type="submit" class="flex-grow bg-green-600 hover:bg-green-700 text-white font-semibold py-2.5 px-8 rounded-xl text-sm">⬆ Upload & Selesaikan</button>
        </div>
    </form>
</div>
</div>
@section Scripts {
<script>
document.getElementById('fileData').addEventListener('change', function() {
    const el = document.getElementById('fileName');
    el.textContent = '✓ ' + this.files[0].name;
    el.classList.remove('hidden');
});
</script>
}
