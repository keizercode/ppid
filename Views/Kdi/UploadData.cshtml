@model UploadDataSubTaskVm
@{
    ViewData["Title"] = "Upload Data — Permintaan Data";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}
<div class="max-w-lg mx-auto">
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

    <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-xl">📊</div>
        <div>
            <h3 class="font-bold text-gray-800">Upload Data Hasil Permintaan</h3>
            <p class="text-xs text-gray-400 font-mono mt-0.5">@Model.NoPermohonan · @Model.NamaPemohon</p>
        </div>
    </div>

    <div class="p-6">
        <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 mb-5">
            <span class="text-[10px] text-gray-400 uppercase font-bold">Judul Penelitian</span>
            <p class="font-semibold text-gray-800 text-sm mt-0.5">@Model.JudulPenelitian</p>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-xl p-3 mb-5 flex gap-2 items-start text-xs text-blue-700">
            <span class="mt-0.5">💡</span>
            <div>
                <p class="font-semibold mb-0.5">Sub-tugas Permintaan Data</p>
                <p>Upload file data yang diminta oleh pemohon. Format: PDF, Excel, CSV, ZIP. Setelah diupload, sub-tugas ini ditandai <strong>Selesai</strong> dan sistem akan otomatis memeriksa apakah semua tugas lain juga sudah selesai.</p>
            </div>
        </div>

        <form asp-action="UploadDataPost" asp-controller="Kdi" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SubTaskID" />
            <input type="hidden" asp-for="PermohonanPPIDID" />
            <input type="hidden" asp-for="NoPermohonan" />
            <input type="hidden" asp-for="NamaPemohon" />
            <input type="hidden" asp-for="JudulPenelitian" />

            @* ── Drag-and-Drop Upload Zone ── *@
            <div class="mb-4">
                <label class="lbl">File Data <span class="text-red-400">*</span></label>

                <div id="dropzone"
                     class="relative border-2 border-dashed border-blue-200 hover:border-blue-500 rounded-2xl p-8 text-center transition-all cursor-pointer bg-blue-50/30 hover:bg-blue-50 group"
                     ondragover="event.preventDefault();this.classList.add('border-blue-500','bg-blue-50')"
                     ondragleave="this.classList.remove('border-blue-500','bg-blue-50')"
                     ondrop="handleDrop(event)">

                    <div id="dz-idle">
                        <div class="text-4xl mb-3">📁</div>
                        <p class="text-sm font-bold text-gray-700 group-hover:text-blue-700 transition-colors">Drag & drop file di sini</p>
                        <p class="text-xs text-gray-400 mt-1">atau <span class="text-blue-600 font-semibold underline cursor-pointer" onclick="document.getElementById('fileData').click()">klik untuk memilih</span></p>
                        <p class="text-xs text-gray-300 mt-2">PDF · Excel (xlsx/csv) · Word · ZIP — maks. 50 MB</p>
                    </div>

                    <div id="dz-selected" class="hidden">
                        <div class="text-3xl mb-2">✅</div>
                        <p id="dz-filename" class="text-sm font-bold text-blue-700"></p>
                        <p id="dz-filesize" class="text-xs text-blue-500 mt-0.5"></p>
                        <button type="button" onclick="clearFile()"
                                class="mt-2 text-xs text-red-400 hover:text-red-600 underline">Hapus file</button>
                    </div>

                    <input asp-for="FileData" type="file" id="fileData"
                           accept=".pdf,.xlsx,.xls,.csv,.doc,.docx,.zip,.rar"
                           class="hidden" onchange="onFileSelected(this)" />
                </div>
                <span asp-validation-for="FileData" class="text-red-500 text-xs mt-1.5 block"></span>
            </div>

            @* ── Catatan ── *@
            <div class="mb-5">
                <label class="lbl">Catatan untuk Pemohon</label>
                <textarea asp-for="Catatan" rows="3"
                          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 resize-none bg-gray-50 focus:bg-white transition-colors"
                          placeholder="Penjelasan isi file, instruksi akses, format data, dll."></textarea>
            </div>

            @* ── Info box ── *@
            <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-3 mb-5 text-xs text-emerald-700 flex gap-2 items-start">
                <span>✅</span>
                <p>Setelah upload berhasil, sub-tugas Permintaan Data ditandai <strong>Selesai</strong>. Jika semua tugas paralel lain juga selesai, status permohonan otomatis menjadi <strong>Data Siap</strong> dan pemohon dapat mengunduh.</p>
            </div>

            <div class="flex gap-3">
                <a href="/kdi/subtasks/@Model.PermohonanPPIDID"
                   class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
                <button type="submit" id="btn-submit"
                        class="flex-grow bg-blue-600 hover:bg-blue-700 disabled:bg-blue-300 text-white font-bold py-2.5 px-8 rounded-xl text-sm shadow-sm transition-colors">
                    ⬆ Upload & Selesaikan Sub-tugas
                </button>
            </div>
        </form>
    </div>
</div>
</div>

<style>
    .lbl{display:block;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
</style>

@section Scripts {
<script>
function onFileSelected(input) {
    if (input.files && input.files[0]) {
        showFile(input.files[0]);
    }
}

function showFile(file) {
    document.getElementById('dz-idle').classList.add('hidden');
    document.getElementById('dz-selected').classList.remove('hidden');
    document.getElementById('dz-filename').textContent = file.name;
    document.getElementById('dz-filesize').textContent = formatSize(file.size);
    document.getElementById('dropzone').classList.add('border-blue-500','bg-blue-50');
}

function clearFile() {
    document.getElementById('fileData').value = '';
    document.getElementById('dz-idle').classList.remove('hidden');
    document.getElementById('dz-selected').classList.add('hidden');
    document.getElementById('dropzone').classList.remove('border-blue-500','bg-blue-50');
}

function handleDrop(e) {
    e.preventDefault();
    document.getElementById('dropzone').classList.remove('border-blue-500','bg-blue-50');
    const dt   = e.dataTransfer;
    const file = dt.files[0];
    if (!file) return;

    // Inject file ke input
    const input  = document.getElementById('fileData');
    const dT     = new DataTransfer();
    dT.items.add(file);
    input.files = dT.files;
    showFile(file);
}

function formatSize(bytes) {
    if (bytes < 1024)       return bytes + ' B';
    if (bytes < 1048576)    return (bytes/1024).toFixed(1) + ' KB';
    return (bytes/1048576).toFixed(1) + ' MB';
}

// Disable submit until file chosen
document.getElementById('fileData').addEventListener('change', function() {
    document.getElementById('btn-submit').disabled = !this.files.length;
});
document.getElementById('btn-submit').disabled = true;
</script>
}
