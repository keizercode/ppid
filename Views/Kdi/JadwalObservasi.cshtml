@* ════════════════════════════════════════════════════════════════════════════
   Views/Kdi/JadwalObservasi.cshtml
   UPDATE: tambah TeleponPIC field
   NOTE: View ini masih digunakan dari halaman Psmdi.cshtml/Bidang.cshtml
         via link /kdi/jadwal/{id} ketika SubTask belum ada (data lama).
         Untuk SubTask baru, controller sudah redirect ke JadwalSubTask view.
   ════════════════════════════════════════════════════════════════════════════ *@
@model JadwalObservasiVm
@{
    ViewData["Title"] = "Buat Jadwal Observasi";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}
<div class="max-w-lg mx-auto">
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
        <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center text-xl">🗓</div>
        <div>
            <h3 class="font-bold text-gray-800">Jadwal Observasi</h3>
            <p class="text-xs text-gray-400 mt-0.5">@Model.NamaPemohon · <span class="font-mono">@Model.NoPermohonan</span></p>
        </div>
    </div>
    <div class="p-6">

        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 mb-4 text-xs text-amber-700 flex gap-2 items-start">
            <span class="mt-0.5 flex-shrink-0">💡</span>
            <p>Jadwal ini akan ditampilkan kepada pemohon secara online melalui halaman lacak permohonan.</p>
        </div>

        <div class="bg-red-50 border border-red-300 rounded-xl p-4 mb-5 flex gap-3 items-start">
            <span class="text-red-500 text-xl flex-shrink-0 mt-0.5">🔔</span>
            <div>
                <p class="font-bold text-red-700 text-sm">Perhatian Petugas</p>
                <p class="text-red-600 text-xs mt-1 leading-relaxed">
                    <strong>Petugas wajib mengingatkan PIC mengenai jadwal observasi ini.</strong>
                    Pastikan narasumber / PIC sudah dikonfirmasi ketersediaannya sebelum jadwal disimpan.
                </p>
            </div>
        </div>

        <form asp-action="JadwalObservasiPost" asp-controller="Kdi" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PermohonanPPIDID"/>
            <input type="hidden" asp-for="NoPermohonan"/>
            <input type="hidden" asp-for="NamaPemohon"/>
            <div class="grid grid-cols-2 gap-3 mb-4">
                <div>
                    <label class="lbl">Tanggal <span class="text-red-400">*</span></label>
                    <input asp-for="TanggalObservasi" type="date" class="fld"/>
                    <span asp-validation-for="TanggalObservasi" class="err"></span>
                </div>
                <div>
                    <label class="lbl">Jam <span class="text-red-400">*</span></label>
                    <input asp-for="WaktuObservasi" type="time" class="fld"/>
                    <span asp-validation-for="WaktuObservasi" class="err"></span>
                </div>
            </div>

            @* ── PIC + Telepon ── *@
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-5">
                <div>
                    <label class="lbl">Nama PIC / Penanggung Jawab <span class="text-red-400">*</span></label>
                    <input asp-for="NamaPIC" class="fld" placeholder="Nama penanggung jawab observasi"/>
                    <span asp-validation-for="NamaPIC" class="err"></span>
                </div>
                <div>
                    <label class="lbl">No. Telepon PIC</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm select-none">📱</span>
                        <input asp-for="TeleponPIC" type="tel" class="fld pl-8" placeholder="08xxxxxxxxxx"/>
                    </div>
                    <span asp-validation-for="TeleponPIC" class="err"></span>
                    <p class="text-[10px] text-gray-400 mt-1">Untuk konfirmasi & pengingat jadwal</p>
                </div>
            </div>

            <div class="flex gap-3">
                <a href="/kdi" class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
                <button type="submit" class="flex-grow bg-orange-500 hover:bg-orange-600 text-white font-bold py-2.5 px-8 rounded-xl text-sm shadow-sm">📅 Simpan Jadwal</button>
            </div>
        </form>
    </div>
</div>
</div>
<style>
    .lbl{display:block;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
    .fld{display:block;width:100%;border:1px solid #e5e7eb;border-radius:10px;padding:9px 14px;font-size:13.5px;background:#fafafa;outline:none;transition:all .15s}
    .fld:focus{box-shadow:0 0 0 2.5px #f59e0b;border-color:transparent;background:white}
    .err{color:#ef4444;font-size:11px;margin-top:3px;display:block}
</style>
