@model JadwalObservasiVm
@{
    ViewData["Title"] = "Buat Jadwal Observasi";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}
<div class="max-w-lg mx-auto">
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
    <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center text-xl">🗓</div>
        <div>
            <h3 class="font-bold text-gray-800">Jadwal Observasi / Wawancara</h3>
            <p class="text-xs text-gray-400">@Model.NamaPemohon · <span class="font-mono">@Model.NoPermohonan</span></p>
        </div>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 mb-5 text-xs text-amber-700 flex gap-2">
        <span>💡</span>
        <p>Jadwal ini akan ditampilkan kepada pemohon secara online melalui halaman lacak permohonan.</p>
    </div>
    <form asp-action="JadwalObservasiPost" asp-controller="Kdi" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PermohonanPPIDID" />
        <input type="hidden" asp-for="NoPermohonan" />
        <input type="hidden" asp-for="NamaPemohon" />
        <div class="grid grid-cols-2 gap-3 mb-4">
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Tanggal <span class="text-red-500">*</span></label>
                <input asp-for="TanggalObservasi" type="date" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <span asp-validation-for="TanggalObservasi" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Jam <span class="text-red-500">*</span></label>
                <input asp-for="WaktuObservasi" type="time" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <span asp-validation-for="WaktuObservasi" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="mb-5">
            <label class="block text-xs font-semibold text-gray-700 mb-1">Nama PIC <span class="text-red-500">*</span></label>
            <input asp-for="NamaPIC" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nama penanggung jawab" />
            <span asp-validation-for="NamaPIC" class="text-red-500 text-xs mt-1 block"></span>
        </div>
        <div class="flex gap-3">
            <a href="/kdi" class="flex-1 text-center border border-gray-300 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
            <button type="submit" class="flex-grow bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2.5 px-8 rounded-xl text-sm">📅 Buat Jadwal</button>
        </div>
    </form>
</div>
</div>
