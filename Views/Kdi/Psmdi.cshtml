@model List<PermohonanPPID>
@{
    ViewData["Title"] = "PSMDI — Disposisi Masuk";
    ViewData["Role"]  = "KDI / PSMDI";
    Layout = "_LayoutAdmin";
}
<div class="flex items-center justify-between mb-4">
    <div>
        <p class="font-bold text-gray-700 text-sm">Disposisi ke PSMDI</p>
        <p class="text-xs text-gray-400 mt-0.5">Pusat Sistem & Manajemen Data Informasi</p>
    </div>
    <a href="/kdi" class="text-xs font-semibold text-blue-600 hover:text-blue-800 flex items-center gap-1">← Kembali</a>
</div>
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    @if (!Model.Any()) {
        <div class="text-center py-20">
  <partial name="Partials/Empty" />
            <p class="text-gray-400 text-sm font-medium">Belum ada disposisi masuk</p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-50">
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Nomor</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Pemohon</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Judul</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Observasi</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model) {
                        <tr class="hover:bg-blue-50/30 transition-colors">
                            <td class="px-5 py-3.5 font-mono text-xs text-blue-600 font-semibold">@item.NoPermohonan</td>
                            <td class="px-5 py-3.5 font-semibold text-gray-800 text-xs">@item.Pribadi?.Nama</td>
                            <td class="px-5 py-3.5 text-xs text-gray-500 max-w-xs truncate">@item.JudulPenelitian</td>
                            <td class="px-5 py-3.5">
                                @if (item.IsObservasi || item.IsWawancara) {
                                    <span class="text-xs bg-orange-50 text-orange-700 border border-orange-200 px-2 py-0.5 rounded-full font-medium">⚠️ Ya</span>
                                } else {
                                    <span class="text-xs text-gray-300 font-medium">Tidak</span>
                                }
                            </td>
                            <td class="px-5 py-3.5">
                                <div class="flex gap-1.5">
                                    <a href="/kdi/terima/@item.PermohonanPPIDID" class="text-xs bg-blue-100 hover:bg-blue-200 text-blue-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">Terima</a>
                                    @if (item.IsObservasi || item.IsWawancara) {
                                        <a href="/kdi/jadwal/@item.PermohonanPPIDID" class="text-xs bg-orange-100 hover:bg-orange-200 text-orange-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">Jadwal</a>
                                    }
                                    <a href="/kdi/upload-data/@item.PermohonanPPIDID" class="text-xs bg-emerald-100 hover:bg-emerald-200 text-emerald-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">Upload</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
