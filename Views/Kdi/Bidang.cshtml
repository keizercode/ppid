@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Bidang Terkait — Disposisi";
    ViewData["Role"]  = "KDI / Bidang Terkait";
    Layout = "_LayoutAdmin";
}
<div class="flex items-center justify-between mb-4">
    <h3 class="font-semibold text-gray-700 text-sm">Disposisi ke Bidang Terkait</h3>
    <a href="/kdi" class="text-sm text-blue-600 hover:text-blue-800">← Kembali</a>
</div>
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    @if (!Model.Any()) {
        <div class="text-center py-14 text-gray-400"><div class="text-3xl mb-2">📭</div><p class="text-sm">Belum ada disposisi</p></div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead><tr class="bg-gray-50 border-b text-left">
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Nomor</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Pemohon</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Bidang</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Keperluan</th>
                    <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Aksi</th>
                </tr></thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var item in Model) {
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-3 font-mono text-xs text-blue-600">@item.NoPermohonan</td>
                            <td class="px-4 py-3 font-medium text-gray-800 text-xs">@item.Pribadi?.Nama</td>
                            <td class="px-4 py-3 text-xs">
                                <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-full">@item.NamaBidang</span>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap gap-1">
                                    @if (item.IsObservasi)      { <span class="text-xs bg-orange-100 text-orange-700 px-1.5 py-0.5 rounded">Obs</span> }
                                    @if (item.IsPermintaanData) { <span class="text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded">Data</span> }
                                    @if (item.IsWawancara)      { <span class="text-xs bg-purple-100 text-purple-700 px-1.5 py-0.5 rounded">Waw</span> }
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex gap-1.5">
                                    <a href="/kdi/terima/@item.PermohonanPPIDID" class="text-xs bg-blue-100 hover:bg-blue-200 text-blue-700 px-2 py-1 rounded-lg">Terima</a>
                                    @if (item.IsObservasi || item.IsWawancara) {
                                        <a href="/kdi/jadwal/@item.PermohonanPPIDID" class="text-xs bg-orange-100 hover:bg-orange-200 text-orange-700 px-2 py-1 rounded-lg">Jadwalkan</a>
                                    }
                                    <a href="/kdi/upload-data/@item.PermohonanPPIDID" class="text-xs bg-green-100 hover:bg-green-200 text-green-700 px-2 py-1 rounded-lg">Upload Data</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
