@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Bidang Terkait — Disposisi";
    ViewData["Role"]  = "KDI / Bidang Terkait";
    Layout = "_LayoutAdmin";
    var q = ViewData["Q"] as string;
}

<div class="flex items-center justify-between mb-4">
    <div>
        <p class="font-bold text-gray-700 text-sm">Disposisi ke Bidang Terkait</p>
        <p class="text-xs text-gray-400 mt-0.5">Unit / bidang pengelola data terkait</p>
    </div>
    <a href="/kdi" class="text-xs font-semibold text-blue-600 hover:text-blue-800 flex items-center gap-1 transition-colors">← Kembali</a>
</div>

<!-- Search -->
<form method="get" class="mb-4">
    <div class="flex gap-2">
        <input type="text" name="q" value="@q" placeholder="Cari nama / nomor permohonan..."
               class="flex-1 border border-gray-200 rounded-xl px-4 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-300" />
        <button type="submit" class="bg-[#002d7a] hover:bg-blue-900 text-white text-xs font-semibold px-4 py-2 rounded-xl transition-colors">Cari</button>
        @if (!string.IsNullOrEmpty(q)) {
            <a href="/kdi/bidang" class="border border-gray-200 text-gray-500 text-xs font-medium px-3 py-2 rounded-xl hover:bg-gray-50 transition-colors">Reset</a>
        }
    </div>
</form>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    @if (!Model.Any()) {
        <div class="text-center py-20">
            <partial name="Partials/Empty" />
            <p class="text-gray-400 text-sm font-medium">
                @(string.IsNullOrEmpty(q) ? "Belum ada disposisi ke bidang terkait" : $"Tidak ada hasil untuk \"{q}\"")
            </p>
        </div>
    } else {
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-gray-50">
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Nomor</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Pemohon</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Bidang</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Status</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Keperluan</th>
                        <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model) {
                        <tr class="hover:bg-blue-50/30 transition-colors group">
                            <td class="px-5 py-3.5 font-mono text-xs text-blue-600 font-semibold">@item.NoPermohonan</td>
                            <td class="px-5 py-3.5 font-semibold text-gray-800 text-xs">@item.Pribadi?.Nama</td>
                            <td class="px-5 py-3.5">
                                <span class="inline-flex items-center gap-1 text-xs bg-emerald-50 text-emerald-700 border border-emerald-100 px-2.5 py-0.5 rounded-full font-medium">
                                    🏢 @item.NamaBidang
                                </span>
                            </td>
                            <td class="px-5 py-3.5">
                                <span class="text-xs bg-amber-50 text-amber-700 px-2.5 py-0.5 rounded-full font-medium">
                                    @item.Status?.NamaStatusPPID
                                </span>
                            </td>
                            <td class="px-5 py-3.5">
                                <div class="flex flex-wrap gap-1">
                                    @if (item.IsObservasi)      { <span class="text-xs bg-orange-50 text-orange-700 border border-orange-100 px-2 py-0.5 rounded-full font-medium">Obs</span> }
                                    @if (item.IsPermintaanData) { <span class="text-xs bg-blue-50 text-blue-700 border border-blue-100 px-2 py-0.5 rounded-full font-medium">Data</span> }
                                    @if (item.IsWawancara)      { <span class="text-xs bg-violet-50 text-violet-700 border border-violet-100 px-2 py-0.5 rounded-full font-medium">Waw</span> }
                                </div>
                            </td>
                            <td class="px-5 py-3.5">
                                <div class="flex gap-1.5 flex-wrap opacity-80 group-hover:opacity-100 transition-opacity">
                                    @if (item.StatusPPIDID == StatusId.Didisposisi) {
                                        <a href="/kdi/terima/@item.PermohonanPPIDID"
                                           class="text-xs bg-blue-100 hover:bg-blue-200 text-blue-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">Terima</a>
                                    }
                                    @if (item.StatusPPIDID == StatusId.DiProses && item.IsObservasi) {
                                        <a href="/kdi/jadwal/@item.PermohonanPPIDID"
                                           class="text-xs bg-orange-100 hover:bg-orange-200 text-orange-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">Jadwal Obs</a>
                                    }
                                    @* BUG FIX: Tombol untuk menyelesaikan observasi *@
                                    @if (item.StatusPPIDID == StatusId.ObservasiDijadwalkan) {
                                        <a href="/kdi/selesai-observasi/@item.PermohonanPPIDID"
                                           class="text-xs bg-purple-100 hover:bg-purple-200 text-purple-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">✅ Selesai Obs</a>
                                    }
                                    @* Upload Data: hanya tampil jika wawancara tidak diperlukan,
   atau wawancara sudah selesai *@
@{
    bool siapUpload =
        (item.StatusPPIDID == StatusId.DiProses && !item.IsWawancara) ||
        (item.StatusPPIDID == StatusId.ObservasiSelesai && !item.IsWawancara) ||
        item.StatusPPIDID == StatusId.WawancaraSelesai;
}
@if (siapUpload) {
    <a href="/kdi/upload-data/@item.PermohonanPPIDID"
       class="text-xs bg-emerald-100 hover:bg-emerald-200 text-emerald-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">
        Upload Data
    </a>
}

@* Tombol jadwal wawancara: jika observasi selesai tapi wawancara belum *@
@if (item.StatusPPIDID == StatusId.ObservasiSelesai && item.IsWawancara) {
    <a href="/kdi/jadwal-wawancara/@item.PermohonanPPIDID"
       class="text-xs bg-violet-100 hover:bg-violet-200 text-violet-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">
        🎤 Jadwal Wawancara
    </a>
}
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
