@model ParallelTasksVm
@{
    ViewData["Title"] = $"Tugas Paralel — {Model.Permohonan.NoPermohonan}";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
    var p = Model.Permohonan;
    var pr = p.Pribadi;
}

<div class="max-w-4xl mx-auto">

    <a href="/kdi" class="inline-flex items-center gap-1.5 text-blue-600 hover:text-blue-800 text-sm font-medium mb-5">← Kembali ke Dashboard</a>

    @* ── Header Card ── *@
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 mb-5">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
                <p class="text-[10px] text-gray-400 uppercase tracking-widest font-semibold">Nomor Permohonan</p>
                <h2 class="text-xl font-extrabold font-mono text-gray-800 mt-0.5">@p.NoPermohonan</h2>
                <p class="text-sm text-gray-600 mt-1">@pr?.Nama
                    @if (!string.IsNullOrEmpty(pr?.PribadiPPID?.Lembaga)) {
                        <span class="text-gray-400 text-xs ml-1">· @pr.PribadiPPID!.Lembaga</span>
                    }
                </p>
                <p class="text-xs text-gray-500 mt-0.5 leading-snug max-w-lg">@p.JudulPenelitian</p>
            </div>
            @* Progress ring *@
            <div class="flex items-center gap-3 flex-shrink-0">
                <div class="relative">
                    <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
                        <circle cx="18" cy="18" r="14" fill="none" stroke="#F3F4F6" stroke-width="3.5"/>
                        <circle cx="18" cy="18" r="14" fill="none"
                                stroke="@(Model.AllDone ? "#10B981" : "#3B82F6")" stroke-width="3.5"
                                stroke-dasharray="@(Math.Round(87.96 * Model.ProgressPct / 100.0, 1)) 87.96"
                                stroke-linecap="round"/>
                    </svg>
                    <span class="absolute inset-0 flex items-center justify-center text-[11px] font-black text-gray-700 rotate-90">
                        @Model.DoneTasks/@Model.TotalTasks
                    </span>
                </div>
                <div>
                    <p class="text-[10px] text-gray-400 uppercase font-bold">Progress</p>
                    <p class="text-sm font-bold @(Model.AllDone ? "text-emerald-600" : "text-blue-600")">
                        @(Model.AllDone ? "Semua Selesai ✓" : $"{Model.DoneTasks} dari {Model.TotalTasks} selesai")
                    </p>
                    <p class="text-xs text-gray-400">@p.Status?.NamaStatusPPID</p>
                </div>
            </div>
        </div>

        @if (Model.AllDone)
        {
            <div class="mt-4 bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 flex items-center gap-3">
                <span class="text-2xl">🎉</span>
                <div>
                    <p class="font-bold text-emerald-800 text-sm">Semua tugas telah selesai!</p>
                    <p class="text-emerald-600 text-xs">Status permohonan otomatis menjadi <strong>Data Siap</strong>. Pemohon dapat mengunduh dan mengisi kuesioner.</p>
                </div>
            </div>
        }
    </div>

    @* ── Subtask Cards ── *@
    <div class="grid grid-cols-1 @(Model.TotalTasks > 1 ? "md:grid-cols-" + Model.TotalTasks : "") gap-4 mb-5">
        @foreach (var task in Model.SubTasks)
        {

                string cardBorder = task.JenisTask switch
                {
                    "PermintaanData" => "border-blue-200",
                    "Observasi"      => "border-orange-200",
                    "Wawancara"      => "border-violet-200",
                    _                => "border-gray-200"
                };
                string iconBg = task.JenisTask switch
                {
                    "PermintaanData" => "bg-blue-100",
                    "Observasi"      => "bg-orange-100",
                    "Wawancara"      => "bg-violet-100",
                    _                => "bg-gray-100"
                };
                string statusDot = task.StatusTask switch
                {
                    SubTaskStatus.Selesai    => "bg-emerald-500",
                    SubTaskStatus.InProgress => "bg-amber-400 animate-pulse",
                    _                        => "bg-gray-300"
                };
                string headerBg = task.StatusTask switch
                {
                    SubTaskStatus.Selesai    => "bg-emerald-50",
                    SubTaskStatus.InProgress => "bg-amber-50",
                    _                        => "bg-gray-50"
                };

            <div class="bg-white rounded-2xl border @cardBorder shadow-sm overflow-hidden flex flex-col">

                @* Card Header *@
                <div class="@headerBg px-4 py-3 flex items-center gap-3 border-b @cardBorder">
                    <div class="w-9 h-9 @iconBg rounded-xl flex items-center justify-center text-lg flex-shrink-0">
                        @JenisTask.GetIcon(task.JenisTask)
                    </div>
                    <div class="flex-1">
                        <p class="font-bold text-gray-800 text-sm">@JenisTask.GetLabel(task.JenisTask)</p>
                        <div class="flex items-center gap-1.5 mt-0.5">
                            <span class="w-1.5 h-1.5 rounded-full @statusDot flex-shrink-0"></span>
                            <span class="text-xs @(task.IsSelesai ? "text-emerald-700 font-semibold" : task.IsInProgress ? "text-amber-700" : "text-gray-400")">
                                @SubTaskStatus.GetLabel(task.StatusTask)
                            </span>
                        </div>
                    </div>
                    @if (task.IsSelesai)
                    {
                        <span class="w-7 h-7 bg-emerald-100 rounded-full flex items-center justify-center text-emerald-600 text-sm font-bold">✓</span>
                    }
                </div>

                @* Card Body *@
                <div class="p-4 flex-1 flex flex-col gap-3">

                    @* Jadwal info (Observasi / Wawancara) *@
                    @if (task.JenisTask != JenisTask.PermintaanData && task.HasJadwal)
                    {
                        <div class="bg-gray-50 rounded-lg px-3 py-2">
                            <p class="text-[10px] text-gray-400 uppercase font-bold">Jadwal</p>
                            <p class="text-sm font-semibold text-gray-800">@task.TanggalJadwal?.ToString("dddd, dd MMM yyyy")</p>
                            <p class="text-xs text-gray-500">Pukul @task.WaktuJadwal?.ToString("HH:mm") · @(task.NamaPIC ?? "—")</p>
                        </div>
                    }

                    @* File info (PermintaanData / Wawancara dengan file) *@
                    @if (task.HasFile)
                    {
                        <div class="bg-emerald-50 border border-emerald-100 rounded-lg px-3 py-2 flex items-center gap-2">
                            <span class="text-emerald-600">📎</span>
                            <div class="min-w-0">
                                <p class="text-xs font-semibold text-emerald-700 truncate">@(task.NamaFile ?? "File tersedia")</p>
                                <a href="@task.FilePath" target="_blank"
                                   class="text-[10px] text-emerald-600 hover:underline">Lihat / Unduh →</a>
                            </div>
                        </div>
                    }

                    @* Catatan *@
                    @if (!string.IsNullOrEmpty(task.Catatan))
                    {
                        <p class="text-xs text-gray-500 leading-relaxed">📝 @task.Catatan</p>
                    }

                    @* Spacer *@
                    <div class="flex-1"></div>

                    @* Action Buttons *@
                    @if (!task.IsSelesai)
                    {
                        <div class="space-y-2">
                            @if (task.JenisTask == JenisTask.PermintaanData)
                            {
                                <a href="/kdi/upload-data/@p.PermohonanPPIDID"
                                   class="flex items-center justify-center gap-2 w-full bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2.5 rounded-xl transition-colors">
                                    ⬆ Upload Data Hasil
                                </a>
                                if (task.IsPending) {
                                    <p class="text-[10px] text-blue-500 text-center">Klik untuk upload file data yang diminta pemohon</p>
                                }
                            }

                            @if (task.JenisTask == JenisTask.Observasi)
                            {
                                if (task.IsPending || task.IsInProgress)
                                {
                                    @if (!task.HasJadwal) {
                                        <a href="/kdi/jadwal/@p.PermohonanPPIDID"
                                           class="flex items-center justify-center gap-2 w-full bg-orange-500 hover:bg-orange-600 text-white text-xs font-bold py-2.5 rounded-xl transition-colors">
                                            📅 Buat Jadwal Observasi
                                        </a>
                                    } else {
                                        <a href="/kdi/jadwal/@p.PermohonanPPIDID"
                                           class="flex items-center justify-center gap-2 w-full bg-orange-50 hover:bg-orange-100 border border-orange-200 text-orange-700 text-xs font-semibold py-2 rounded-xl">
                                            ✏️ Edit Jadwal
                                        </a>
                                        <a href="/kdi/selesai-observasi/@p.PermohonanPPIDID"
                                           class="flex items-center justify-center gap-2 w-full bg-orange-600 hover:bg-orange-700 text-white text-xs font-bold py-2.5 rounded-xl transition-colors">
                                            ✅ Tandai Selesai
                                        </a>
                                    }
                                }
                            }

                            @if (task.JenisTask == JenisTask.Wawancara)
                            {
                                if (!task.HasJadwal) {
                                    <a href="/kdi/jadwal-wawancara/@p.PermohonanPPIDID"
                                       class="flex items-center justify-center gap-2 w-full bg-violet-600 hover:bg-violet-700 text-white text-xs font-bold py-2.5 rounded-xl transition-colors">
                                        📅 Buat Jadwal Wawancara
                                    </a>
                                } else {
                                    <a href="/kdi/jadwal-wawancara/@p.PermohonanPPIDID"
                                       class="flex items-center justify-center gap-2 w-full bg-violet-50 hover:bg-violet-100 border border-violet-200 text-violet-700 text-xs font-semibold py-2 rounded-xl">
                                        ✏️ Edit Jadwal
                                    </a>
                                    <a href="/kdi/selesai-wawancara/@p.PermohonanPPIDID"
                                       class="flex items-center justify-center gap-2 w-full bg-violet-600 hover:bg-violet-700 text-white text-xs font-bold py-2.5 rounded-xl transition-colors">
                                        ✅ Tandai Selesai
                                    </a>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="bg-emerald-50 border border-emerald-100 rounded-xl py-2 text-center">
                            <p class="text-xs font-semibold text-emerald-700">✓ Selesai</p>
                            @if (task.SelesaiAt.HasValue)
                            {
                                <p class="text-[10px] text-emerald-500">@task.SelesaiAt.Value.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</p>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* ── Progress Timeline ── *@
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
        <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">Alur Penyelesaian Paralel</p>
        <div class="flex items-center gap-2 overflow-x-auto pb-1">
            @{
                var steps = new[]
                {
                    ("Disposisi Diterima", p.StatusPPIDID >= StatusId.DiProses),
                    ("Tugas Aktif", Model.SubTasks.Any(t => t.IsInProgress)),
                    ("Semua Selesai", Model.AllDone),
                    ("Data Siap", p.StatusPPIDID >= StatusId.DataSiap),
                };
            }
            @foreach (var (label, done) in steps)
            {
                <div class="flex items-center gap-2 flex-shrink-0">
                    <div class="flex flex-col items-center">
                        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold @(done ? "bg-emerald-500 text-white" : "bg-gray-100 text-gray-400")">
                            @(done ? "✓" : "○")
                        </div>
                        <p class="text-[9px] text-gray-400 mt-1 text-center max-w-[64px] leading-tight">@label</p>
                    </div>
                    @if (label != "Data Siap")
                    {
                        <div class="w-10 h-0.5 @(done ? "bg-emerald-300" : "bg-gray-100") flex-shrink-0 mb-4"></div>
                    }
                </div>
            }
        </div>
    </div>

</div>
