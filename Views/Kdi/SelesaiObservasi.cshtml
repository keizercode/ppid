@model SelesaiObservasiVm
@{
    ViewData["Title"] = "Selesaikan Observasi";
    ViewData["Role"] = "KDI";
    Layout = "_LayoutAdmin";
}

<div class="max-w-lg mx-auto">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

        <div class="px-6 py-5 border-b border-gray-50 flex items-center gap-3">
            <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center text-xl">✅</div>
            <div>
                <h3 class="font-bold text-gray-800">Konfirmasi Observasi Selesai</h3>
                <p class="text-xs text-gray-400 mt-0.5">@Model.NamaPemohon · <span
                    class="font-mono">@Model.NoPermohonan</span></p>
                </div>
            </div>

            <div class="p-6">
                <div class="bg-gray-50 border border-gray-100 rounded-xl p-3 mb-5">
                    <span class="text-[10px] text-gray-400 uppercase font-bold">Judul Penelitian</span>
                    <p class="font-semibold text-gray-800 text-sm mt-0.5">@Model.JudulPenelitian</p>
                </div>

                <div
                    class="bg-orange-50 border border-orange-200 rounded-xl p-3 mb-5 text-xs text-orange-700 flex gap-2 items-start">
                    <span class="mt-0.5">💡</span>
                    <p>Setelah dikonfirmasi, status berubah ke <strong>Observasi Selesai</strong> dan Anda akan diarahkan ke
                        halaman Upload Data.</p>
                    </div>

                    <form asp-action="SelesaiObservasiPost" asp-controller="Kdi" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="PermohonanPPIDID" />
                        <input type="hidden" asp-for="NoPermohonan" />
                        <input type="hidden" asp-for="NamaPemohon" />
                        <input type="hidden" asp-for="JudulPenelitian" />

                        <div class="mb-5">
                            <label class="lbl">Catatan Hasil Observasi <span
                                class="text-gray-400 font-normal">(opsional)</span></label>
                                <textarea asp-for="Catatan" rows="3"
                                          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-300 resize-none bg-gray-50 focus:bg-white transition-colors"
                                          placeholder="Catatan internal mengenai hasil observasi..."></textarea>
                            </div>

                            <div class="flex gap-3">
                                <a href="/kdi"
                                   class="flex-1 text-center border border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50 transition-colors">Batal</a>
                                <button type="submit"
                                        class="flex-grow bg-orange-500 hover:bg-orange-600 text-white font-bold py-2.5 px-8 rounded-xl text-sm shadow-sm transition-colors">
                                    ✅ Konfirmasi Selesai
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <style>
                .lbl {
                    display: block;
                    font-size: 11px;
                    font-weight: 700;
                    color: #6b7280;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                    margin-bottom: 4px;
                }
            </style>
