@model TerimaDisposisiVm
@{
    ViewData["Title"] = "Terima Disposisi";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}
<div class="max-w-xl mx-auto">
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7">
    <div class="flex items-center gap-3 mb-5">
        <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-xl">📥</div>
        <div>
            <h3 class="font-bold text-gray-800">Terima Disposisi Permintaan Data</h3>
            <p class="text-xs font-mono text-gray-400">@Model.NoPermohonan · @Model.NamaPemohon</p>
        </div>
    </div>
    <div class="bg-gray-50 rounded-xl p-4 mb-5 text-sm space-y-2">
        <div><span class="text-xs text-gray-400">Judul</span><p class="font-medium text-gray-800">@Model.JudulPenelitian</p></div>
        <div><span class="text-xs text-gray-400">Latar Belakang</span><p class="text-gray-700 text-xs line-clamp-3">@Model.LatarBelakang</p></div>
        @if (!string.IsNullOrEmpty(Model.CatatanDisposisi)) {
            <div><span class="text-xs text-gray-400">Catatan Kepegawaian</span><p class="text-gray-700 text-xs">@Model.CatatanDisposisi</p></div>
        }
        <div><span class="text-xs text-gray-400">Perlu Observasi</span>
            <p class="@(Model.PerluObservasi ? "text-orange-600 font-semibold" : "text-gray-600") text-xs">
                @(Model.PerluObservasi ? "⚠️ Ya — perlu jadwal" : "Tidak")
            </p>
        </div>
    </div>
    <form asp-action="TerimaDisposisiPost" asp-controller="Kdi" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PermohonanPPIDID" />
        <input type="hidden" asp-for="NoPermohonan" />
        <input type="hidden" asp-for="NamaPemohon" />
        <input type="hidden" asp-for="JudulPenelitian" />
        <input type="hidden" asp-for="LatarBelakang" />
        <input type="hidden" asp-for="PerluObservasi" />
        <div class="mb-5">
            <label class="block text-xs font-semibold text-gray-700 mb-1">Catatan Penerimaan</label>
            <textarea asp-for="Catatan" rows="3" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none" placeholder="Catatan internal..."></textarea>
        </div>
        <div class="flex gap-3">
            <a href="/kdi" class="flex-1 text-center border border-gray-300 text-gray-600 font-semibold py-2.5 rounded-xl text-sm hover:bg-gray-50">Batal</a>
            <button type="submit" class="flex-grow bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-8 rounded-xl text-sm">✓ Terima</button>
        </div>
    </form>
</div>
</div>
