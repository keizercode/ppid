@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Dashboard KDI";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}

@{
    int kdiPsmdi  = Model.Count(p => string.IsNullOrEmpty(p.NamaBidang));
    int kdiBidang = Model.Count(p => !string.IsNullOrEmpty(p.NamaBidang));
    int kdiTotal  = Model.Count;

    int pctPsmdi  = kdiTotal > 0 ? (int)Math.Round(kdiPsmdi  * 100.0 / kdiTotal) : 0;
    int pctBidang = kdiTotal > 0 ? (int)Math.Round(kdiBidang * 100.0 / kdiTotal) : 0;
}

<!-- Quick Access Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

    <div class="kdi-card bg-[#0f1f4a] rounded-2xl p-5 relative overflow-hidden shadow-md flex flex-col justify-between min-h-[120px]">
        <div class="kdi-bg-circle"></div>
        <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-blue-300/70 mb-1">Total Disposisi</p>
            <p class="text-5xl font-black text-white leading-none tracking-tight" style="font-variant-numeric:tabular-nums">@kdiTotal</p>
        </div>
        <div class="flex items-center justify-between mt-3">
            <div class="flex gap-2">
                <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-blue-200/60 bg-white/5 px-2 py-0.5 rounded-full border border-white/10">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-300 animate-pulse"></span>
                    @kdiPsmdi PSMDI
                </span>
                <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-emerald-200/60 bg-white/5 px-2 py-0.5 rounded-full border border-white/10">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-300"></span>
                    @kdiBidang Bidang
                </span>
            </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-400 via-blue-300 to-transparent"></div>
    </div>

    <a href="/kdi/psmdi" class="kdi-card group bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden flex flex-col justify-between min-h-[120px]">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-gray-400 mb-1">PSMDI</p>
                <p class="text-4xl font-black text-gray-800 leading-none tracking-tight" style="font-variant-numeric:tabular-nums">@kdiPsmdi</p>
            </div>
            <div class="relative flex-shrink-0">
                <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#EFF6FF" stroke-width="3.5" />
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#3B82F6" stroke-width="3.5"
                            stroke-dasharray="@(Math.Round(87.96 * pctPsmdi / 100.0, 1)) 87.96" stroke-linecap="round" />
                </svg>
                <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-blue-500 rotate-90">@pctPsmdi%</span>
            </div>
        </div>
        <div>
            <p class="text-xs text-gray-400 mb-2">Peran Serta Masyarakat, Data dan Informasi</p>
            <div class="w-full bg-blue-50 rounded-full h-1 overflow-hidden">
                <div class="kdi-bar bg-blue-500 h-full rounded-full" style="width:@pctPsmdi%"></div>
            </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-500 to-transparent opacity-30"></div>
        <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-200 group-hover:text-blue-400 group-hover:translate-x-0.5 transition-all"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
    </a>

    <a href="/kdi/bidang" class="kdi-card group bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden flex flex-col justify-between min-h-[120px]">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-gray-400 mb-1">Bidang Terkait</p>
                <p class="text-4xl font-black text-gray-800 leading-none tracking-tight" style="font-variant-numeric:tabular-nums">@kdiBidang</p>
            </div>
            <div class="relative flex-shrink-0">
                <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#ECFDF5" stroke-width="3.5" />
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#10B981" stroke-width="3.5"
                            stroke-dasharray="@(Math.Round(87.96 * pctBidang / 100.0, 1)) 87.96" stroke-linecap="round" />
                </svg>
                <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-emerald-500 rotate-90">@pctBidang%</span>
            </div>
        </div>
        <div>
            <p class="text-xs text-gray-400 mb-2">Unit / bidang pengelola data terkait</p>
            <div class="w-full bg-emerald-50 rounded-full h-1 overflow-hidden">
                <div class="kdi-bar bg-emerald-500 h-full rounded-full" style="width:@pctBidang%"></div>
            </div>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-emerald-500 to-transparent opacity-30"></div>
        <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-200 group-hover:text-emerald-400 group-hover:translate-x-0.5 transition-all"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
    </a>

</div>

<style>
    .kdi-card { transition: transform .18s ease, box-shadow .18s ease; }
    .kdi-card:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(0,0,0,.09); }
    .kdi-bg-circle { position:absolute; top:-24px; right:-24px; width:100px; height:100px; border-radius:50%; background:rgba(255,255,255,.04); pointer-events:none; }
    .kdi-bar { animation: kdiBarGrow .8s cubic-bezier(.4,0,.2,1) .15s both; transform-origin: left; }
    @@keyframes kdiBarGrow { from { transform:scaleX(0); } to { transform:scaleX(1); } }
</style>

<!-- All disposisi table -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-50 flex items-center justify-between">
        <p class="font-bold text-gray-700 text-sm">Semua Disposisi Masuk</p>
        <span class="text-xs text-gray-400 bg-gray-50 border border-gray-200 rounded-lg px-2.5 py-1">@Model.Count total</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-50">
                    <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Nomor</th>
                    <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Pemohon</th>
                    <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Judul</th>
                    <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Disposisi</th>
                    <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Status</th>
                    <th class="px-5 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-blue-50/30 transition-colors group">
                        <td class="px-5 py-3.5 font-mono text-xs text-blue-600 font-semibold">@item.NoPermohonan</td>
                        <td class="px-5 py-3.5 font-semibold text-gray-800 text-xs">@item.Pribadi?.Nama</td>
                        <td class="px-5 py-3.5 text-xs text-gray-500 max-w-xs truncate">@item.JudulPenelitian</td>
                        <td class="px-5 py-3.5">
                            @if (string.IsNullOrEmpty(item.NamaBidang))
                            {
                                <span class="inline-flex items-center gap-1.5 text-xs bg-blue-50 text-blue-700 px-2.5 py-0.5 rounded-full font-medium">
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400 flex-shrink-0"></span>PSMDI
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 text-xs bg-emerald-50 text-emerald-700 px-2.5 py-0.5 rounded-full font-medium">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>@item.NamaBidang
                                </span>
                            }
                        </td>
                        <td class="px-5 py-3.5">
                            @{
                                // Warna badge berdasarkan status
                                string badgeClass = item.StatusPPIDID switch
                                {
                                    StatusId.WawancaraDijadwalkan => "bg-violet-50 text-violet-700",
                                    StatusId.WawancaraSelesai     => "bg-purple-50 text-purple-700",
                                    StatusId.ObservasiDijadwalkan => "bg-orange-50 text-orange-700",
                                    StatusId.ObservasiSelesai     => "bg-yellow-50 text-yellow-700",
                                    StatusId.DiProses             => "bg-blue-50 text-blue-700",
                                    _                             => "bg-amber-50 text-amber-700"
                                };
                            }
                            <span class="text-xs @badgeClass px-2.5 py-0.5 rounded-full font-medium">
                                @item.Status?.NamaStatusPPID
                            </span>
                        </td>
                        <td class="px-5 py-3.5">
                            <div class="flex gap-1.5 flex-wrap opacity-80 group-hover:opacity-100 transition-opacity">

                                @* Terima disposisi — hanya jika belum diproses *@
                                @if (item.StatusPPIDID == StatusId.Didisposisi)
                                {
                                    <a href="/kdi/terima/@item.PermohonanPPIDID"
                                       class="text-xs bg-[#002d7a] hover:bg-blue-900 text-white px-3 py-1.5 rounded-lg font-semibold transition-colors">Terima</a>
                                }

                                @* Jadwal Observasi *@
                                @if (item.StatusPPIDID == StatusId.DiProses && item.IsObservasi)
                                {
                                    <a href="/kdi/jadwal/@item.PermohonanPPIDID"
                                       class="text-xs bg-orange-100 hover:bg-orange-200 text-orange-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">Jadwal Obs</a>
                                }

                                @* Jadwal Wawancara (tanpa observasi) *@
                                @if (item.StatusPPIDID == StatusId.DiProses && item.IsWawancara && !item.IsObservasi)
                                {
                                    <a href="/kdi/jadwal-wawancara/@item.PermohonanPPIDID"
                                       class="text-xs bg-violet-100 hover:bg-violet-200 text-violet-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">🎤 Jadwal Wawancara</a>
                                }

                                @* Selesai Observasi *@
                                @if (item.StatusPPIDID == StatusId.ObservasiDijadwalkan)
                                {
                                    <a href="/kdi/selesai-observasi/@item.PermohonanPPIDID"
                                       class="text-xs bg-purple-100 hover:bg-purple-200 text-purple-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">✅ Selesai Obs</a>
                                }

                                @* Jadwal Wawancara setelah observasi selesai *@
                                @if (item.StatusPPIDID == StatusId.ObservasiSelesai && item.IsWawancara)
                                {
                                    <a href="/kdi/jadwal-wawancara/@item.PermohonanPPIDID"
                                       class="text-xs bg-violet-100 hover:bg-violet-200 text-violet-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">🎤 Jadwal Wawancara</a>
                                }

                                @* Upload Data — setelah semua proses selesai (tanpa wawancara, atau wawancara sudah selesai) *@
                                @{
                                    bool siapUpload =
                                        (item.StatusPPIDID == StatusId.DiProses        && !item.IsWawancara && !item.IsObservasi) ||
                                        (item.StatusPPIDID == StatusId.ObservasiSelesai && !item.IsWawancara) ||
                                         item.StatusPPIDID == StatusId.WawancaraSelesai;
                                }
                                @if (siapUpload)
                                {
                                    <a href="/kdi/upload-data/@item.PermohonanPPIDID"
                                       class="text-xs bg-emerald-100 hover:bg-emerald-200 text-emerald-700 px-2.5 py-1 rounded-lg font-semibold transition-colors">⬆ Upload Data</a>
                                }

                                @* Info status wawancara sedang berjalan (tidak ada aksi KDI) *@
                                @if (item.StatusPPIDID == StatusId.WawancaraDijadwalkan)
                                {
                                    <span class="text-xs bg-violet-50 text-violet-500 px-2.5 py-1 rounded-lg font-medium border border-violet-100">
                                        🎤 Menunggu ProdusenData
                                    </span>
                                }

                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-6 py-16 text-center">
                            <partial name="Partials/Empty" />
                            <p class="text-gray-400 text-sm">Belum ada disposisi masuk</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
