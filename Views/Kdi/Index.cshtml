@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Dashboard KDI";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
}
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
    <a href="/kdi/psmdi" class="bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">💾</div>
        <div>
            <p class="font-bold text-gray-800">PSMDI</p>
            <p class="text-sm text-gray-500 mt-0.5">Pusat Sistem & Manajemen Data Informasi</p>
            <span class="mt-1 inline-block text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-medium">
                @Model.Count(p => string.IsNullOrEmpty(p.NamaBidang)) masuk
            </span>
        </div>
    </a>
    <a href="/kdi/bidang" class="bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-2xl flex-shrink-0">🏢</div>
        <div>
            <p class="font-bold text-gray-800">Bidang Terkait</p>
            <p class="text-sm text-gray-500 mt-0.5">Unit / bidang pengelola data terkait</p>
            <span class="mt-1 inline-block text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium">
                @Model.Count(p => !string.IsNullOrEmpty(p.NamaBidang)) masuk
            </span>
        </div>
    </a>
</div>
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100"><p class="font-semibold text-gray-700 text-sm">Semua Disposisi Masuk</p></div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead><tr class="bg-gray-50 border-b text-left">
                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Nomor</th>
                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Pemohon</th>
                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Judul</th>
                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Disposisi</th>
                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Status</th>
                <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Aksi</th>
            </tr></thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var item in Model) {
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-mono text-xs text-blue-600">@item.NoPermohonan</td>
                        <td class="px-4 py-3 font-medium text-gray-800 text-xs">@item.Pribadi?.Nama</td>
                        <td class="px-4 py-3 text-xs text-gray-600 max-w-xs truncate">@item.JudulPenelitian</td>
                        <td class="px-4 py-3">
                            @if (string.IsNullOrEmpty(item.NamaBidang))
                            { <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">💾 PSMDI</span> }
                            else
                            { <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">🏢 @item.NamaBidang</span> }
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">@item.Status?.NamaStatusPPID</span>
                        </td>
                        <td class="px-4 py-3">
                            <a href="/kdi/terima/@item.PermohonanPPIDID" class="text-xs bg-blue-600 hover:bg-blue-700 text-white px-2.5 py-1 rounded-lg">Proses</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
