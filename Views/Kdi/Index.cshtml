@model List<PermohonanPPID>
@{
    ViewData["Title"] = "Dashboard KDI";
    ViewData["Role"]  = "KDI";
    Layout = "_LayoutAdmin";
    var subTaskMap = ViewData["SubTasks"] as Dictionary<Guid, List<SubTaskPPID>> ?? new();
}
@{
    int kdiPsmdi  = Model.Count(p => string.IsNullOrEmpty(p.NamaBidang));
    int kdiBidang = Model.Count(p => !string.IsNullOrEmpty(p.NamaBidang));
    int kdiTotal  = Model.Count;
    int pctPsmdi  = kdiTotal > 0 ? (int)Math.Round(kdiPsmdi  * 100.0 / kdiTotal) : 0;
    int pctBidang = kdiTotal > 0 ? (int)Math.Round(kdiBidang * 100.0 / kdiTotal) : 0;
}

<!-- Quick Access Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="kdi-card bg-[#0f1f4a] rounded-2xl p-5 relative overflow-hidden shadow-md flex flex-col justify-between min-h-[120px]">
        <div class="kdi-bg-circle"></div>
        <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-blue-300/70 mb-1">Total Disposisi</p>
            <p class="text-5xl font-black text-white leading-none tracking-tight" style="font-variant-numeric:tabular-nums">@kdiTotal</p>
        </div>
        <div class="flex items-center gap-2 mt-3">
            <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-blue-200/60 bg-white/5 px-2 py-0.5 rounded-full border border-white/10">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-300 animate-pulse"></span>@kdiPsmdi PSMDI
            </span>
            <span class="inline-flex items-center gap-1 text-[10px] font-semibold text-emerald-200/60 bg-white/5 px-2 py-0.5 rounded-full border border-white/10">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-300"></span>@kdiBidang Bidang
            </span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-400 to-transparent"></div>
    </div>

    <a href="/kdi/psmdi" class="kdi-card group bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden flex flex-col justify-between min-h-[120px]">
        <div class="flex items-start justify-between">
            <div><p class="text-[10px] font-bold uppercase tracking-[0.15em] text-gray-400 mb-1">PSMDI</p><p class="text-4xl font-black text-gray-800 leading-none">@kdiPsmdi</p></div>
            <div class="relative flex-shrink-0">
                <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#EFF6FF" stroke-width="3.5"/>
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#3B82F6" stroke-width="3.5" stroke-dasharray="@(Math.Round(87.96 * pctPsmdi / 100.0, 1)) 87.96" stroke-linecap="round"/>
                </svg>
                <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-blue-500 rotate-90">@pctPsmdi%</span>
            </div>
        </div>
        <div><p class="text-xs text-gray-400 mb-1">Peran Serta Masyarakat, Data dan Informasi</p><div class="w-full bg-blue-50 rounded-full h-1"><div class="bg-blue-500 h-full rounded-full" style="width:@pctPsmdi%"></div></div></div>
    </a>

    <a href="/kdi/bidang" class="kdi-card group bg-white rounded-2xl p-5 border border-gray-100 shadow-sm relative overflow-hidden flex flex-col justify-between min-h-[120px]">
        <div class="flex items-start justify-between">
            <div><p class="text-[10px] font-bold uppercase tracking-[0.15em] text-gray-400 mb-1">Bidang Terkait</p><p class="text-4xl font-black text-gray-800 leading-none">@kdiBidang</p></div>
            <div class="relative flex-shrink-0">
                <svg class="w-12 h-12 -rotate-90" viewBox="0 0 36 36">
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#ECFDF5" stroke-width="3.5"/>
                    <circle cx="18" cy="18" r="14" fill="none" stroke="#10B981" stroke-width="3.5" stroke-dasharray="@(Math.Round(87.96 * pctBidang / 100.0, 1)) 87.96" stroke-linecap="round"/>
                </svg>
                <span class="absolute inset-0 flex items-center justify-center text-[9px] font-bold text-emerald-500 rotate-90">@pctBidang%</span>
            </div>
        </div>
        <div><p class="text-xs text-gray-400 mb-1">Unit / bidang pengelola data terkait</p><div class="w-full bg-emerald-50 rounded-full h-1"><div class="bg-emerald-500 h-full rounded-full" style="width:@pctBidang%"></div></div></div>
    </a>
</div>

<!-- Tabel semua disposisi dengan progress subtask -->
<div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-50 flex items-center justify-between">
        <p class="font-bold text-gray-700 text-sm">Semua Disposisi Masuk</p>
        <span class="text-xs text-gray-400 bg-gray-50 border border-gray-200 rounded-lg px-2.5 py-1">@Model.Count total</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-gray-50">
                    <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Nomor</th>
                    <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Pemohon</th>
                    <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Disposisi</th>
                    <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Progress Sub-tugas</th>
                    <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Status</th>
                    <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-wider">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @foreach (var item in Model)
                {
                    subTaskMap.TryGetValue(item.PermohonanPPIDID, out var tasks);
                    tasks ??= new List<SubTaskPPID>();
                    int doneTasks  = tasks.Count(t => t.StatusTask == SubTaskStatus.Selesai);
                    int totalTasks = tasks.Count;
                    bool allDone   = totalTasks > 0 && doneTasks == totalTasks;

                    <tr class="hover:bg-blue-50/30 group">
                        <td class="px-4 py-3 font-mono text-xs text-blue-600 font-semibold">@item.NoPermohonan</td>
                        <td class="px-4 py-3">
                            <p class="font-semibold text-gray-800 text-xs">@item.Pribadi?.Nama</p>
                            <p class="text-gray-400 text-[10px] truncate max-w-[140px]">@item.JudulPenelitian</p>
                        </td>
                        <td class="px-4 py-3">
                            @if (string.IsNullOrEmpty(item.NamaBidang))
                            {
                                <span class="inline-flex items-center gap-1 text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full font-medium">
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>PSMDI
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full font-medium max-w-[130px] truncate">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>@item.NamaBidang
                                </span>
                            }
                        </td>
                        <td class="px-4 py-3">
                            @if (totalTasks == 0)
                            {
                                @* Belum terima disposisi *@
                                <span class="text-xs text-gray-400">—</span>
                            }
                            else
                            {
                                @* Progress bar + task badges *@
                                <div class="flex items-center gap-2 mb-1">
                                    <div class="flex-1 bg-gray-100 rounded-full h-1.5 max-w-[80px]">
                                        <div class="@(allDone ? "bg-emerald-500" : "bg-blue-500") h-full rounded-full"
                                             style="width:@(totalTasks > 0 ? doneTasks*100/totalTasks : 0)%"></div>
                                    </div>
                                    <span class="text-[10px] font-bold @(allDone ? "text-emerald-600" : "text-gray-500")">@doneTasks/@totalTasks</span>
                                </div>
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var t in tasks)
                                    {
                                        <span class="text-[9px] px-1.5 py-0.5 rounded-full font-semibold border
                                            @(t.IsSelesai ? "bg-emerald-50 text-emerald-700 border-emerald-100" :
                                              t.IsInProgress ? "bg-amber-50 text-amber-700 border-amber-100" :
                                                               "bg-gray-50 text-gray-400 border-gray-100")">
                                            @JenisTask.GetIcon(t.JenisTask)
                                            @(t.IsSelesai ? "✓" : t.IsInProgress ? "⏳" : "○")
                                        </span>
                                    }
                                </div>
                            }
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-0.5 rounded-full font-medium
                                @(item.StatusPPIDID == StatusId.DataSiap     ? "bg-emerald-50 text-emerald-700" :
                                  item.StatusPPIDID == StatusId.WawancaraDijadwalkan ? "bg-violet-50 text-violet-700" :
                                  item.StatusPPIDID == StatusId.ObservasiDijadwalkan ? "bg-orange-50 text-orange-700" :
                                  item.StatusPPIDID == StatusId.DiProses     ? "bg-blue-50 text-blue-700" :
                                  "bg-amber-50 text-amber-700")">
                                @item.Status?.NamaStatusPPID
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex gap-1.5 flex-wrap opacity-80 group-hover:opacity-100">
                                @if (item.StatusPPIDID == StatusId.Didisposisi)
                                {
                                    <a href="/kdi/terima/@item.PermohonanPPIDID"
                                       class="text-xs bg-[#002d7a] hover:bg-blue-900 text-white px-3 py-1.5 rounded-lg font-semibold">Terima →</a>
                                }
                                else if (totalTasks > 0)
                                {
                                    <a href="/kdi/subtasks/@item.PermohonanPPIDID"
                                       class="text-xs @(allDone ? "bg-emerald-100 text-emerald-700" : "bg-blue-100 text-blue-700") hover:opacity-80 px-3 py-1.5 rounded-lg font-semibold">
                                        @(allDone ? "✓ Selesai" : "🔧 Kelola Tugas")
                                    </a>
                                }
                                else
                                {
                                    <a href="/kdi/subtasks/@item.PermohonanPPIDID"
                                       class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-700 px-2.5 py-1.5 rounded-lg font-medium">Detail</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="px-6 py-16 text-center">
                        <div class="text-4xl mb-3">📊</div>
                        <p class="text-gray-400 text-sm">Belum ada disposisi masuk</p>
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .kdi-card{transition:transform .18s ease,box-shadow .18s ease}
    .kdi-card:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(0,0,0,.09)}
    .kdi-bg-circle{position:absolute;top:-24px;right:-24px;width:100px;height:100px;border-radius:50%;background:rgba(255,255,255,.04);pointer-events:none}
</style>
